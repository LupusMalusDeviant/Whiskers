@inject Whiskers.Services.Setup.IProductionReadinessService Readiness
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

@* W3.4: static "production ready?" checklist. Read-only, informational — each failed item says
   what to do and links to the place to fix it. *@

@if (_checks is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
        @L["ProductionReadinessPanel_Summary", _okCount, _checks.Count]
    </MudText>
    <MudList T="string" Dense="true">
        @foreach (var check in _checks)
        {
            <MudListItem T="string">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@(check.Ok ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.ErrorOutline)"
                             Color="@(check.Ok ? Color.Success : Color.Warning)" Size="Size.Small" />
                    <div style="min-width: 0;">
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@check.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @check.Detail
                            @if (!check.Ok && check.LinkHref != null)
                            {
                                <MudLink Href="@check.LinkHref" Class="ml-1" Typo="Typo.caption">@check.LinkText</MudLink>
                            }
                        </MudText>
                    </div>
                </MudStack>
            </MudListItem>
        }
    </MudList>
    <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-2"
               StartIcon="@Icons.Material.Filled.Rocket" Href="ai-operations">@L["ProductionReadinessPanel_AiOpsLink"]</MudButton>
}

@code {
    private IReadOnlyList<Whiskers.Services.Setup.ReadinessCheck>? _checks;
    private int _okCount;

    protected override async Task OnInitializedAsync()
    {
        var isHttps = Nav.Uri.StartsWith("https://", StringComparison.OrdinalIgnoreCase);
        _checks = await Readiness.GetChecksAsync(isHttps);
        _okCount = _checks.Count(c => c.Ok);
    }
}
