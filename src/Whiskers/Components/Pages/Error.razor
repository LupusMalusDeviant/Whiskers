@page "/Error"
@attribute [AllowAnonymous]
@using System.Diagnostics
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Error_PageTitle"]</PageTitle>

<h1 class="text-danger">@L["Error_Title"]</h1>
<h2 class="text-danger">@L["Error_Subtitle"]</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@L["Error_RequestId_Label"]</strong> <code>@RequestId</code>
    </p>
}

<h3>@L["Error_DevMode_Heading"]</h3>
<p>
    @((MarkupString)L["Error_DevMode_Info"].Value)
</p>
<p>
    @((MarkupString)L["Error_DevMode_Warning"].Value)
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
