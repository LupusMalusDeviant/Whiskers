@page "/firewall/{ServerId}"
@attribute [Authorize]
@inject Whiskers.Services.Server.IFirewallService FirewallService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IStringLocalizer<SharedResource> L

<PageTitle>Firewall - Whiskers</PageTitle>

@* RoadToSAP Phase 1: gated by the HostManagement module. When off, ModuleGuard shows a "disabled" notice
   instead of the firewall UI. The IFirewallService injection resolves the Core no-op default either way. *@
<ModuleGuard ModuleId="host-management">

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(""))" />
    <MudText Typo="Typo.h5">Firewall</MudText>
    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@_serverName</MudChip>
    <MudSpacer />
    @if (_role >= AppRole.Admin)
    {
        <MudSwitch T="bool" Value="@_firewallActive" ValueChanged="ToggleFirewall" Color="Color.Success"
                   Label="@(_firewallActive ? L["Firewall_Status_Active"].Value : L["Firewall_Status_Inactive"].Value)" />
    }
    else
    {
        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">@(_firewallActive ? L["Firewall_Status_Active"].Value : L["Firewall_Status_Inactive"].Value)</MudChip>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="@_rules" Dense="true" Hover="true" Striped="true" Elevation="2">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@L["Firewall_Table_Title"]</MudText>
            <MudSpacer />
            @if (_role >= AppRole.Admin)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Filled"
                           OnClick="OpenAddDialog">@L["Firewall_Button_AddRule"]</MudButton>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Refresh" Color="Color.Default" Variant="Variant.Outlined"
                       OnClick="LoadRules" Class="ml-2">@L["Firewall_Button_Refresh"]</MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>#</MudTh>
            <MudTh>@L["Firewall_Header_Port"]</MudTh>
            <MudTh>@L["Firewall_Header_Action"]</MudTh>
            <MudTh>@L["Firewall_Header_Direction"]</MudTh>
            <MudTh>@L["Firewall_Header_From"]</MudTh>
            <MudTh>@L["Firewall_Header_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Number</MudTd>
            <MudTd><MudText Style="font-family: monospace;">@context.Port</MudText></MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Action.Contains("ALLOW") ? Color.Success : Color.Error)"
                         Variant="Variant.Filled">@context.Action</MudChip>
            </MudTd>
            <MudTd>@context.Direction</MudTd>
            <MudTd>@context.From</MudTd>
            <MudTd>
                @if (_role >= AppRole.Admin)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteRule(context.Number))" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["Firewall_Empty_NoRules"]</MudText>
        </NoRecordsContent>
    </MudTable>
}

</ModuleGuard>

@code {
    [Parameter] public string ServerId { get; set; } = "";

    private string _serverName = "";
    private bool _loading = true;
    private bool _firewallActive;
    private List<Whiskers.Services.Server.FirewallRule> _rules = new();
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["Firewall_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        var server = ServerConfigService.GetServer(ServerId);
        _serverName = server?.Name ?? ServerId;
        await LoadRules();
    }

    private async Task LoadRules()
    {
        _loading = true;
        try
        {
            var status = await FirewallService.GetStatusAsync(ServerId);
            _firewallActive = status.Active;
            _rules = status.Rules;
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Firewall_Snackbar_LoadError", ex.Message].Value, Severity.Error);
        }
        _loading = false;
    }

    private async Task ToggleFirewall(bool enable)
    {
        if (!Require(AppRole.Admin)) return;

        // Disabling the firewall exposes the host — confirm explicitly.
        if (!enable)
        {
            var confirmed = await DialogService.ShowMessageBoxAsync(
                L["Firewall_Dialog_DisableTitle"].Value, L["Firewall_Dialog_DisableMessage"].Value,
                yesText: L["Firewall_Dialog_DisableYes"].Value, cancelText: L["Firewall_Dialog_Cancel"].Value);
            if (confirmed != true) return;
        }

        try
        {
            var result = await FirewallService.SetStatusAsync(ServerId, enable);
            if (result.Success)
            {
                _firewallActive = enable;
                Snackbar.Add(enable ? L["Firewall_Snackbar_Enabled"].Value : L["Firewall_Snackbar_Disabled"].Value, Severity.Success);
                await LoadRules();
            }
            else
                Snackbar.Add(L["Firewall_Snackbar_Error", result.Error ?? ""].Value, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeleteRule(int ruleNumber)
    {
        if (!Require(AppRole.Admin)) return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["Firewall_Dialog_DeleteTitle"].Value, L["Firewall_Dialog_DeleteMessage", ruleNumber].Value, yesText: L["Firewall_Dialog_DeleteYes"].Value, cancelText: L["Firewall_Dialog_Cancel"].Value);
        if (confirmed != true) return;

        try
        {
            var result = await FirewallService.RemoveRuleAsync(ServerId, ruleNumber);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "firewall.remove", "firewall", ruleNumber.ToString(), $"Rule #{ruleNumber}", serverId: ServerId, success: result.Success);
            if (result.Success)
            {
                Snackbar.Add(L["Firewall_Snackbar_RuleRemoved"].Value, Severity.Success);
                await LoadRules();
            }
            else
                Snackbar.Add(L["Firewall_Snackbar_Error", result.Error ?? ""].Value, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenAddDialog()
    {
        if (!Require(AppRole.Admin)) return;

        var parameters = new DialogParameters<AddFirewallRuleDialog>
        {
            { x => x.ServerId, ServerId }
        };
        var dialog = await DialogService.ShowAsync<AddFirewallRuleDialog>(L["Firewall_Dialog_AddRuleTitle"].Value, parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
            await LoadRules();
    }
}
