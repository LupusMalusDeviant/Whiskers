@page "/logs"
@attribute [Authorize]

<PageTitle>Log-Suche - Whiskers</PageTitle>

@* RoadToSAP Phase 1: thin route wrapper. ModuleGuard renders the interactive LogSearchView only when the
   LogMonitor module is enabled; otherwise it shows a clean "module disabled" notice (and LogSearchView —
   which injects ILogSearchService / ILogMonitorService — is never instantiated, so there is no DI error). *@
<ModuleGuard ModuleId="logmonitor">
    <LogSearchView />
</ModuleGuard>
