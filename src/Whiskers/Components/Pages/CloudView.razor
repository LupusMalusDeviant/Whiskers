@using Whiskers.Models
@using Whiskers.Models.Cloud
@inject Whiskers.Services.Cloud.ICloudControlService CloudControl
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject IStringLocalizer<SharedResource> L

@* The interactive cloud-control UI. Rendered by Cloud.razor only when the CloudControl module is enabled
   (via ModuleGuard), so a disabled module never reaches the ICloudControlService injection. *@

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["CloudView_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["CloudView_Header_Subtitle"]</MudText>
        </div>
    </MudStack>
</div>

<MudStack Row="true" Class="mb-4" Spacing="2">
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAll" Disabled="@_loading">
        @L["CloudView_Button_Refresh"]
    </MudButton>
</MudStack>

<MudTable Items="@_servers" Dense="true" Hover="true" Striped="true" Loading="@_loading"
          LoadingProgressColor="Color.Primary" Elevation="2">
    <HeaderContent>
        <MudTh>@L["CloudView_Table_Server"]</MudTh>
        <MudTh>@L["CloudView_Table_Provider"]</MudTh>
        <MudTh>@L["CloudView_Table_Status"]</MudTh>
        <MudTh>@L["CloudView_Table_Type"]</MudTh>
        <MudTh>@L["CloudView_Table_Ipv4"]</MudTh>
        <MudTh>@L["CloudView_Table_Traffic"]</MudTh>
        <MudTh>@L["CloudView_Table_Actions"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.WhiskersName</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Name (#@context.CloudId)</MudText>
        </MudTd>
        <MudTd>@context.Provider</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">@context.Status</MudChip>
        </MudTd>
        <MudTd>@(context.Type ?? "-")</MudTd>
        <MudTd><MudText Typo="Typo.body2" Style="font-family: monospace;">@(context.Ipv4 ?? "-")</MudText></MudTd>
        <MudTd>
            @if (context.Provider == CloudProvider.Hetzner && context.TrafficPercent.HasValue)
            {
                <MudText Typo="Typo.caption">@context.TrafficPercent%</MudText>
            }
            else
            {
                <MudText Typo="Typo.caption">-</MudText>
            }
        </MudTd>
        <MudTd>
            @if (_role >= AppRole.Admin)
            {
                @if (context.Status == "running")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small" Color="Color.Info"
                                   title="@L["CloudView_Action_Reboot"]" OnClick="@(() => Act(context, "reboot"))" Disabled="@_busy" />
                    <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew" Size="Size.Small" Color="Color.Warning"
                                   title="@L["CloudView_Action_Shutdown"]" OnClick="@(() => Act(context, "shutdown"))" Disabled="@_busy" />
                    <MudIconButton Icon="@Icons.Material.Filled.FlashOn" Size="Size.Small" Color="Color.Error"
                                   title="@L["CloudView_Action_HardReset"]" OnClick="@(() => Act(context, "reset"))" Disabled="@_busy" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                   title="@L["CloudView_Action_PowerOn"]" OnClick="@(() => Act(context, "poweron"))" Disabled="@_busy" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" Color="Color.Primary"
                               title="@L["CloudView_Action_Snapshot"]" OnClick="@(() => Act(context, "snapshot"))" Disabled="@_busy" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="pa-4">@L["CloudView_Empty_Prefix"] <MudLink Href="servers">@L["CloudView_Empty_Link"]</MudLink> @L["CloudView_Empty_Suffix"]</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<CloudServerInfo> _servers = new();
    private bool _loading = true;
    private bool _busy;
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["CloudView_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        await LoadAll();
    }

    private async Task LoadAll()
    {
        _loading = true;
        try { _servers = await CloudControl.ListAllAsync(); }
        catch (Exception ex) { Snackbar.Add(L["CloudView_Snackbar_LoadError", ex.Message].Value, Severity.Error); }
        finally { _loading = false; }
    }

    private async Task Act(CloudServerInfo s, string action)
    {
        if (!Require(AppRole.Admin)) return;

        // Confirm out-of-band power actions that interrupt the running server.
        var confirmPrompt = action switch
        {
            "reboot" => L["CloudView_Confirm_Reboot", s.WhiskersName].Value,
            "shutdown" => L["CloudView_Confirm_Shutdown", s.WhiskersName].Value,
            "reset" => L["CloudView_Confirm_HardReset", s.WhiskersName].Value,
            _ => null
        };
        if (confirmPrompt != null)
        {
            var confirmed = await DialogService.ShowMessageBoxAsync(
                L["CloudView_Confirm_Title"].Value, confirmPrompt, yesText: L["CloudView_Button_Execute"].Value, cancelText: L["CloudView_Button_Cancel"].Value);
            if (confirmed != true) return;
        }

        _busy = true;
        try
        {
            var msg = action switch
            {
                "poweron" => await CloudControl.PowerOnAsync(s.WhiskersId),
                "shutdown" => await CloudControl.ShutdownAsync(s.WhiskersId),
                "reboot" => await CloudControl.RebootAsync(s.WhiskersId),
                "reset" => await CloudControl.HardResetAsync(s.WhiskersId),
                "snapshot" => await CloudControl.CreateSnapshotAsync(s.WhiskersId, $"{s.Name} {DateTime.UtcNow:yyyy-MM-dd HH:mm} UTC"),
                _ => L["CloudView_Snackbar_UnknownAction"].Value
            };
            Snackbar.Add(msg, Severity.Success);
            await LoadAll();
        }
        catch (Exception ex) { Snackbar.Add(L["CloudView_Snackbar_ActionError", action, s.WhiskersName, ex.Message].Value, Severity.Error); }
        finally { _busy = false; }
    }

    private static Color GetStatusColor(string status) => status?.ToLowerInvariant() switch
    {
        "running" => Color.Success,
        "off" or "stopped" or "stopping" => Color.Error,
        "starting" or "initializing" => Color.Info,
        _ => Color.Default
    };
}
