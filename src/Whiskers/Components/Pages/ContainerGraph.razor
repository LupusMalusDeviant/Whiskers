@page "/graph"
@attribute [Authorize]
@inject IDockerService DockerService
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["ContainerGraph_PageTitle"]</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["ContainerGraph_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["ContainerGraph_Header_Subtitle"]</MudText>
        </div>
        <MudSpacer />
        <MudStack Row="true" Spacing="1">
            <MudChip T="string" Size="Size.Small" Style="background: rgba(52, 211, 153, 0.15); color: #34d399;">Running</MudChip>
            <MudChip T="string" Size="Size.Small" Style="background: rgba(248, 113, 113, 0.15); color: #f87171;">Stopped</MudChip>
            <MudChip T="string" Size="Size.Small" Style="background: rgba(96, 165, 250, 0.15); color: #60a5fa;">Database</MudChip>
    </MudStack>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadGraph">@L["ContainerGraph_Button_Refresh"]</MudButton>
    </MudStack>
</div>

<MudPaper Elevation="0" Style="border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06);">
    <div id="topology-graph" style="height: calc(100vh - 200px); min-height: 500px; width: 100%; background: rgba(0,0,0,0.2);"></div>
</MudPaper>

@code {

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadGraph();
        }
    }

    private async Task LoadGraph()
    {
        try
        {
            var containers = await DockerService.ListAllContainersAsync(all: true);
            var networks = await DockerService.ListNetworksAsync();

            var nodes = new List<object>();
            var edges = new List<object>();
            var containerIds = new HashSet<string>();

            // Build nodes from containers
            foreach (var c in containers)
            {
                containerIds.Add(c.Id);
                nodes.Add(new
                {
                    id = c.Id,
                    label = c.Name,
                    tooltip = L["ContainerGraph_Node_Tooltip", c.Name, c.Image, c.State, c.HealthStatus, c.ComposeProject].Value,
                    group = c.ComposeProject,
                    state = c.State,
                    isDatabase = c.IsDatabase
                });

                // depends_on edges from labels
                if (c.Labels.TryGetValue("com.docker.compose.depends_on", out var deps) && !string.IsNullOrEmpty(deps))
                {
                    foreach (var dep in deps.Split(',', StringSplitOptions.RemoveEmptyEntries))
                    {
                        var depName = dep.Split(':')[0].Trim();
                        var depContainer = containers.FirstOrDefault(x =>
                            x.Labels.TryGetValue("com.docker.compose.service", out var svc) && svc == depName &&
                            x.ComposeProject == c.ComposeProject);
                        if (depContainer != null)
                        {
                            edges.Add(new { from = c.Id, to = depContainer.Id, label = "depends_on", arrows = true, dashes = true });
                        }
                    }
                }
            }

            // Build edges from network connections
            foreach (var net in networks)
            {
                if (net.Name is "bridge" or "host" or "none") continue;
                if (net.Containers.Count < 2) continue;

                // Connect containers in the same network
                var netContainers = net.Containers.Where(nc => containerIds.Contains(nc.ContainerId)).ToList();
                for (int i = 0; i < netContainers.Count; i++)
                {
                    for (int j = i + 1; j < netContainers.Count; j++)
                    {
                        edges.Add(new
                        {
                            from = netContainers[i].ContainerId,
                            to = netContainers[j].ContainerId,
                            label = net.Name.Length > 20 ? net.Name[..20] + "..." : net.Name,
                            arrows = false,
                            dashes = false
                        });
                    }
                }
            }

            await JS.InvokeVoidAsync("Whiskers.Graph.create", "topology-graph", nodes, edges);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Graph load failed: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("Whiskers.Graph.destroy"); } catch { }
    }
}
