@page "/deploy"
@attribute [Authorize]
@inject IDeploymentService DeploymentService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Deploy_PageTitle"]</PageTitle>

@* RoadToSAP Phase 1: gated by the Deployment module; when off, ModuleGuard shows a "disabled" notice.
   The IDeploymentService injection resolves the Core no-op default either way. *@
<ModuleGuard ModuleId="deployment">

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["Deploy_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Deploy_Header_Subtitle"]</MudText>
        </div>
    </MudStack>
</div>

@* Server Selection (applies to both tabs) *@
<MudSelect T="string" @bind-Value="_serverId" Label="@L["Deploy_Label_TargetServer"]" Variant="Variant.Outlined" Class="mb-4" Style="max-width: 320px;">
    @foreach (var srv in _servers)
    {
        <MudSelectItem Value="@srv.Id">@srv.Name</MudSelectItem>
    }
</MudSelect>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
    @* Tab 1: Form Deploy *@
    <MudTabPanel Text="@L["Deploy_Tab_Form"]" Icon="@Icons.Material.Filled.EditNote">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_formRequest.Image" Label="@L["Deploy_Label_ImageName"]" Variant="Variant.Outlined"
                              Placeholder="nginx:latest" Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_formRequest.ContainerName" Label="@L["Deploy_Label_ContainerName"]"
                              Variant="Variant.Outlined" Placeholder="my-container" />
            </MudItem>

            @* Port Mappings *@
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle1" Class="mb-2">@L["Deploy_Section_PortMappings"]</MudText>
                @for (var i = 0; i < _ports.Count; i++)
                {
                    var idx = i;
                    <MudStack Row="true" Class="mb-2">
                        <MudTextField @bind-Value="_ports[idx].Host" Label="@L["Deploy_Label_HostPort"]" Variant="Variant.Outlined"
                                      Style="max-width: 150px;" />
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="align-self-center" />
                        <MudTextField @bind-Value="_ports[idx].Container" Label="@L["Deploy_Label_ContainerPort"]" Variant="Variant.Outlined"
                                      Style="max-width: 150px;" />
                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => _ports.RemoveAt(idx))" Class="align-self-center" />
                    </MudStack>
                }
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                           OnClick="@(() => _ports.Add(new PortEntry()))">@L["Deploy_Button_AddPort"]</MudButton>
            </MudItem>

            @* Volumes *@
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle1" Class="mb-2">@L["Deploy_Section_Volumes"]</MudText>
                @for (var i = 0; i < _volumes.Count; i++)
                {
                    var idx = i;
                    <MudStack Row="true" Class="mb-2">
                        <MudTextField @bind-Value="_volumes[idx]" Label="host:container" Variant="Variant.Outlined"
                                      Placeholder="/data:/app/data" />
                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => _volumes.RemoveAt(idx))" Class="align-self-center" />
                    </MudStack>
                }
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                           OnClick="@(() => _volumes.Add(""))">@L["Deploy_Button_AddVolume"]</MudButton>
            </MudItem>

            @* Environment Variables *@
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle1" Class="mb-2">@L["Deploy_Section_EnvVars"]</MudText>
                @for (var i = 0; i < _envVars.Count; i++)
                {
                    var idx = i;
                    <MudStack Row="true" Class="mb-2">
                        <MudTextField @bind-Value="_envVars[idx].Key" Label="Key" Variant="Variant.Outlined"
                                      Style="max-width: 200px;" />
                        <MudTextField @bind-Value="_envVars[idx].Value" Label="Value" Variant="Variant.Outlined" />
                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => _envVars.RemoveAt(idx))" Class="align-self-center" />
                    </MudStack>
                }
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                           OnClick="@(() => _envVars.Add(new EnvEntry()))">@L["Deploy_Button_AddEnvVar"]</MudButton>
            </MudItem>

            @* Options *@
            <MudItem xs="12" md="6">
                <MudSelect T="string" @bind-Value="_formRequest.RestartPolicy" Label="@L["Deploy_Label_RestartPolicy"]"
                           Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("unless-stopped")">@L["Deploy_RestartPolicy_UnlessStopped"]</MudSelectItem>
                    <MudSelectItem T="string" Value="@("always")">@L["Deploy_RestartPolicy_Always"]</MudSelectItem>
                    <MudSelectItem T="string" Value="@("on-failure")">@L["Deploy_RestartPolicy_OnFailure"]</MudSelectItem>
                    <MudSelectItem T="string" Value="@("no")">@L["Deploy_RestartPolicy_No"]</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_formRequest.NetworkName" Label="@L["Deploy_Label_Network"]"
                              Variant="Variant.Outlined" Placeholder="bridge" />
            </MudItem>

            <MudItem xs="12">
                @if (_role >= AppRole.Operator)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DeployFromForm"
                               Disabled="_deploying" StartIcon="@Icons.Material.Filled.RocketLaunch">
                        @if (_deploying) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        @L["Deploy_Button_Deploy"]
                    </MudButton>
                }
            </MudItem>
        </MudGrid>

        @if (!string.IsNullOrEmpty(_deployProgress))
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">@_deployProgress</MudAlert>
        }
    </MudTabPanel>

    @* Tab 2: Compose Deploy *@
    <MudTabPanel Text="Compose" Icon="@Icons.Material.Filled.Description">
        <MudTextField @bind-Value="_composeYaml" Label="docker-compose.yml" Variant="Variant.Outlined"
                      Lines="15" Placeholder="@L["Deploy_Placeholder_ComposeContent"]"
                      Style="font-family: 'Cascadia Code', monospace; font-size: 13px;" />

        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="ValidateCompose"
                       StartIcon="@Icons.Material.Filled.CheckCircle">
                @L["Deploy_Button_Validate"]
            </MudButton>
            @if (_role >= AppRole.Operator)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DeployFromCompose"
                           Disabled="@(_deploying || string.IsNullOrWhiteSpace(_composeYaml))"
                           StartIcon="@Icons.Material.Filled.RocketLaunch">
                    @if (_deploying) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @L["Deploy_Button_DeployAll"]
                </MudButton>
            }
        </MudStack>

        @if (_validationResult != null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="1">
                @if (_validationResult.IsValid)
                {
                    <MudAlert Severity="Severity.Success">
                        @L["Deploy_Validation_Valid", _validationResult.Services.Count]
                        @string.Join(", ", _validationResult.Services.Select(s => s.ContainerName ?? s.Image))
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Error">
                        @L["Deploy_Validation_ErrorsTitle"]
                        <ul>
                            @foreach (var err in _validationResult.Errors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    </MudAlert>
                }
            </MudPaper>
        }

        @if (!string.IsNullOrEmpty(_deployProgress))
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">@_deployProgress</MudAlert>
        }
    </MudTabPanel>
</MudTabs>

</ModuleGuard>

@code {
    private DeploymentRequest _formRequest = new() { RestartPolicy = "unless-stopped" };
    private List<PortEntry> _ports = new();
    private List<string> _volumes = new();
    private List<EnvEntry> _envVars = new();
    private string _composeYaml = string.Empty;
    private DeploymentValidationResult? _validationResult;
    private bool _deploying;
    private string _deployProgress = string.Empty;
    private AppRole _role = AppRole.Viewer;
    private List<Whiskers.Models.ServerConfig> _servers = new();
    private string _serverId = "local";

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["Deploy_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _servers = ServerConfigService.GetEnabledServers();
        _serverId = ServerConfigService.GetDefaultServer()?.Id ?? "local";
    }

    private async Task DeployFromForm()
    {
        if (!Require(AppRole.Operator)) return;
        if (string.IsNullOrWhiteSpace(_formRequest.Image))
        {
            Snackbar.Add(L["Deploy_Snackbar_ImageRequired"].Value, Severity.Warning);
            return;
        }

        _formRequest.PortMappings = _ports
            .Where(p => !string.IsNullOrWhiteSpace(p.Host) && !string.IsNullOrWhiteSpace(p.Container))
            .ToDictionary(p => p.Host, p => p.Container);
        _formRequest.Volumes = _volumes.Where(v => !string.IsNullOrWhiteSpace(v)).ToList();
        _formRequest.EnvironmentVars = _envVars
            .Where(e => !string.IsNullOrWhiteSpace(e.Key))
            .ToDictionary(e => e.Key, e => e.Value ?? "");

        _deploying = true;
        _deployProgress = "";
        try
        {
            var progress = new Progress<string>(msg =>
            {
                _deployProgress = msg;
                InvokeAsync(StateHasChanged);
            });
            var id = await DeploymentService.DeployFromFormAsync(_formRequest, progress, _serverId);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            var appName = string.IsNullOrWhiteSpace(_formRequest.ContainerName) ? _formRequest.Image : _formRequest.ContainerName;
            await AuditLog.LogAsync(actor, "web", "deploy.app", "container", id, appName, details: $"Image: {_formRequest.Image}", serverId: _serverId);
            Snackbar.Add(L["Deploy_Snackbar_Deployed", id[..12]].Value, Severity.Success);
            _deployProgress = L["Deploy_Progress_Success", id[..12]].Value;
        }
        catch (Exception ex)
        {
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            var appName = string.IsNullOrWhiteSpace(_formRequest.ContainerName) ? _formRequest.Image : _formRequest.ContainerName;
            await AuditLog.LogAsync(actor, "web", "deploy.app", "container", appName, appName, details: $"Image: {_formRequest.Image}; {ex.Message}", serverId: _serverId, success: false);
            Snackbar.Add(L["Deploy_Snackbar_DeployFailed", ex.Message].Value, Severity.Error);
            _deployProgress = L["Deploy_Progress_Error", ex.Message].Value;
        }
        finally
        {
            _deploying = false;
        }
    }

    private void ValidateCompose()
    {
        _validationResult = DeploymentService.ValidateCompose(_composeYaml);
    }

    private async Task DeployFromCompose()
    {
        if (!Require(AppRole.Operator)) return;
        _deploying = true;
        _deployProgress = "";
        try
        {
            var progress = new Progress<string>(msg =>
            {
                _deployProgress = msg;
                InvokeAsync(StateHasChanged);
            });
            var ids = await DeploymentService.DeployFromComposeAsync(_composeYaml, progress, _serverId);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "deploy.compose", "container", _serverId, "compose", details: $"{ids.Count} Container", serverId: _serverId);
            Snackbar.Add(L["Deploy_Snackbar_ComposeDeployed", ids.Count].Value, Severity.Success);
            _deployProgress = L["Deploy_Progress_ComposeSuccess", ids.Count].Value;
        }
        catch (Exception ex)
        {
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "deploy.compose", "container", _serverId, "compose", details: ex.Message, serverId: _serverId, success: false);
            Snackbar.Add(L["Deploy_Snackbar_DeployFailed", ex.Message].Value, Severity.Error);
            _deployProgress = L["Deploy_Progress_Error", ex.Message].Value;
        }
        finally
        {
            _deploying = false;
        }
    }

    private class PortEntry
    {
        public string Host { get; set; } = "";
        public string Container { get; set; } = "";
    }

    private class EnvEntry
    {
        public string Key { get; set; } = "";
        public string Value { get; set; } = "";
    }
}
