@page "/webhooks"
@attribute [Authorize]

<PageTitle>Webhooks - Whiskers</PageTitle>

@* RoadToSAP Phase 1: thin route wrapper. ModuleGuard renders the interactive WebhooksView only when the
   Webhooks module is enabled; otherwise it shows a clean "module disabled" notice (and WebhooksView — which
   injects IWebhookService — is never instantiated, so there is no DI error). The inbound trigger endpoint
   /api/webhooks/{id} lives in Program.cs and answers 400 when the module is off (via NoopWebhookService). *@
<ModuleGuard ModuleId="webhooks">
    <WebhooksView />
</ModuleGuard>
