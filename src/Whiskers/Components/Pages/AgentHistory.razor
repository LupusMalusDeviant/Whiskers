@page "/agent-history"
@attribute [Authorize]
@inject Whiskers.Services.Observability.IMcpCallLogStore CallLog
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["AgentHistory_PageTitle"]</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Policy" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["AgentHistory_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["AgentHistory_Header_Subtitle"]</MudText>
        </div>
    </MudStack>
</div>

<MudStack Row="true" Class="mb-4" Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
    <MudTextField T="string" Value="@_actorFilter" ValueChanged="OnActorChanged" DebounceInterval="400"
                  Label="@L["AgentHistory_Filter_Actor"]" Variant="Variant.Outlined" Dense="true" Style="max-width: 200px;"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" Clearable="true" />
    <MudTextField T="string" Value="@_toolFilter" ValueChanged="OnToolChanged" DebounceInterval="400"
                  Label="@L["AgentHistory_Filter_Tool"]" Variant="Variant.Outlined" Dense="true" Style="max-width: 200px;"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Build" Clearable="true" />
    <MudSelect T="string" Value="@_period" ValueChanged="OnPeriodChanged"
               Label="@L["AgentHistory_Filter_Period"]" Variant="Variant.Outlined" Dense="true" Style="max-width: 160px;">
        <MudSelectItem Value="@("1h")">@L["AgentHistory_Period_LastHour"]</MudSelectItem>
        <MudSelectItem Value="@("24h")">@L["AgentHistory_Period_Last24h"]</MudSelectItem>
        <MudSelectItem Value="@("7d")">@L["AgentHistory_Period_Last7Days"]</MudSelectItem>
        <MudSelectItem Value="@("30d")">@L["AgentHistory_Period_Last30Days"]</MudSelectItem>
        <MudSelectItem Value="@("all")">@L["AgentHistory_Period_All"]</MudSelectItem>
    </MudSelect>
    <MudSwitch T="bool" Value="@_writesOnly" ValueChanged="OnWritesOnlyChanged"
               Color="Color.Warning" Label="@L["AgentHistory_Filter_WritesOnly"]" />
    <MudSwitch T="bool" Value="@_deniesOnly" ValueChanged="OnDeniesOnlyChanged"
               Color="Color.Error" Label="@L["AgentHistory_Filter_DeniesOnly"]" />
    <MudSpacer />
    <MudText Typo="Typo.body2" Class="align-self-center" Style="color: #888;">
        @L["AgentHistory_TotalCount", _totalCount]
    </MudText>
</MudStack>

<MudTable Items="@_entries" Dense="true" Hover="true" Striped="true" Loading="@_loading"
          FixedHeader="true" Height="calc(100vh - 300px)" OnRowClick="OnRowClick"
          T="Whiskers.Models.McpToolCallEntity">
    <HeaderContent>
        <MudTh Style="width: 150px;">@L["AgentHistory_Column_Timestamp"]</MudTh>
        <MudTh Style="width: 190px;">@L["AgentHistory_Column_Actor"]</MudTh>
        <MudTh>@L["AgentHistory_Column_Tool"]</MudTh>
        <MudTh Style="width: 90px;">@L["AgentHistory_Column_Level"]</MudTh>
        <MudTh Style="width: 100px;">@L["AgentHistory_Column_Verdict"]</MudTh>
        <MudTh Style="width: 80px;" Align="Align.Right">@L["AgentHistory_Column_Duration"]</MudTh>
        <MudTh Style="width: 70px;">@L["AgentHistory_Column_Status"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L["AgentHistory_Column_Timestamp"]">
            <MudText Typo="Typo.body2" Style="font-family: monospace;">
                @context.Timestamp.ToLocalTime().ToString("dd.MM.yy HH:mm:ss")
            </MudText>
        </MudTd>
        <MudTd DataLabel="@L["AgentHistory_Column_Actor"]">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@ActorColor(context.ActorType)">
                @context.Actor
            </MudChip>
        </MudTd>
        <MudTd DataLabel="@L["AgentHistory_Column_Tool"]"><code>@context.ToolName</code></MudTd>
        <MudTd DataLabel="@L["AgentHistory_Column_Level"]">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@LevelColor(context.Level)">
                @context.Level
            </MudChip>
        </MudTd>
        <MudTd DataLabel="@L["AgentHistory_Column_Verdict"]">
            <MudChip T="string" Size="Size.Small" Color="@VerdictColor(context.Verdict)">
                @context.Verdict
            </MudChip>
        </MudTd>
        <MudTd DataLabel="@L["AgentHistory_Column_Duration"]" Style="text-align: right; font-family: monospace;">@context.DurationMs ms</MudTd>
        <MudTd DataLabel="@L["AgentHistory_Column_Status"]">
            @if (context.Success)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <div style="text-align:center; padding:2rem 1rem;">
            <MudIcon Icon="@Icons.Material.Filled.Policy" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
            <MudText Typo="Typo.body1">@L["AgentHistory_Empty_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="max-width:520px; margin:0.25rem auto 0;">
                @L["AgentHistory_Empty_Body"]
            </MudText>
        </div>
    </NoRecordsContent>
</MudTable>

@if (_totalCount > _pageSize)
{
    <MudStack Row="true" Class="mt-3" Justify="Justify.Center">
        <MudPagination Count="@((int)Math.Ceiling(_totalCount / (double)_pageSize))"
                       Selected="@(_currentPage + 1)" SelectedChanged="OnPageChanged" />
    </MudStack>
}

@code {
    private List<Whiskers.Models.McpToolCallEntity> _entries = new();
    private bool _loading = true;
    private string? _actorFilter;
    private string? _toolFilter;
    private string _period = "24h";
    private bool _writesOnly;
    private bool _deniesOnly;
    private int _totalCount;
    private int _currentPage;
    private const int _pageSize = 50;

    protected override async Task OnInitializedAsync() => await LoadData();

    private DateTime? Since() => _period switch
    {
        "1h" => DateTime.UtcNow.AddHours(-1),
        "24h" => DateTime.UtcNow.AddHours(-24),
        "7d" => DateTime.UtcNow.AddDays(-7),
        "30d" => DateTime.UtcNow.AddDays(-30),
        _ => null,
    };

    private string? Verdict() => _deniesOnly ? "deny" : null;

    private async Task LoadData()
    {
        _loading = true;
        var since = Since();
        _totalCount = await CallLog.CountAsync(_actorFilter, _toolFilter, Verdict(), _writesOnly, since);
        _entries = await CallLog.GetRecentAsync(_pageSize, _currentPage * _pageSize,
            _actorFilter, _toolFilter, Verdict(), _writesOnly, since);
        _loading = false;
    }

    private async Task Reload()
    {
        _currentPage = 0;
        await LoadData();
    }

    private async Task OnActorChanged(string v) { _actorFilter = v; await Reload(); }
    private async Task OnToolChanged(string v) { _toolFilter = v; await Reload(); }
    private async Task OnPeriodChanged(string v) { _period = v; await Reload(); }
    private async Task OnWritesOnlyChanged(bool v) { _writesOnly = v; await Reload(); }
    private async Task OnDeniesOnlyChanged(bool v) { _deniesOnly = v; await Reload(); }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page - 1;
        await LoadData();
    }

    private async Task OnRowClick(TableRowClickEventArgs<Whiskers.Models.McpToolCallEntity> args)
    {
        if (args.Item is null) return;
        await DialogService.ShowAsync<AgentCallDetailDialog>(
            args.Item.ToolName,
            new DialogParameters { ["Entry"] = args.Item },
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
    }

    [Inject] private IDialogService DialogService { get; set; } = default!;

    private static Color ActorColor(string actorType) => actorType switch
    {
        "agent-web" => Color.Primary,
        "agent-mcp" => Color.Tertiary,
        "mcp-direct" => Color.Info,
        "trigger" => Color.Warning,
        _ => Color.Default,
    };

    private static Color LevelColor(string level) => level switch
    {
        "admin" => Color.Error,
        "write" => Color.Warning,
        "read" => Color.Success,
        _ => Color.Default,
    };

    private static Color VerdictColor(string verdict) => verdict switch
    {
        "deny" => Color.Error,
        "confirm" => Color.Warning,
        "allow" => Color.Success,
        _ => Color.Default,
    };
}
