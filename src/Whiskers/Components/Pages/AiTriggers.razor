@page "/ai-triggers"
@attribute [Authorize]

@* Route wrapper (DI-safe module gating). AiTriggersView injects the AI-trigger + guardrail stores, so it is
   rendered only while the Agent module is enabled; otherwise ModuleGuard shows a "module disabled" notice. *@
<ModuleGuard ModuleId="agent">
    <AiTriggersView />
</ModuleGuard>
