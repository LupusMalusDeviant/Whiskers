@using Whiskers.Models
@inject IStringLocalizer<SharedResource> L

<MudDialog>
    <DialogContent>
        @if (Entry is not null)
        {
            <MudStack Spacing="3" Style="min-width: 320px;">
                <MudSimpleTable Dense="true" Bordered="false" Striped="true" Style="background: transparent;">
                    <tbody>
                        <tr><td><b>@L["AgentCallDetailDialog_Field_Timestamp"]</b></td><td>@Entry.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td></tr>
                        <tr><td><b>@L["AgentCallDetailDialog_Field_Actor"]</b></td><td>@Entry.Actor <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@Entry.ActorType</MudChip></td></tr>
                        <tr><td><b>@L["AgentCallDetailDialog_Field_Tool"]</b></td><td><code>@Entry.ToolName</code></td></tr>
                        <tr><td><b>@L["AgentCallDetailDialog_Field_Level"]</b></td><td>@Entry.Level</td></tr>
                        <tr>
                            <td><b>@L["AgentCallDetailDialog_Field_Verdict"]</b></td>
                            <td><MudChip T="string" Size="Size.Small" Color="@VerdictColor(Entry.Verdict)">@Entry.Verdict</MudChip></td>
                        </tr>
                        <tr>
                            <td><b>@L["AgentCallDetailDialog_Field_Status"]</b></td>
                            <td>
                                @if (Entry.Success)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">@L["AgentCallDetailDialog_Status_Success"]</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">@L["AgentCallDetailDialog_Status_Failure"]</MudChip>
                                }
                            </td>
                        </tr>
                        <tr><td><b>@L["AgentCallDetailDialog_Field_Duration"]</b></td><td>@Entry.DurationMs ms</td></tr>
                        @if (!string.IsNullOrEmpty(Entry.ServerId))
                        {
                            <tr><td><b>@L["AgentCallDetailDialog_Field_Server"]</b></td><td>@Entry.ServerId</td></tr>
                        }
                        @if (!string.IsNullOrEmpty(Entry.CorrelationId))
                        {
                            <tr><td><b>@L["AgentCallDetailDialog_Field_Correlation"]</b></td><td><code>@Entry.CorrelationId</code></td></tr>
                        }
                    </tbody>
                </MudSimpleTable>

                <div>
                    <MudText Typo="Typo.subtitle2" Class="mb-1">@L["AgentCallDetailDialog_Params_Title"]</MudText>
                    <pre class="sw-call-detail">@(string.IsNullOrWhiteSpace(Entry.ParamsJson) ? "—" : Entry.ParamsJson)</pre>
                </div>

                @if (!string.IsNullOrWhiteSpace(Entry.ResultSummary))
                {
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="mb-1">@L["AgentCallDetailDialog_Result_Title"]</MudText>
                        <pre class="sw-call-detail">@Entry.ResultSummary</pre>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Entry.Error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined">@Entry.Error</MudAlert>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog?.Close())">@L["AgentCallDetailDialog_Close_Button"]</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .sw-call-detail {
        white-space: pre-wrap;
        word-break: break-word;
        max-height: 260px;
        overflow: auto;
        background: rgba(0, 0, 0, 0.25);
        border-radius: 6px;
        padding: 10px 12px;
        font-size: 0.8rem;
        margin: 0;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public McpToolCallEntity? Entry { get; set; }

    private static Color VerdictColor(string verdict) => verdict switch
    {
        "deny" => Color.Error,
        "confirm" => Color.Warning,
        "allow" => Color.Success,
        _ => Color.Default,
    };
}
