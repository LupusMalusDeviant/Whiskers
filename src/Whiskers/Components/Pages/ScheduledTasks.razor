@page "/tasks"
@attribute [Authorize]

<PageTitle>Geplante Tasks - Whiskers</PageTitle>

@* RoadToSAP Phase 1: thin route wrapper. ModuleGuard renders the interactive ScheduledTasksView only when the
   Scheduler module is enabled; otherwise it shows a clean "module disabled" notice (and ScheduledTasksView —
   which injects ISchedulerService — is never instantiated, so there is no DI error). *@
<ModuleGuard ModuleId="scheduler">
    <ScheduledTasksView />
</ModuleGuard>
