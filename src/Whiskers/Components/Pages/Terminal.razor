@page "/terminal/{ServerId}/{ContainerId}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Terminal - Whiskers</PageTitle>

@* RoadToSAP Phase 1: thin route wrapper. ModuleGuard renders the interactive TerminalView only when the
   Terminal module is enabled; otherwise it shows a clean "module disabled" notice (and TerminalView — which
   injects ITerminalSessionManager — is never instantiated, so there is no DI error). *@
<ModuleGuard ModuleId="terminal">
    <TerminalView ServerId="@ServerId" ContainerId="@ContainerId" />
</ModuleGuard>

@code {
    [Parameter] public string? ServerId { get; set; }
    [Parameter] public string? ContainerId { get; set; }
}
