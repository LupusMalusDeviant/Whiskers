@using Markdig
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using System.Text
@using Whiskers.Configuration
@using Whiskers.Models
@using Whiskers.Models.Agent
@using Whiskers.Services.Agent
@using Whiskers.Services.Agent.Approvals
@using Whiskers.Services.Agent.Chat
@using Whiskers.Services.Agent.Guardrails
@using Whiskers.Services.Agent.Providers
@using Whiskers.Services.Auth
@inject IAgentService AgentService
@inject IGuardrailStore GuardrailStore
@inject IOptionsMonitor<AgentSettings> Settings
@inject ICurrentUserService CurrentUser
@inject IAgentTranscriptStore TranscriptStore
@inject IAgentSettingsStore SettingsStore
@inject IAgentProviderFactory ProviderFactory
@inject IApprovalCoordinator ApprovalCoordinator
@inject IApprovalStore ApprovalStore
@inject IChatWidgetParser WidgetParser
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Agent</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div style="display:flex; align-items:center; gap:10px;">
        <img src="logo.png" alt="Whiskers-Agent" width="40" height="40"
             style="border-radius:50%; flex:0 0 auto; box-shadow:0 1px 4px rgba(0,0,0,0.4);" />
        <MudText Typo="Typo.h5" Class="mb-1 flex-1">Whiskers-Agent</MudText>
        @if (_lines.Count > 0)
        {
            <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.DeleteSweep"
                       Variant="Variant.Text" OnClick="ClearChat">Verlauf leeren</MudButton>
        }
    </div>
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: rgba(255,255,255,0.5);">
        Handelnder Assistent — führt Aktionen nur innerhalb der Guardrails und nie über deine eigenen Rechte hinaus aus.
    </MudText>

    @if (!Settings.CurrentValue.Enabled)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Der Agent ist nicht aktiviert. Setze <code>Agent:Enabled=true</code>, einen Provider und einen API-Key in der Konfiguration.
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="@(_isAdmin ? 7 : 12)">
            <MudPaper Class="pa-3" Style="display:flex; flex-direction:column; height: calc(100vh - 210px); min-height: 460px;">
                <div @ref="_chatScroll" style="flex:1; overflow-y:auto; overflow-x:hidden; display:flex; flex-direction:column; gap:8px; padding-right:4px;">
                    @if (_lines.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-8" Style="color: rgba(255,255,255,0.3);">
                            Sag dem Agenten, was er tun soll — z.B. „liste alle unhealthy Container".
                        </MudText>
                    }
                    @foreach (var line in _lines)
                    {
                        <div style="@LineStyle(line.Kind)">
                            @if (line.Kind == "tool")
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" Class="mr-1" />
                            }
                            @if (line.Kind == "assistant")
                            {
                                @if (WidgetParser.HasWidgets(line.Text))
                                {
                                    @foreach (var seg in WidgetParser.Parse(line.Text))
                                    {
                                        if (seg.IsWidget)
                                        {
                                            <ChatWidget Spec="seg.Widget" />
                                        }
                                        else if (!string.IsNullOrEmpty(seg.Text))
                                        {
                                            <div class="sw-md">@((MarkupString)RenderMarkdown(seg.Text))</div>
                                        }
                                    }
                                }
                                else
                                {
                                    <div class="sw-md">@((MarkupString)RenderMarkdown(line.Text))</div>
                                }
                            }
                            else
                            {
                                <span style="white-space: pre-wrap; overflow-wrap:anywhere; word-break:break-word;">@line.Text</span>
                            }
                        </div>
                    }
                    @if (_pendingConfirm is not null)
                    {
                        <MudPaper Class="pa-3" Outlined="true" Style="border-color: var(--mud-palette-warning);">
                            <MudText Typo="Typo.body2" Class="mb-2">
                                <b>Bestätigung nötig:</b> @_pendingConfirm.Name — @_pendingReason
                            </MudText>
                            <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                       OnClick="@(() => Resolve(true))" Class="mr-2">Freigeben</MudButton>
                            <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                       OnClick="@(() => Resolve(false))">Ablehnen</MudButton>
                        </MudPaper>
                    }
                    @if (_running && _pendingConfirm is null)
                    {
                        <div style="display:flex; align-items:center; gap:8px; color: rgba(255,255,255,0.4);">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <span>Arbeitet…</span>
                        </div>
                    }
                </div>
                @if (_attachments.Count > 0)
                {
                    <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:8px;">
                        @foreach (var att in _attachments)
                        {
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.AttachFile"
                                     OnClose="@(() => _attachments.Remove(att))">
                                @att.Name (@FormatSize(att.Content.Length))
                            </MudChip>
                        }
                    </div>
                }
                <div style="display:flex; gap:8px; margin-top:8px; align-items:center;">
                    <MudFileUpload @ref="_fileUpload" T="IBrowserFile" FilesChanged="OnFileSelected" Class="d-none"
                                   Accept=".txt,.log,.json,.yml,.yaml,.md,.csv,.conf,.ini,.env,.sh,.cs,.xml,.html,.py,.js,.ts,.sql,Dockerfile" />
                    <MudIconButton Icon="@Icons.Material.Filled.AttachFile" title="Textdatei anhängen"
                                   OnClick="OpenFilePicker" Disabled="@_running" />
                    <MudTextField @bind-Value="_input" Placeholder="Auftrag… (Enter sendet)" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Immediate="true" Disabled="@_running"
                                  OnKeyDown="OnKeyDown" Class="flex-1" />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Send"
                               Disabled="@(_running || (string.IsNullOrWhiteSpace(_input) && _attachments.Count == 0))">Senden</MudButton>
                </div>
            </MudPaper>
        </MudItem>

        @if (_isAdmin)
        {
            <MudItem xs="12" md="5">
                <MudPaper Class="pa-4" Style="height: calc(100vh - 210px); min-height: 460px; overflow-y:auto;">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">LLM-Provider</MudText>
                    <MudSwitch @bind-Value="_llmEnabled" Color="Color.Primary" Label="Agent aktiviert" />
                    <MudSelect T="string" Value="_llmProvider" ValueChanged="OnProviderChanged" Label="Provider" Margin="Margin.Dense"
                               Variant="Variant.Outlined" Class="mt-2">
                        <MudSelectItem Value="@("openai")">openai</MudSelectItem>
                        <MudSelectItem Value="@("openrouter")">openrouter</MudSelectItem>
                        <MudSelectItem Value="@("ollama")">ollama</MudSelectItem>
                        <MudSelectItem Value="@("gemini")">gemini</MudSelectItem>
                        <MudSelectItem Value="@("anthropic")">anthropic</MudSelectItem>
                        <MudSelectItem Value="@("claude-code")">claude-code</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_llmEndpoint" Label="Endpoint (optional)" Margin="Margin.Dense"
                                  Variant="Variant.Outlined" Class="mt-2" OnBlur="MaybeTestAsync" />
                    <MudTextField @bind-Value="_llmKey" Label="API-Key" InputType="InputType.Password" Margin="Margin.Dense"
                                  Variant="Variant.Outlined" Class="mt-2" OnBlur="MaybeTestAsync"
                                  Immediate="true" DebounceInterval="700" OnDebounceIntervalElapsed="OnKeyDebounced" />

                    <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;" class="mt-2">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.NetworkCheck"
                                   OnClick="ForceTestAsync" Disabled="@(_modelTesting || _llmProvider == "claude-code")">
                            Verbindung testen
                        </MudButton>
                        @if (_modelTesting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5);">Teste…</MudText>
                        }
                        else if (_modelStatus == "ok")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                            <MudText Typo="Typo.caption" Style="color:#86efac;">@_modelStatusMsg</MudText>
                        }
                        else if (_modelStatus == "fail")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error" />
                            <MudText Typo="Typo.caption" Style="color:#fca5a5;">@_modelStatusMsg</MudText>
                        }
                    </div>

                    <MudAutocomplete T="string" @bind-Value="_llmModel" Label="Modell" Margin="Margin.Dense"
                                     Variant="Variant.Outlined" Class="mt-2" SearchFunc="SearchModels"
                                     CoerceValue="true" CoerceText="false" ResetValueOnEmptyText="false" MaxItems="300"
                                     AdornmentIcon="@Icons.Material.Filled.ExpandMore" Clearable="true"
                                     HelperText="@(_availableModels.Count > 0 ? $"{_availableModels.Count} Modelle verfügbar — tippen zum Filtern" : "Frei eingeben, oder API-Key testen für Vorschläge")" />

                    <MudNumericField @bind-Value="_llmIterations" Label="Max. Tool-Iterationen" Min="1" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mt-2" />

                    <MudExpansionPanels Elevation="0" Class="mt-2" Style="background:transparent;">
                        <MudExpansionPanel Style="background:transparent;">
                            <TitleContent>
                                <div style="display:flex; align-items:center; gap:8px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">System-Prompt</MudText>
                                    @if (_systemPrompt.Trim() != DefaultSystemPrompt.Trim())
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">angepasst</MudChip>
                                    }
                                </div>
                            </TitleContent>
                            <ChildContent>
                                <MudText Typo="Typo.caption" Class="mb-2" Style="color: rgba(255,255,255,0.5);">
                                    Anweisung an das LLM. Leer = Standard. Ändert NICHT die Guardrails — die greifen
                                    code-erzwungen am Tool-Boundary, egal was hier steht.
                                </MudText>
                                <MudTextField @bind-Value="_systemPrompt" Lines="12" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Style="font-size:0.82rem;" />
                                <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Restore"
                                           OnClick="ResetSystemPrompt" Class="mt-1">Auf Standard zurücksetzen</MudButton>
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>

                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveLlm" Class="mt-3" FullWidth="true">
                        Provider speichern
                    </MudButton>
                    <MudText Typo="Typo.caption" Class="mt-1" Style="color: rgba(255,255,255,0.4);">
                        Wird ohne Neustart übernommen (reloadOnChange).
                    </MudText>

                    <MudDivider Class="my-4" />
                    <MudButton Href="guardrails" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Shield" FullWidth="true">
                        Guardrails verwalten
                    </MudButton>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private sealed record Line(string Kind, string Text);

    private readonly List<Line> _lines = new();
    private string _input = "";
    private bool _running;
    private bool _isAdmin;

    private sealed record Attachment(string Name, string Content);
    private readonly List<Attachment> _attachments = new();
    private MudFileUpload<IBrowserFile> _fileUpload = null!;

    private async Task OpenFilePicker()
    {
        if (_fileUpload is not null) await _fileUpload.OpenFilePickerAsync();
    }

    private static readonly MarkdownPipeline MdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().DisableHtml().Build();
    private static string RenderMarkdown(string? text)
        => Whiskers.Utils.MarkdownSanitizer.NeutralizeUnsafeHrefs(Markdown.ToHtml(text ?? "", MdPipeline));
    private static string FormatSize(int chars) => chars < 1024 ? $"{chars} B" : $"{chars / 1024} KB";

    private IAgentSession? _session;
    private AgentContext? _context;
    private AgentToolCall? _pendingConfirm;
    private string _pendingReason = "";
    private string? _pendingApprovalId;

    private string _email = "local@serverwatch.local";
    private IReadOnlyList<AgentMessage> _seedHistory = Array.Empty<AgentMessage>();

    // LLM provider editor (admin)
    private bool _llmEnabled;
    private string _llmProvider = "openai";
    private string _llmModel = "";
    private string _llmEndpoint = "";
    private string _llmKey = "";
    private int _llmIterations = 8;
    private string _systemPrompt = "";

    // The built-in default prompt (fully qualified — "AgentService" the type is shadowed by the injected instance).
    private static readonly string DefaultSystemPrompt = Whiskers.Services.Agent.AgentService.SystemPrompt;

    // Model discovery (key test → available models)
    private List<string> _availableModels = new();
    private bool _modelTesting;
    private string _modelStatus = "";       // "", "ok", "fail"
    private string _modelStatusMsg = "";
    private string _lastTestedSignature = "";   // provider|endpoint|key — avoids redundant probes

    // Known Claude Code models (no listing API; the CLI resolves these).
    private static readonly string[] ClaudeCodeModels =
        { "claude-opus-4-8", "claude-opus-4-7", "claude-sonnet-4-6", "claude-haiku-4-5" };

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await CurrentUser.HasRoleAsync(AppRole.Admin);

        var cfg = Settings.CurrentValue;
        _llmEnabled = cfg.Enabled;
        _llmProvider = cfg.Provider;
        _llmModel = cfg.Model;
        _llmEndpoint = cfg.Endpoint ?? "";
        _llmKey = cfg.ApiKey;
        _llmIterations = cfg.MaxToolIterations;
        _systemPrompt = string.IsNullOrWhiteSpace(cfg.SystemPrompt) ? DefaultSystemPrompt : cfg.SystemPrompt;

        // Load the persisted conversation — used both for display and as seed context for the new session.
        _email = await CurrentUser.GetEmailAsync() ?? "local@serverwatch.local";
        _seedHistory = await TranscriptStore.LoadAsync(_email);
        foreach (var m in _seedHistory)
        {
            switch (m.Role)
            {
                case AgentRole.User: _lines.Add(new Line("user", m.Text ?? "")); break;
                case AgentRole.Assistant when !string.IsNullOrEmpty(m.Text): _lines.Add(new Line("assistant", m.Text!)); break;
                case AgentRole.Tool: _lines.Add(new Line("tool", $"{(m.IsError ? "⚠ " : "")}{Truncate(m.Text ?? "")}")); break;
            }
        }
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await Send();
    }

    private async Task OnFileSelected(IBrowserFile? file)
    {
        if (file is null) return;
        const long max = 512 * 1024;
        if (file.Size > max)
        {
            Snackbar.Add($"{file.Name} ist zu groß (max. 512 KB Text).", Severity.Warning);
            return;
        }
        try
        {
            using var reader = new StreamReader(file.OpenReadStream(max));
            var content = await reader.ReadToEndAsync();
            _attachments.Add(new Attachment(file.Name, content));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Datei konnte nicht gelesen werden: {ex.Message}", Severity.Error);
        }
    }

    private async Task Send()
    {
        if (_running || (string.IsNullOrWhiteSpace(_input) && _attachments.Count == 0)) return;
        var typed = _input.Trim();
        _input = "";

        // Build the message: attachment contents (for the agent) + the typed prompt.
        var full = new StringBuilder();
        foreach (var a in _attachments)
            full.Append($"[Angehängte Datei: {a.Name}]\n```\n{a.Content}\n```\n\n");
        full.Append(typed);
        var message = full.ToString().Trim();

        // Display line: the typed text + a note of attached files (not the full content).
        var display = _attachments.Count > 0
            ? $"{typed}\n📎 {string.Join(", ", _attachments.Select(a => a.Name))}".Trim()
            : typed;
        _attachments.Clear();

        _lines.Add(new Line("user", display));
        _running = true;
        StateHasChanged();

        if (_session is null)
        {
            _context = await BuildContextAsync();
            _session = await AgentService.StartSessionAsync(_context, _seedHistory);
        }

        try
        {
            await foreach (var ev in _session.SendAsync(message))
            {
                switch (ev)
                {
                    case AgentEvent.AssistantDelta d:
                        AppendAssistant(d.Text);
                        break;
                    case AgentEvent.ToolExecuted t:
                        _lines.Add(new Line("tool", $"{(t.Result.IsError ? "⚠ " : "")}{Truncate(t.Result.Content)}"));
                        break;
                    case AgentEvent.ConfirmationRequired c:
                        _pendingConfirm = c.Call;
                        _pendingReason = c.Reason;
                        // Register centrally so the bell + "Freigaben" page can also decide.
                        if (_session is not null && _context is not null)
                        {
                            var approval = await ApprovalCoordinator.RaiseAsync(_session, c.Call, _context, c.Reason);
                            _pendingApprovalId = approval.Id;
                        }
                        break;
                    case AgentEvent.Failed f:
                        _lines.Add(new Line("error", f.Message));
                        break;
                    case AgentEvent.TurnCompleted:
                        break;
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _lines.Add(new Line("error", $"Fehler: {ex.Message}"));
        }
        finally
        {
            _running = false;
            _pendingConfirm = null;
            _pendingApprovalId = null;
            StateHasChanged();
        }

        if (_session is not null)
            await TranscriptStore.SaveAsync(_email, _session.History);
    }

    private async Task ClearChat()
    {
        if (_session is not null) await ApprovalStore.CancelForSessionAsync(_session.SessionId);
        _lines.Clear();
        _session = null;
        _context = null;
        _pendingConfirm = null;
        _pendingApprovalId = null;
        _seedHistory = Array.Empty<AgentMessage>();
        await TranscriptStore.ClearAsync(_email);
    }

    private async Task Resolve(bool approved)
    {
        var call = _pendingConfirm;
        var approvalId = _pendingApprovalId;
        _pendingConfirm = null;
        _pendingApprovalId = null;
        StateHasChanged();

        // Route through the central store so the bell + "Freigaben" page stay consistent (idempotent:
        // whoever resolves first wins). Fall back to the session directly if no approval was registered.
        if (approvalId is not null)
            await ApprovalStore.ResolveAsync(approvalId, approved, _email);
        else if (_session is not null && call is not null)
            await _session.ResolveConfirmationAsync(call.Id, approved);
    }

    private void AppendAssistant(string text)
    {
        if (_lines.Count > 0 && _lines[^1].Kind == "assistant")
            _lines[^1] = _lines[^1] with { Text = _lines[^1].Text + text };
        else
            _lines.Add(new Line("assistant", text));
    }

    private async Task<AgentContext> BuildContextAsync()
    {
        var principal = await BuildPrincipalAsync();
        return new AgentContext(Guid.NewGuid().ToString("N"), principal, AgentOrigin.WebUi, GuardrailStore.Current);
    }

    private async Task<AgentPrincipal> BuildPrincipalAsync()
    {
        var email = await CurrentUser.GetEmailAsync() ?? "local@serverwatch.local";
        var role = await CurrentUser.GetRoleAsync();
        var level = role switch
        {
            AppRole.Admin => McpPermissionLevels.Admin,
            AppRole.Operator => McpPermissionLevels.Write,
            _ => McpPermissionLevels.Read,
        };
        return new AgentPrincipal(AgentPrincipalKind.WebUser, email, level, null, UserEmail: email);
    }

    private async Task SaveLlm()
    {
        if (!_isAdmin) { Snackbar.Add("Nur Admins dürfen die Agent-Einstellungen ändern.", Severity.Error); return; }
        await SettingsStore.SaveAsync(new AgentSettings
        {
            Enabled = _llmEnabled,
            Provider = _llmProvider,
            Model = _llmModel,
            Endpoint = string.IsNullOrWhiteSpace(_llmEndpoint) ? null : _llmEndpoint,
            ApiKey = _llmKey,
            MaxToolIterations = _llmIterations,
            // Store empty when unchanged from default, so it keeps tracking the built-in prompt.
            SystemPrompt = _systemPrompt.Trim() == DefaultSystemPrompt.Trim() ? "" : _systemPrompt,
        }, await BuildPrincipalAsync());
        Snackbar.Add("Provider gespeichert.", Severity.Success);
    }

    private void ResetSystemPrompt() => _systemPrompt = DefaultSystemPrompt;

    // === Model discovery ===

    private ElementReference _chatScroll;
    private int _lastScrolledCount = -1;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _isAdmin && (_llmProvider == "claude-code" || !string.IsNullOrWhiteSpace(_llmKey)))
            await MaybeTestAsync();

        // Keep the chat pinned to the newest message whenever a line was added.
        if (_lines.Count != _lastScrolledCount)
        {
            _lastScrolledCount = _lines.Count;
            try { await JS.InvokeVoidAsync("swChat.scrollToBottom", _chatScroll); } catch { /* JS not ready */ }
        }
    }

    private string Signature() => $"{_llmProvider}|{_llmEndpoint}|{_llmKey}";

    /// <summary>Auto-test when a relevant field changed and a key is present (avoids redundant probes).</summary>
    private async Task MaybeTestAsync()
    {
        if (_modelTesting) return;
        if (_llmProvider != "claude-code" && string.IsNullOrWhiteSpace(_llmKey)) return;
        if (Signature() == _lastTestedSignature && _availableModels.Count > 0) return;
        await TestAndLoadModelsAsync();
    }

    private async Task ForceTestAsync()
    {
        _lastTestedSignature = "";
        await TestAndLoadModelsAsync();
    }

    // Fires shortly after the key is pasted/typed (debounced) → auto-test without waiting for blur.
    private Task OnKeyDebounced(string _) => MaybeTestAsync();

    /// <summary>Pick a sensible default model from the fetched list (prefers fast/cheap variants).</summary>
    private static string PickPreferredModel(IReadOnlyList<string> models)
    {
        string[] prefs = { "flash", "gpt-4o-mini", "mini", "sonnet", "haiku", "gpt-4o" };
        foreach (var p in prefs)
        {
            var hit = models.FirstOrDefault(m => m.Contains(p, StringComparison.OrdinalIgnoreCase));
            if (hit is not null) return hit;
        }
        return models[0];
    }

    private async Task OnProviderChanged(string provider)
    {
        _llmProvider = provider;
        _availableModels.Clear();
        _modelStatus = "";
        _lastTestedSignature = "";
        if (provider == "claude-code" || !string.IsNullOrWhiteSpace(_llmKey))
            await TestAndLoadModelsAsync();
    }

    private async Task TestAndLoadModelsAsync()
    {
        if (_llmProvider == "claude-code")
        {
            _availableModels = ClaudeCodeModels.ToList();
            if (!_availableModels.Contains(_llmModel, StringComparer.OrdinalIgnoreCase))
                _llmModel = PickPreferredModel(_availableModels);
            _modelStatus = "ok";
            _modelStatusMsg = $"{_availableModels.Count} Modelle";
            _lastTestedSignature = Signature();
            return;
        }
        if (string.IsNullOrWhiteSpace(_llmKey))
        {
            _modelStatus = "";
            _availableModels.Clear();
            return;
        }

        _modelTesting = true;
        _modelStatus = "";
        StateHasChanged();
        try
        {
            var probe = new AgentSettings
            {
                Provider = _llmProvider,
                ApiKey = _llmKey,
                Endpoint = string.IsNullOrWhiteSpace(_llmEndpoint) ? null : _llmEndpoint,
                Model = _llmModel,
            };
            var models = await ProviderFactory.Resolve(probe).ListModelsAsync();
            _availableModels = models.ToList();
            // Auto-fill the model after a successful test if the current value isn't valid for this provider.
            if (_availableModels.Count > 0 && !_availableModels.Contains(_llmModel, StringComparer.OrdinalIgnoreCase))
                _llmModel = PickPreferredModel(_availableModels);
            _modelStatus = "ok";
            _modelStatusMsg = _availableModels.Count > 0
                ? $"{_availableModels.Count} Modelle gefunden"
                : "Key gültig, keine Modelle gelistet";
            _lastTestedSignature = Signature();
        }
        catch (Exception)
        {
            _availableModels.Clear();
            _modelStatus = "fail";
            _modelStatusMsg = "Verbindung fehlgeschlagen — Key/Endpoint prüfen";
        }
        finally
        {
            _modelTesting = false;
            StateHasChanged();
        }
    }

    private Task<IEnumerable<string>> SearchModels(string value, CancellationToken ct)
    {
        IEnumerable<string> items = string.IsNullOrWhiteSpace(value)
            ? _availableModels
            : _availableModels.Where(m => m.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(items);
    }

    private static string Truncate(string s) => s.Length > 600 ? s[..600] + "…" : s;

    // Every bubble breaks long unbreakable tokens (JSON log lines, URLs) so the chat never scrolls sideways.
    private const string Wrap = " overflow-wrap:anywhere; word-break:break-word; min-width:0;";

    private static string LineStyle(string kind) => kind switch
    {
        "user" => "align-self:flex-end; max-width:85%; padding:8px 12px; border-radius:12px 12px 4px 12px; background:rgba(96,165,250,0.15); font-size:0.85rem;" + Wrap,
        "tool" => "align-self:flex-start; max-width:90%; padding:6px 10px; border-radius:8px; background:rgba(255,255,255,0.03); font-size:0.8rem; color:rgba(255,255,255,0.7);" + Wrap,
        "error" => "align-self:flex-start; max-width:90%; padding:8px 12px; border-radius:8px; background:rgba(239,68,68,0.12); font-size:0.82rem; color:#fca5a5;" + Wrap,
        _ => "align-self:flex-start; max-width:90%; padding:10px 14px; border-radius:12px 12px 12px 4px; background:rgba(255,255,255,0.05); font-size:0.85rem; line-height:1.5;" + Wrap,
    };
}
