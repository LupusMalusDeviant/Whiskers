@page "/audit-log"
@attribute [Authorize]
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLogService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["AuditLog_PageTitle"]</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["AuditLog_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["AuditLog_Header_Subtitle"]</MudText>
        </div>
    </MudStack>
</div>

<MudStack Row="true" Class="mb-4" Spacing="2">
    <MudSelect T="string" Value="@_actionFilter" ValueChanged="OnActionFilterChanged"
               Label="@L["AuditLog_Filter_ActionLabel"]" Variant="Variant.Outlined" Dense="true" Style="max-width: 200px;" Clearable="true">
        <MudSelectItem Value="@("container")">@L["AuditLog_Filter_Container"]</MudSelectItem>
        <MudSelectItem Value="@("server")">@L["AuditLog_Filter_Server"]</MudSelectItem>
        <MudSelectItem Value="@("config")">@L["AuditLog_Filter_Config"]</MudSelectItem>
        <MudSelectItem Value="@("env")">@L["AuditLog_Filter_Env"]</MudSelectItem>
        <MudSelectItem Value="@("firewall")">@L["AuditLog_Filter_Firewall"]</MudSelectItem>
        <MudSelectItem Value="@("nginx")">@L["AuditLog_Filter_Nginx"]</MudSelectItem>
        <MudSelectItem Value="@("network")">@L["AuditLog_Filter_Networks"]</MudSelectItem>
        <MudSelectItem Value="@("backup")">@L["AuditLog_Filter_Backups"]</MudSelectItem>
        <MudSelectItem Value="@("deploy")">@L["AuditLog_Filter_Deploy"]</MudSelectItem>
    </MudSelect>
    <MudSelect T="string" Value="@_targetTypeFilter" ValueChanged="OnTargetTypeFilterChanged"
               Label="@L["AuditLog_Filter_TargetTypeLabel"]" Variant="Variant.Outlined" Dense="true" Style="max-width: 200px;" Clearable="true">
        <MudSelectItem Value="@("container")">@L["AuditLog_Filter_Container"]</MudSelectItem>
        <MudSelectItem Value="@("server")">@L["AuditLog_Filter_Server"]</MudSelectItem>
        <MudSelectItem Value="@("config")">@L["AuditLog_Filter_Config"]</MudSelectItem>
        <MudSelectItem Value="@("firewall")">@L["AuditLog_Filter_Firewall"]</MudSelectItem>
        <MudSelectItem Value="@("nginx")">@L["AuditLog_Filter_Nginx"]</MudSelectItem>
        <MudSelectItem Value="@("network")">@L["AuditLog_Filter_Network"]</MudSelectItem>
        <MudSelectItem Value="@("volume")">@L["AuditLog_Filter_Volume"]</MudSelectItem>
    </MudSelect>
    <MudSpacer />
    <MudText Typo="Typo.body2" Class="align-self-center" Style="color: #888;">
        @L["AuditLog_EntryCount", _totalCount]
    </MudText>
</MudStack>

<MudTable Items="@_entries" Dense="true" Hover="true" Striped="true" Loading="@_loading"
          FixedHeader="true" Height="calc(100vh - 280px)">
    <HeaderContent>
        <MudTh Style="width: 160px;">@L["AuditLog_Table_Timestamp"]</MudTh>
        <MudTh Style="width: 160px;">@L["AuditLog_Table_Actor"]</MudTh>
        <MudTh Style="width: 200px;">@L["AuditLog_Table_Action"]</MudTh>
        <MudTh>@L["AuditLog_Table_Target"]</MudTh>
        <MudTh Style="width: 80px;">@L["AuditLog_Table_Status"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L["AuditLog_Table_Timestamp"]">
            <MudText Typo="Typo.body2" Style="font-family: monospace;">
                @context.Timestamp.ToLocalTime().ToString("dd.MM.yy HH:mm:ss")
            </MudText>
        </MudTd>
        <MudTd DataLabel="@L["AuditLog_Table_Actor"]">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Color="@GetActorColor(context.ActorType)">
                @context.Actor
            </MudChip>
        </MudTd>
        <MudTd DataLabel="@L["AuditLog_Table_Action"]">
            <MudChip T="string" Size="Size.Small" Color="@GetActionColor(context.Action)">
                @FormatAction(context.Action)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="@L["AuditLog_Table_Target"]">
            <code>@context.TargetName</code>
            @if (!string.IsNullOrEmpty(context.Details))
            {
                <MudTooltip Text="@context.Details">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                             Style="vertical-align: middle; color: #888; margin-left: 4px;" />
                </MudTooltip>
            }
        </MudTd>
        <MudTd DataLabel="@L["AuditLog_Table_Status"]">
            @if (context.Success)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <div style="text-align:center; padding:2rem 1rem;">
            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
            <MudText Typo="Typo.body1">@L["AuditLog_Empty_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="max-width:520px; margin:0.25rem auto 0;">
                @L["AuditLog_Empty_Body"]
            </MudText>
        </div>
    </NoRecordsContent>
</MudTable>

@if (_totalCount > _pageSize)
{
    <MudStack Row="true" Class="mt-3" Justify="Justify.Center">
        <MudPagination Count="@((int)Math.Ceiling(_totalCount / (double)_pageSize))"
                       Selected="@(_currentPage + 1)"
                       SelectedChanged="OnPageChanged" />
    </MudStack>
}

@code {
    private List<Whiskers.Models.AuditLogEntity> _entries = new();
    private bool _loading = true;
    private string? _actionFilter;
    private string? _targetTypeFilter;
    private int _totalCount;
    private int _currentPage;
    private const int _pageSize = 50;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _totalCount = await AuditLogService.GetTotalCountAsync(_actionFilter, _targetTypeFilter);
        _entries = await AuditLogService.GetRecentAsync(_pageSize, _currentPage * _pageSize, _actionFilter, _targetTypeFilter);
        _loading = false;
    }

    private async Task OnActionFilterChanged(string value)
    {
        _actionFilter = value;
        _currentPage = 0;
        await LoadData();
    }

    private async Task OnTargetTypeFilterChanged(string value)
    {
        _targetTypeFilter = value;
        _currentPage = 0;
        await LoadData();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page - 1;
        await LoadData();
    }

    private static Color GetActorColor(string actorType) => actorType switch
    {
        "web" => Color.Primary,
        "mcp" => Color.Tertiary,
        "system" => Color.Default,
        _ => Color.Default
    };

    private static Color GetActionColor(string action) => action switch
    {
        var a when a.Contains("delete") || a.Contains("remove") || a.Contains("stop") => Color.Error,
        var a when a.Contains("start") || a.Contains("create") || a.Contains("add") || a.Contains("deploy") => Color.Success,
        var a when a.Contains("update") || a.Contains("restart") || a.Contains("set") || a.Contains("save") => Color.Warning,
        _ => Color.Info
    };

    private string FormatAction(string action) => action switch
    {
        "container.start" => L["AuditLog_Action_ContainerStart"].Value,
        "container.stop" => L["AuditLog_Action_ContainerStop"].Value,
        "container.restart" => L["AuditLog_Action_ContainerRestart"].Value,
        "container.remove" => L["AuditLog_Action_ContainerRemove"].Value,
        "container.update" => L["AuditLog_Action_ContainerUpdate"].Value,
        "env.save" => L["AuditLog_Action_EnvSave"].Value,
        "server.add" => L["AuditLog_Action_ServerAdd"].Value,
        "server.update" => L["AuditLog_Action_ServerUpdate"].Value,
        "server.remove" => L["AuditLog_Action_ServerRemove"].Value,
        "deploy.app" => L["AuditLog_Action_DeployApp"].Value,
        "deploy.compose" => L["AuditLog_Action_DeployCompose"].Value,
        "config.save" => L["AuditLog_Action_ConfigSave"].Value,
        "firewall.add" => L["AuditLog_Action_FirewallAdd"].Value,
        "firewall.remove" => L["AuditLog_Action_FirewallRemove"].Value,
        "nginx.update" => L["AuditLog_Action_NginxUpdate"].Value,
        "systemd.manage" => L["AuditLog_Action_SystemdManage"].Value,
        "ssl.renew" => L["AuditLog_Action_SslRenew"].Value,
        "network.create" => L["AuditLog_Action_NetworkCreate"].Value,
        "network.remove" => L["AuditLog_Action_NetworkRemove"].Value,
        "backup.create" => L["AuditLog_Action_BackupCreate"].Value,
        "backup.restore" => L["AuditLog_Action_BackupRestore"].Value,
        "backup.delete" => L["AuditLog_Action_BackupDelete"].Value,
        "command.execute" => L["AuditLog_Action_CommandExecute"].Value,
        _ => action
    };
}
