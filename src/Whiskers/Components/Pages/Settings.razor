    private async Task TestMatrix()
    {
        // IMatrixNotificationService lives in the Notifications module — resolve it lazily so /settings still
        // loads when that module is disabled (in which case the Matrix panel and this button aren't rendered).
        var matrix = ServiceProvider.GetService<Whiskers.Services.Notifications.IMatrixNotificationService>();
        if (matrix is null)
        {
            Snackbar.Add(L["Settings_Snackbar_NotificationsModuleDisabled"].Value, Severity.Warning);
            return;
        }
        try
        {
            await matrix.SendTestAsync();
            Snackbar.Add(L["Settings_Snackbar_MatrixTestSent"].Value, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Settings_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    // === Roles ===

    private async Task AddRole()
    {
        if (string.IsNullOrWhiteSpace(_newRoleEmail)) return;
        _roleEntries.Add(new Whiskers.Models.UserRoleEntry { Email = _newRoleEmail.Trim(), Role = _newRoleRole });
        _newRoleEmail = "";
        await SaveRoles();
    }

    private async Task SaveRoles()
    {
        if (!await CurrentUser.HasRoleAsync(AppRole.Admin)) { Snackbar.Add(L["Settings_Snackbar_NoPermission"].Value, Severity.Error); return; }
        await RoleService.SaveRoleDataAsync(new Whiskers.Models.UserRoleData { Roles = _roleEntries });
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        await AuditLog.LogAsync(actor, "web", "config.save", "config", "roles", "Benutzerrollen");
        Snackbar.Add(L["Settings_Snackbar_RolesSaved"].Value, Severity.Success);
    }

    // === Vault ===

    private void LoadVault()
    {
        _vaultEntries = VaultService.ListSecrets();
    }

    private async Task DeleteVaultSecret(string key)
    {
        if (!await CurrentUser.HasRoleAsync(AppRole.Admin)) { Snackbar.Add(L["Settings_Snackbar_NoPermission"].Value, Severity.Error); return; }
        await VaultService.DeleteSecretAsync(key);
        await AuditVault("vault.delete", key);
        LoadVault();
    }

    private async Task AddVaultSecret()
    {
        if (!await CurrentUser.HasRoleAsync(AppRole.Admin)) { Snackbar.Add(L["Settings_Snackbar_NoPermission"].Value, Severity.Error); return; }
        if (string.IsNullOrWhiteSpace(_newVaultKey) || string.IsNullOrWhiteSpace(_newVaultValue)) return;
        var key = _newVaultKey.Trim();
        try
        {
            await VaultService.SetSecretAsync(key, _newVaultValue);
            await AuditVault("vault.set", key);
            Snackbar.Add(L["Settings_Snackbar_SecretSaved", key].Value, Severity.Success);
            _newVaultKey = ""; _newVaultValue = "";
            LoadVault();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Settings_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    // Audit a vault mutation — key NAMES only, never values.
    private async Task AuditVault(string action, string key)
    {
        try
        {
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", action, "vault", key, key);
        }
        catch { }
    }

    // === CVE Monitor ===

    private Task TriggerCveScan()
    {
        if (CveStore.IsScanning) return Task.CompletedTask;
        Snackbar.Add(L["Settings_Snackbar_CveScanStarted"].Value, MudBlazor.Severity.Info);
        _ = Task.Run(async () =>
        {
            try { await CveMonitor.RunOneCycleAsync(); }
            catch (Exception ex) { Console.Error.WriteLine($"Manual CVE scan failed: {ex.Message}"); }
        });
        return Task.CompletedTask;
    }
}
