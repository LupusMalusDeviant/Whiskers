@page "/settings"
@using Whiskers.Configuration
@using Microsoft.Extensions.DependencyInjection
@attribute [Authorize]
@inject IOptionsMonitor<Whiskers.Configuration.MattermostSettings> MattermostOptions
@inject IOptionsMonitor<Whiskers.Configuration.HealthMonitorSettings> HealthOptions
@inject IOptionsMonitor<Whiskers.Configuration.TerminalSettings> TerminalOptions
@inject Whiskers.Modules.IModuleRegistry ModuleRegistry
@inject IOptionsMonitor<Whiskers.Configuration.GoogleAuthSettings> AuthOptions
@inject INotificationService NotificationService
@inject IOptionsMonitor<Whiskers.Configuration.MatrixSettings> MatrixOptions
@inject IServiceProvider ServiceProvider
@inject IWhitelistService WhitelistService
@inject Whiskers.Services.Auth.IRoleService RoleService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject Microsoft.JSInterop.IJSRuntime JS
@inject Whiskers.Services.Vault.IVaultService VaultService
@inject Whiskers.Services.Mcp.IMcpPermissionService McpPermissionService
@inject ISnackbar Snackbar
@inject IOptionsMonitor<Whiskers.Configuration.CveMonitorSettings> CveSettings
@inject Whiskers.Services.Cve.ICveFindingsStore CveStore
@inject Whiskers.Services.Cve.ICveMonitorService CveMonitor
@inject IOptionsMonitor<Whiskers.Configuration.MetricAlertSettings> MetricAlertOptions
@inject IOptionsMonitor<Whiskers.Configuration.ImageUpdateSettings> ImageUpdateOptions
@inject IOptionsMonitor<Whiskers.Configuration.AiChatSettings> AiChatOptions
@inject IOptionsMonitor<Whiskers.Configuration.TelegramSettings> TelegramOptions
@inject IOptionsMonitor<Whiskers.Configuration.NtfySettings> NtfyOptions
@inject IOptionsMonitor<Whiskers.Configuration.DiscordSettings> DiscordOptions
@inject IOptionsMonitor<Whiskers.Configuration.SlackSettings> SlackOptions
@inject IOptionsMonitor<Whiskers.Configuration.EmailSettings> EmailOptions
@inject IOptionsMonitor<Whiskers.Configuration.WebhookNotificationSettings> WebhookOptions
@inject Whiskers.Services.Persistence.IAppSettingsStore AppSettings
@inject IConfiguration Configuration
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Settings_PageTitle"]</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["Settings_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Settings_Header_Subtitle"]</MudText>
        </div>
    </MudStack>
</div>

@if (_role < AppRole.Admin)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">
        @L["Settings_Alert_NoAccess", _role]
    </MudAlert>
}
else
{
<MudExpansionPanels MultiExpansion="true">
    @* W3.4: static production-readiness checklist. CORE, read-only, first panel on purpose. *@
    <MudExpansionPanel Text="@L["Settings_Panel_ProductionReady"]" Icon="@Icons.Material.Filled.Checklist">
        <ProductionReadinessPanel />
    </MudExpansionPanel>

    @* F3: Whiskers self-backup & restore. CORE (not module-gated) — always available to admins. *@
    <MudExpansionPanel Text="Backup & Restore" Icon="@Icons.Material.Filled.SettingsBackupRestore">
        <SelfBackupPanel />
    </MudExpansionPanel>

    @* F8: UI-managed registries (credentials in the vault, used for authenticated pulls). CORE. *@
    <MudExpansionPanel Text="Registries" Icon="@Icons.Material.Filled.Widgets">
        <RegistriesPanel />
    </MudExpansionPanel>

    @* RoadToSAP Phase 1: hide the channel + composite settings when the Notifications module is off. The
       /notifications feed (bell + page) stays available — it's Core (the in-app store), not this module. *@
    @if (ModuleRegistry.IsEnabled("notifications"))
    {
    @* Notifications (Mattermost + Matrix) *@
    <MudExpansionPanel Text="@L["Settings_Panel_Notifications"]" Icon="@Icons.Material.Filled.Notifications" Expanded="true">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Mattermost</MudText>
        <MudGrid>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_mmEnabled" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_mmWebhook" Label="@L["Settings_Label_WebhookUrl"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_mmChannel" Label="@L["Settings_Label_Channel"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_mmBot" Label="@L["Settings_Label_BotUsername"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_mmThrottle" Label="@L["Settings_Label_ThrottleMinutes"]" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="TestMattermost" StartIcon="@Icons.Material.Filled.Send"
                   Disabled="@(!_mmEnabled)" Class="mt-1">@L["Settings_Button_TestNotification"]</MudButton>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">Matrix</MudText>
        <MudGrid>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_mxEnabled" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_mxHomeserver" Label="@L["Settings_Label_HomeserverUrl"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mxRoom" Label="@L["Settings_Label_RoomId"]" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="!abc123:matrix.org" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mxToken" Label="Access Token" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_mxThrottle" Label="@L["Settings_Label_ThrottleMinutes"]" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="TestMatrix" StartIcon="@Icons.Material.Filled.Send"
                   Disabled="@(!_mxEnabled)" Class="mt-1">@L["Settings_Button_TestNotification"]</MudButton>

        <MudDivider Class="my-3" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveNotifications">@L["Settings_Button_SaveNotifications"]</MudButton>
    </MudExpansionPanel>

    @* Additional notification channels (Telegram / ntfy / Discord / Email / Webhook) *@
    <MudExpansionPanel Text="@L["Settings_Panel_MoreChannels"]" Icon="@Icons.Material.Filled.Campaign">
        <MudText Typo="Typo.subtitle2" Class="mb-1">Telegram</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_tgEnabled" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_tgToken" Label="@L["Settings_Label_BotToken"]" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_tgChat" Label="@L["Settings_Label_ChatId"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">ntfy</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_ntfyEnabled" /></MudItem>
            <MudItem xs="12" md="5"><MudTextField @bind-Value="_ntfyServer" Label="@L["Settings_Label_ServerUrl"]" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="https://ntfy.sh" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_ntfyTopic" Label="Topic" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_ntfyToken" Label="Token (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">Discord</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_dcEnabled" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_dcWebhook" Label="@L["Settings_Label_WebhookUrl"]" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">Slack</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_slEnabled" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_slWebhook" Label="@L["Settings_Label_WebhookUrl"]" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">Email (SMTP)</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_mailEnabled" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailHost" Label="@L["Settings_Label_SmtpHost"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="6" md="3"><MudNumericField @bind-Value="_mailPort" Label="Port" Min="1" Max="65535" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="6" md="3" Class="d-flex align-center"><MudSwitch T="bool" Color="Color.Primary" Label="SSL/TLS" @bind-Value="_mailSsl" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailUser" Label="@L["Settings_Label_Username"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailPass" Label="@L["Settings_Label_Password"]" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailFrom" Label="@L["Settings_Label_MailFrom"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailTo" Label="@L["Settings_Label_MailTo"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">@L["Settings_Heading_GenericWebhook"]</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_whEnabled" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_whUrl" Label="URL (POST JSON)" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveChannels">@L["Settings_Button_SaveChannels"]</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send" OnClick="TestChannels">@L["Settings_Button_SendTestNotification"]</MudButton>
        </MudStack>
    </MudExpansionPanel>
    }

    @* Health Monitoring *@
    <MudExpansionPanel Text="@L["Settings_Panel_HealthMonitoring"]" Icon="@Icons.Material.Filled.MonitorHeart">
        <MudGrid>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hInterval" Label="@L["Settings_Label_CheckIntervalSeconds"]" Min="5" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hRetention" Label="@L["Settings_Label_HistoryRetentionHours"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hLoopThreshold" Label="@L["Settings_Label_RestartLoopThreshold"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hLoopWindow" Label="@L["Settings_Label_RestartLoopWindow"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveHealth" Class="mt-2">@L["Settings_Button_Save"]</MudButton>
    </MudExpansionPanel>

    @* Metric alerts *@
    <MudExpansionPanel Text="@L["Settings_Panel_MetricAlerts"]" Icon="@Icons.Material.Filled.Insights">
        <MudGrid>
            <MudItem xs="12"><MudSwitch @bind-Value="_maEnabled" Color="Color.Primary" Label="@L["Settings_Label_MetricAlertsEnabled"]" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maCpu" Label="@L["Settings_Label_CpuThreshold"]" Min="1" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maMem" Label="@L["Settings_Label_MemoryThreshold"]" Min="1" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maDisk" Label="@L["Settings_Label_DiskThreshold"]" Min="1" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maSustained" Label="@L["Settings_Label_SustainedMinutes"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maCooldown" Label="@L["Settings_Label_CooldownMinutes"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudDivider Class="my-2" />
        <MudGrid>
            <MudItem xs="12"><MudSwitch @bind-Value="_maAnom" Color="Color.Secondary" Label="@L["Settings_Label_AnomalyEnabled"]" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maAnomWindow" Label="@L["Settings_Label_AnomalyWindow"]" Min="5" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(!_maAnom)" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maAnomSigma" Label="@L["Settings_Label_AnomalySigma"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(!_maAnom)" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maAnomFloor" Label="@L["Settings_Label_AnomalyFloor"]" Min="0" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(!_maAnom)" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveMetricAlert" Class="mt-2">@L["Settings_Button_Save"]</MudButton>
    </MudExpansionPanel>

    @* RoadToSAP Phase 1: hide the Image-Updates settings when the ImageUpdate module is disabled. *@
    @if (ModuleRegistry.IsEnabled("image-updates"))
    {
    @* Image / Auto-Update *@
    <MudExpansionPanel Text="@L["Settings_Panel_ImageUpdates"]" Icon="@Icons.Material.Filled.SystemUpdate">
        <MudGrid>
            <MudItem xs="12"><MudSwitch @bind-Value="_iuEnabled" Color="Color.Primary" Label="@L["Settings_Label_ImageUpdateEnabled"]" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_iuInterval" Label="@L["Settings_Label_CheckIntervalHours"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudSwitch @bind-Value="_iuNotify" Color="Color.Primary" Label="@L["Settings_Label_NotifyOnUpdate"]" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveImageUpdate" Class="mt-2">@L["Settings_Button_Save"]</MudButton>
    </MudExpansionPanel>
    }

    @* Terminal *@
    @* RoadToSAP Phase 1: hide the CVE-Monitor settings when the Cve module is disabled. *@
    @if (ModuleRegistry.IsEnabled("cve"))
    {
    @* CVE-Monitor *@
    <MudExpansionPanel Text="@L["Settings_Panel_CveMonitor"]" Icon="@Icons.Material.Filled.Security">
        @{
            var cveCfg = CveSettings.CurrentValue;
        }
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(cveCfg.Enabled ? Color.Success : Color.Default)"
                             Variant="Variant.Outlined">
                        @(cveCfg.Enabled ? L["Settings_Chip_Active"] : L["Settings_Chip_Disabled"])
                    </MudChip>
                    @if (CveStore.IsScanning)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> @L["Settings_Chip_ScanRunning"]
                        </MudChip>
                    }
                    @if (CveStore.LastScanAt is { } lsa)
                    {
                        <MudText Typo="Typo.body2" Style="color:#888;">
                            @L["Settings_Text_LastScan", lsa.ToString("yyyy-MM-dd HH:mm 'UTC'")]
                        </MudText>
                    }
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               Href="cves" StartIcon="@Icons.Material.Filled.OpenInNew">
                        @L["Settings_Button_GoToCves"]
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Search" OnClick="TriggerCveScan"
                               Disabled="@(CveStore.IsScanning || !cveCfg.Enabled)">
                        @L["Settings_Button_ScanNow"]
                    </MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveEnabled" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" /></MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveScanContainers" Color="Color.Primary" Label="@L["Settings_Label_ScanContainers"]" /></MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveScanOs" Color="Color.Primary" Label="@L["Settings_Label_ScanHostOs"]" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_cveInterval" Label="@L["Settings_Label_CheckIntervalHours"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_cveMaxScans" Label="@L["Settings_Label_MaxParallelScans"]" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_cveTrivy" Label="@L["Settings_Label_TrivyImage"]" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" @bind-Value="_cveSeverity" Label="@L["Settings_Label_NotifySeverity"]" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Critical")">Critical</MudSelectItem>
                    <MudSelectItem Value="@("High")">High</MudSelectItem>
                    <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                    <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveNotify" Color="Color.Primary" Label="@L["Settings_Label_NotifyOnFinding"]" /></MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveOsIds" Color="Color.Primary" Label="@L["Settings_Label_ResolveOsCveIds"]" /></MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveCve">@L["Settings_Button_Save"]</MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>
    }

    @* RoadToSAP Phase 1: hide the Terminal settings when the Terminal module is disabled. *@
    @if (ModuleRegistry.IsEnabled("terminal"))
    {
    <MudExpansionPanel Text="Terminal" Icon="@Icons.Material.Filled.Terminal">
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_termEnabled" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_termShell" Label="@L["Settings_Label_DefaultShell"]" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField @bind-Value="_termMaxSessions" Label="@L["Settings_Label_MaxSessions"]" Min="1" Max="50" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField @bind-Value="_termIdle" Label="@L["Settings_Label_IdleTimeout"]" Min="1" Max="1440" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveTerminal"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-3">@L["Settings_Button_SaveTerminal"]</MudButton>
    </MudExpansionPanel>
    }

    @* AI advisor chat — belongs to the Agent module (RoadToSAP Phase 1 §3.8); hidden when it's disabled. *@
    @if (ModuleRegistry.IsEnabled("agent"))
    {
    <MudExpansionPanel Text="@L["Settings_Panel_AiChat"]" Icon="@Icons.Material.Filled.Chat">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            @L["Settings_Alert_AiChatInfo"]
        </MudAlert>
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" Color="Color.Primary" Label="@L["Settings_Label_Enabled"]" @bind-Value="_aiEnabled" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" @bind-Value="_aiProvider" Label="Provider" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("openai")">@L["Settings_Option_OpenAiCompatible"]</MudSelectItem>
                    <MudSelectItem Value="@("anthropic")">Anthropic</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_aiModel" Label="@L["Settings_Label_Model"]" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="@L["Settings_Placeholder_ModelExample"]" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_aiApiUrl" Label="@L["Settings_Label_ApiUrlOptional"]" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="@L["Settings_Placeholder_ApiUrlDefault"]" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_aiApiKey" Label="@L["Settings_Label_ApiKey"]" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" />
            </MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveAiChat"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-3">@L["Settings_Button_SaveAiChat"]</MudButton>
    </MudExpansionPanel>
    }

    @* Restart-only / environment settings — read-only (set via .env, applied on restart) *@
    <MudExpansionPanel Text="@L["Settings_Panel_Environment"]" Icon="@Icons.Material.Filled.Dns">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            @((MarkupString)L["Settings_Alert_EnvInfo"].Value)
        </MudAlert>
        <MudSimpleTable Dense="true" Hover="true" Striped="true">
            <tbody>
                <tr><td>@L["Settings_Env_LoginDisabled"]</td><td>@(Configuration["Auth:Disabled"] ?? "false")</td></tr>
                <tr><td>Google OAuth</td><td>@(string.IsNullOrWhiteSpace(Configuration["GoogleAuth:ClientId"]) ? L["Settings_Env_NotConfigured"] : L["Settings_Env_Configured"])</td></tr>
                <tr><td>@L["Settings_Env_OidcEnabled"]</td><td>@(Configuration["Oidc:Enabled"] ?? "false")</td></tr>
                <tr><td>OIDC Authority</td><td>@(string.IsNullOrWhiteSpace(Configuration["Oidc:Authority"]) ? "—" : Configuration["Oidc:Authority"])</td></tr>
                <tr><td>@L["Settings_Env_OidcDisplayName"]</td><td>@(string.IsNullOrWhiteSpace(Configuration["Oidc:DisplayName"]) ? "—" : Configuration["Oidc:DisplayName"])</td></tr>
                <tr><td>PathBase</td><td>@(string.IsNullOrWhiteSpace(Configuration["PathBase"]) ? "(root)" : Configuration["PathBase"])</td></tr>
                <tr><td>@L["Settings_Env_VpnProvider"]</td><td>@(string.IsNullOrWhiteSpace(Configuration["Vpn:Provider"]) ? "none" : Configuration["Vpn:Provider"])</td></tr>
            </tbody>
        </MudSimpleTable>
    </MudExpansionPanel>

    @* MCP Permissions *@
    <MudExpansionPanel Text="@L["Settings_Panel_McpPermissions"]" Icon="@Icons.Material.Filled.VpnKey"
                       Expanded="false">
        <MudText Typo="Typo.subtitle1" Class="mb-3">@L["Settings_Heading_ApiKeys"]</MudText>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            @((MarkupString)L["Settings_Alert_ApiKeyLevels"].Value)
        </MudAlert>

        <MudTable Items="@_mcpApiKeys" Dense="true" Hover="true" Class="mb-4">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>@L["Settings_Th_Key"]</MudTh>
                <MudTh>@L["Settings_Th_Level"]</MudTh>
                <MudTh>@L["Settings_Th_Active"]</MudTh>
                <MudTh>@L["Settings_Th_Created"]</MudTh>
                <MudTh>@L["Settings_Th_Actions"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2" Style="font-family: monospace;">
                            @((_revealedKeys.Contains(context.Id)) ? context.Key : context.Key[..8] + "..." + context.Key[^4..])
                        </MudText>
                        <MudIconButton Icon="@(_revealedKeys.Contains(context.Id) ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                       Size="Size.Small" OnClick="@(() => ToggleKeyVisibility(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                       OnClick="@(async () => await CopyKey(context.Key))" />
                    </MudStack>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(context.PermissionLevel)">
                        @GetLevelLabel(context.PermissionLevel)
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudSwitch T="bool" @bind-Value="context.Enabled" Color="Color.Success" />
                </MudTd>
                <MudTd>@context.CreatedAt.ToString("dd.MM.yyyy")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveApiKey(context.Id))" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-6">
            <MudTextField @bind-Value="_newKeyName" Label="Name" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Style="max-width: 200px;" Placeholder="@L["Settings_Placeholder_KeyName"]" />
            <MudSelect @bind-Value="_newKeyLevel" Label="@L["Settings_Label_Level"]" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width: 150px;">
                <MudSelectItem Value="@("read")">@L["Settings_Level_Read"]</MudSelectItem>
                <MudSelectItem Value="@("write")">@L["Settings_Level_Write"]</MudSelectItem>
                <MudSelectItem Value="@("admin")">@L["Settings_Level_Admin"]</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="AddApiKey" StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@string.IsNullOrWhiteSpace(_newKeyName)">@L["Settings_Button_CreateKey"]</MudButton>
        </MudStack>

        <MudDivider Class="mb-4" />

        <MudText Typo="Typo.subtitle1" Class="mb-3">@L["Settings_Heading_ToolPermissions"]</MudText>

        @foreach (var category in _mcpTools.GroupBy(t => t.Value.Category).OrderBy(g => g.Key))
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mt-3 mb-1">@category.Key</MudText>
            <MudTable Items="@category.ToList()" Dense="true" Hover="true" Class="mb-2">
                <HeaderContent>
                    <MudTh>Tool</MudTh>
                    <MudTh>@L["Settings_Th_MinLevel"]</MudTh>
                    <MudTh>@L["Settings_Th_Enabled"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Style="font-family: monospace; font-size: 0.85rem;">@context.Key</MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(context.Value.RequiredLevel)">
                            @GetLevelLabel(context.Value.RequiredLevel)
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudSwitch T="bool" @bind-Value="context.Value.Enabled" Color="Color.Success" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveMcpPermissions"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-4" Disabled="@_savingMcp">
            @(_savingMcp ? L["Settings_Button_Saving"] : L["Settings_Button_SaveMcpPermissions"])
        </MudButton>
    </MudExpansionPanel>


    @* Cloud-Provider (Hetzner/Hostinger) credentials are configured per server under "Server". *@

    @* User Roles *@
    <MudExpansionPanel Text="@L["Settings_Panel_UserRoles"]" Icon="@Icons.Material.Filled.AdminPanelSettings">
        <MudGrid>
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    <strong>Viewer:</strong> @L["Settings_Role_ViewerDesc"] |
                    <strong>Operator:</strong> @L["Settings_Role_OperatorDesc"] |
                    <strong>Admin:</strong> @L["Settings_Role_AdminDesc"]
                </MudAlert>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="@_roleEntries" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>@L["Settings_Th_Email"]</MudTh>
                        <MudTh>@L["Settings_Th_Role"]</MudTh>
                        <MudTh Style="width: 60px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.Email</code></MudTd>
                        <MudTd>
                            <MudSelect T="Whiskers.Models.AppRole" Value="@context.Role" Dense="true"
                                       ValueChanged="@(async (Whiskers.Models.AppRole r) => { context.Role = r; await SaveRoles(); })"
                                       Variant="Variant.Text" Style="max-width: 140px;">
                                <MudSelectItem Value="Whiskers.Models.AppRole.Viewer">Viewer</MudSelectItem>
                                <MudSelectItem Value="Whiskers.Models.AppRole.Operator">Operator</MudSelectItem>
                                <MudSelectItem Value="Whiskers.Models.AppRole.Admin">Admin</MudSelectItem>
                            </MudSelect>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(async () => { _roleEntries.Remove(context); await SaveRoles(); })" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                    <MudTextField @bind-Value="_newRoleEmail" Label="@L["Settings_Label_Email"]" Variant="Variant.Outlined" Style="max-width: 300px;" />
                    <MudSelect T="Whiskers.Models.AppRole" @bind-Value="_newRoleRole" Label="@L["Settings_Label_Role"]" Variant="Variant.Outlined" Dense="true" Style="max-width: 140px;">
                        <MudSelectItem Value="Whiskers.Models.AppRole.Viewer">Viewer</MudSelectItem>
                        <MudSelectItem Value="Whiskers.Models.AppRole.Operator">Operator</MudSelectItem>
                        <MudSelectItem Value="Whiskers.Models.AppRole.Admin">Admin</MudSelectItem>
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddRole"
                               Disabled="@string.IsNullOrWhiteSpace(_newRoleEmail)">@L["Settings_Button_Add"]</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* Secret Vault *@
    <MudExpansionPanel Text="Secret Vault" Icon="@Icons.Material.Filled.VpnKey">
        <MudGrid>
            @if (!VaultService.IsEnabled)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        @((MarkupString)L["Settings_Alert_VaultDisabled"].Value)
                    </MudAlert>
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                        @L["Settings_Alert_VaultActive", _vaultEntries.Count]
                    </MudAlert>
                </MudItem>
                <MudItem xs="12">
                    <MudTable Items="@_vaultEntries" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Key</MudTh>
                            <MudTh>Container</MudTh>
                            <MudTh>@L["Settings_Th_Created"]</MudTh>
                            <MudTh>Rotation</MudTh>
                            <MudTh Style="width: 60px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><code style="font-weight: 600;">@context.Key</code></MudTd>
                            <MudTd>@(context.ContainerName ?? "-")</MudTd>
                            <MudTd>@context.CreatedAt.ToLocalTime().ToString("dd.MM.yy")</MudTd>
                            <MudTd>
                                @if (context.RotateAfterDays.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@L["Settings_Chip_RotationDays", context.RotateAfterDays]</MudChip>
                                }
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(async () => await DeleteVaultSecret(context.Key))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_newVaultKey" Label="Key" Variant="Variant.Outlined" Style="max-width: 200px;" />
                        <MudTextField @bind-Value="_newVaultValue" Label="Value" Variant="Variant.Outlined"
                                      InputType="InputType.Password" Style="flex: 1;" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddVaultSecret"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newVaultKey) || string.IsNullOrWhiteSpace(_newVaultValue))">@L["Settings_Button_Save"]</MudButton>
                    </MudStack>
                </MudItem>
            }
        </MudGrid>
    </MudExpansionPanel>

    @* Auth *@
    <MudExpansionPanel Text="@L["Settings_Panel_Authentication"]" Icon="@Icons.Material.Filled.Security">
        <MudGrid>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle1">Google OAuth</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @L["Settings_Text_ClientId"] @(string.IsNullOrWhiteSpace(AuthOptions.CurrentValue.ClientId) ? L["Settings_Text_ClientIdNotConfigured"] : L["Settings_Text_ClientIdConfigured"])
                </MudText>
            </MudItem>
            <MudItem xs="12">
                <MudSwitch T="bool" @bind-Value="_whitelistEnabled" Color="Color.Primary"
                           Label="@L["Settings_Label_WhitelistEnabled"]" />
            </MudItem>
            @if (_whitelistEnabled && _whitelistEmails.Count == 0)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning">
                        @L["Settings_Alert_WhitelistEmpty"]
                    </MudAlert>
                </MudItem>
            }
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Settings_Heading_AllowedEmails"]</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var email in _whitelistEmails)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                 OnClose="@(() => RemoveEmail(email))">@email</MudChip>
                    }
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_newEmail" Label="@L["Settings_Label_AddEmail"]" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Style="max-width: 350px;"
                                  Placeholder="@L["Settings_Placeholder_Email"]"
                                  OnKeyUp="@(async (e) => { if (e.Key == "Enter") await AddEmail(); })" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddEmail" StartIcon="@Icons.Material.Filled.Add"
                               Disabled="@string.IsNullOrWhiteSpace(_newEmail)">@L["Settings_Button_Add"]</MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveWhitelist"
                           StartIcon="@Icons.Material.Filled.Save" Disabled="@_savingWhitelist">
                    @(_savingWhitelist ? L["Settings_Button_Saving"] : L["Settings_Button_SaveWhitelist"])
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>
</MudExpansionPanels>
}

@code {
    private AppRole _role = AppRole.Viewer;
    private bool _whitelistEnabled;
    private List<string> _whitelistEmails = new();
    private string _newEmail = "";
    private bool _savingWhitelist;

    // Roles
    private List<Whiskers.Models.UserRoleEntry> _roleEntries = new();
    private string _newRoleEmail = "";
    private Whiskers.Models.AppRole _newRoleRole = Whiskers.Models.AppRole.Operator;

    // Vault
    private List<Whiskers.Models.VaultEntry> _vaultEntries = new();
    private string _newVaultKey = "";
    private string _newVaultValue = "";

    // MCP Permissions
    private List<Whiskers.Models.McpApiKeyConfig> _mcpApiKeys = new();
    private Dictionary<string, Whiskers.Models.McpToolConfig> _mcpTools = new();
    private string _newKeyName = "";
    private string _newKeyLevel = "read";
    private bool _savingMcp;
    private HashSet<string> _revealedKeys = new();

    // Editable settings (saved live to app-settings.json, no restart)
    private bool _mmEnabled; private string _mmWebhook = ""; private string _mmChannel = ""; private string _mmBot = ""; private int _mmThrottle = 5;
    private bool _mxEnabled; private string _mxHomeserver = ""; private string _mxRoom = ""; private string _mxToken = ""; private int _mxThrottle = 5;
    private int _hInterval = 30; private int _hRetention = 24; private int _hLoopThreshold = 5; private int _hLoopWindow = 10;
    private bool _maEnabled = true; private double _maCpu = 90; private double _maMem = 90; private double _maDisk = 90; private int _maSustained = 3; private int _maCooldown = 15;
    private bool _maAnom; private int _maAnomWindow = 20; private double _maAnomSigma = 3; private double _maAnomFloor = 40;
    private bool _cveEnabled; private int _cveInterval = 12; private bool _cveScanContainers = true; private bool _cveScanOs = true; private bool _cveOsIds = true;
    private string _cveTrivy = "aquasec/trivy:latest"; private bool _cveNotify = true; private string _cveSeverity = "High"; private int _cveMaxScans = 3;
    private bool _iuEnabled = true; private int _iuInterval = 6; private bool _iuNotify = true;
    private bool _termEnabled = true; private string _termShell = "/bin/bash"; private int _termMaxSessions = 5; private int _termIdle = 30;
    private bool _aiEnabled; private string _aiProvider = "openai"; private string _aiModel = ""; private string _aiApiUrl = ""; private string _aiApiKey = "";
    // Additional notification channels
    private bool _tgEnabled; private string _tgToken = ""; private string _tgChat = "";
    private bool _ntfyEnabled; private string _ntfyServer = "https://ntfy.sh"; private string _ntfyTopic = ""; private string _ntfyToken = "";
    private bool _dcEnabled; private string _dcWebhook = "";
    private bool _slEnabled; private string _slWebhook = "";
    private bool _mailEnabled; private string _mailHost = ""; private int _mailPort = 587; private bool _mailSsl = true; private string _mailUser = ""; private string _mailPass = ""; private string _mailFrom = ""; private string _mailTo = "";
    private bool _whEnabled; private string _whUrl = "";

    protected override async Task OnInitializedAsync()
    {
        // Settings holds whitelist, roles, vault secrets and MCP keys — Admin only.
        // Non-admins get an access-denied panel and we skip loading sensitive data into the circuit.
        _role = await CurrentUser.GetRoleAsync();
        if (_role < AppRole.Admin) return;

        var data = WhitelistService.GetWhitelist();
        _whitelistEnabled = data.Enabled;
        _whitelistEmails = data.Emails;

        var mcpData = McpPermissionService.GetPermissionData();
        _mcpApiKeys = mcpData.ApiKeys;
        _mcpTools = mcpData.Tools;

        // Roles — merge whitelisted users that aren't in roles yet
        _roleEntries = RoleService.GetRoleData().Roles;
        foreach (var email in _whitelistEmails)
        {
            if (!_roleEntries.Any(r => r.Email.Equals(email, StringComparison.OrdinalIgnoreCase)))
                _roleEntries.Add(new Whiskers.Models.UserRoleEntry { Email = email, Role = Whiskers.Models.AppRole.Admin });
        }

        // Vault
        LoadVault();

        // Editable settings — load current effective values.
        var mm = MattermostOptions.CurrentValue;
        _mmEnabled = mm.Enabled; _mmWebhook = mm.WebhookUrl; _mmChannel = mm.Channel; _mmBot = mm.BotUsername; _mmThrottle = mm.ThrottleMinutes;
        var mx = MatrixOptions.CurrentValue;
        _mxEnabled = mx.Enabled; _mxHomeserver = mx.HomeserverUrl; _mxRoom = mx.RoomId; _mxToken = mx.AccessToken; _mxThrottle = mx.ThrottleMinutes;
        var h = HealthOptions.CurrentValue;
        _hInterval = h.CheckIntervalSeconds; _hRetention = h.HistoryRetentionHours; _hLoopThreshold = h.RestartLoopThreshold; _hLoopWindow = h.RestartLoopWindowMinutes;
        var ma = MetricAlertOptions.CurrentValue;
        _maEnabled = ma.Enabled; _maCpu = ma.CpuPercent; _maMem = ma.MemoryPercent; _maDisk = ma.DiskPercent; _maSustained = ma.SustainedMinutes; _maCooldown = ma.CooldownMinutes;
        _maAnom = ma.AnomalyEnabled; _maAnomWindow = ma.AnomalyWindow; _maAnomSigma = ma.AnomalySigma; _maAnomFloor = ma.AnomalyFloorPercent;
        var cv = CveSettings.CurrentValue;
        _cveEnabled = cv.Enabled; _cveInterval = cv.CheckIntervalHours; _cveScanContainers = cv.ScanContainers; _cveScanOs = cv.ScanOs; _cveOsIds = cv.EnableOsCveIds;
        _cveTrivy = cv.TrivyImage; _cveNotify = cv.NotifyOnFinding; _cveSeverity = cv.NotifySeverity; _cveMaxScans = cv.MaxConcurrentScans;
        var iu = ImageUpdateOptions.CurrentValue;
        _iuEnabled = iu.Enabled; _iuInterval = iu.CheckIntervalHours; _iuNotify = iu.NotifyOnUpdate;
        var t = TerminalOptions.CurrentValue;
        _termEnabled = t.Enabled; _termShell = t.DefaultShell; _termMaxSessions = t.MaxSessions; _termIdle = t.IdleTimeoutMinutes;
        var ai = AiChatOptions.CurrentValue;
        _aiEnabled = ai.Enabled; _aiProvider = ai.Provider; _aiModel = ai.Model; _aiApiUrl = ai.ApiUrl ?? ""; _aiApiKey = ai.ApiKey;
        var tg = TelegramOptions.CurrentValue; _tgEnabled = tg.Enabled; _tgToken = tg.BotToken; _tgChat = tg.ChatId;
        var nt = NtfyOptions.CurrentValue; _ntfyEnabled = nt.Enabled; _ntfyServer = nt.ServerUrl; _ntfyTopic = nt.Topic; _ntfyToken = nt.Token;
        var dc = DiscordOptions.CurrentValue; _dcEnabled = dc.Enabled; _dcWebhook = dc.WebhookUrl;
        var sl = SlackOptions.CurrentValue; _slEnabled = sl.Enabled; _slWebhook = sl.WebhookUrl;
        var ml = EmailOptions.CurrentValue; _mailEnabled = ml.Enabled; _mailHost = ml.Host; _mailPort = ml.Port; _mailSsl = ml.UseSsl; _mailUser = ml.Username; _mailPass = ml.Password; _mailFrom = ml.From; _mailTo = ml.To;
        var wh = WebhookOptions.CurrentValue; _whEnabled = wh.Enabled; _whUrl = wh.Url;
    }

    private async Task SaveNotifications()
    {
        var mmCur = MattermostOptions.CurrentValue;
        await AppSettings.SaveSectionAsync("Mattermost", new MattermostSettings
        {
            Enabled = _mmEnabled, WebhookUrl = _mmWebhook?.Trim() ?? "", Channel = _mmChannel?.Trim() ?? "",
            BotUsername = string.IsNullOrWhiteSpace(_mmBot) ? "Whiskers" : _mmBot.Trim(),
            BotIconUrl = mmCur.BotIconUrl, ThrottleMinutes = _mmThrottle,
        });
        await AppSettings.SaveSectionAsync("Matrix", new MatrixSettings
        {
            Enabled = _mxEnabled, HomeserverUrl = _mxHomeserver?.Trim() ?? "", RoomId = _mxRoom?.Trim() ?? "",
            AccessToken = _mxToken ?? "", ThrottleMinutes = _mxThrottle,
        });
        await Audit("notifications");
        Snackbar.Add(L["Settings_Snackbar_NotificationsSaved"].Value, Severity.Success);
    }

    private async Task SaveHealth()
    {
        await AppSettings.SaveSectionAsync("HealthMonitor", new HealthMonitorSettings
        {
            CheckIntervalSeconds = _hInterval, HistoryRetentionHours = _hRetention,
            RestartLoopThreshold = _hLoopThreshold, RestartLoopWindowMinutes = _hLoopWindow,
        });
        await Audit("healthmonitor");
        Snackbar.Add(L["Settings_Snackbar_HealthSaved"].Value, Severity.Success);
    }

    private async Task SaveMetricAlert()
    {
        await AppSettings.SaveSectionAsync("MetricAlert", new MetricAlertSettings
        {
            Enabled = _maEnabled, CpuPercent = _maCpu, MemoryPercent = _maMem, DiskPercent = _maDisk,
            SustainedMinutes = _maSustained, CooldownMinutes = _maCooldown,
            AnomalyEnabled = _maAnom, AnomalyWindow = _maAnomWindow, AnomalySigma = _maAnomSigma, AnomalyFloorPercent = _maAnomFloor,
        });
        await Audit("metricalert");
        Snackbar.Add(L["Settings_Snackbar_MetricAlertsSaved"].Value, Severity.Success);
    }

    private async Task SaveCve()
    {
        var cur = CveSettings.CurrentValue;
        await AppSettings.SaveSectionAsync("CveMonitor", new CveMonitorSettings
        {
            Enabled = _cveEnabled, CheckIntervalHours = _cveInterval, ScanContainers = _cveScanContainers,
            ScanOs = _cveScanOs, EnableOsCveIds = _cveOsIds, TrivyImage = string.IsNullOrWhiteSpace(_cveTrivy) ? cur.TrivyImage : _cveTrivy.Trim(),
            NotifyOnFinding = _cveNotify, NotifySeverity = _cveSeverity, MaxConcurrentScans = _cveMaxScans,
            OsChangelogTimeoutSeconds = cur.OsChangelogTimeoutSeconds,
        });
        await Audit("cvemonitor");
        Snackbar.Add(L["Settings_Snackbar_CveSaved"].Value, Severity.Success);
    }

    private async Task SaveImageUpdate()
    {
        await AppSettings.SaveSectionAsync("ImageUpdate", new ImageUpdateSettings
        {
            Enabled = _iuEnabled, CheckIntervalHours = _iuInterval, NotifyOnUpdate = _iuNotify,
        });
        await Audit("imageupdate");
        Snackbar.Add(L["Settings_Snackbar_ImageUpdatesSaved"].Value, Severity.Success);
    }

    private async Task SaveTerminal()
    {
        await AppSettings.SaveSectionAsync("Terminal", new TerminalSettings
        {
            Enabled = _termEnabled,
            DefaultShell = string.IsNullOrWhiteSpace(_termShell) ? "/bin/bash" : _termShell.Trim(),
            MaxSessions = _termMaxSessions,
            IdleTimeoutMinutes = _termIdle,
        });
        await Audit("terminal");
        Snackbar.Add(L["Settings_Snackbar_TerminalSaved"].Value, Severity.Success);
    }

    private async Task SaveAiChat()
    {
