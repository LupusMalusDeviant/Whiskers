        {
            Enabled = _aiEnabled,
            Provider = string.IsNullOrWhiteSpace(_aiProvider) ? "openai" : _aiProvider,
            Model = _aiModel?.Trim() ?? "",
            ApiUrl = string.IsNullOrWhiteSpace(_aiApiUrl) ? null : _aiApiUrl.Trim(),
            ApiKey = _aiApiKey ?? "",
        });
