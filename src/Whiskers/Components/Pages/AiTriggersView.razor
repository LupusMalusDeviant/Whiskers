@using Microsoft.AspNetCore.Authorization
@using Whiskers.Models
@using Whiskers.Services.Agent.Guardrails
@using Whiskers.Services.Agent.Triggers
@using Whiskers.Services.Auth
@using Whiskers.Services.LogMonitor
@inject IAiTriggerStore Store
@inject IGuardrailStore GuardrailStore
@inject ILogMonitorService LogMonitor
@inject ICurrentUserService CurrentUser
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["AiTriggersView_Title"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div style="display:flex; align-items:center; gap:12px;" class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Primary" />
        <MudText Typo="Typo.h5">@L["AiTriggersView_Title"]</MudText>
    </div>
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: rgba(255,255,255,0.5);">
        @((MarkupString)L["AiTriggersView_Intro"].Value)
    </MudText>

    @if (!_isAdmin)
    {
        <MudAlert Severity="Severity.Warning">@L["AiTriggersView_AdminOnly_Warning"]</MudAlert>
    }
    else
    {
        <div style="display:flex; gap:8px;" class="mb-3">
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" OnClick="AddTrigger">@L["AiTriggersView_NewTrigger_Button"]</MudButton>
            <MudSpacer />
            <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAll">@L["AiTriggersView_Save_Button"]</MudButton>
        </div>

        <MudPaper Class="pa-3 mb-4" Style="background: var(--sw-glass);">
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5);" Class="mb-2">
                @L["AiTriggersView_Templates_Caption"]
            </MudText>
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.BugReport"
                           OnClick="AddErrorLogSetup">@L["AiTriggersView_Template_ErrorLogs_Button"]</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="@(() => AddTemplate(L["AiTriggersView_Template_Unhealthy_Name"].Value, new[]{"unhealthy","restart_loop"}, "Check the affected container (status, recent logs), determine the cause and restart it if this is a transient failure. Otherwise summarize the cause and recommend actions."))">@L["AiTriggersView_Template_Unhealthy_Button"]</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Memory"
                           OnClick="@(() => AddTemplate(L["AiTriggersView_Template_HighCpu_Name"].Value, new[]{"high_cpu"}, "Investigate the container's sustained high CPU load: check logs and metrics, identify the likely cause and summarize it with a recommended action."))">@L["AiTriggersView_Template_HighCpu_Button"]</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Storage"
                           OnClick="@(() => AddTemplate(L["AiTriggersView_Template_HighMem_Name"].Value, new[]{"high_memory"}, "Investigate the container's sustained high memory usage (possible leak?), check logs/metrics and summarize the cause plus a recommendation."))">@L["AiTriggersView_Template_HighMem_Button"]</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Insights"
                           OnClick="@(() => AddTemplate(L["AiTriggersView_Template_Anomaly_Name"].Value, new[]{"metric_anomaly"}, "Es wurde ein Ausreißer in den Metriken erkannt. Untersuche den Container und das Umfeld, bewerte ob es kritisch ist und fasse das Ergebnis zusammen."))">@L["AiTriggersView_Template_Anomaly_Button"]</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Security"
                           OnClick="@(() => AddTemplate(L["AiTriggersView_Template_Cve_Name"].Value, new[]{"cve_finding"}, "Bewerte die neu gefundene Schwachstelle: Schweregrad, betroffene Komponente, ob ein Update verfügbar ist, und empfiehl konkrete Schritte."))">@L["AiTriggersView_Template_Cve_Button"]</MudButton>
            </div>
        </MudPaper>

        @if (_triggers.Count == 0)
        {
            <MudAlert Severity="Severity.Info">@L["AiTriggersView_Empty"]</MudAlert>
        }

        @foreach (var t in _triggers)
        {
            <MudPaper Class="pa-4 mb-3" Style="@(t.Enabled ? "" : "opacity:0.6;")">
                <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;" class="mb-2">
                    <MudSwitch @bind-Value="t.Enabled" Color="Color.Success" />
                    <MudTextField @bind-Value="t.Name" Label="@L["AiTriggersView_Name_Label"]" Margin="Margin.Dense" Variant="Variant.Outlined"
                                  Style="min-width:220px;" />
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => _triggers.Remove(t))" title="@L["AiTriggersView_DeleteTrigger_Tooltip"]" />
                </div>

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" Label="@L["AiTriggersView_Events_Label"]" MultiSelection="true"
                                   SelectedValues="t.EventTypes" SelectedValuesChanged="@(v => t.EventTypes = v.ToList())"
                                   Margin="Margin.Dense" Variant="Variant.Outlined"
                                   MultiSelectionTextFunc="@(s => L["AiTriggersView_EventsCount", s.Count].Value)">
                            @foreach (var e in AiTriggerEvents.All)
                            {
                                <MudSelectItem T="string" Value="@e.Type">@e.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="t.NameFilter" Label="@L["AiTriggersView_NameFilter_Label"]"
                                      Placeholder="@L["AiTriggersView_NameFilter_Placeholder"]" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" @bind-Value="t.GuardrailPreset" Label="@L["AiTriggersView_Preset_Label"]"
                                   Margin="Margin.Dense" Variant="Variant.Outlined">
                            @foreach (var p in _presets)
                            {
                                <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="t.CooldownSeconds" Label="@L["AiTriggersView_Cooldown_Label"]"
                                         Min="0" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="t.Prompt" Label="@L["AiTriggersView_Prompt_Label"]"
                                      Lines="4" Margin="Margin.Dense" Variant="Variant.Outlined"
                                      Placeholder="@L["AiTriggersView_Prompt_Placeholder"]" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private bool _isAdmin;
    private List<AiTrigger> _triggers = new();
    private List<string> _presets = new();

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await CurrentUser.HasRoleAsync(AppRole.Admin);
        if (!_isAdmin) return;

        _triggers = Store.Triggers.Select(Clone).ToList();
        _presets = GuardrailStore.Config.Presets.Select(p => p.Name).ToList();
        if (_presets.Count == 0) _presets.Add("Standard");
    }

    private void AddTrigger()
    {
        _triggers.Add(new AiTrigger
        {
            Name = $"Trigger {_triggers.Count + 1}",
            GuardrailPreset = _presets.FirstOrDefault() ?? "Standard",
        });
    }

    private void AddTemplate(string name, string[] events, string prompt)
    {
        _triggers.Add(new AiTrigger
        {
            Name = name,
            EventTypes = events.ToList(),
            Prompt = prompt,
            GuardrailPreset = _presets.FirstOrDefault() ?? "Standard",
        });
        Snackbar.Add(L["AiTriggersView_TemplateAdded_Snackbar", name].Value, Severity.Info);
    }

    /// <summary>Creates the matching log-alert rule (so log_alert events actually fire) plus the trigger.</summary>
    private async Task AddErrorLogSetup()
    {
        const string ruleName = "Fehler/Errors (AI-Trigger)";
        try
        {
            var rules = await LogMonitor.GetRulesAsync();
            if (!rules.Any(r => r.Name == ruleName))
            {
                await LogMonitor.CreateRuleAsync(new LogAlertRuleEntity
                {
                    Name = ruleName,
                    Pattern = @"(?i)(error|exception|fatal|panic|traceback)",
                    IsRegex = true,
                    Severity = "error",
                    Enabled = true,
                });
                Snackbar.Add(L["AiTriggersView_LogRuleCreated_Snackbar"].Value, Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["AiTriggersView_LogRuleFailed_Snackbar", ex.Message].Value, Severity.Warning);
        }

        AddTemplate(L["AiTriggersView_Template_ErrorLogs_Name"].Value, new[] { "log_alert" },
            "Analyze the reported error from the container log: fetch the most recent logs, determine the likely cause and fix it if possible (within the bounds of the guardrails). Otherwise summarize the cause and recommend concrete actions.");
    }

    private async Task SaveAll()
    {
        foreach (var t in _triggers)
            if (string.IsNullOrWhiteSpace(t.Name)) t.Name = "Trigger";
        try
        {
            await Store.SaveAsync(_triggers, await BuildPrincipalAsync());
            Snackbar.Add(L["AiTriggersView_Saved_Snackbar", _triggers.Count].Value, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task<Models.Agent.AgentPrincipal> BuildPrincipalAsync()
    {
        var email = await CurrentUser.GetEmailAsync() ?? "local@serverwatch.local";
        var role = await CurrentUser.GetRoleAsync();
        var level = role switch
        {
            AppRole.Admin => McpPermissionLevels.Admin,
            AppRole.Operator => McpPermissionLevels.Write,
            _ => McpPermissionLevels.Read,
        };
        return new Models.Agent.AgentPrincipal(Models.Agent.AgentPrincipalKind.WebUser, email, level, null, UserEmail: email);
    }

    private static AiTrigger Clone(AiTrigger s) => new()
    {
        Id = s.Id,
        Name = s.Name,
        Enabled = s.Enabled,
        EventTypes = new(s.EventTypes),
        NameFilter = s.NameFilter,
        Prompt = s.Prompt,
        GuardrailPreset = s.GuardrailPreset,
        CooldownSeconds = s.CooldownSeconds,
    };
}
