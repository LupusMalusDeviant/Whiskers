@using Microsoft.AspNetCore.Authorization
@using Whiskers.Models
@using Whiskers.Services.Agent.Guardrails
@using Whiskers.Services.Agent.Triggers
@using Whiskers.Services.Auth
@using Whiskers.Services.LogMonitor
@inject IAiTriggerStore Store
@inject IGuardrailStore GuardrailStore
@inject ILogMonitorService LogMonitor
@inject ICurrentUserService CurrentUser
@inject ISnackbar Snackbar

<PageTitle>AI-Trigger</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div style="display:flex; align-items:center; gap:12px;" class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Primary" />
        <MudText Typo="Typo.h5">AI-Trigger</MudText>
    </div>
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: rgba(255,255,255,0.5);">
        Ereignisse, die den Agenten <b>autonom</b> auslösen. Pro Trigger: Ereignistyp(en), optionaler Namensfilter,
        ein eigener Auftrag/Workflow und das Guardrail-Preset, das den Lauf begrenzt. Bestätigungen werden im
        autonomen Lauf bis zum Preset-Level automatisch freigegeben. Nur Admins.
    </MudText>

    @if (!_isAdmin)
    {
        <MudAlert Severity="Severity.Warning">Nur Admins können AI-Trigger verwalten.</MudAlert>
    }
    else
    {
        <div style="display:flex; gap:8px;" class="mb-3">
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" OnClick="AddTrigger">Neuer Trigger</MudButton>
            <MudSpacer />
            <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAll">Speichern</MudButton>
        </div>

        <MudPaper Class="pa-3 mb-4" Style="background: var(--sw-glass);">
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5);" Class="mb-2">
                Schnell-Vorlagen (fügen einen vorausgefüllten Trigger hinzu — danach „Speichern"):
            </MudText>
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.BugReport"
                           OnClick="AddErrorLogSetup">Fehler-Logs → Agent</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="@(() => AddTemplate("Unhealthy → analysieren/neustarten", new[]{"unhealthy","restart_loop"}, "Prüfe den betroffenen Container (Status, jüngste Logs), bestimme die Ursache und starte ihn neu, falls es ein transienter Fehler ist. Sonst fasse die Ursache zusammen und empfiehl Maßnahmen."))">Unhealthy/Crash-Loop</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Memory"
                           OnClick="@(() => AddTemplate("Hohe CPU untersuchen", new[]{"high_cpu"}, "Untersuche die anhaltend hohe CPU-Last des Containers: prüfe Logs und Metriken, identifiziere die wahrscheinliche Ursache und fasse sie mit einer Handlungsempfehlung zusammen."))">Hohe CPU</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Storage"
                           OnClick="@(() => AddTemplate("Hohe RAM untersuchen", new[]{"high_memory"}, "Untersuche die anhaltend hohe RAM-Nutzung des Containers (mögliches Leck?), prüfe Logs/Metriken und fasse Ursache + Empfehlung zusammen."))">Hohe RAM</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Insights"
                           OnClick="@(() => AddTemplate("Metrik-Anomalie", new[]{"metric_anomaly"}, "Es wurde ein Ausreißer in den Metriken erkannt. Untersuche den Container und das Umfeld, bewerte ob es kritisch ist und fasse das Ergebnis zusammen."))">Anomalie</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Security"
                           OnClick="@(() => AddTemplate("Neue CVE → Bericht", new[]{"cve_finding"}, "Bewerte die neu gefundene Schwachstelle: Schweregrad, betroffene Komponente, ob ein Update verfügbar ist, und empfiehl konkrete Schritte."))">Neue CVE</MudButton>
            </div>
        </MudPaper>

        @if (_triggers.Count == 0)
        {
            <MudAlert Severity="Severity.Info">Noch keine Trigger. „Neuer Trigger" anlegen.</MudAlert>
        }

        @foreach (var t in _triggers)
        {
            <MudPaper Class="pa-4 mb-3" Style="@(t.Enabled ? "" : "opacity:0.6;")">
                <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;" class="mb-2">
                    <MudSwitch @bind-Value="t.Enabled" Color="Color.Success" />
                    <MudTextField @bind-Value="t.Name" Label="Name" Margin="Margin.Dense" Variant="Variant.Outlined"
                                  Style="min-width:220px;" />
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => _triggers.Remove(t))" title="Trigger löschen" />
                </div>

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" Label="Ereignisse" MultiSelection="true"
                                   SelectedValues="t.EventTypes" SelectedValuesChanged="@(v => t.EventTypes = v.ToList())"
                                   Margin="Margin.Dense" Variant="Variant.Outlined"
                                   MultiSelectionTextFunc="@(s => $"{s.Count} Ereignis(se)")">
                            @foreach (var e in AiTriggerEvents.All)
                            {
                                <MudSelectItem T="string" Value="@e.Type">@e.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="t.NameFilter" Label="Namensfilter (Glob, optional)"
                                      Placeholder="z.B. prod-*  oder  nginx" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" @bind-Value="t.GuardrailPreset" Label="Guardrail-Preset"
                                   Margin="Margin.Dense" Variant="Variant.Outlined">
                            @foreach (var p in _presets)
                            {
                                <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="t.CooldownSeconds" Label="Cooldown (Sekunden, pro Container)"
                                         Min="0" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="t.Prompt" Label="Auftrag / Workflow für den Agenten"
                                      Lines="4" Margin="Margin.Dense" Variant="Variant.Outlined"
                                      Placeholder="z.B. „Prüfe die Logs des betroffenen Containers, identifiziere die Ursache und starte ihn neu, falls es ein transienter Fehler ist. Fasse die Ursache zusammen." />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private bool _isAdmin;
    private List<AiTrigger> _triggers = new();
    private List<string> _presets = new();

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await CurrentUser.HasRoleAsync(AppRole.Admin);
        if (!_isAdmin) return;

        _triggers = Store.Triggers.Select(Clone).ToList();
        _presets = GuardrailStore.Config.Presets.Select(p => p.Name).ToList();
        if (_presets.Count == 0) _presets.Add("Standard");
    }

    private void AddTrigger()
    {
        _triggers.Add(new AiTrigger
        {
            Name = $"Trigger {_triggers.Count + 1}",
            GuardrailPreset = _presets.FirstOrDefault() ?? "Standard",
        });
    }

    private void AddTemplate(string name, string[] events, string prompt)
    {
        _triggers.Add(new AiTrigger
        {
            Name = name,
            EventTypes = events.ToList(),
            Prompt = prompt,
            GuardrailPreset = _presets.FirstOrDefault() ?? "Standard",
        });
        Snackbar.Add($"Vorlage '{name}' hinzugefügt — nicht vergessen zu speichern.", Severity.Info);
    }

    /// <summary>Creates the matching log-alert rule (so log_alert events actually fire) plus the trigger.</summary>
    private async Task AddErrorLogSetup()
    {
        const string ruleName = "Fehler/Errors (AI-Trigger)";
        try
        {
            var rules = await LogMonitor.GetRulesAsync();
            if (!rules.Any(r => r.Name == ruleName))
            {
                await LogMonitor.CreateRuleAsync(new LogAlertRuleEntity
                {
                    Name = ruleName,
                    Pattern = @"(?i)(error|exception|fatal|panic|traceback)",
                    IsRegex = true,
                    Severity = "error",
                    Enabled = true,
                });
                Snackbar.Add("Log-Alert-Regel 'Fehler/Errors' angelegt — feuert bei Fehlern in Container-Logs.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Log-Regel konnte nicht angelegt werden: {ex.Message}", Severity.Warning);
        }

        AddTemplate("Fehler-Logs → Agent", new[] { "log_alert" },
            "Analysiere die gemeldete Fehlermeldung aus dem Container-Log: rufe die jüngsten Logs ab, bestimme die wahrscheinliche Ursache und behebe sie wenn möglich (im Rahmen der Guardrails). Sonst fasse die Ursache zusammen und empfiehl konkrete Maßnahmen.");
    }

    private async Task SaveAll()
    {
        foreach (var t in _triggers)
            if (string.IsNullOrWhiteSpace(t.Name)) t.Name = "Trigger";
        try
        {
            await Store.SaveAsync(_triggers, await BuildPrincipalAsync());
            Snackbar.Add($"{_triggers.Count} Trigger gespeichert.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task<Models.Agent.AgentPrincipal> BuildPrincipalAsync()
    {
        var email = await CurrentUser.GetEmailAsync() ?? "local@serverwatch.local";
        var role = await CurrentUser.GetRoleAsync();
        var level = role switch
        {
            AppRole.Admin => McpPermissionLevels.Admin,
            AppRole.Operator => McpPermissionLevels.Write,
            _ => McpPermissionLevels.Read,
        };
        return new Models.Agent.AgentPrincipal(Models.Agent.AgentPrincipalKind.WebUser, email, level, null, UserEmail: email);
    }

    private static AiTrigger Clone(AiTrigger s) => new()
    {
        Id = s.Id,
        Name = s.Name,
        Enabled = s.Enabled,
        EventTypes = new(s.EventTypes),
        NameFilter = s.NameFilter,
        Prompt = s.Prompt,
        GuardrailPreset = s.GuardrailPreset,
        CooldownSeconds = s.CooldownSeconds,
    };
}
