@page "/networks"
@attribute [Authorize]
@inject IDockerService DockerService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Networks_PageTitle"]</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["Networks_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Networks_Header_Subtitle"]</MudText>
        </div>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="ShowCreateDialog">@L["Networks_Button_Create"]</MudButton>
        }
        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadNetworks">@L["Networks_Button_Refresh"]</MudButton>
    </MudStack>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @foreach (var group in _networks.GroupBy(n => n.ServerName))
    {
        <MudText Typo="Typo.subtitle1" Class="mb-2 mt-4">@group.Key</MudText>
        <MudTable Items="@group.ToList()" Dense="true" Hover="true" Striped="true" Elevation="2" Class="mb-4">
            <HeaderContent>
                <MudTh>@L["Networks_Table_Name"]</MudTh>
                <MudTh>@L["Networks_Table_Driver"]</MudTh>
                <MudTh>@L["Networks_Table_Scope"]</MudTh>
                <MudTh>@L["Networks_Table_Subnet"]</MudTh>
                <MudTh>@L["Networks_Table_Containers"]</MudTh>
                <MudTh>@L["Networks_Table_Actions"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><code>@context.Name</code></MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@(context.Driver == "bridge" ? Color.Primary : context.Driver == "overlay" ? Color.Tertiary : Color.Default)">
                        @context.Driver
                    </MudChip>
                    @if (context.Internal)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">@L["Networks_Chip_Internal"]</MudChip>
                    }
                </MudTd>
                <MudTd>@context.Scope</MudTd>
                <MudTd Style="font-family: monospace;">@(string.IsNullOrEmpty(context.Subnet) ? "-" : context.Subnet)</MudTd>
                <MudTd>
                    @if (context.Containers.Any())
                    {
                        <MudTooltip>
                            <ChildContent>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Containers.Count</MudChip>
                            </ChildContent>
                            <TooltipContent>
                                @foreach (var c in context.Containers)
                                {
                                    <div>@c.Name (@c.IPv4Address)</div>
                                }
                            </TooltipContent>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Style="color: #888;">0</MudText>
                    }
                </MudTd>
                <MudTd>
                    @if (!IsSystemNetwork(context.Name) && _role >= AppRole.Admin)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteNetwork(context))" title="@L["Networks_Action_Delete"]" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

<MudDialog Visible="_showCreateDialog" VisibleChanged="@(v => _showCreateDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@L["Networks_Dialog_CreateTitle"]</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_newNetworkName" Label="@L["Networks_Field_Name"]" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect T="string" @bind-Value="_newNetworkServerId" Label="@L["Networks_Field_TargetServer"]" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var srv in _servers)
                {
                    <MudSelectItem Value="@srv.Id">@srv.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect @bind-Value="_newNetworkDriver" Label="@L["Networks_Field_Driver"]" Variant="Variant.Outlined">
                <MudSelectItem Value="@("bridge")">bridge</MudSelectItem>
                <MudSelectItem Value="@("overlay")">overlay</MudSelectItem>
                <MudSelectItem Value="@("macvlan")">macvlan</MudSelectItem>
            </MudSelect>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showCreateDialog = false)">@L["Networks_Button_Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateNetwork"
                       Disabled="@string.IsNullOrWhiteSpace(_newNetworkName)">@L["Networks_Button_CreateConfirm"]</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    private List<Whiskers.Models.NetworkInfo> _networks = new();
    private bool _loading = true;
    private bool _showCreateDialog;
    private string _newNetworkName = "";
    private string _newNetworkDriver = "bridge";
    private List<Whiskers.Models.ServerConfig> _servers = new();
    private string _newNetworkServerId = "local";
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["Networks_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _servers = ServerConfigService.GetEnabledServers();
        await LoadNetworks();
    }

    private async Task LoadNetworks()
    {
        _loading = true;
        try
        {
            _networks = (await DockerService.ListNetworksAsync()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Networks_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
        _loading = false;
    }

    private void ShowCreateDialog()
    {
        _newNetworkName = "";
        _newNetworkDriver = "bridge";
        _newNetworkServerId = ServerConfigService.GetDefaultServer()?.Id ?? "local";
        _showCreateDialog = true;
    }

    private async Task CreateNetwork()
    {
        if (!Require(AppRole.Admin)) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        var sid = _newNetworkServerId == "local" ? null : _newNetworkServerId;
        try
        {
            var id = await DockerService.CreateNetworkAsync(_newNetworkName, _newNetworkDriver, sid);
            await AuditLog.LogAsync(actor, "web", "network.create", "network", id, _newNetworkName, details: $"Driver: {_newNetworkDriver}", serverId: sid);
            Snackbar.Add(L["Networks_Snackbar_Created", _newNetworkName].Value, Severity.Success);
            _showCreateDialog = false;
            await LoadNetworks();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "network.create", "network", _newNetworkName, _newNetworkName, details: ex.Message, serverId: sid, success: false);
            Snackbar.Add(L["Networks_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    private async Task DeleteNetwork(Whiskers.Models.NetworkInfo network)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["Networks_Dialog_DeleteTitle"].Value,
            L["Networks_Dialog_DeleteMessage", network.Name].Value,
            yesText: L["Networks_Dialog_DeleteYes"].Value, cancelText: L["Networks_Button_Cancel"].Value);
        if (confirmed != true) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        var sid = network.ServerId == "local" ? null : network.ServerId;
        try
        {
            await DockerService.RemoveNetworkAsync(network.Id, sid);
            await AuditLog.LogAsync(actor, "web", "network.remove", "network", network.Id, network.Name, serverId: sid);
            Snackbar.Add(L["Networks_Snackbar_Deleted", network.Name].Value, Severity.Success);
            await LoadNetworks();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "network.remove", "network", network.Id, network.Name, details: ex.Message, serverId: sid, success: false);
            Snackbar.Add(L["Networks_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    private static bool IsSystemNetwork(string name) =>
        name is "bridge" or "host" or "none";
}
