@page "/nginx/{ServerId}"
@attribute [Authorize]
@inject Whiskers.Services.Server.INginxService NginxService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IStringLocalizer<SharedResource> L

<PageTitle>Nginx - Whiskers</PageTitle>

@* RoadToSAP Phase 1: gated by the HostManagement module; when off, ModuleGuard shows a "disabled" notice.
   The INginxService injection resolves the Core no-op default either way. *@
<ModuleGuard ModuleId="host-management">

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(""))" />
    <MudText Typo="Typo.h5">@L["NginxManager_Title"]</MudText>
    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@_serverName</MudChip>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Variant="Variant.Outlined"
               OnClick="TestConfig">@L["NginxManager_Button_TestConfig"]</MudButton>
    @if (_role >= AppRole.Admin)
    {
        <MudButton StartIcon="@Icons.Material.Filled.Refresh" Color="Color.Info" Variant="Variant.Outlined"
                   OnClick="ReloadNginx" Class="ml-2">@L["NginxManager_Button_Reload"]</MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_editingSite != null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => _editingSite = null)" />
        <MudText Typo="Typo.h6">@_editingSite</MudText>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Save" Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="SaveConfig" Disabled="@_saving">@L["NginxManager_Button_SaveReload"]</MudButton>
        }
    </MudStack>
    <MudTextField @bind-Value="_editContent" Lines="30" Variant="Variant.Outlined"
                  Style="font-family: monospace; font-size: 13px;" FullWidth="true" />
}
else
{
    <MudTable Items="@_sites" Dense="true" Hover="true" Striped="true" Elevation="2">
        <HeaderContent>
            <MudTh>@L["NginxManager_Header_Name"]</MudTh>
            <MudTh>@L["NginxManager_Header_Status"]</MudTh>
            <MudTh>@L["NginxManager_Header_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudLink OnClick="@(() => EditSite(context.Name))">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-1" />
                    @context.Name
                </MudLink>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Enabled ? Color.Success : Color.Default)"
                         Variant="Variant.Filled">
                    @(context.Enabled ? L["NginxManager_Status_Enabled"].Value : L["NginxManager_Status_Available"].Value)
                </MudChip>
            </MudTd>
            <MudTd>
                @if (_role >= AppRole.Admin)
                {
                    @if (context.Enabled)
                    {
                        <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Text"
                                   OnClick="@(() => ToggleSite(context.Name, false))">@L["NginxManager_Button_Disable"]</MudButton>
                    }
                    else
                    {
                        <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                                   OnClick="@(() => ToggleSite(context.Name, true))">@L["NginxManager_Button_Enable"]</MudButton>
                    }
                }
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => EditSite(context.Name))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

</ModuleGuard>

@code {
    [Parameter] public string ServerId { get; set; } = "";

    private string _serverName = "";
    private bool _loading = true;
    private bool _saving;
    private List<Whiskers.Services.Server.NginxSite> _sites = new();
    private string? _editingSite;
    private string _editContent = "";
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["NginxManager_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        var server = ServerConfigService.GetServer(ServerId);
        _serverName = server?.Name ?? ServerId;
        await LoadSites();
    }

    private async Task LoadSites()
    {
        _loading = true;
        try { _sites = await NginxService.ListSitesAsync(ServerId); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _loading = false;
    }

    private async Task EditSite(string name)
    {
        try
        {
            _editContent = await NginxService.GetSiteConfigAsync(ServerId, name);
            _editingSite = name;
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task SaveConfig()
    {
        if (!Require(AppRole.Admin)) return;
        if (_editingSite == null) return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["NginxManager_Dialog_SaveTitle"].Value, L["NginxManager_Dialog_SaveMessage", _editingSite].Value,
            yesText: L["NginxManager_Button_SaveReload"].Value, cancelText: L["NginxManager_Dialog_Cancel"].Value);
        if (confirmed != true) return;

        _saving = true;
        try
        {
            var result = await NginxService.UpdateSiteConfigAsync(ServerId, _editingSite, _editContent);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "nginx.update", "nginx", _editingSite, _editingSite, serverId: ServerId, success: result.Success);
            if (result.Success)
            {
                Snackbar.Add(L["NginxManager_Snackbar_SavedReloaded"].Value, Severity.Success);
                _editingSite = null;
                await LoadSites();
            }
            else
                Snackbar.Add(L["NginxManager_Snackbar_Error", result.Error ?? ""].Value, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _saving = false;
    }

    private async Task ToggleSite(string name, bool enable)
    {
        if (!Require(AppRole.Admin)) return;

        try
        {
            var result = enable
                ? await NginxService.EnableSiteAsync(ServerId, name)
                : await NginxService.DisableSiteAsync(ServerId, name);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "nginx.update", "nginx", name, name, details: enable ? "enabled" : "disabled", serverId: ServerId, success: result.Success);
            if (result.Success)
            {
                Snackbar.Add(enable ? L["NginxManager_Snackbar_SiteEnabled", name].Value : L["NginxManager_Snackbar_SiteDisabled", name].Value, Severity.Success);
                await LoadSites();
            }
            else
                Snackbar.Add(L["NginxManager_Snackbar_Error", result.Error ?? ""].Value, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task TestConfig()
    {
        var result = await NginxService.TestConfigAsync(ServerId);
        Snackbar.Add(result.Success ? L["NginxManager_Snackbar_TestSuccess"].Value : L["NginxManager_Snackbar_TestFailed", result.Error ?? ""].Value,
            result.Success ? Severity.Success : Severity.Error);
    }

    private async Task ReloadNginx()
    {
        if (!Require(AppRole.Admin)) return;

        try
        {
            var result = await NginxService.ReloadAsync(ServerId);
            Snackbar.Add(result.Success ? L["NginxManager_Snackbar_Reloaded"].Value : L["NginxManager_Snackbar_ReloadFailed", result.Error ?? ""].Value,
                result.Success ? Severity.Success : Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(L["NginxManager_Snackbar_Error", ex.Message].Value, Severity.Error); }
    }
}
