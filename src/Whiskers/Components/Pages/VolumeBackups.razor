@page "/backups"
@attribute [Authorize]

<PageTitle>Volume-Backups - Whiskers</PageTitle>

@* RoadToSAP Phase 1: thin route wrapper. ModuleGuard renders the interactive VolumeBackupsView only when the
   VolumeBackups module is enabled; otherwise it shows a clean "module disabled" notice (and VolumeBackupsView —
   which injects IVolumeBackupService — is never instantiated, so there is no DI error). *@
<ModuleGuard ModuleId="volumebackups">
    <VolumeBackupsView />
</ModuleGuard>
