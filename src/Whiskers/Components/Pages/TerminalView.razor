@inject IJSRuntime JS
@inject ITerminalSessionManager SessionManager
@inject NavigationManager Nav
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

@* The interactive container-terminal UI. Rendered by Terminal.razor only when the Terminal module is
   enabled (via ModuleGuard), so a disabled module never reaches the ITerminalSessionManager injection. *@

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                   OnClick="@(() => Nav.NavigateTo($"container/{ServerId}/{ContainerId}"))" />
    <MudText Typo="Typo.h5">@L["TerminalView_Title"]</MudText>
    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
        @(string.IsNullOrEmpty(ContainerId) ? "" : ContainerId[..Math.Min(12, ContainerId.Length)])
    </MudChip>
</MudStack>

<MudPaper Elevation="2" Class="pa-0" Style="height: calc(100vh - 160px); min-height: 400px; overflow: hidden;">
    <div id="terminal-container" style="height: 100%; width: 100%;"></div>
</MudPaper>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
}

@code {
    [Parameter] public string? ContainerId { get; set; }
    [Parameter] public string? ServerId { get; set; }

    private Whiskers.Services.Terminal.TerminalSession? _session;
    private string _error = string.Empty;
    private DotNetObjectReference<TerminalView>? _dotNetRef;
    private bool _initialized;
    private CancellationTokenSource _cts = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized) return;
        _initialized = true;

        if (string.IsNullOrEmpty(ContainerId))
        {
            _error = L["TerminalView_Error_NoContainerId"].Value;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (await CurrentUser.GetRoleAsync() < AppRole.Operator)
        {
            _error = L["TerminalView_Error_OperatorRequired"].Value;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("Whiskers.Terminal.create", "terminal-container", _dotNetRef);

            _session = SessionManager.CreateSession(ContainerId, ServerId);

            _ = ReadStreamAsync(_session.Process!.StandardOutput, _cts.Token);
            _ = ReadStreamAsync(_session.Process!.StandardError, _cts.Token);
        }
        catch (Exception ex)
        {
            _error = L["TerminalView_Error_InitFailed", ex.Message].Value;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReadStreamAsync(System.IO.StreamReader reader, CancellationToken ct)
    {
        var buffer = new char[4096];
        try
        {
            while (!ct.IsCancellationRequested)
            {
                var bytesRead = await reader.ReadAsync(buffer, 0, buffer.Length);
                if (bytesRead == 0) break;

                // Streaming output is activity too — keep the session from being idle-killed mid-output.
                _session?.Touch();
                var text = new string(buffer, 0, bytesRead);
                await InvokeAsync(async () =>
                {
                    await JS.InvokeVoidAsync("Whiskers.Terminal.write", "terminal-container", text);
                });
            }
        }
        catch (OperationCanceledException) { }
        catch { }

        await InvokeAsync(async () =>
        {
            await JS.InvokeVoidAsync("Whiskers.Terminal.write", "terminal-container",
                $"\r\n\x1b[31m--- {L["TerminalView_Terminal_SessionEnded"].Value} ---\x1b[0m\r\n");
        });
    }

    [JSInvokable]
    public async Task OnTerminalInput(string data)
    {
        if (_session is { IsRunning: true })
        {
            await _session.WriteAsync(data);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        try
        {
            if (_session != null)
            {
                await SessionManager.DestroySession(_session.SessionId);
            }
            await JS.InvokeVoidAsync("Whiskers.Terminal.dispose", "terminal-container");
        }
        catch { }
        _dotNetRef?.Dispose();
        _cts.Dispose();
    }
}
