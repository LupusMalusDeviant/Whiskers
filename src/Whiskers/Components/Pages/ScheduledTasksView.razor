@inject Whiskers.Services.Scheduler.ISchedulerService Scheduler
@inject IDockerService DockerService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IStringLocalizer<SharedResource> L

@* The interactive scheduled-tasks UI. Rendered by ScheduledTasks.razor only when the Scheduler module is
   enabled (via ModuleGuard), so a disabled module never reaches the ISchedulerService injection. *@

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["ScheduledTasksView_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["ScheduledTasksView_Header_Subtitle"]</MudText>
        </div>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="ShowCreateDialog">@L["ScheduledTasksView_Button_CreateTask"]</MudButton>
        }
    </MudStack>
</div>

@* Stats Cards *@
<MudGrid Class="mb-4">
    <MudItem xs="6" sm="3">
        <div class="sw-stat-card" style="text-align: center;">
            <div class="sw-stat-value" style="color: var(--sw-accent-blue);">@_tasks.Count</div>
            <div class="sw-stat-label">@L["ScheduledTasksView_Stat_Total"]</div>
        </div>
    </MudItem>
    <MudItem xs="6" sm="3">
        <div class="sw-stat-card" style="text-align: center;">
            <div class="sw-stat-value" style="color: var(--sw-accent-green);">@_tasks.Count(t => t.Enabled)</div>
            <div class="sw-stat-label">@L["ScheduledTasksView_Stat_Active"]</div>
        </div>
    </MudItem>
    <MudItem xs="6" sm="3">
        <div class="sw-stat-card" style="text-align: center;">
            <div class="sw-stat-value" style="color: var(--sw-accent-green);">@_tasks.Count(t => t.LastSuccess)</div>
            <div class="sw-stat-label">@L["ScheduledTasksView_Stat_LastRunOk"]</div>
        </div>
    </MudItem>
    <MudItem xs="6" sm="3">
        <div class="sw-stat-card" style="text-align: center;">
            <div class="sw-stat-value" style="color: var(--sw-accent-red);">@_tasks.Count(t => !t.LastSuccess && t.LastRun != null)</div>
            <div class="sw-stat-label">@L["ScheduledTasksView_Stat_Failed"]</div>
        </div>
    </MudItem>
</MudGrid>

@* Task List *@
@if (!_tasks.Any())
{
    <MudAlert Severity="Severity.Info">@L["ScheduledTasksView_Empty_NoTasks"]</MudAlert>
}
else
{
    <MudTable Items="@_tasks" Dense="true" Hover="true" Striped="true" Elevation="0">
        <HeaderContent>
            <MudTh>@L["ScheduledTasksView_Table_Name"]</MudTh>
            <MudTh>@L["ScheduledTasksView_Table_Type"]</MudTh>
            <MudTh>@L["ScheduledTasksView_Table_Schedule"]</MudTh>
            <MudTh>@L["ScheduledTasksView_Table_Target"]</MudTh>
            <MudTh>@L["ScheduledTasksView_Table_NextRun"]</MudTh>
            <MudTh>@L["ScheduledTasksView_Table_LastRun"]</MudTh>
            <MudTh>@L["ScheduledTasksView_Table_Status"]</MudTh>
            <MudTh>@L["ScheduledTasksView_Table_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><strong>@context.Name</strong></MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetTypeColor(context.TaskType)" Variant="Variant.Outlined">
                    @GetTypeLabel(context.TaskType)
                </MudChip>
            </MudTd>
            <MudTd><code>@context.CronExpression</code></MudTd>
            <MudTd><code>@(context.TargetName ?? context.TargetId ?? "-")</code></MudTd>
            <MudTd>
                @if (context.NextRun != null)
                {
                    <MudText Typo="Typo.body2">@context.NextRun.Value.ToLocalTime().ToString("dd.MM. HH:mm")</MudText>
                }
            </MudTd>
            <MudTd>
                @if (context.LastRun != null)
                {
                    <MudText Typo="Typo.body2">@context.LastRun.Value.ToLocalTime().ToString("dd.MM. HH:mm")</MudText>
                }
            </MudTd>
            <MudTd>
                @if (context.LastRun == null)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color: var(--sw-text-muted);">@L["ScheduledTasksView_Chip_NeverRun"]</MudChip>
                }
                else if (context.LastSuccess)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
                else
                {
                    <MudTooltip Text="@context.LastResult">
                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                    </MudTooltip>
                }
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="0">
                    @if (_role >= AppRole.Operator)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary" Size="Size.Small"
                                       OnClick="@(() => RunNow(context))" title="@L["ScheduledTasksView_Tooltip_RunNow"]" />
                    }
                    @if (_role >= AppRole.Admin)
                    {
                        <MudSwitch T="bool" Value="@context.Enabled" Color="Color.Success" Size="Size.Small"
                                   ValueChanged="@((bool v) => ToggleEnabled(context, v))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteTask(context))" title="@L["ScheduledTasksView_Tooltip_Delete"]" />
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* Run History *@
@if (_history.Any())
{
    <MudText Typo="Typo.subtitle1" Class="mt-6 mb-2" Style="font-weight: 600;">@L["ScheduledTasksView_History_Title"]</MudText>
    <MudTable Items="@_history" Dense="true" Hover="true" Striped="true" Elevation="0">
        <HeaderContent>
            <MudTh>@L["ScheduledTasksView_History_Task"]</MudTh>
            <MudTh>@L["ScheduledTasksView_History_Type"]</MudTh>
            <MudTh>@L["ScheduledTasksView_History_Started"]</MudTh>
            <MudTh>@L["ScheduledTasksView_History_Duration"]</MudTh>
            <MudTh>@L["ScheduledTasksView_History_Result"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.TaskName</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Text">@GetTypeLabel(context.TaskType)</MudChip></MudTd>
            <MudTd>@context.StartedAt.ToLocalTime().ToString("dd.MM. HH:mm:ss")</MudTd>
            <MudTd>@((context.CompletedAt ?? context.StartedAt).Subtract(context.StartedAt).TotalSeconds.ToString("F1"))s</MudTd>
            <MudTd>
                @if (context.Success)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    @if (!string.IsNullOrEmpty(context.Output))
                    {
                        <MudTooltip Text="@context.Output"><MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color: var(--sw-text-muted);" /></MudTooltip>
                    }
                }
                else
                {
                    <MudTooltip Text="@context.Error">
                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* Create Dialog *@
<MudDialog Visible="_showDialog" VisibleChanged="@(v => _showDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@L["ScheduledTasksView_Dialog_CreateTitle"]</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_formName" Label="@L["ScheduledTasksView_Field_Name"]" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect T="string" Value="_formServerId" ValueChanged="OnTaskServerChanged" Label="@L["ScheduledTasksView_Field_TargetServer"]" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var srv in _servers)
                {
                    <MudSelectItem Value="@srv.Id">@srv.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="Whiskers.Models.ScheduledTaskType" @bind-Value="_formType" Label="@L["ScheduledTasksView_Field_Type"]" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="Whiskers.Models.ScheduledTaskType.ContainerRestart">@L["ScheduledTasksView_TaskType_ContainerRestart"]</MudSelectItem>
                <MudSelectItem Value="Whiskers.Models.ScheduledTaskType.DbBackup">@L["ScheduledTasksView_TaskType_DbBackup"]</MudSelectItem>
                <MudSelectItem Value="Whiskers.Models.ScheduledTaskType.VolumeBackup">@L["ScheduledTasksView_TaskType_VolumeBackup"]</MudSelectItem>
                <MudSelectItem Value="Whiskers.Models.ScheduledTaskType.SelfBackup">@L["ScheduledTasksView_TaskType_SelfBackup"]</MudSelectItem>
                <MudSelectItem Value="Whiskers.Models.ScheduledTaskType.CustomCommand">@L["ScheduledTasksView_TaskType_CustomCommand"]</MudSelectItem>
                <MudSelectItem Value="Whiskers.Models.ScheduledTaskType.Cleanup">@L["ScheduledTasksView_TaskType_Cleanup"]</MudSelectItem>
            </MudSelect>

            @if (_formType is ScheduledTaskType.ContainerRestart or ScheduledTaskType.DbBackup)
            {
                <MudSelect T="string" @bind-Value="_formTargetId" Label="@L["ScheduledTasksView_Field_Container"]" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var c in _containers.Where(c => _formType == ScheduledTaskType.DbBackup ? c.IsDatabase : true))
                    {
                        <MudSelectItem Value="@c.Name">@c.Name (@c.Image)</MudSelectItem>
                    }
                </MudSelect>
            }
            else if (_formType == ScheduledTaskType.VolumeBackup)
            {
                <MudTextField @bind-Value="_formTargetId" Label="@L["ScheduledTasksView_Field_VolumeName"]" Variant="Variant.Outlined" Class="mb-3" />
            }
            else if (_formType == ScheduledTaskType.CustomCommand)
            {
                <MudTextField @bind-Value="_formCommand" Label="@L["ScheduledTasksView_Field_Command"]" Variant="Variant.Outlined" Class="mb-3"
                              Style="font-family: 'JetBrains Mono', monospace;" Placeholder="docker system prune -f" />
            }

            <MudTextField @bind-Value="_formCron" Label="@L["ScheduledTasksView_Field_CronSchedule"]" Variant="Variant.Outlined" Class="mb-3"
                          Style="font-family: 'JetBrains Mono', monospace;"
                          HelperText="@L["ScheduledTasksView_Field_CronHelperText"]" />

            <MudStack Row="true" Spacing="1" Class="mb-3">
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _formCron = "0 2 * * *")">@L["ScheduledTasksView_CronPreset_Daily"]</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _formCron = "0 */6 * * *")">@L["ScheduledTasksView_CronPreset_Every6h"]</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _formCron = "0 3 * * 0")">@L["ScheduledTasksView_CronPreset_Sunday"]</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _formCron = "0 0 1 * *")">@L["ScheduledTasksView_CronPreset_Monthly"]</MudButton>
            </MudStack>

            @if (_formType is ScheduledTaskType.DbBackup or ScheduledTaskType.VolumeBackup or ScheduledTaskType.SelfBackup)
            {
                <MudNumericField T="int" @bind-Value="_formMaxBackups" Label="@L["ScheduledTasksView_Field_MaxBackups"]"
                                 Variant="Variant.Outlined" Min="0" Max="100" />
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showDialog = false)">@L["ScheduledTasksView_Button_Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateTask"
                       Disabled="@(string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formCron))">@L["ScheduledTasksView_Button_Create"]</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    private List<Whiskers.Models.ScheduledTaskEntity> _tasks = new();
    private List<Whiskers.Models.TaskRunHistoryEntity> _history = new();
    private List<Whiskers.Models.ContainerInfo> _containers = new();
    private bool _showDialog;

    // Form
    private string _formName = "";
    private ScheduledTaskType _formType = ScheduledTaskType.ContainerRestart;
    private string _formTargetId = "";
    private string _formCron = "0 2 * * *";
    private string _formCommand = "";
    private int _formMaxBackups = 7;
    private List<Whiskers.Models.ServerConfig> _servers = new();
    private string _formServerId = "local";
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["ScheduledTasksView_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _servers = ServerConfigService.GetEnabledServers();
        await LoadData();
    }

    private async Task LoadData()
    {
        _tasks = await Scheduler.GetTasksAsync();
        _history = await Scheduler.GetHistoryAsync(limit: 20);
    }

    private async Task ShowCreateDialog()
    {
        _formName = ""; _formTargetId = ""; _formCron = "0 2 * * *"; _formCommand = ""; _formMaxBackups = 7;
        _formServerId = ServerConfigService.GetDefaultServer()?.Id ?? "local";
        await LoadContainersForServer();
        _showDialog = true;
    }

    private async Task OnTaskServerChanged(string serverId)
    {
        _formServerId = serverId;
        _formTargetId = "";
        await LoadContainersForServer();
    }

    private async Task LoadContainersForServer()
    {
        var sid = _formServerId == "local" ? null : _formServerId;
        _containers = (await DockerService.ListContainersAsync(all: true, serverId: sid)).ToList();
    }

    private async Task CreateTask()
    {
        if (!Require(AppRole.Admin)) return;
        try
        {
            var config = new Dictionary<string, string>();
            if (_formMaxBackups > 0) config["maxBackups"] = _formMaxBackups.ToString();
            if (!string.IsNullOrEmpty(_formCommand)) config["command"] = _formCommand;

            await Scheduler.CreateTaskAsync(new Whiskers.Models.ScheduledTaskEntity
            {
                Name = _formName,
                CronExpression = _formCron,
                TaskType = _formType,
                TargetId = _formTargetId,
                TargetName = _formTargetId,
                ServerId = _formServerId,
                Config = config.Any() ? System.Text.Json.JsonSerializer.Serialize(config) : null
            });
            await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
                "task.create", "scheduled-task", _formName, _formName, serverId: _formServerId);
            Snackbar.Add(L["ScheduledTasksView_Snackbar_TaskCreated", _formName].Value, Severity.Success);
            _showDialog = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["ScheduledTasksView_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    private async Task RunNow(Whiskers.Models.ScheduledTaskEntity task)
    {
        if (!Require(AppRole.Operator)) return;
        Snackbar.Add(L["ScheduledTasksView_Snackbar_TaskRunning", task.Name].Value, Severity.Info);
        var (success, output) = await Scheduler.RunNowAsync(task.TaskId);
        await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
            "task.run-now", "scheduled-task", task.TaskId, task.Name, serverId: task.ServerId, success: success);
        Snackbar.Add(success ? L["ScheduledTasksView_Snackbar_RunSuccess", output].Value : L["ScheduledTasksView_Snackbar_Error", output].Value,
            success ? Severity.Success : Severity.Error);
        await LoadData();
    }

    private async Task ToggleEnabled(Whiskers.Models.ScheduledTaskEntity task, bool enabled)
    {
        if (!Require(AppRole.Admin)) return;
        task.Enabled = enabled;
        await Scheduler.UpdateTaskAsync(task);
        await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
            enabled ? "task.enable" : "task.disable", "scheduled-task", task.TaskId, task.Name, serverId: task.ServerId);
        await LoadData();
    }

    private async Task DeleteTask(Whiskers.Models.ScheduledTaskEntity task)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["ScheduledTasksView_Dialog_DeleteTitle"].Value,
            L["ScheduledTasksView_Dialog_DeleteMessage", task.Name].Value,
            yesText: L["ScheduledTasksView_Dialog_DeleteConfirm"].Value, cancelText: L["ScheduledTasksView_Dialog_Cancel"].Value);
        if (confirmed != true) return;
        try
        {
            await Scheduler.DeleteTaskAsync(task.TaskId);
            await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
                "task.delete", "scheduled-task", task.TaskId, task.Name, serverId: task.ServerId);
            Snackbar.Add(L["ScheduledTasksView_Snackbar_TaskDeleted", task.Name].Value, Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["ScheduledTasksView_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    private static Color GetTypeColor(ScheduledTaskType type) => type switch
    {
        ScheduledTaskType.ContainerRestart => Color.Primary,
        ScheduledTaskType.DbBackup => Color.Warning,
        ScheduledTaskType.VolumeBackup => Color.Info,
        ScheduledTaskType.SelfBackup => Color.Success,
        ScheduledTaskType.CustomCommand => Color.Tertiary,
        ScheduledTaskType.Cleanup => Color.Default,
        _ => Color.Default
    };

    private string GetTypeLabel(ScheduledTaskType type) => type switch
    {
        ScheduledTaskType.ContainerRestart => L["ScheduledTasksView_TypeLabel_Restart"].Value,
        ScheduledTaskType.DbBackup => L["ScheduledTasksView_TypeLabel_DbBackup"].Value,
        ScheduledTaskType.VolumeBackup => L["ScheduledTasksView_TypeLabel_VolumeBackup"].Value,
        ScheduledTaskType.SelfBackup => L["ScheduledTasksView_TypeLabel_SelfBackup"].Value,
        ScheduledTaskType.CustomCommand => L["ScheduledTasksView_TypeLabel_Command"].Value,
        ScheduledTaskType.Cleanup => L["ScheduledTasksView_TypeLabel_Cleanup"].Value,
        _ => type.ToString()
    };
}
