@inject Whiskers.Services.LogMonitor.ILogSearchService SearchService
@inject Whiskers.Services.LogMonitor.ILogMonitorService MonitorService
@inject IDockerService DockerService
@inject ISnackbar Snackbar
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject IStringLocalizer<SharedResource> L

@* The interactive log-search + alert-rules UI. Rendered by LogSearch.razor only when the LogMonitor module
   is enabled (via ModuleGuard), so a disabled module never reaches the ILogSearchService / ILogMonitorService
   injections. *@

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["LogSearchView_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["LogSearchView_Header_Subtitle"]</MudText>
        </div>
    </MudStack>
</div>

@* Search Section *@
<MudPaper Class="pa-4 mb-4" Elevation="0">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End" Class="mb-3">
        <MudTextField @bind-Value="_searchPattern" Label="@L["LogSearchView_Search_PatternLabel"]" Variant="Variant.Outlined"
                      Style="flex: 1; font-family: 'JetBrains Mono', monospace;"
                      Placeholder="ERROR|Exception|OOM" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" />
        <MudSwitch @bind-Value="_isRegex" Label="@L["LogSearchView_Search_RegexLabel"]" Color="Color.Primary" />
        <MudSelect T="string" @bind-Value="_searchContainer" Label="@L["LogSearchView_Search_ContainerLabel"]" Variant="Variant.Outlined"
                   Dense="true" Clearable="true" Style="min-width: 200px;">
            @foreach (var c in _containers)
            {
                <MudSelectItem Value="@c.Name">@c.Name</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Search"
                   StartIcon="@Icons.Material.Filled.Search" Disabled="@(_searching || string.IsNullOrWhiteSpace(_searchPattern))">
            @if (_searching) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
            @L["LogSearchView_Search_Button"]
        </MudButton>
    </MudStack>

    @if (_results != null)
    {
        <MudText Typo="Typo.body2" Class="mb-2" Style="color: var(--sw-text-secondary);">
            @(_results.Count >= 200 ? L["LogSearchView_Results_CountLimit", _results.Count].Value : L["LogSearchView_Results_Count", _results.Count].Value)
        </MudText>
        <MudTable Items="@_results" Dense="true" Hover="true" Striped="true" FixedHeader="true" Height="400px" Elevation="0">
            <HeaderContent>
                <MudTh Style="width: 180px;">@L["LogSearchView_Table_Container"]</MudTh>
                <MudTh>@L["LogSearchView_Table_LogLine"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ContainerName</MudChip>
                </MudTd>
                <MudTd>
                    <code style="font-size: 0.8rem; word-break: break-all;">@context.Line</code>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@* Alert Rules *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@L["LogSearchView_Rules_Heading"]</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
               OnClick="ShowCreateRule">@L["LogSearchView_Rules_CreateButton"]</MudButton>
</MudStack>

@if (!_rules.Any())
{
    <MudAlert Severity="Severity.Info" Dense="true">@L["LogSearchView_Rules_Empty"]</MudAlert>
}
else
{
    <MudTable Items="@_rules" Dense="true" Hover="true" Striped="true" Elevation="0">
        <HeaderContent>
            <MudTh>@L["LogSearchView_RulesTable_Name"]</MudTh>
            <MudTh>@L["LogSearchView_RulesTable_Pattern"]</MudTh>
            <MudTh>@L["LogSearchView_RulesTable_Container"]</MudTh>
            <MudTh>@L["LogSearchView_RulesTable_Severity"]</MudTh>
            <MudTh>@L["LogSearchView_RulesTable_Triggered"]</MudTh>
            <MudTh>@L["LogSearchView_RulesTable_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><strong>@context.Name</strong></MudTd>
            <MudTd><code>@context.Pattern</code> @if (context.IsRegex) { <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@L["LogSearchView_Search_RegexLabel"]</MudChip> }</MudTd>
            <MudTd>@(context.ContainerName ?? L["LogSearchView_Rules_AllContainers"].Value)</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(context.Severity)">@context.Severity</MudChip></MudTd>
            <MudTd>@context.TriggerCount×@(context.LastTriggered != null ? $" ({context.LastTriggered.Value.ToLocalTime():dd.MM. HH:mm})" : "")</MudTd>
            <MudTd>
                <MudSwitch T="bool" Value="@context.Enabled" Color="Color.Success" Size="Size.Small"
                           ValueChanged="@((bool v) => ToggleRule(context, v))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteRule(context))" title="@L["LogSearchView_Rules_DeleteTooltip"]" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* Create Rule Dialog *@
<MudDialog Visible="_showRuleDialog" VisibleChanged="@(v => _showRuleDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@L["LogSearchView_Dialog_Title"]</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_ruleName" Label="@L["LogSearchView_Dialog_NameLabel"]" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_rulePattern" Label="@L["LogSearchView_Dialog_PatternLabel"]" Variant="Variant.Outlined" Class="mb-3"
                          Style="font-family: 'JetBrains Mono', monospace;" Placeholder="ERROR|Exception|fatal" />
            <MudSwitch @bind-Value="_ruleIsRegex" Label="@L["LogSearchView_Dialog_RegexLabel"]" Color="Color.Primary" Class="mb-3" />
            <MudSelect T="string" @bind-Value="_ruleContainer" Label="@L["LogSearchView_Dialog_ContainerLabel"]" Variant="Variant.Outlined"
                       Class="mb-3" Clearable="true">
                @foreach (var c in _containers)
                {
                    <MudSelectItem Value="@c.Name">@c.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" @bind-Value="_ruleSeverity" Label="@L["LogSearchView_Dialog_SeverityLabel"]" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="@("info")">@L["LogSearchView_Severity_Info"]</MudSelectItem>
                <MudSelectItem Value="@("warning")">@L["LogSearchView_Severity_Warning"]</MudSelectItem>
                <MudSelectItem Value="@("error")">@L["LogSearchView_Severity_Error"]</MudSelectItem>
                <MudSelectItem Value="@("critical")">@L["LogSearchView_Severity_Critical"]</MudSelectItem>
            </MudSelect>
            <MudNumericField T="int" @bind-Value="_ruleCooldown" Label="@L["LogSearchView_Dialog_CooldownLabel"]" Variant="Variant.Outlined"
                             Min="1" Max="1440" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showRuleDialog = false)">@L["LogSearchView_Dialog_Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateRule"
                       Disabled="@(string.IsNullOrWhiteSpace(_ruleName) || string.IsNullOrWhiteSpace(_rulePattern))">@L["LogSearchView_Dialog_Create"]</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    private List<Whiskers.Models.ContainerInfo> _containers = new();
    private List<Whiskers.Services.LogMonitor.LogSearchResult>? _results;
    private List<Whiskers.Models.LogAlertRuleEntity> _rules = new();
    private string _searchPattern = "";
    private string? _searchContainer;
    private bool _isRegex;
    private bool _searching;

    // Rule form
    private bool _showRuleDialog;
    private string _ruleName = "";
    private string _rulePattern = "";
    private bool _ruleIsRegex;
    private string? _ruleContainer;
    private string _ruleSeverity = "error";
    private int _ruleCooldown = 10;
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["LogSearchView_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _containers = (await DockerService.ListAllContainersAsync(all: false)).ToList();
        _rules = await MonitorService.GetRulesAsync();
    }

    private async Task Search()
    {
        _searching = true;
        try
        {
            _results = await SearchService.SearchAsync(_searchPattern, _isRegex, _searchContainer);
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["LogSearchView_Snackbar_SearchError", ex.Message].Value, Severity.Error);
        }
        finally { _searching = false; }
    }

    private async Task ShowCreateRule()
    {
        _ruleName = ""; _rulePattern = ""; _ruleIsRegex = false; _ruleContainer = null;
        _ruleSeverity = "error"; _ruleCooldown = 10;
        _showRuleDialog = true;
    }

    private async Task CreateRule()
    {
        if (!Require(AppRole.Operator)) return;
        try
        {
            await MonitorService.CreateRuleAsync(new Whiskers.Models.LogAlertRuleEntity
            {
                Name = _ruleName,
                Pattern = _rulePattern,
                IsRegex = _ruleIsRegex,
                ContainerName = _ruleContainer,
                Severity = _ruleSeverity,
                CooldownMinutes = _ruleCooldown
            });
            Snackbar.Add(L["LogSearchView_Snackbar_RuleCreated", _ruleName].Value, Severity.Success);
            _showRuleDialog = false;
            _rules = await MonitorService.GetRulesAsync();
        }
        catch (Exception ex) { Snackbar.Add(L["LogSearchView_Snackbar_Error", ex.Message].Value, Severity.Error); }
    }

    private async Task ToggleRule(Whiskers.Models.LogAlertRuleEntity rule, bool enabled)
    {
        if (!Require(AppRole.Operator)) return;
        await MonitorService.ToggleRuleAsync(rule.RuleId, enabled);
        _rules = await MonitorService.GetRulesAsync();
    }

    private async Task DeleteRule(Whiskers.Models.LogAlertRuleEntity rule)
    {
        if (!Require(AppRole.Operator)) return;
        await MonitorService.DeleteRuleAsync(rule.RuleId);
        Snackbar.Add(L["LogSearchView_Snackbar_RuleDeleted"].Value, Severity.Success);
        _rules = await MonitorService.GetRulesAsync();
    }

    private static Color GetSeverityColor(string severity) => severity switch
    {
        "critical" => Color.Error,
        "error" => Color.Error,
        "warning" => Color.Warning,
        "info" => Color.Info,
        _ => Color.Default
    };
}
