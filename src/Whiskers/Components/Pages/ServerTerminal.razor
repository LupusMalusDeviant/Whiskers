@page "/server-terminal/{ServerId}"
@attribute [Authorize]

<PageTitle>Server-Terminal - Whiskers</PageTitle>

@* RoadToSAP Phase 1: thin route wrapper. ModuleGuard renders the interactive ServerTerminalView only when
   the Terminal module is enabled; otherwise a clean "module disabled" notice (and the view — which injects
   ITerminalSessionManager — is never instantiated). No @rendermode here: it inherits the app's global
   InteractiveServer, exactly as the page did before the split. *@
<ModuleGuard ModuleId="terminal">
    <ServerTerminalView ServerId="@ServerId" />
</ModuleGuard>

@code {
    [Parameter] public string ServerId { get; set; } = "";
}
