@inject Whiskers.Services.Webhooks.IWebhookService WebhookService
@inject IDockerService DockerService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IJSRuntime JS

@* The interactive webhooks UI. Rendered by Webhooks.razor only when the Webhooks module is enabled (via
   ModuleGuard), so a disabled module never reaches the IWebhookService injection. *@

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Webhook" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Webhooks & CI/CD Trigger</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Automatische Deployments und Benachrichtigungen</MudText>
        </div>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="ShowCreateDialog">Webhook erstellen</MudButton>
        }
    </MudStack>
</div>

<MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
    Webhooks können von GitHub, GitLab oder anderen CI/CD-Systemen aufgerufen werden um Container automatisch neu zu starten oder zu deployen.
</MudAlert>

@if (!_webhooks.Any())
{
    <MudAlert Severity="Severity.Info">Noch keine Webhooks konfiguriert.</MudAlert>
}
else
{
    <MudTable Items="@_webhooks" Dense="true" Hover="true" Striped="true" Elevation="0">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>URL</MudTh>
            <MudTh>Aktion</MudTh>
            <MudTh>Ziel</MudTh>
            <MudTh>Ausgelöst</MudTh>
            <MudTh>Aktionen</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><strong>@context.Name</strong></MudTd>
            <MudTd>
                @if (string.IsNullOrEmpty(context.Secret))
                {
                    <MudTooltip Text="Legacy-Webhook ohne Secret — deaktiviert. Secret neu generieren, dann wieder aktivieren.">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.Warning">Kein Secret</MudChip>
                    </MudTooltip>
                }
                else if (context.Enabled)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Aktiv</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Deaktiviert</MudChip>
                }
            </MudTd>
            <MudTd>
                <code style="font-size: 0.75rem; word-break: break-all;">
                    @($"{Nav.BaseUri}api/webhooks/{context.WebhookId}")
                </code>
            </MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetActionColor(context.Action)" Variant="Variant.Outlined">@context.Action</MudChip></MudTd>
            <MudTd><code>@context.TargetId</code></MudTd>
            <MudTd>@context.TriggerCount×</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary" Size="Size.Small"
                               OnClick="@(() => TestWebhook(context))" title="Signierten Test senden" />
                @if (_role >= AppRole.Admin)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Autorenew" Color="Color.Warning" Size="Size.Small"
                                   OnClick="@(() => RegenerateSecret(context))" title="Secret neu generieren (einmalige Anzeige)" />
                    <MudIconButton Icon="@(context.Enabled ? Icons.Material.Filled.PauseCircle : Icons.Material.Filled.PlayCircle)"
                                   Color="@(context.Enabled ? Color.Default : Color.Success)" Size="Size.Small"
                                   OnClick="@(() => ToggleEnabled(context))"
                                   title="@(context.Enabled ? "Deaktivieren" : "Aktivieren")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteWebhook(context))" title="Löschen" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* One-time secret display (create + regenerate). The secret is shown exactly once and never again. *@
<MudDialog Visible="_showSecretDialog" VisibleChanged="@(v => { _showSecretDialog = v; if (!v) _shownSecret = null; })"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, BackdropClick = false })">
    <TitleContent>Webhook-Secret — einmalige Anzeige</TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            Dieses Secret wird nur JETZT angezeigt und kann später nicht mehr abgerufen werden.
            Im CI-System (z. B. GitHub-Webhook-Secret) hinterlegen — Payload wird als
            <code>X-Hub-Signature-256</code> (HMAC-SHA256) signiert erwartet.
        </MudAlert>
        <MudTextField Value="@_shownSecretUrl" Label="Webhook-URL" Variant="Variant.Outlined" ReadOnly="true"
                      Class="mb-3" Style="font-family: 'JetBrains Mono', monospace;"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="@(() => CopyToClipboard(_shownSecretUrl))" />
        <MudTextField Value="@_shownSecret" Label="Secret" Variant="Variant.Outlined" ReadOnly="true"
                      Style="font-family: 'JetBrains Mono', monospace;"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="@(() => CopyToClipboard(_shownSecret))" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@(() => { _showSecretDialog = false; _shownSecret = null; })">Secret gesichert — schließen</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog Visible="_showDialog" VisibleChanged="@(v => _showDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Webhook erstellen</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_formName" Label="Name" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect T="string" Value="_formServerId" ValueChanged="OnWebhookServerChanged" Label="Ziel-Server" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var srv in _servers)
                {
                    <MudSelectItem Value="@srv.Id">@srv.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" @bind-Value="_formAction" Label="Aktion" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="@("restart")">Container neustarten</MudSelectItem>
                <MudSelectItem Value="@("rebuild")">Container neu bauen (Pull + Recreate)</MudSelectItem>
                <MudSelectItem Value="@("deploy")">Compose Deploy (Pull + Up)</MudSelectItem>
            </MudSelect>
            @if (_formAction is "restart" or "rebuild")
            {
                <MudSelect T="string" @bind-Value="_formTarget" Label="Container" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var c in _containers)
                    {
                        <MudSelectItem Value="@c.Name">@c.Name</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudTextField @bind-Value="_formTarget" Label="Compose-Verzeichnis" Variant="Variant.Outlined" Class="mb-3"
                              Placeholder="/opt/deployments/my-app" Style="font-family: 'JetBrains Mono', monospace;" />
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showDialog = false)">Abbrechen</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateWebhook"
                       Disabled="@(string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formTarget))">Erstellen</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    private List<Whiskers.Models.WebhookEntity> _webhooks = new();
    private List<Whiskers.Models.ContainerInfo> _containers = new();
    private bool _showDialog;
    private bool _showSecretDialog;
    private string? _shownSecret;
    private string _shownSecretUrl = "";
    private string _formName = "";
    private string _formAction = "restart";
    private string _formTarget = "";
    private List<Whiskers.Models.ServerConfig> _servers = new();
    private string _formServerId = "local";
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add($"Keine Berechtigung — {required} erforderlich (deine Rolle: {_role}).", Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _servers = ServerConfigService.GetEnabledServers();
        _webhooks = await WebhookService.GetWebhooksAsync();
    }

    private async Task ShowCreateDialog()
    {
        _formName = ""; _formAction = "restart"; _formTarget = "";
        _formServerId = ServerConfigService.GetDefaultServer()?.Id ?? "local";
        await LoadContainersForServer();
        _showDialog = true;
    }

    private async Task OnWebhookServerChanged(string serverId)
    {
        _formServerId = serverId;
        _formTarget = "";
        await LoadContainersForServer();
    }

    private async Task LoadContainersForServer()
    {
        var sid = _formServerId == "local" ? null : _formServerId;
        _containers = (await DockerService.ListContainersAsync(all: false, serverId: sid)).ToList();
    }

    private async Task CreateWebhook()
    {
        if (!Require(AppRole.Admin)) return;
        try
        {
            var wh = await WebhookService.CreateWebhookAsync(new Whiskers.Models.WebhookEntity
            {
                Name = _formName,
                Action = _formAction,
                TargetType = _formAction == "deploy" ? "compose" : "container",
                TargetId = _formTarget,
                ServerId = _formServerId
            });
            _showDialog = false;
            await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
                "webhook.create", "webhook", wh.WebhookId, wh.Name, serverId: wh.ServerId);
            // One-time display: the secret is only ever available right here.
            ShowSecretOnce(wh.WebhookId, wh.Secret);
            _webhooks = await WebhookService.GetWebhooksAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
    }

    private async Task TestWebhook(Whiskers.Models.WebhookEntity wh)
    {
        // Triggering runs restart/rebuild/deploy on the host — gate it behind Operator so a Viewer
        // cannot fire host actions from the UI.
        if (!Require(AppRole.Operator)) return;
        Snackbar.Add($"Webhook '{wh.Name}' wird getestet (signierter Request)...", Severity.Info);
        // Signed end-to-end test: same HMAC validation path as an external CI caller.
        var (success, output) = await WebhookService.TriggerSignedTestAsync(wh.WebhookId);
        await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
            "webhook.test", "webhook", wh.WebhookId, wh.Name, serverId: wh.ServerId, success: success);
        Snackbar.Add(success ? $"OK: {output}" : $"Fehler: {output}", success ? Severity.Success : Severity.Error);
        _webhooks = await WebhookService.GetWebhooksAsync();
    }

    private async Task RegenerateSecret(Whiskers.Models.WebhookEntity wh)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Secret neu generieren",
            $"Secret für '{wh.Name}' neu generieren? Das alte Secret wird sofort ungültig — CI-Systeme müssen aktualisiert werden.",
            yesText: "Neu generieren", cancelText: "Abbrechen");
        if (confirmed != true) return;
        try
        {
            var secret = await WebhookService.RegenerateSecretAsync(wh.WebhookId);
            await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
                "webhook.regenerate-secret", "webhook", wh.WebhookId, wh.Name, serverId: wh.ServerId);
            ShowSecretOnce(wh.WebhookId, secret);
            _webhooks = await WebhookService.GetWebhooksAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
    }

    private async Task ToggleEnabled(Whiskers.Models.WebhookEntity wh)
    {
        if (!Require(AppRole.Admin)) return;
        try
        {
            await WebhookService.SetEnabledAsync(wh.WebhookId, !wh.Enabled);
            await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
                wh.Enabled ? "webhook.disable" : "webhook.enable", "webhook", wh.WebhookId, wh.Name, serverId: wh.ServerId);
            Snackbar.Add(wh.Enabled ? "Webhook deaktiviert." : "Webhook aktiviert.", Severity.Success);
            _webhooks = await WebhookService.GetWebhooksAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
    }

    private void ShowSecretOnce(string webhookId, string secret)
    {
        _shownSecret = secret;
        _shownSecretUrl = $"{Nav.BaseUri}api/webhooks/{webhookId}";
        _showSecretDialog = true;
    }

    private async Task CopyToClipboard(string? text)
    {
        if (string.IsNullOrEmpty(text)) return;
        await JS.InvokeVoidAsync("swClipboard.copy", text);
        Snackbar.Add("In die Zwischenablage kopiert.", Severity.Success);
    }

    private async Task DeleteWebhook(Whiskers.Models.WebhookEntity wh)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Webhook löschen",
            $"Webhook '{wh.Name}' wirklich löschen? Die zugehörige URL wird ungültig und kann nicht mehr ausgelöst werden.",
            yesText: "Löschen", cancelText: "Abbrechen");
        if (confirmed != true) return;
        try
        {
            await WebhookService.DeleteWebhookAsync(wh.WebhookId);
            await AuditLog.LogAsync(await CurrentUser.GetEmailAsync() ?? "unknown", "web",
                "webhook.delete", "webhook", wh.WebhookId, wh.Name, serverId: wh.ServerId);
            Snackbar.Add("Webhook gelöscht.", Severity.Success);
            _webhooks = await WebhookService.GetWebhooksAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetActionColor(string action) => action switch
    {
        "restart" => Color.Primary,
        "rebuild" => Color.Warning,
        "deploy" => Color.Tertiary,
        _ => Color.Default
    };
}
