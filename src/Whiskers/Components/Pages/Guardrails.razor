@page "/guardrails"
@using Microsoft.AspNetCore.Authorization
@using Whiskers.Configuration
@using Whiskers.Models
@using Whiskers.Services.Agent
@using Whiskers.Services.Agent.Guardrails
@using Whiskers.Services.Auth
@attribute [Authorize]
@inject IGuardrailStore GuardrailStore
@inject IAgentToolRegistry ToolRegistry
@inject ICurrentUserService CurrentUser
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Guardrails</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div style="display:flex; align-items:center; gap:12px;" class="mb-1">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                       OnClick="@(() => Nav.NavigateTo("agent"))" title="Zurück zum Agent" />
        <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" />
        <MudText Typo="Typo.h5">Guardrails</MudText>
    </div>
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: rgba(255,255,255,0.5);">
        Code-erzwungene, unumgängliche Sicherheits-Policy. Wird am Tool-Boundary durchgesetzt (nicht im Prompt).
        Lege mehrere Presets an und schalte das aktive um — der Agent benutzt immer das aktive Preset. Nur Admins.
    </MudText>

    @if (!_isAdmin)
    {
        <MudAlert Severity="Severity.Warning">Nur Admins können die Guardrails ändern.</MudAlert>
    }
    else if (_edit is not null)
    {
        @* Preset bar *@
        <MudPaper Class="pa-4 mb-4">
            <div style="display:flex; align-items:flex-end; gap:12px; flex-wrap:wrap;">
                <MudSelect T="int" Value="_editIndex" ValueChanged="OnSelectPreset" Label="Preset bearbeiten"
                           Margin="Margin.Dense" Variant="Variant.Outlined" Style="min-width:220px;">
                    @for (var i = 0; i < _config.Presets.Count; i++)
                    {
                        var idx = i;
                        <MudSelectItem T="int" Value="idx">
                            @_config.Presets[idx].Name @(_config.Presets[idx].Name == _config.ActivePreset ? " — aktiv" : "")
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudTextField @bind-Value="_edit.Name" Label="Name" Margin="Margin.Dense"
                              Variant="Variant.Outlined" Style="min-width:200px;" />

                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="NewPreset">Neu</MudButton>
                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="DuplicatePreset">Duplizieren</MudButton>
                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error"
                           OnClick="DeletePreset" Disabled="@(_config.Presets.Count <= 1)">Löschen</MudButton>

                <MudSpacer />
                @if (_edit.Name == _config.ActivePreset)
                {
                    <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">aktiv</MudChip>
                }
                else
                {
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Bolt" OnClick="MakeActive">Als aktiv setzen</MudButton>
                }
            </div>
        </MudPaper>

        @* Kill switch *@
        <MudPaper Class="pa-4 mb-4" Style="border-left: 3px solid var(--mud-palette-warning);">
            <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
                <MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Warning" Size="Size.Large" />
                <div style="flex:1; min-width:220px;">
                    <MudText Typo="Typo.subtitle1">Read-Only-Modus (Kill-Switch)</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5);">
                        Blockiert sofort alles oberhalb von „read" — egal welche andere Einstellung.
                    </MudText>
                </div>
                <MudSwitch @bind-Value="_edit.Policy.ReadOnlyMode" Color="Color.Warning" />
            </div>
        </MudPaper>

        <MudGrid>
            @* Autonomy *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Style="height:100%;">
                    <div style="display:flex; align-items:center; gap:8px;" class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle1">Autonomie &amp; Bestätigung</MudText>
                    </div>
                    <MudSelect T="string" @bind-Value="_edit.Policy.MaxAutonomousLevel" Label="Autonomes Maximal-Level"
                               Margin="Margin.Dense" Variant="Variant.Outlined"
                               HelperText="Höchstes Level OHNE Bestätigung.">
                        <MudSelectItem Value="@("read")">read — nur lesen</MudSelectItem>
                        <MudSelectItem Value="@("write")">write — auch ändern</MudSelectItem>
                        <MudSelectItem Value="@("admin")">admin — alles</MudSelectItem>
                    </MudSelect>
                    <MudSwitch @bind-Value="_edit.Policy.RequireConfirmationForWrites" Color="Color.Primary"
                               Label="Writes erfordern Bestätigung" Class="mt-3" />
                    <MudNumericField @bind-Value="_edit.Policy.MaxActionsPerSession" Label="Max. Aktionen pro Session"
                                     Margin="Margin.Dense" Variant="Variant.Outlined" Min="1" Class="mt-2" />
                </MudPaper>
            </MudItem>

            @* Free text *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Style="height:100%;">
                    <div style="display:flex; align-items:center; gap:8px;" class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Code" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle1">Ressourcen &amp; Muster (Freitext)</MudText>
                    </div>
                    <MudTextField Value="@CsvProtected" ValueChanged="@(v => _edit!.Policy.ProtectedResources = SplitCsv(v))"
                                  T="string" Label="Geschützte Ressourcen (Glob, Komma)" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Lines="2"
                                  HelperText="Container/Server/DB, die der Agent nie anfassen darf — z.B. serverwatch*" />
                    <MudTextField Value="@CsvForbidden" ValueChanged="@(v => _edit!.Policy.ForbiddenArgPatterns = SplitCsv(v))"
                                  T="string" Label="Verbotene Argument-Muster (Regex, Komma)" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Lines="2" Class="mt-2"
                                  HelperText="Regex gegen destruktive Shell-/SQL-Argumente." />
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Tool grid *@
        <MudPaper Class="pa-4 mt-4">
            <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;" class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Apps" Color="Color.Primary" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1">Tools — was geht, was nicht</MudText>
                <MudSpacer />
                <MudSelect T="string" Value="_edit.Policy.ToolMode" ValueChanged="OnModeChanged" Label="Modus"
                           Margin="Margin.Dense" Variant="Variant.Outlined" Style="min-width:280px;">
                    <MudSelectItem Value="@("deny")">Deny — alles erlaubt außer abgewählte</MudSelectItem>
                    <MudSelectItem Value="@("allow")">Whitelist — nur angeklickte erlaubt</MudSelectItem>
                </MudSelect>
            </div>
            <MudText Typo="Typo.caption" Class="mb-3" Style="color: rgba(255,255,255,0.5);">
                Häkchen = der Agent darf dieses Tool (im Rahmen von Level/Bestätigung) nutzen.
                @(_edit.Policy.ToolMode == "allow" ? "Whitelist: nichts ist erlaubt außer den Angeklickten." : "Deny: alles ist erlaubt außer den Abgewählten.")
            </MudText>

            @foreach (var grp in _toolsByCategory)
            {
                <div class="mt-2 mb-1" style="display:flex; align-items:center; gap:8px;">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">@grp.Key</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.4);">(@grp.Count())</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => SetCategory(grp, true))">Alle</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => SetCategory(grp, false))">Keine</MudButton>
                </div>
                <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:2px 16px;">
                    @foreach (var t in grp)
                    {
                        var name = t.Name;
                        <MudCheckBox T="bool" Dense="true" Color="Color.Primary"
                                     Value="@IsAllowed(name)" ValueChanged="@(v => SetAllowed(name, v))">
                            <span style="font-family:monospace; font-size:0.8rem;">@name</span>
                            <span style="color:rgba(255,255,255,0.35); font-size:0.7rem;"> · @t.Level</span>
                        </MudCheckBox>
                    }
                </div>
            }
        </MudPaper>

        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAll"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-4" Size="Size.Large">
            Alle Presets speichern
        </MudButton>
    }
</MudContainer>

@code {
    private sealed record ToolInfo(string Name, string Category, string Level);

    private bool _isAdmin;
    private GuardrailConfig _config = new();
    private int _editIndex;
    private GuardrailPreset? _edit;
    private List<IGrouping<string, ToolInfo>> _toolsByCategory = new();

    private string CsvProtected => string.Join(", ", _edit?.Policy.ProtectedResources ?? new());
    private string CsvForbidden => string.Join(", ", _edit?.Policy.ForbiddenArgPatterns ?? new());

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await CurrentUser.HasRoleAsync(AppRole.Admin);
        if (!_isAdmin) return;

        _config = Clone(GuardrailStore.Config);
        if (_config.Presets.Count == 0)
            _config.Presets.Add(new GuardrailPreset { Name = "Standard", Policy = GuardrailPolicy.SafeDefault() });

        var activeIdx = _config.Presets.FindIndex(p => p.Name == _config.ActivePreset);
        _editIndex = activeIdx >= 0 ? activeIdx : 0;
        _edit = _config.Presets[_editIndex];

        _toolsByCategory = ToolRegistry.Tools.Values
            .Select(e => new ToolInfo(e.Name, string.IsNullOrEmpty(e.Category) ? "Andere" : e.Category, e.RequiredLevel))
            .OrderBy(t => t.Category).ThenBy(t => t.Name)
            .GroupBy(t => t.Category)
            .ToList();
    }

    private void OnSelectPreset(int idx)
    {
        _editIndex = idx;
        _edit = _config.Presets[idx];
    }

    // === Tool gating ===

    private bool IsAllowed(string tool) =>
        _edit!.Policy.ToolMode == "allow"
            ? _edit.Policy.ToolAllowList.Contains(tool)
            : !_edit.Policy.ToolDenyList.Contains(tool);

    private void SetAllowed(string tool, bool allowed)
    {
        var p = _edit!.Policy;
        if (p.ToolMode == "allow")
        {
            if (allowed) { if (!p.ToolAllowList.Contains(tool)) p.ToolAllowList.Add(tool); }
            else p.ToolAllowList.Remove(tool);
        }
        else
        {
            if (allowed) p.ToolDenyList.Remove(tool);
            else { if (!p.ToolDenyList.Contains(tool)) p.ToolDenyList.Add(tool); }
        }
    }

    private void SetCategory(IEnumerable<ToolInfo> tools, bool allowed)
    {
        foreach (var t in tools) SetAllowed(t.Name, allowed);
    }

    private void OnModeChanged(string newMode)
    {
        var p = _edit!.Policy;
        if (newMode == p.ToolMode) return;
        var allNames = _toolsByCategory.SelectMany(g => g).Select(t => t.Name).ToList();
        // Preserve the currently-allowed set across the switch.
        var allowedNow = allNames.Where(IsAllowed).ToHashSet();
        if (newMode == "allow")
        {
            p.ToolAllowList = allowedNow.ToList();
            p.ToolDenyList.Clear();
        }
        else
        {
            p.ToolDenyList = allNames.Where(n => !allowedNow.Contains(n)).ToList();
            p.ToolAllowList.Clear();
        }
        p.ToolMode = newMode;
    }

    // === Preset ops ===

    private void NewPreset()
    {
        var name = UniqueName("Neues Preset");
        _config.Presets.Add(new GuardrailPreset { Name = name, Policy = GuardrailPolicy.SafeDefault() });
        OnSelectPreset(_config.Presets.Count - 1);
    }

    private void DuplicatePreset()
    {
        var copy = new GuardrailPreset { Name = UniqueName(_edit!.Name + " Kopie"), Policy = ClonePolicy(_edit.Policy) };
        _config.Presets.Add(copy);
        OnSelectPreset(_config.Presets.Count - 1);
    }

    private void DeletePreset()
    {
        if (_config.Presets.Count <= 1) return;
        var wasActive = _edit!.Name == _config.ActivePreset;
        _config.Presets.RemoveAt(_editIndex);
        if (wasActive) _config.ActivePreset = _config.Presets[0].Name;
        OnSelectPreset(Math.Min(_editIndex, _config.Presets.Count - 1));
    }

    private void MakeActive() => _config.ActivePreset = _edit!.Name;

    private string UniqueName(string baseName)
    {
        var name = baseName;
        var n = 2;
        while (_config.Presets.Any(p => p.Name == name)) name = $"{baseName} {n++}";
        return name;
    }

    private async Task SaveAll()
    {
        // Reconcile: drop empty names, keep ActivePreset valid.
        foreach (var p in _config.Presets)
            if (string.IsNullOrWhiteSpace(p.Name)) p.Name = UniqueName("Preset");
        if (!_config.Presets.Any(p => p.Name == _config.ActivePreset))
            _config.ActivePreset = _config.Presets[0].Name;

        try
        {
            await GuardrailStore.SaveConfigAsync(_config, await BuildPrincipalAsync());
            Snackbar.Add($"Guardrails gespeichert. Aktiv: {_config.ActivePreset}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task<Models.Agent.AgentPrincipal> BuildPrincipalAsync()
    {
        var email = await CurrentUser.GetEmailAsync() ?? "local@serverwatch.local";
        var role = await CurrentUser.GetRoleAsync();
        var level = role switch
        {
            AppRole.Admin => McpPermissionLevels.Admin,
            AppRole.Operator => McpPermissionLevels.Write,
            _ => McpPermissionLevels.Read,
        };
        return new Models.Agent.AgentPrincipal(Models.Agent.AgentPrincipalKind.WebUser, email, level, null, UserEmail: email);
    }

    private static List<string> SplitCsv(string? csv) =>
        (csv ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private static GuardrailConfig Clone(GuardrailConfig s) => new()
    {
        ActivePreset = s.ActivePreset,
        Presets = s.Presets.Select(p => new GuardrailPreset { Name = p.Name, Policy = ClonePolicy(p.Policy) }).ToList(),
    };

    private static GuardrailPolicy ClonePolicy(GuardrailPolicy s) => new()
    {
        MaxAutonomousLevel = s.MaxAutonomousLevel,
        ReadOnlyMode = s.ReadOnlyMode,
        RequireConfirmationForWrites = s.RequireConfirmationForWrites,
        MaxActionsPerSession = s.MaxActionsPerSession,
        ToolMode = s.ToolMode,
        ToolDenyList = new(s.ToolDenyList),
        ToolAllowList = new(s.ToolAllowList),
        ProtectedResources = new(s.ProtectedResources),
        ForbiddenArgPatterns = new(s.ForbiddenArgPatterns),
    };
}
