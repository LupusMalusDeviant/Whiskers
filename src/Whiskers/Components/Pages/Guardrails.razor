@page "/guardrails"
@attribute [Authorize]

@* Route wrapper (DI-safe module gating). GuardrailsView injects the guardrail store + agent tool registry, so
   it is rendered only while the Agent module is enabled; otherwise ModuleGuard shows a "module disabled" notice. *@
<ModuleGuard ModuleId="agent">
    <GuardrailsView />
</ModuleGuard>
