@page "/cloud"
@attribute [Authorize]

<PageTitle>Cloud - Whiskers</PageTitle>

@* RoadToSAP Phase 1: thin route wrapper. ModuleGuard renders the interactive CloudView only when the
   CloudControl module is enabled; otherwise it shows a clean "module disabled" notice (and CloudView — which
   injects ICloudControlService — is never instantiated, so there is no DI error). *@
<ModuleGuard ModuleId="cloud-control">
    <CloudView />
</ModuleGuard>
