@inject Whiskers.Services.Backup.IVolumeBackupService BackupService
@inject IDockerService DockerService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IStringLocalizer<SharedResource> L

@* The interactive volume-backup UI. Rendered by VolumeBackups.razor only when the VolumeBackups module is
   enabled (via ModuleGuard), so a disabled module never reaches the IVolumeBackupService injection. *@

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Backup" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["VolumeBackupsView_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["VolumeBackupsView_Header_Subtitle"]</MudText>
        </div>
        <MudSpacer />
        @if (_role >= AppRole.Operator)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Backup"
                       OnClick="ShowBackupDialog">@L["VolumeBackupsView_Button_CreateBackup"]</MudButton>
        }
    </MudStack>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_backups.Any())
{
    <MudAlert Severity="Severity.Info">@L["VolumeBackupsView_Alert_NoBackups"]</MudAlert>
}
else
{
    <MudTable Items="@_backups" Dense="true" Hover="true" Striped="true" Elevation="2">
        <HeaderContent>
            <MudTh>@L["VolumeBackupsView_Table_Volume"]</MudTh>
            <MudTh>@L["VolumeBackupsView_Table_Container"]</MudTh>
            <MudTh>@L["VolumeBackupsView_Table_Server"]</MudTh>
            <MudTh>@L["VolumeBackupsView_Table_Size"]</MudTh>
            <MudTh>@L["VolumeBackupsView_Table_Created"]</MudTh>
            <MudTh>@L["VolumeBackupsView_Table_Notes"]</MudTh>
            <MudTh>@L["VolumeBackupsView_Table_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><code>@context.VolumeName</code></MudTd>
            <MudTd>@context.ContainerName</MudTd>
            <MudTd>@context.ServerId</MudTd>
            <MudTd>@FormatBytes(context.SizeBytes)</MudTd>
            <MudTd>@context.CreatedAt.ToLocalTime().ToString("dd.MM.yy HH:mm")</MudTd>
            <MudTd>@(context.Notes ?? "-")</MudTd>
            <MudTd>
                @if (_role >= AppRole.Admin)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Restore" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => RestoreBackup(context))" title="@L["VolumeBackupsView_Action_Restore"]" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteBackup(context))" title="@L["VolumeBackupsView_Action_Delete"]" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog Visible="_showBackupDialog" VisibleChanged="@(v => _showBackupDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@L["VolumeBackupsView_Dialog_CreateTitle"]</TitleContent>
        <DialogContent>
            <MudSelect T="string" Value="_backupServerId" ValueChanged="OnBackupServerChanged" Label="@L["VolumeBackupsView_Field_TargetServer"]"
                       Variant="Variant.Outlined" Class="mb-3">
                @foreach (var srv in _servers)
                {
                    <MudSelectItem Value="@srv.Id">@srv.Name</MudSelectItem>
                }
            </MudSelect>
            @if (_volumes.Any())
            {
                <MudSelect @bind-Value="_selectedVolume" Label="@L["VolumeBackupsView_Field_Volume"]" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var v in _volumes.OrderBy(v => !_volumeLabels.ContainsKey(v)).ThenBy(v => v))
                    {
                        <MudSelectItem Value="@v">@GetVolumeDisplayName(v)</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudTextField @bind-Value="_selectedVolume" Label="@L["VolumeBackupsView_Field_VolumeName"]" Variant="Variant.Outlined" Class="mb-3" />
            }
            <MudTextField @bind-Value="_backupContainerName" Label="@L["VolumeBackupsView_Field_Container"]"
                          Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_backupNotes" Label="@L["VolumeBackupsView_Field_Notes"]" Variant="Variant.Outlined" Class="mb-3" />
            @if (_creating)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showBackupDialog = false)" Disabled="@_creating">@L["VolumeBackupsView_Button_Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateBackup"
                       Disabled="@(string.IsNullOrWhiteSpace(_selectedVolume) || _creating)">@L["VolumeBackupsView_Button_StartBackup"]</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    private List<Whiskers.Models.VolumeBackupEntity> _backups = new();
    private List<string> _volumes = new();
    private Dictionary<string, string> _volumeLabels = new(); // volume name → "container (project)"
    private bool _loading = true;
    private bool _showBackupDialog;
    private bool _creating;
    private string _selectedVolume = "";
    private string _backupContainerName = "";
    private string _backupNotes = "";
    private List<Whiskers.Models.ServerConfig> _servers = new();
    private string _backupServerId = "local";
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["VolumeBackupsView_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    private string GetVolumeDisplayName(string volumeName)
    {
        if (_volumeLabels.TryGetValue(volumeName, out var label))
            return $"{volumeName}  —  {label}";
        return volumeName;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _servers = ServerConfigService.GetEnabledServers();
        _backupServerId = ServerConfigService.GetDefaultServer()?.Id ?? "local";
        await LoadBackups();
    }

    private async Task LoadBackups()
    {
        _loading = true;
        try
        {
            _backups = await BackupService.ListBackupsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["VolumeBackupsView_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
        _loading = false;
    }

    private async Task ShowBackupDialog()
    {
        _selectedVolume = "";
        _backupContainerName = "";
        _backupNotes = "";
        _backupServerId = ServerConfigService.GetDefaultServer()?.Id ?? "local";
        _showBackupDialog = true;
        await LoadVolumesForServer();
    }

    private async Task OnBackupServerChanged(string serverId)
    {
        _backupServerId = serverId;
        _selectedVolume = "";
        await LoadVolumesForServer();
    }

    private async Task LoadVolumesForServer()
    {
        _volumeLabels.Clear();
        var sid = _backupServerId == "local" ? null : _backupServerId;

        try
        {
            _volumes = await BackupService.ListVolumesAsync(sid);

            // Map volumes to containers for readable labels
            var containers = await DockerService.ListContainersAsync(serverId: sid);
            foreach (var c in containers)
            {
                // Docker labels contain mount info; we check via container name matching volume prefix
                var project = c.ComposeProject;
                foreach (var vol in _volumes)
                {
                    // Compose volumes are typically named: {project}_{service}_data or similar
                    if (vol.StartsWith(project + "_", StringComparison.OrdinalIgnoreCase) ||
                        vol.StartsWith(project + "-", StringComparison.OrdinalIgnoreCase))
                    {
                        _volumeLabels.TryAdd(vol, $"{c.Name} ({project})");
                    }
                }
            }
        }
        catch { _volumes = new(); }
    }

    private async Task CreateBackup()
    {
        if (!Require(AppRole.Operator)) return;
        _creating = true;
        try
        {
            var backup = await BackupService.BackupVolumeAsync(
                _selectedVolume, _backupContainerName, _backupServerId, _backupNotes);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "backup.create", "volume", backup.BackupId, _selectedVolume, serverId: _backupServerId == "local" ? null : _backupServerId);
            Snackbar.Add(L["VolumeBackupsView_Snackbar_BackupCreated", backup.FileName, FormatBytes(backup.SizeBytes)].Value, Severity.Success);
            _showBackupDialog = false;
            await LoadBackups();
        }
        catch (Exception ex)
        {
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "backup.create", "volume", _selectedVolume, _selectedVolume, details: ex.Message, serverId: _backupServerId == "local" ? null : _backupServerId, success: false);
            Snackbar.Add(L["VolumeBackupsView_Snackbar_BackupFailed", ex.Message].Value, Severity.Error);
        }
        finally
        {
            _creating = false;
        }
    }

    private async Task RestoreBackup(Whiskers.Models.VolumeBackupEntity backup)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["VolumeBackupsView_Dialog_RestoreTitle"].Value,
            L["VolumeBackupsView_Dialog_RestoreMessage", backup.VolumeName].Value,
            yesText: L["VolumeBackupsView_Dialog_RestoreYes"].Value, cancelText: L["VolumeBackupsView_Button_Cancel"].Value);
        if (confirmed != true) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            await BackupService.RestoreVolumeAsync(backup.BackupId);
            await AuditLog.LogAsync(actor, "web", "backup.restore", "volume", backup.BackupId, backup.VolumeName, serverId: backup.ServerId);
            Snackbar.Add(L["VolumeBackupsView_Snackbar_Restored", backup.VolumeName].Value, Severity.Success);
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "backup.restore", "volume", backup.BackupId, backup.VolumeName, details: ex.Message, serverId: backup.ServerId, success: false);
            Snackbar.Add(L["VolumeBackupsView_Snackbar_RestoreFailed", ex.Message].Value, Severity.Error);
        }
    }

    private async Task DeleteBackup(Whiskers.Models.VolumeBackupEntity backup)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["VolumeBackupsView_Dialog_DeleteTitle"].Value,
            L["VolumeBackupsView_Dialog_DeleteMessage", backup.VolumeName, backup.CreatedAt.ToLocalTime().ToString("dd.MM.yy HH:mm")].Value,
            yesText: L["VolumeBackupsView_Dialog_DeleteYes"].Value, cancelText: L["VolumeBackupsView_Button_Cancel"].Value);
        if (confirmed != true) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            await BackupService.DeleteBackupAsync(backup.BackupId);
            await AuditLog.LogAsync(actor, "web", "backup.delete", "volume", backup.BackupId, backup.VolumeName, serverId: backup.ServerId);
            Snackbar.Add(L["VolumeBackupsView_Snackbar_Deleted"].Value, Severity.Success);
            await LoadBackups();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "backup.delete", "volume", backup.BackupId, backup.VolumeName, details: ex.Message, serverId: backup.ServerId, success: false);
            Snackbar.Add(L["VolumeBackupsView_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1073741824 => $"{bytes / 1073741824.0:F1} GB",
        >= 1048576 => $"{bytes / 1048576.0:F1} MB",
        >= 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes} B"
    };
}
