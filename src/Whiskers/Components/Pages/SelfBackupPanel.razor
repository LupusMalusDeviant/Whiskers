@inject Whiskers.Services.Backup.IBackupService BackupService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject Whiskers.Modules.IModuleRegistry ModuleRegistry
@inject IConfiguration Configuration
@inject Microsoft.AspNetCore.Components.NavigationManager NavManager
@inject IStringLocalizer<SharedResource> L

@* F3 self-backup & restore. Rendered inside the Core "Backup & Restore" panel in Settings (already Admin-gated).
   Backs up Whiskers' OWN /app/data: download, restore an on-box or uploaded archive, and (via the scheduler
   module) a scheduled backup. Restore is data-safety-sensitive — it replaces all state and restarts the app. *@

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
    @((MarkupString)L["SelfBackupPanel_Text_Intro"].Value)
</MudText>

@if (_encrypted)
{
    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
        @((MarkupString)L["SelfBackupPanel_Alert_Encrypted"].Value)
    </MudAlert>
}
else
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
        @((MarkupString)L["SelfBackupPanel_Alert_Unencrypted"].Value)
    </MudAlert>
}

@if (_provider == "postgres")
{
    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
        @((MarkupString)L["SelfBackupPanel_Alert_Postgres"].Value)
    </MudAlert>
}

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Wrap="Wrap.Wrap">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Backup"
               OnClick="CreateBackup" Disabled="@_busy">@L["SelfBackupPanel_Button_CreateBackup"]</MudButton>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="LoadBackups" Disabled="@_busy">@L["SelfBackupPanel_Button_Refresh"]</MudButton>
    <MudSpacer />
    @if (ModuleRegistry.IsEnabled("scheduler"))
    {
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Schedule" Href="/tasks"
                   title="@L["SelfBackupPanel_Tooltip_ScheduleBackups"]">
            @L["SelfBackupPanel_Button_ScheduleBackups"]
        </MudButton>
    }
</MudStack>

@if (_busy) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

@if (!_backups.Any())
{
    <MudAlert Severity="Severity.Info" Dense="true">@L["SelfBackupPanel_Alert_NoBackups"]</MudAlert>
}
else
{
    <MudTable Items="@_backups" Dense="true" Hover="true" Striped="true" Elevation="0">
        <HeaderContent>
            <MudTh>@L["SelfBackupPanel_Th_Created"]</MudTh>
            <MudTh>Label</MudTh>
            <MudTh>@L["SelfBackupPanel_Th_Size"]</MudTh>
            <MudTh>DB</MudTh>
            <MudTh>@L["SelfBackupPanel_Th_Encrypted"]</MudTh>
            <MudTh>@L["SelfBackupPanel_Th_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["SelfBackupPanel_Th_Created"]">@context.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yy HH:mm")</MudTd>
            <MudTd DataLabel="Label">@(string.IsNullOrEmpty(context.Label) ? "-" : context.Label)</MudTd>
            <MudTd DataLabel="@L["SelfBackupPanel_Th_Size"]">@FormatBytes(context.SizeBytes)</MudTd>
            <MudTd DataLabel="DB">@context.Provider</MudTd>
            <MudTd DataLabel="@L["SelfBackupPanel_Th_Encrypted"]">
                @if (context.Encrypted)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Success" Size="Size.Small" title="@L["SelfBackupPanel_Tooltip_Encrypted"]" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.LockOpen" Color="Color.Warning" Size="Size.Small" title="@L["SelfBackupPanel_Tooltip_Unencrypted"]" />
                }
            </MudTd>
            <MudTd DataLabel="@L["SelfBackupPanel_Th_Actions"]">
                <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" title="@L["SelfBackupPanel_Tooltip_Download"]"
                               OnClick="@(() => Download(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Restore" Color="Color.Primary" Size="Size.Small"
                               title="@L["SelfBackupPanel_Tooltip_Restore"]" OnClick="@(() => RestoreExisting(context))" Disabled="@_busy" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               title="@L["SelfBackupPanel_Tooltip_Delete"]" OnClick="@(() => DeleteBackup(context))" Disabled="@_busy" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDivider Class="my-4" />

<MudText Typo="Typo.subtitle2" Class="mb-1">@L["SelfBackupPanel_Heading_RestoreFromFile"]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
    @L["SelfBackupPanel_Text_UploadInfo"]
</MudText>
<InputFile OnChange="OnFileSelected" accept=".gz,.enc" disabled="@_busy" />

@code {
    private List<Whiskers.Services.Backup.SelfBackupInfo> _backups = new();
    private AppRole _role = AppRole.Viewer;
    private bool _busy;
    private bool _encrypted;
    private string _provider = "sqlite";

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _encrypted = !string.IsNullOrEmpty(Configuration["VAULT_KEY"] ?? Environment.GetEnvironmentVariable("VAULT_KEY"));
        _provider = (Configuration["WHISKERS_DB_PROVIDER"] ?? Configuration["Database:Provider"] ?? "sqlite").ToLowerInvariant();
        await LoadBackups();
    }

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["SelfBackupPanel_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    private async Task LoadBackups()
    {
        try { _backups = (await BackupService.ListBackupsAsync()).ToList(); }
        catch (Exception ex) { Snackbar.Add(L["SelfBackupPanel_Snackbar_LoadError", ex.Message].Value, Severity.Error); }
    }

    private async Task CreateBackup()
    {
        if (!Require(AppRole.Admin)) return;
        _busy = true;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            var info = await BackupService.CreateBackupAsync("manual", CancellationToken.None);
            await AuditLog.LogAsync(actor, "web", "selfbackup.create", "whiskers", info.Id, info.FileName);
            Snackbar.Add(L["SelfBackupPanel_Snackbar_BackupCreated", FormatBytes(info.SizeBytes) + (info.Encrypted ? L["SelfBackupPanel_Snackbar_EncryptedSuffix"].Value : "")].Value, Severity.Success);
            await LoadBackups();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "selfbackup.create", "whiskers", "", "", details: ex.Message, success: false);
            Snackbar.Add(L["SelfBackupPanel_Snackbar_BackupFailed", ex.Message].Value, Severity.Error);
        }
        finally { _busy = false; }
    }

    private void Download(Whiskers.Services.Backup.SelfBackupInfo info)
    {
        if (!Require(AppRole.Admin)) return;
        // Full browser navigation (bypasses the Blazor router) to the admin-only streaming endpoint; the
        // attachment response downloads the file without replacing the page.
        NavManager.NavigateTo($"backups/self/{info.Id}/download", forceLoad: true);
    }

    private async Task DeleteBackup(Whiskers.Services.Backup.SelfBackupInfo info)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["SelfBackupPanel_Dialog_DeleteTitle"].Value,
            L["SelfBackupPanel_Dialog_DeleteMessage", info.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yy HH:mm")].Value,
            yesText: L["SelfBackupPanel_Dialog_DeleteYes"].Value, cancelText: L["SelfBackupPanel_Dialog_Cancel"].Value);
        if (confirmed != true) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            await BackupService.DeleteBackupAsync(info.Id);
            await AuditLog.LogAsync(actor, "web", "selfbackup.delete", "whiskers", info.Id, info.FileName);
            Snackbar.Add(L["SelfBackupPanel_Snackbar_BackupDeleted"].Value, Severity.Success);
            await LoadBackups();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "selfbackup.delete", "whiskers", info.Id, info.FileName, details: ex.Message, success: false);
            Snackbar.Add(L["SelfBackupPanel_Snackbar_Error", ex.Message].Value, Severity.Error);
        }
    }

    private async Task RestoreExisting(Whiskers.Services.Backup.SelfBackupInfo info)
    {
        if (!Require(AppRole.Admin)) return;
        var path = BackupService.ResolveArchivePath(info.Id);
        if (path is null) { Snackbar.Add(L["SelfBackupPanel_Snackbar_ArchiveNotFound"].Value, Severity.Error); return; }
        await ConfirmAndRestore(path, L["SelfBackupPanel_Text_BackupFrom", info.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yy HH:mm")].Value);
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        if (!Require(AppRole.Admin)) return;
        var file = e.File;
        if (file is null) return;
        _busy = true;
        string? staged = null;
        try
        {
            // Stream straight to a temp file (no MemoryStream) — restore archives can be large. 2 GB cap.
            await using (var upload = file.OpenReadStream(maxAllowedSize: 2L * 1024 * 1024 * 1024))
                staged = await BackupService.StageUploadAsync(upload, CancellationToken.None);

            await ConfirmAndRestore(staged, L["SelfBackupPanel_Text_UploadedFile", file.Name].Value);
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["SelfBackupPanel_Snackbar_UploadRestoreFailed", ex.Message].Value, Severity.Error);
        }
        finally
        {
            // Always discard the upload temp — idempotent + safe (only deletes our .upload-*.tmp). If a restore
            // committed, BeginRestore already removed it; if the user cancelled or it failed, this cleans up.
            if (staged is not null) { try { await BackupService.DiscardUploadAsync(staged); } catch { } }
            _busy = false;
        }
    }

    private async Task ConfirmAndRestore(string archivePath, string description)
    {
        if (!Require(AppRole.Admin)) return;

        // Validate before asking, so we can show a precise error instead of a scary confirm on a bad file.
        var validation = await BackupService.ValidateArchiveAsync(archivePath);
        if (!validation.Ok)
        {
            Snackbar.Add(L["SelfBackupPanel_Snackbar_RestoreNotPossible", validation.Error].Value, Severity.Error);
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["SelfBackupPanel_Dialog_RestoreTitle"].Value,
            L["SelfBackupPanel_Dialog_RestoreMessage", description].Value,
            yesText: L["SelfBackupPanel_Dialog_RestoreYes"].Value, cancelText: L["SelfBackupPanel_Dialog_Cancel"].Value);
        if (confirmed != true) return;

        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        await AuditLog.LogAsync(actor, "web", "selfbackup.restore", "whiskers", "", description);
        Snackbar.Add(L["SelfBackupPanel_Snackbar_RestoreRunning"].Value, Severity.Info);
        try
        {
            // This enters maintenance, stages the restore and stops the process — the circuit will drop here.
            await BackupService.BeginRestoreAsync(archivePath, actor);
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "selfbackup.restore", "whiskers", "", description, details: ex.Message, success: false);
            Snackbar.Add(L["SelfBackupPanel_Snackbar_RestoreFailed", ex.Message].Value, Severity.Error);
        }
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1073741824 => $"{bytes / 1073741824.0:F1} GB",
        >= 1048576 => $"{bytes / 1048576.0:F1} MB",
        >= 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes} B"
    };
}
