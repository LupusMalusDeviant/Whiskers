    private async Task RemoveContainer(ContainerInfo container)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["Dashboard_Dialog_RemoveTitle"].Value,
            L["Dashboard_Dialog_RemoveMessage", container.Name].Value,
            yesText: L["Dashboard_Dialog_RemoveYes"].Value, cancelText: L["Dashboard_Dialog_Cancel"].Value);
        if (confirmed != true) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            await DockerService.RemoveContainerAsync(container.Id, force: true, serverId: container.ServerId);
            await AuditLog.LogAsync(actor, "web", "container.remove", "container", container.Id, container.Name, serverId: container.ServerId);
            Snackbar.Add(L["Dashboard_Snackbar_Removed", container.Name].Value, Severity.Success);
            await RefreshAll();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "container.remove", "container", container.Id, container.Name, details: ex.Message, serverId: container.ServerId, success: false);
            Snackbar.Add(L["Dashboard_Snackbar_RemoveError", container.Name, ex.Message].Value, Severity.Error);
        }
    }

    private bool HasUpdate(ContainerInfo c)
        => ImageUpdateStore.Get(c.Id, c.ServerId)?.UpdateAvailable == true;

    private string GetUpdateTooltip(ContainerInfo c)
    {
        var info = ImageUpdateStore.Get(c.Id, c.ServerId);
        if (info == null) return "";
        var local = info.LocalDigest.Length > 19 ? info.LocalDigest[..19] : info.LocalDigest;
        var remote = info.RemoteDigest.Length > 19 ? info.RemoteDigest[..19] : info.RemoteDigest;
        return L["Dashboard_Tooltip_UpdateAvailable", info.Image, local, remote].Value;
    }

    private async Task UpdateContainer(ContainerInfo container)
    {
        if (!Require(AppRole.Operator)) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            Snackbar.Add(L["Dashboard_Snackbar_Updating", container.Name].Value, Severity.Info);
            var progress = new Progress<string>(msg => Snackbar.Add(msg, Severity.Info));
            // C12: snapshot the current image + config BEFORE recreating, so this update can be rolled back.
            // Best-effort — a snapshot failure must not block the update itself.
            try { await AutoUpdate.CaptureSnapshotAsync(container); }
            catch (Exception cex) { _logger?.LogWarning(cex, "Rollback snapshot capture failed for {Container}", container.Name); }
            await DockerService.RecreateContainerAsync(container.Id, container.ServerId, progress);
            ImageUpdateStore.Remove(container.Id, container.ServerId);
            await AuditLog.LogAsync(actor, "web", "container.update", "container", container.Id, container.Name, serverId: container.ServerId);
            Snackbar.Add(L["Dashboard_Snackbar_Updated", container.Name].Value, Severity.Success);
            await RefreshAll();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "container.update", "container", container.Id, container.Name, details: ex.Message, serverId: container.ServerId, success: false);
            Snackbar.Add(L["Dashboard_Snackbar_UpdateError", container.Name, ex.Message].Value, Severity.Error);
        }
    }

    // C12: a rollback snapshot exists for this container (captured on its last update).
    private bool HasRollback(ContainerInfo c) => _rollbacks.ContainsKey($"{c.ServerId}|{c.Name}");

    private async Task RollbackContainer(ContainerInfo container)
    {
        if (!Require(AppRole.Operator)) return;
        if (!_rollbacks.TryGetValue($"{container.ServerId}|{container.Name}", out var snap)) return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["Dashboard_Dialog_RollbackTitle"].Value,
            L["Dashboard_Dialog_RollbackMessage", container.Name, snap.CapturedAt.ToLocalTime().ToString("g")].Value,
            yesText: L["Dashboard_Dialog_RollbackYes"].Value, cancelText: L["Dashboard_Dialog_Cancel"].Value);
        if (confirmed != true) return;

        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            Snackbar.Add(L["Dashboard_Snackbar_RollingBack", container.Name].Value, Severity.Info);
            var msg = await AutoUpdate.RollbackAsync(snap.Id);
            await AuditLog.LogAsync(actor, "web", "container.rollback", "container", container.Id, container.Name, serverId: container.ServerId);
            Snackbar.Add(msg, Severity.Success);
            await RefreshAll();
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "container.rollback", "container", container.Id, container.Name, details: ex.Message, serverId: container.ServerId, success: false);
            Snackbar.Add(L["Dashboard_Snackbar_RollbackError", container.Name, ex.Message].Value, Severity.Error);
        }
    }

    private static Color GetStateColor(string state) => state switch
    {
        "running" => Color.Success,
        "exited" => Color.Error,
        "paused" => Color.Warning,
        "restarting" => Color.Info,
        _ => Color.Default
    };

    private static string TruncateImage(string image) =>
        image.Length > 40 ? image[..37] + "..." : image;

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1073741824 => $"{bytes / 1073741824.0:F1} GB",
        >= 1048576 => $"{bytes / 1048576.0:F1} MB",
        >= 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes} B"
    };

    private bool GetServerReachable(string serverId)
        => _serverInfos.TryGetValue(serverId, out var info) && info.IsReachable;

    private void ToggleServerExpand(string serverId)
    {
        if (!_expandedServers.Remove(serverId))
        {
            _expandedServers.Add(serverId);
            _ = LoadServerHistory(serverId);
        }
    }

    private TimeSpan ChartPeriodSpan() => _chartPeriod switch
    {
        "1h" => TimeSpan.FromHours(1),
        "6h" => TimeSpan.FromHours(6),
        "24h" => TimeSpan.FromHours(24),
        "7d" => TimeSpan.FromDays(7),
        _ => TimeSpan.FromHours(1)
    };

    private async Task LoadServerHistory(string serverId)
    {
        try
        {
            var period = ChartPeriodSpan();
            _serverCpuHistory[serverId] = await MetricsQuery.GetServerCpuHistoryAsync(serverId, period);
            _serverMemHistory[serverId] = await MetricsQuery.GetServerMemoryHistoryAsync(serverId, period);
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task ReloadAllServerHistory()
    {
        foreach (var serverId in _expandedServers.ToList())
            await LoadServerHistory(serverId);
    }

    private static ApexCharts.ApexChartOptions<MetricPoint> CreateChartOptions(string color)
    {
        return new ApexCharts.ApexChartOptions<MetricPoint>
        {
            Chart = new ApexCharts.Chart
            {
                Background = "transparent",
                Toolbar = new ApexCharts.Toolbar { Show = false },
                Sparkline = new ApexCharts.ChartSparkline { Enabled = false },
                Zoom = new ApexCharts.Zoom { Enabled = false }
            },
            Theme = new ApexCharts.Theme { Mode = ApexCharts.Mode.Dark },
            Stroke = new ApexCharts.Stroke { Curve = ApexCharts.Curve.Smooth, Width = 2 },
            Fill = new ApexCharts.Fill { Opacity = new List<double> { 0.15 }, Type = new List<ApexCharts.FillType> { ApexCharts.FillType.Solid } },
            Colors = new List<string> { color },
            Xaxis = new ApexCharts.XAxis { Type = ApexCharts.XAxisType.Datetime },
            Yaxis = new List<ApexCharts.YAxis>
            {
                new ApexCharts.YAxis
                {
                    Min = 0,
                    Max = 100,
                    Labels = new ApexCharts.YAxisLabels { Formatter = "function(v) { return v.toFixed(0) + '%' }" }
                }
            },
            Tooltip = new ApexCharts.Tooltip { X = new ApexCharts.TooltipX { Format = "HH:mm:ss" } },
            Grid = new ApexCharts.Grid { BorderColor = "#333" }
        };
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

    private class ServerGroupViewModel
    {
        public string ServerId { get; set; } = string.Empty;
        public string ServerName { get; set; } = string.Empty;
        public string? Group { get; set; }
        public List<string> Tags { get; set; } = new();
        public List<ProjectGroupViewModel> Projects { get; set; } = new();
    }

    private class ProjectGroupViewModel
    {
        public string Project { get; set; } = string.Empty;
        public List<ContainerInfo> Containers { get; set; } = new();
    }
