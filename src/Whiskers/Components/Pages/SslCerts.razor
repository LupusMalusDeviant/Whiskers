@page "/ssl/{ServerId}"
@attribute [Authorize]
@inject Whiskers.Services.Server.ISslCertService SslCertService
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["SslCerts_PageTitle"]</PageTitle>

@* RoadToSAP Phase 1: gated by the HostManagement module; when off, ModuleGuard shows a "disabled" notice.
   The ISslCertService injection resolves the Core no-op default either way. *@
<ModuleGuard ModuleId="host-management">

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(""))" />
    <MudText Typo="Typo.h5">@L["SslCerts_Header_Title"]</MudText>
    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@_serverName</MudChip>
    <MudSpacer />
    @if (_role >= AppRole.Admin)
    {
        <MudButton StartIcon="@Icons.Material.Filled.Autorenew" Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="RenewAll" Disabled="@_renewing">@L["SslCerts_Button_RenewAll"]</MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="@_certs" Dense="true" Hover="true" Striped="true" Elevation="2">
        <HeaderContent>
            <MudTh>@L["SslCerts_Table_Certificate"]</MudTh>
            <MudTh>@L["SslCerts_Table_Domains"]</MudTh>
            <MudTh>@L["SslCerts_Table_ExpiresAt"]</MudTh>
            <MudTh>@L["SslCerts_Table_DaysRemaining"]</MudTh>
            <MudTh>@L["SslCerts_Table_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudText Style="font-family: monospace;">@context.CertName</MudText></MudTd>
            <MudTd>
                @foreach (var d in context.Domains)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@d</MudChip>
                }
            </MudTd>
            <MudTd>@(context.ExpiresAt?.ToString("yyyy-MM-dd") ?? L["SslCerts_Expiry_Unknown"].Value)</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.DaysUntilExpiry is not { } d ? Color.Default : d <= 7 ? Color.Error : context.IsExpiringSoon ? Color.Warning : Color.Success)"
                         Variant="Variant.Filled">
                    @(context.DaysUntilExpiry is { } days ? L["SslCerts_Chip_DaysLeft", days].Value : L["SslCerts_Chip_ExpiryUnknown"].Value)
                </MudChip>
            </MudTd>
            <MudTd>
                @if (_role >= AppRole.Admin)
                {
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.Autorenew"
                               OnClick="@(() => RenewCert(context.CertName))" Disabled="@_renewing">
                        @L["SslCerts_Button_Renew"]
                    </MudButton>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["SslCerts_NoRecords"]</MudText>
        </NoRecordsContent>
    </MudTable>
}

</ModuleGuard>

@code {
    [Parameter] public string ServerId { get; set; } = "";

    private string _serverName = "";
    private bool _loading = true;
    private bool _renewing;
    private List<Whiskers.Services.Server.SslCertificate> _certs = new();
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["SslCerts_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        var server = ServerConfigService.GetServer(ServerId);
        _serverName = server?.Name ?? ServerId;
        await LoadCerts();
    }

    private async Task LoadCerts()
    {
        _loading = true;
        try { _certs = await SslCertService.ListCertificatesAsync(ServerId); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _loading = false;
    }

    private async Task RenewCert(string certName)
    {
        if (!Require(AppRole.Admin)) return;

        _renewing = true;
        try
        {
            var result = await SslCertService.RenewAsync(ServerId, certName);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "ssl.renew", "ssl", certName, certName, serverId: ServerId, success: result.Success);
            Snackbar.Add(result.Success ? L["SslCerts_Snackbar_Renewed", certName].Value : L["SslCerts_Snackbar_Error", result.Error].Value,
                result.Success ? Severity.Success : Severity.Error);
            await LoadCerts();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _renewing = false;
    }

    private async Task RenewAll()
    {
        if (!Require(AppRole.Admin)) return;

        _renewing = true;
        try
        {
            var result = await SslCertService.RenewAllAsync(ServerId);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "ssl.renew", "ssl", "all", "all", serverId: ServerId, success: result.Success);
            Snackbar.Add(result.Success ? L["SslCerts_Snackbar_AllRenewed"].Value : L["SslCerts_Snackbar_Error", result.Error].Value,
                result.Success ? Severity.Success : Severity.Error);
            await LoadCerts();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _renewing = false;
    }
}
