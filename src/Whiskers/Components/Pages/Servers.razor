@page "/servers"
@attribute [Authorize]
@inject Whiskers.Services.ServerConfig.IServerConfigService ServerConfigService
@inject Whiskers.Services.Docker.IDockerConnectionManager ConnectionManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Whiskers.Services.Auth.ICurrentUserService CurrentUser
@inject Whiskers.Services.Onboarding.IOnboardingService Onboarding
@inject Whiskers.Services.AuditLog.IAuditLogService AuditLog
@inject NavigationManager Nav
@inject Whiskers.Services.Workloads.IWorkloadProviderFactory WorkloadFactory
@inject Whiskers.Services.Workloads.Kubernetes.IKubernetesClientCache KubeClients
@inject Whiskers.Services.Vault.IVaultService Vault
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Servers_PageTitle"]</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">@L["Servers_Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Servers_Header_Subtitle"]</MudText>
        </div>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="ShowAddDialog">@L["Servers_Button_Add"]</MudButton>
        }
    </MudStack>
</div>

<MudTable Items="@_servers" Dense="true" Hover="true" Striped="true" Elevation="2">
    <HeaderContent>
        <MudTh>@L["Servers_Table_Name"]</MudTh>
        <MudTh>@L["Servers_Table_Host"]</MudTh>
        <MudTh>@L["Servers_Table_Type"]</MudTh>
        <MudTh>@L["Servers_Table_Status"]</MudTh>
        <MudTh>@L["Servers_Table_Actions"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            @context.Name
            @if (context.IsDefault)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="ml-2">@L["Servers_Chip_Default"]</MudChip>
            }
        </MudTd>
        <MudTd Style="font-family: monospace;">
            @switch (context.ConnectionType)
            {
                case Whiskers.Models.ConnectionType.Local:
                    @context.SocketPath
                    break;
                case Whiskers.Models.ConnectionType.TCP:
                    @($"{context.TcpHost}:{context.TcpPort}")
                    break;
                case Whiskers.Models.ConnectionType.SSH:
                    @($"{context.SshUser}@{context.SshHost}:{context.SshPort}")
                    break;
            }
        </MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Color="@(context.ConnectionType == Whiskers.Models.ConnectionType.SSH ? Color.Warning : context.ConnectionType == Whiskers.Models.ConnectionType.TCP ? Color.Info : Color.Success)">
                @context.ConnectionType
            </MudChip>
        </MudTd>
        <MudTd>
            @if (_testResults.TryGetValue(context.Id, out var result))
            {
                @if (result.Success)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                        @L["Servers_Chip_ContainerCount", result.ContainerCount]
                    </MudChip>
                }
                else
                {
                    <MudTooltip Text="@result.Error">
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">@L["Servers_Chip_Error"]</MudChip>
                    </MudTooltip>
                }
            }
            else if (_testing.Contains(context.Id))
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.NetworkCheck" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => TestConnection(context))" title="@L["Servers_Action_TestConnection"]" />
            @if (context.ConnectionType == Whiskers.Models.ConnectionType.SSH && _role >= AppRole.Admin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Hub" Size="Size.Small" Color="Color.Tertiary"
                               OnClick="@(() => StartOnboarding(context))" title="@L["Servers_Action_Onboard"]" />
            }
            @if (!context.IsDefault && _role >= AppRole.Admin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default"
                               OnClick="@(() => EditServer(context))" title="@L["Servers_Action_Edit"]" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteServer(context))" title="@L["Servers_Action_Delete"]" />
            }
        </MudTd>
    </RowTemplate>
</MudTable>

<MudDialog Visible="_showDialog" VisibleChanged="@(v => _showDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@(_editingServer == null ? L["Servers_Dialog_TitleAdd"].Value : L["Servers_Dialog_TitleEdit"].Value)</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_form.Name" Label="@L["Servers_Field_Name"]" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect @bind-Value="_form.ConnectionType" Label="@L["Servers_Field_ConnectionType"]" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="Whiskers.Models.ConnectionType.TCP">@L["Servers_ConnType_Tcp"]</MudSelectItem>
                <MudSelectItem Value="Whiskers.Models.ConnectionType.SSH">@L["Servers_ConnType_Ssh"]</MudSelectItem>
                <MudSelectItem Value="Whiskers.Models.ConnectionType.Kubernetes">@L["Servers_ConnType_Kubernetes"]</MudSelectItem>
            </MudSelect>

            @if (_form.ConnectionType == Whiskers.Models.ConnectionType.TCP)
            {
                <MudTextField @bind-Value="_form.TcpHost" Label="@L["Servers_Field_Host"]" Variant="Variant.Outlined" Class="mb-3" />
                <MudNumericField @bind-Value="_form.TcpPort" Label="@L["Servers_Field_Port"]" Variant="Variant.Outlined" Min="1" Max="65535" Class="mb-3" />
                <MudSwitch @bind-Value="_form.TcpUseTls" Label="@L["Servers_Field_UseTls"]" Color="Color.Primary" />
                <MudSwitch @bind-Value="_form.TailscaleSsh" Label="@L["Servers_Field_TailscaleSsh"]" Color="Color.Primary" />
                @if (_form.TailscaleSsh)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-1">
                        @L["Servers_TailscaleSsh_Hint"] <code>tailscale set --ssh</code> @L["Servers_TailscaleSsh_HintSuffix"]
                    </MudText>
                }
            }
            else if (_form.ConnectionType == Whiskers.Models.ConnectionType.Kubernetes)
            {
                @if (!Vault.IsEnabled)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        @L["Servers_KubeVaultWarning_Prefix"] <code>VAULT_KEY</code> @L["Servers_KubeVaultWarning_Suffix"]
                    </MudAlert>
                }
                <MudTextField @bind-Value="_kubeconfigYaml" Label="@L["Servers_Field_Kubeconfig"]" Variant="Variant.Outlined"
                              Lines="8" Class="mb-2" Style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;"
                              Placeholder="apiVersion: v1&#10;kind: Config&#10;clusters: …"
                              HelperText="@(_editingServer != null ? L["Servers_Kubeconfig_HelperKeep"].Value : L["Servers_Kubeconfig_HelperVault"].Value)" />
                <MudTextField @bind-Value="_form.KubeContext" Label="@L["Servers_Field_KubeContext"]" Variant="Variant.Outlined" Class="mb-3"
                              HelperText="@L["Servers_Field_KubeContext_Helper"]" />
                <MudTextField @bind-Value="_kubeNamespacesCsv" Label="@L["Servers_Field_KubeNamespaces"]" Variant="Variant.Outlined" Class="mb-2"
                              HelperText="@L["Servers_Field_KubeNamespaces_Helper"]" />
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                    @L["Servers_KubeRbacHint"] <code>deploy/k8s/whiskers-agent-rbac.yaml</code>.
                </MudAlert>
            }
            else if (_form.ConnectionType == Whiskers.Models.ConnectionType.SSH)
            {
                <MudTextField @bind-Value="_form.SshHost" Label="@L["Servers_Field_Host"]" Variant="Variant.Outlined" Class="mb-3" />
                <MudNumericField @bind-Value="_form.SshPort" Label="@L["Servers_Field_SshPort"]" Variant="Variant.Outlined" Min="1" Max="65535" Class="mb-3" />
                <MudTextField @bind-Value="_form.SshUser" Label="@L["Servers_Field_SshUser"]" Variant="Variant.Outlined" Class="mb-3" />

                <MudSwitch @bind-Value="_useSshPassword" Color="Color.Primary" Class="mb-1"
                           Label="@L["Servers_Field_UseSshPassword"]" />
                @if (_useSshPassword)
                {
                    <MudTextField @bind-Value="_form.SshPassword" Label="@L["Servers_Field_SshPassword"]" Variant="Variant.Outlined"
                                  InputType="InputType.Password" Class="mb-2"
                                  HelperText="@L["Servers_Field_SshPassword_Helper"]" />
                }
                else
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Key"
                                   HtmlTag="label" for="ssh-key-upload">
                            @(_sshKeyFileName ?? L["Servers_Button_UploadSshKey"].Value)
                        </MudButton>
                        <InputFile id="ssh-key-upload" OnChange="OnSshKeyFileChanged" style="display:none;" />
                    </MudStack>
                }

                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                    @((MarkupString)L["Servers_OnboardInfo"].Value)
                </MudAlert>
            }

            @if (_form.ConnectionType is Whiskers.Models.ConnectionType.TCP or Whiskers.Models.ConnectionType.SSH)
            {
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Servers_Cloud_SectionTitle"]</MudText>
                <MudSelect @bind-Value="_form.CloudProvider" Label="@L["Servers_Field_CloudProvider"]" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem Value="Whiskers.Models.CloudProvider.None">@L["Servers_Cloud_ProviderNone"]</MudSelectItem>
                    <MudSelectItem Value="Whiskers.Models.CloudProvider.Hetzner">Hetzner Cloud</MudSelectItem>
                    <MudSelectItem Value="Whiskers.Models.CloudProvider.Hostinger">Hostinger VPS</MudSelectItem>
                </MudSelect>
                @if (_form.CloudProvider != Whiskers.Models.CloudProvider.None)
                {
                    <MudTextField @bind-Value="_cloudApiKey" Label="@L["Servers_Field_CloudApiKey"]" Variant="Variant.Outlined"
                                  InputType="InputType.Password" Class="mb-1"
                                  HelperText="@(_hasCloudKey ? L["Servers_CloudKey_HelperKeep"].Value : L["Servers_CloudKey_HelperNew"].Value)" />
                }
            }

            @if (!string.IsNullOrEmpty(_connectError))
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                    @L["Servers_ConnectError_Prefix"] @_connectError
                    <br />@L["Servers_ConnectError_Hint"]
                </MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showDialog = false)" Disabled="_saving">@L["Servers_Button_Cancel"]</MudButton>
            @if (_form.ConnectionType == Whiskers.Models.ConnectionType.SSH)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="SaveAndOnboard"
                           Disabled="@(_saving || string.IsNullOrWhiteSpace(_form.Name))"
                           StartIcon="@Icons.Material.Filled.Hub">
                    @L["Servers_Button_SaveAndOnboard"]
                </MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveServer"
                       Disabled="@(_saving || string.IsNullOrWhiteSpace(_form.Name))">
                @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                @(_saving ? L["Servers_Button_Connecting"].Value : L["Servers_Button_Save"].Value)
            </MudButton>
        </DialogActions>
    </MudDialog>

<MudDialog Visible="_onboarding" VisibleChanged="@(v => { if (!_onboardBusy) _onboarding = v; })"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>@L["Servers_Onboard_DialogTitle", _onboardingServer?.Name ?? ""]</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                @L["Servers_Onboard_Description"]
            </MudText>
            <MudPaper Class="pa-3" Outlined="true" Style="max-height:55vh; overflow-y:auto; font-size:0.88rem;">
                @foreach (var line in _onboardLog)
                {
                    @if (line.StartsWith(Whiskers.Services.Onboarding.OnboardingService.LinkMarker))
                    {
                        var url = line.Substring(Whiskers.Services.Onboarding.OnboardingService.LinkMarker.Length);
                        <MudAlert Severity="Severity.Info" Class="my-2">
                            <MudText Typo="Typo.body2" Class="mb-2">@L["Servers_Onboard_TailscaleLoginHint"]</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@url" Target="_blank"
                                       StartIcon="@Icons.Material.Filled.OpenInNew">@L["Servers_Onboard_OpenTailscaleLogin"]</MudButton>
                        </MudAlert>
                    }
                    else
                    {
                        <div style="font-family:monospace;">@line</div>
                    }
                }
                @if (_onboardBusy)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
                }
            </MudPaper>
            @if (!_onboardBusy && _onboardResult is { Success: false })
            {
                <MudAlert Severity="Severity.Warning" Class="mt-3">
                    <strong>@L["Servers_Onboard_FailedAtStep", _onboardResult.FailedStep?.ToString() ?? ""]</strong> @_onboardResult.Error
                    <br />@L["Servers_Onboard_IdempotentHint"]
                </MudAlert>
            }
        </DialogContent>
        <DialogActions>
            @if (!_onboardBusy && _onboardResult is { Success: false } && _onboardingServer != null)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Replay"
                           OnClick="@(() => StartOnboarding(_onboardingServer, skipPreflight: true))">@L["Servers_Button_Retry"]</MudButton>
            }
            <MudButton OnClick="@(() => { if (!_onboardBusy) _onboarding = false; })" Disabled="_onboardBusy">
                @(_onboardBusy ? L["Servers_Button_Running"].Value : L["Servers_Button_Close"].Value)
            </MudButton>
        </DialogActions>
    </MudDialog>

@code {
    private List<Whiskers.Models.ServerConfig> _servers = new();
    private bool _showDialog;
    private bool _saving;
    private string? _connectError;
    private bool _useSshPassword;
    private Whiskers.Models.ServerConfig? _editingServer;
    private Whiskers.Models.ServerConfig _form = new();
    private string? _sshKeyFileName;
    private byte[]? _sshKeyData;
    private string _cloudApiKey = "";
    private bool _hasCloudKey;
    // Kubernetes (Track B.2): kubeconfig is pasted here and stored in the VAULT, never persisted
    // in the form/servers.json; namespaces are edited as a comma-separated string.
    private string _kubeconfigYaml = "";
    private string _kubeNamespacesCsv = "";
    private HashSet<string> _testing = new();
    private Dictionary<string, TestResult> _testResults = new();

    private bool _onboarding;
    private bool _onboardBusy;
    private List<string> _onboardLog = new();
    private Whiskers.Models.ServerConfig? _onboardingServer;
    private Whiskers.Services.Onboarding.OnboardingResult? _onboardResult;

    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add(L["Servers_Snackbar_NoPermission", required, _role].Value, Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _servers = ServerConfigService.GetServers();

        // Deep link from the dashboard empty state (W3): ?add=onboard preselects the SSH bootstrap
        // path (one-click onboarding), ?add=classic the plain Docker-API path.
        var query = System.Web.HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);
        var add = query.Get("add");
        if (add is "onboard" or "classic" && _role >= AppRole.Admin)
        {
            ShowAddDialog();
            if (add == "onboard")
            {
                _form.ConnectionType = Whiskers.Models.ConnectionType.SSH;
                _useSshPassword = true;
            }
        }
    }

    private void ShowAddDialog()
    {
        _editingServer = null;
        _form = new Whiskers.Models.ServerConfig { ConnectionType = Whiskers.Models.ConnectionType.TCP };
        _sshKeyFileName = null;
        _sshKeyData = null;
        _cloudApiKey = "";
        _hasCloudKey = false;
        _kubeconfigYaml = "";
        _kubeNamespacesCsv = "";
        _connectError = null;
        _useSshPassword = false;
        _showDialog = true;
    }

    private void EditServer(Whiskers.Models.ServerConfig server)
    {
        _editingServer = server;
        _form = server.Clone();   // full copy — no field can be silently dropped on save
        _sshKeyFileName = server.SshKeyFileName;
        _sshKeyData = null;
        _cloudApiKey = "";                                  // never prefill the secret
        _hasCloudKey = !string.IsNullOrWhiteSpace(server.CloudApiKey);
        _kubeconfigYaml = "";                               // never prefill the secret (vault-only)
        _kubeNamespacesCsv = string.Join(", ", server.KubeNamespaces);
        _connectError = null;
        _useSshPassword = false;
        _showDialog = true;
    }

    // Persists the form (add/update + SSH key) and returns the live in-memory ServerConfig — which
    // keeps the transient SshPassword (used for onboarding) that is never written to disk.
    private async Task<Whiskers.Models.ServerConfig> PersistServerAsync()
    {
        // Kubernetes cluster (Track B.2): the kubeconfig goes into the VAULT (encrypted, never on
        // disk); servers.json only carries the selectors. Vault is a hard requirement here.
        if (_form.ConnectionType == Whiskers.Models.ConnectionType.Kubernetes)
        {
            if (!Vault.IsEnabled)
                throw new InvalidOperationException(L["Servers_Error_KubeNeedsVault"].Value);
            if (_editingServer == null && string.IsNullOrWhiteSpace(_kubeconfigYaml))
                throw new InvalidOperationException(L["Servers_Error_KubeconfigMissing"].Value);

            _form.KubeNamespaces = _kubeNamespacesCsv
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
            if (!string.IsNullOrWhiteSpace(_kubeconfigYaml))
            {
                await Vault.SetSecretAsync(
                    Whiskers.Services.Workloads.Kubernetes.KubernetesClientCache.KubeconfigVaultKey(_editingServer?.Id ?? _form.Id),
                    _kubeconfigYaml.Trim());
            }
        }

        // Resolve the cloud API key: blank field = keep the existing one; clearing the provider clears the key.
        if (_form.CloudProvider == Whiskers.Models.CloudProvider.None)
            _form.CloudApiKey = null;
        else if (!string.IsNullOrWhiteSpace(_cloudApiKey))
            _form.CloudApiKey = _cloudApiKey.Trim();
        else
            _form.CloudApiKey = _editingServer?.CloudApiKey;   // keep existing (null for new server)

        // Key vs password are mutually exclusive — drop a stale password if the user picked key auth.
        if (!_useSshPassword) _form.SshPassword = null;

        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        if (_editingServer != null)
        {
            _form.Id = _editingServer.Id;
            _form.IsDefault = _editingServer.IsDefault;
            _form.Enabled = _editingServer.Enabled;

            if (_sshKeyData != null && _sshKeyFileName != null)
                await ServerConfigService.SaveSshKeyAsync(_form.Id, _sshKeyFileName, _sshKeyData);

            await ServerConfigService.UpdateServerAsync(_form);
            ConnectionManager.InvalidateClient(_form.Id);
            KubeClients.Invalidate(_form.Id); // rebuild on next use if kubeconfig/context changed
            await AuditLog.LogAsync(actor, "web", "server.update", "server", _form.Id, _form.Name, serverId: _form.Id);
        }
        else
        {
            await ServerConfigService.AddServerAsync(_form);

            if (_sshKeyData != null && _sshKeyFileName != null)
                await ServerConfigService.SaveSshKeyAsync(_form.Id, _sshKeyFileName, _sshKeyData);

            await AuditLog.LogAsync(actor, "web", "server.add", "server", _form.Id, _form.Name, serverId: _form.Id);
        }

        _servers = ServerConfigService.GetServers();
        return ServerConfigService.GetServer(_form.Id) ?? _form;
    }

    private async Task SaveServer()
    {
        if (!Require(AppRole.Admin)) return;
        _saving = true;
        _connectError = null;
        StateHasChanged();
        try
        {
            Whiskers.Models.ServerConfig saved;
            try
            {
                saved = await PersistServerAsync();
            }
            catch (InvalidOperationException ex)
            {
                // Validation failures (e.g. Kubernetes without vault/kubeconfig) — surface, keep dialog open.
                Snackbar.Add(ex.Message, Severity.Error);
                return;
            }
            // Build + probe the connection before closing, so a broken server isn't saved silently
            // (which would otherwise drag the dashboard with timeouts later).
            var (ok, info) = await TryConnectAsync(saved.Id, TimeSpan.FromSeconds(12));
            if (ok)
            {
                Snackbar.Add(L["Servers_Snackbar_SavedConnected", _form.Name, info].Value, Severity.Success);
                _showDialog = false;
            }
            else
            {
                _connectError = info;
                Snackbar.Add(L["Servers_Snackbar_SavedConnectFailed", _form.Name].Value, Severity.Warning);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    // Save, then run the one-time onboarding (Tailscale + mTLS proxy) over the SSH key / root password
    // just entered. The bootstrap credentials are auto-deleted on success.
    private async Task SaveAndOnboard()
    {
        if (!Require(AppRole.Admin)) return;
        // Ask the Tailscale question BEFORE saving/closing anything — cancelling leaves the form open
        // so the user can simply hit "Speichern" for the classic (no-mesh) path instead.
        if (!await ConfirmTailscalePreflight()) return;
        _saving = true;
        _connectError = null;
        StateHasChanged();
        try
        {
            var saved = await PersistServerAsync();
            _showDialog = false;
            await StartOnboarding(saved, skipPreflight: true);
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>Forces a fresh client for the server and probes it (list containers) within a timeout,
    /// so the save flow can report whether the connection actually comes up.</summary>
    private async Task<(bool ok, string info)> TryConnectAsync(string serverId, TimeSpan timeout)
    {
        try
        {
            // Kubernetes clusters are probed through the workload seam (list pods ≈ GET /version
            // + list) — the Docker connection manager is Docker-only.
            var cfg = ServerConfigService.GetServer(serverId);
            if (cfg?.ConnectionType == Whiskers.Models.ConnectionType.Kubernetes)
            {
                using var kcts = new System.Threading.CancellationTokenSource(timeout);
                var pods = await WorkloadFactory.GetForServer(serverId).ListWorkloadsAsync(all: true, kcts.Token);
                return (true, L["Servers_Status_Pods", pods.Count].Value);
            }

            ConnectionManager.InvalidateClient(serverId);
            var client = await ConnectionManager.GetClientAsync(serverId);
            using var cts = new System.Threading.CancellationTokenSource(timeout);
            var containers = await client.Containers.ListContainersAsync(
                new Docker.DotNet.Models.ContainersListParameters { All = true }, cts.Token);
            return (true, L["Servers_Status_Containers", containers.Count].Value);
        }
        catch (OperationCanceledException)
        {
            return (false, L["Servers_Status_Timeout", timeout.TotalSeconds].Value);
        }
        catch (Exception ex)
        {
            return (false, ex.Message);
        }
    }

    private async Task DeleteServer(Whiskers.Models.ServerConfig server)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["Servers_Dialog_DeleteTitle"].Value,
            L["Servers_Dialog_DeleteMessage", server.Name].Value,
            yesText: L["Servers_Button_Delete"].Value, cancelText: L["Servers_Button_Cancel"].Value);
        if (confirmed != true) return;
        var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
        try
        {
            ConnectionManager.InvalidateClient(server.Id);
            await ServerConfigService.RemoveServerAsync(server.Id);
            // A Kubernetes server leaves its kubeconfig in the vault — clean that up too.
            if (server.ConnectionType == Whiskers.Models.ConnectionType.Kubernetes && Vault.IsEnabled)
                await Vault.DeleteSecretAsync(
                    Whiskers.Services.Workloads.Kubernetes.KubernetesClientCache.KubeconfigVaultKey(server.Id));
            _servers = ServerConfigService.GetServers();
            await AuditLog.LogAsync(actor, "web", "server.remove", "server", server.Id, server.Name, serverId: server.Id);
            Snackbar.Add(L["Servers_Snackbar_Removed", server.Name].Value, Severity.Success);
        }
        catch (Exception ex)
        {
            await AuditLog.LogAsync(actor, "web", "server.remove", "server", server.Id, server.Name, details: ex.Message, serverId: server.Id, success: false);
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task TestConnection(Whiskers.Models.ServerConfig server)
    {
        _testing.Add(server.Id);
        _testResults.Remove(server.Id);
        StateHasChanged();

        try
        {
            if (server.ConnectionType == Whiskers.Models.ConnectionType.Kubernetes)
            {
                var pods = await WorkloadFactory.GetForServer(server.Id).ListWorkloadsAsync(all: true);
                _testResults[server.Id] = new TestResult { Success = true, ContainerCount = pods.Count };
                return;
            }

            var client = await ConnectionManager.GetClientAsync(server.Id);
            var containers = await client.Containers.ListContainersAsync(
                new Docker.DotNet.Models.ContainersListParameters { All = true });
            _testResults[server.Id] = new TestResult { Success = true, ContainerCount = containers.Count };
        }
        catch (Exception ex)
        {
            _testResults[server.Id] = new TestResult { Success = false, Error = ex.Message };
        }
        finally
        {
            _testing.Remove(server.Id);
        }
    }

    /// <summary>W3: the Tailscale account requirement used to surface mid-flow (::TS_LOGIN:: marker) —
    /// now asked UP FRONT so nobody starts the onboarding without knowing what's coming.</summary>
    private async Task<bool> ConfirmTailscalePreflight()
    {
        var choice = await DialogService.ShowMessageBoxAsync(
            L["Servers_Dialog_TailscaleTitle"].Value,
            (MarkupString)L["Servers_Dialog_TailscaleMessage"].Value,
            yesText: L["Servers_Button_ContinueTailscale"].Value, cancelText: L["Servers_Button_Cancel"].Value);
        return choice == true;
    }

    private async Task StartOnboarding(Whiskers.Models.ServerConfig server, bool skipPreflight = false)
    {
        if (!Require(AppRole.Admin)) return;
        if (!skipPreflight && !await ConfirmTailscalePreflight()) return;
        _onboardingServer = server;
        _onboardLog = new();
        _onboardResult = null;
        _onboarding = true;
        _onboardBusy = true;
        StateHasChanged();

        var progress = new Progress<string>(msg =>
        {
            _onboardLog.Add(msg);
            InvokeAsync(StateHasChanged);
        });

        try
        {
            _onboardResult = await Onboarding.OnboardServerAsync(server.Id, progress, CancellationToken.None);
        }
        catch (Exception ex)
        {
            _onboardLog.Add($"❌ {ex.Message}");
        }
        finally
        {
            _onboardBusy = false;
            _servers = ServerConfigService.GetServers();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnSshKeyFileChanged(InputFileChangeEventArgs e)
    {
        var file = e.File;
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 1024 * 100).CopyToAsync(ms);
        _sshKeyData = ms.ToArray();
        _sshKeyFileName = file.Name;
    }

    private class TestResult
    {
        public bool Success { get; set; }
        public int ContainerCount { get; set; }
        public string? Error { get; set; }
    }
}
