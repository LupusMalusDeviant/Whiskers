@page "/login"
@layout Whiskers.Components.Layout.MainLayout
@inject IConfiguration Config
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 80vh;">
    <MudPaper Elevation="4" Class="pa-8 mx-auto" Style="width: 100%; max-width: 400px;">
        <div class="d-flex flex-column align-center">
            <img src="brand.png" alt="Whiskers" width="96" height="96" class="mb-3"
                 style="filter: drop-shadow(0 2px 8px rgba(0,0,0,0.45));" />
            <MudText Typo="Typo.h4" Class="mb-2">Whiskers</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
                @L["Login_Subtitle"]
            </MudText>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4 mud-width-full">
                    @(_error switch
                    {
                        "unauthorized" => L["Login_Error_Unauthorized"].Value,
                        "invalid" => L["Login_Error_Invalid"].Value,
                        _ => _error
                    })
                </MudAlert>
            }

            @if (_googleEnabled)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           FullWidth="true" Href="login-google"
                           StartIcon="@Icons.Material.Filled.Login">
                    @L["Login_Button_Google"]
                </MudButton>
            }
            @if (_oidcEnabled)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large"
                           FullWidth="true" Href="login-oidc" Class="@(_googleEnabled ? "mt-3" : "")"
                           StartIcon="@Icons.Material.Filled.VpnKey">
                    @L["Login_Button_Oidc", _oidcName]
                </MudButton>
            }
            @if (_localEnabled)
            {
                @* Plain server-rendered form: a native POST to /login-local (which sets the cookie). Uses raw
                   <input name=…> — interactive MudBlazor inputs are NOT serialized into a form submission.
                   <AntiforgeryToken/> renders the hidden token the existing UseAntiforgery() middleware checks. *@
                <form method="post" action="login-local"
                      class="d-flex flex-column mud-width-full @((_googleEnabled || _oidcEnabled) ? "mt-4" : "")" style="gap: 12px;">
                    <AntiforgeryToken />
                    <input type="email" name="email" autocomplete="username" required
                           placeholder="@L["Login_Field_Email"]" aria-label="@L["Login_Field_Email"]"
                           style="padding: 12px; border-radius: 8px; border: 1px solid var(--mud-palette-lines-inputs); background: var(--mud-palette-background-grey); color: var(--mud-palette-text-primary);" />
                    <input type="password" name="password" autocomplete="current-password" required
                           placeholder="@L["Login_Field_Password"]" aria-label="@L["Login_Field_Password"]"
                           style="padding: 12px; border-radius: 8px; border: 1px solid var(--mud-palette-lines-inputs); background: var(--mud-palette-background-grey); color: var(--mud-palette-text-primary);" />
                    <button type="submit"
                            style="padding: 11px; border: none; border-radius: 8px; cursor: pointer; font-weight: 500; background: var(--mud-palette-primary); color: var(--mud-palette-primary-text);">
                        @L["Login_Button_Local"]
                    </button>
                </form>
            }
            @if (!_googleEnabled && !_oidcEnabled && !_localEnabled)
            {
                <MudAlert Severity="Severity.Warning" Class="mud-width-full">
                    @L["Login_NoProvider"]
                </MudAlert>
            }
        </div>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? _error { get; set; }

    private bool _googleEnabled;
    private bool _oidcEnabled;
    private bool _localEnabled;
    private string _oidcName = "SSO";

    protected override void OnInitialized()
    {
        // When auth is disabled for LAN deployments, there is no login flow —
        // send users straight to the dashboard.
        if (Config.GetValue<bool>("Auth:Disabled"))
        {
            Nav.NavigateTo("/", forceLoad: false);
            return;
        }

        _googleEnabled = !string.IsNullOrWhiteSpace(Config["GoogleAuth:ClientId"]);
        _oidcEnabled = Config.GetValue<bool>("Oidc:Enabled") && !string.IsNullOrWhiteSpace(Config["Oidc:Authority"]);
        _oidcName = string.IsNullOrWhiteSpace(Config["Oidc:DisplayName"]) ? "SSO" : Config["Oidc:DisplayName"]!;
        // Local username/password login (F1) — on by default so the "no provider" dead-end disappears; a
        // deployment that wants federated-only can set Auth:LocalLogin:Enabled=false.
        _localEnabled = Config.GetValue("Auth:LocalLogin:Enabled", true);
    }
}
