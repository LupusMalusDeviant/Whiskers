@inject IConfiguration Config
<!DOCTYPE html>
<html lang="en">

@{
    // Normalize PathBase to "/foo/" form (or "/" when empty) for <base href>.
    var rawPathBase = Config["PathBase"] ?? "";
    var baseHref = string.IsNullOrWhiteSpace(rawPathBase)
        ? "/"
        : "/" + rawPathBase.Trim('/') + "/";
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@baseHref" />
    <script>
        // Apply the saved theme before first paint (no flash of default colours).
        (function () {
            try { document.documentElement.setAttribute('data-theme', localStorage.getItem('sw-theme') || 'ember'); }
            catch (e) { document.documentElement.setAttribute('data-theme', 'ember'); }
        })();
    </script>
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Whiskers.styles.css"]" />
    @* Content-fingerprinted icon URLs: the hash changes whenever the file content changes,
       so browsers refetch the new icon instead of serving a stale one from the favicon cache. *@
    <link rel="icon" type="image/x-icon" href="@Assets["favicon.ico"]" />
    <link rel="icon" type="image/png" href="@Assets["favicon.png"]" />
    <link rel="apple-touch-icon" href="@Assets["apple-touch-icon.png"]" />
    <link rel="manifest" href="manifest.json" />
    <meta name="theme-color" content="#0a0a1a" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    @* Vendored locally (no CDN dependency, works air-gapped, no supply-chain injection) — see wwwroot/js/vendor/. *@
    <script src="js/vendor/xterm.min.js"></script>
    <script src="js/vendor/xterm-addon-fit.min.js"></script>
    <script src="js/vendor/xterm-addon-web-links.min.js"></script>
    <link rel="stylesheet" href="js/vendor/xterm.css" />
    <script src="js/terminal-interop.js"></script>
    <script src="js/vendor/vis-network.min.js"></script>
    <script src="js/graph-interop.js"></script>
    <script src="js/vendor/html2canvas.min.js"></script>
    <script src="js/theme-interop.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('service-worker.js').catch(function(err) { console.log('SW:', err); });
        }
    </script>
</body>

</html>
