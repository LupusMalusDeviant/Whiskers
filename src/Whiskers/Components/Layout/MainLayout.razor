@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject Whiskers.Modules.IModuleRegistry ModuleRegistry
@inject IStringLocalizer<SharedResource> L

<MudThemeProvider @ref="_mudThemeProvider" Theme="_theme" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" Class="d-md-none" />
        @* App-bar brand only on mobile, where the sidebar (which carries the brand) is hidden. *@
        <div class="d-flex d-md-none align-center">
            <img src="brand.png?v=4" alt="Whiskers" width="30" height="30"
                 style="border-radius:7px; margin-right:8px; filter: hue-rotate(var(--sw-logo-hue, 0deg)) drop-shadow(0 0 7px var(--sw-accent-primary-glow));" />
            <MudText Typo="Typo.h6" Class="sw-gradient-text" Style="font-weight:700; letter-spacing:-0.02em;">Whiskers</MudText>
        </div>
        <MudSpacer />
        <Whiskers.Components.Shared.NotificationBell />
        <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit" title="Theme"
                 AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            @* F12: dark / light / system mode — independent of the accent theme below. *@
            @foreach (var (mode, icon, label) in new[]
            {
                ("light", Icons.Material.Filled.LightMode, L["Theme_Mode_Light"].Value),
                ("dark", Icons.Material.Filled.DarkMode, L["Theme_Mode_Dark"].Value),
                ("system", Icons.Material.Filled.SettingsBrightness, L["Theme_Mode_System"].Value),
            })
            {
                <MudMenuItem OnClick="@(() => SetModeAsync(mode))">
                    <div style="display: flex; align-items: center; gap: 10px; min-width: 150px;">
                        <MudIcon Icon="@icon" Size="Size.Small" />
                        <span>@label</span>
                        @if (_mode == mode)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                     Color="Color.Primary" Style="margin-left: auto;" />
                        }
                    </div>
                </MudMenuItem>
            }
            <MudDivider />
            @foreach (var th in AppThemes.All)
            {
                <MudMenuItem OnClick="@(() => SetThemeAsync(th.Key))">
                    <div style="display: flex; align-items: center; gap: 10px; min-width: 150px;">
                        <span style="width: 16px; height: 16px; border-radius: 50%; flex: 0 0 auto;
                                     background: linear-gradient(135deg, @th.Primary, @th.Accent2);
                                     box-shadow: 0 0 7px @th.Primary;"></span>
                        <span>@th.Name</span>
                        @if (_themeKey == th.Key)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                     Color="Color.Primary" Style="margin-left: auto;" />
                        }
                    </div>
                </MudMenuItem>
            }
        </MudMenu>
        <LanguageSwitcher />
        <AuthorizeView>
            <Authorized>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color: var(--sw-text-secondary);">
                    @context.User.Identity?.Name
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               Href="logout" title="Abmelden" Style="color: var(--sw-text-muted);" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="@DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always" Breakpoint="Breakpoint.Md">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="padding-top: 68px;">
        <div class="pa-4 pa-md-6" style="max-width: 1600px;">
            @Body
        </div>
    </MudMainContent>

    @* The global AI-chat advisor widget belongs to the Agent module — render it only when that module is
       enabled, so disabling the agent (Features:agent:Enabled=false) removes it app-wide instead of throwing
       on every page from its @inject of the agent services. *@
    @if (ModuleRegistry.IsEnabled("agent"))
    {
        <Whiskers.Components.Shared.AiChat />
    }
</MudLayout>

@code {
    private bool _drawerOpen = true;

    // Selected theme (persisted in localStorage as "sw-theme"); drives both the MudBlazor
    // palette and the data-theme attribute that switches the CSS glassmorphism variables.
    private string _themeKey = AppThemes.DefaultKey;
    private MudTheme _theme = AppThemes.Get(AppThemes.DefaultKey).ToMudTheme();

    // F12 dark/light mode: "dark" | "light" | "system" (persisted in localStorage as "sw-mode").
    // _isDarkMode is the RESOLVED value MudBlazor renders with; the data-mode attribute on <html>
    // (set by swTheme JS) switches the CSS variable block in app.css in lockstep.
    private string _mode = "system";
    private bool _isDarkMode = true;
    private MudThemeProvider _mudThemeProvider = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var stored = await JS.InvokeAsync<string?>("swTheme.get");
        if (!string.IsNullOrEmpty(stored) && stored != _themeKey && AppThemes.All.Any(t => t.Key == stored))
        {
            _themeKey = stored;
            _theme = AppThemes.Get(stored).ToMudTheme();
        }

        _mode = await JS.InvokeAsync<string?>("swTheme.getMode") ?? "system";
        _isDarkMode = _mode switch
        {
            "light" => false,
            "dark" => true,
            _ => await _mudThemeProvider.GetSystemDarkModeAsync(),
        };
        // Follow OS preference changes live while in "system" mode.
        await _mudThemeProvider.WatchSystemDarkModeAsync(OnSystemDarkModeChangedAsync);
        await JS.InvokeVoidAsync("swTheme.applyDark", _isDarkMode);
        StateHasChanged();
    }

    private async Task OnSystemDarkModeChangedAsync(bool systemIsDark)
    {
        if (_mode != "system") return;
        _isDarkMode = systemIsDark;
        await JS.InvokeVoidAsync("swTheme.applyDark", _isDarkMode);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetModeAsync(string mode)
    {
        _mode = mode;
        _isDarkMode = mode switch
        {
            "light" => false,
            "dark" => true,
            _ => await _mudThemeProvider.GetSystemDarkModeAsync(),
        };
        await JS.InvokeVoidAsync("swTheme.setMode", mode, _isDarkMode);
        StateHasChanged();
    }

    private async Task SetThemeAsync(string key)
    {
        _themeKey = key;
        _theme = AppThemes.Get(key).ToMudTheme();
        await JS.InvokeVoidAsync("swTheme.set", key);
        StateHasChanged();
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
