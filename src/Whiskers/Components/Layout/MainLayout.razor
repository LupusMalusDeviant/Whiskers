@inherits LayoutComponentBase
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" Class="d-md-none" />
        @* App-bar brand only on mobile, where the sidebar (which carries the brand) is hidden. *@
        <div class="d-flex d-md-none align-center">
            <img src="brand.png?v=4" alt="Whiskers" width="30" height="30"
                 style="border-radius:7px; margin-right:8px; filter: hue-rotate(var(--sw-logo-hue, 0deg)) drop-shadow(0 0 7px var(--sw-accent-primary-glow));" />
            <MudText Typo="Typo.h6" Class="sw-gradient-text" Style="font-weight:700; letter-spacing:-0.02em;">Whiskers</MudText>
        </div>
        <MudSpacer />
        <Whiskers.Components.Shared.NotificationBell />
        <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit" title="Theme"
                 AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            @foreach (var th in AppThemes.All)
            {
                <MudMenuItem OnClick="@(() => SetThemeAsync(th.Key))">
                    <div style="display: flex; align-items: center; gap: 10px; min-width: 150px;">
                        <span style="width: 16px; height: 16px; border-radius: 50%; flex: 0 0 auto;
                                     background: linear-gradient(135deg, @th.Primary, @th.Accent2);
                                     box-shadow: 0 0 7px @th.Primary;"></span>
                        <span>@th.Name</span>
                        @if (_themeKey == th.Key)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                     Color="Color.Primary" Style="margin-left: auto;" />
                        }
                    </div>
                </MudMenuItem>
            }
        </MudMenu>
        <LanguageSwitcher />
        <AuthorizeView>
            <Authorized>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color: rgba(255,255,255,0.6);">
                    @context.User.Identity?.Name
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               Href="logout" title="Abmelden" Style="color: rgba(255,255,255,0.4);" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="@DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always" Breakpoint="Breakpoint.Md">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="padding-top: 68px;">
        <div class="pa-4 pa-md-6" style="max-width: 1600px;">
            @Body
        </div>
    </MudMainContent>

    <Whiskers.Components.Shared.AiChat />
</MudLayout>

@code {
    private bool _drawerOpen = true;

    // Selected theme (persisted in localStorage as "sw-theme"); drives both the MudBlazor
    // palette and the data-theme attribute that switches the CSS glassmorphism variables.
    private string _themeKey = AppThemes.DefaultKey;
    private MudTheme _theme = AppThemes.Get(AppThemes.DefaultKey).ToMudTheme();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var stored = await JS.InvokeAsync<string?>("swTheme.get");
        if (!string.IsNullOrEmpty(stored) && stored != _themeKey && AppThemes.All.Any(t => t.Key == stored))
        {
            _themeKey = stored;
            _theme = AppThemes.Get(stored).ToMudTheme();
            StateHasChanged();
        }
    }

    private async Task SetThemeAsync(string key)
    {
        _themeKey = key;
        _theme = AppThemes.Get(key).ToMudTheme();
        await JS.InvokeVoidAsync("swTheme.set", key);
        StateHasChanged();
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
