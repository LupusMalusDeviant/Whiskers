@inject Whiskers.Modules.IModuleRegistry ModuleRegistry
@inject IStringLocalizer<SharedResource> L

<div class="sw-sidebar-logo">
    <img src="brand.png?v=4" alt="Whiskers" class="sw-sidebar-logo-img" />
    <span class="sw-gradient-text sw-logo-text">Whiskers</span>
</div>

@* RoadToSAP Phase 1: the sidebar renders from IModuleRegistry (the enabled modules' merged nav) instead
   of a hard-coded list. Named groups (ordered by their lowest item Order) each become a MudNavGroup with a
   divider after it; ungrouped items render as top-level links. Every item shows regardless of role — this
   mirrors today's behaviour (the page itself gates via RoleGuard); NavItem.MinRole is reserved for later
   role-gated module nav. *@
<MudNavMenu>
    @foreach (var group in _groups)
    {
        <MudNavGroup Title="@GroupTitle(group.Name)" Icon="@GroupIcon(group.Name)" Expanded="false">
            @foreach (var item in group.Items)
            {
                <MudNavLink Href="@item.Href" Icon="@item.Icon"
                            Match="@(string.IsNullOrEmpty(item.Href) ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                    @L[item.LocKey]
                </MudNavLink>
            }
        </MudNavGroup>
        <div class="sw-nav-divider"></div>
    }
    @foreach (var item in _topLevel)
    {
        <MudNavLink Href="@item.Href" Icon="@item.Icon">
            @L[item.LocKey]
        </MudNavLink>
    }
</MudNavMenu>

@code {
    // Group heading icons — sidebar-shell metadata (NavItem carries only the per-item icon).
    private static readonly Dictionary<string, string> GroupIcons = new()
    {
        ["Übersicht"] = Icons.Material.Filled.SpaceDashboard,
        ["Deployment"] = Icons.Material.Filled.RocketLaunch,
        ["Infrastruktur"] = Icons.Material.Filled.Storage,
        ["Automatisierung"] = Icons.Material.Filled.AutoMode,
    };

    private IReadOnlyList<Whiskers.Modules.NavGroup> _groups = [];
    private IReadOnlyList<Whiskers.Modules.NavItem> _topLevel = [];

    protected override void OnInitialized()
    {
        var items = ModuleRegistry.NavItems;
        _groups = Whiskers.Modules.NavLayout.Grouped(items);
        _topLevel = Whiskers.Modules.NavLayout.TopLevel(items);
    }

    private static string GroupIcon(string group) =>
        GroupIcons.TryGetValue(group, out var icon) ? icon : Icons.Material.Filled.Folder;

    // F2 i18n: group NAMES stay German-internal grouping ids on NavItem (module contract stability);
    // only the display goes through the localizer. Unknown groups fall back to their raw name.
    private static readonly Dictionary<string, string> GroupKeys = new()
    {
        ["Übersicht"] = "NavGroup_Overview",
        ["Deployment"] = "NavGroup_Deployment",
        ["Infrastruktur"] = "NavGroup_Infrastructure",
        ["Automatisierung"] = "NavGroup_Automation",
    };

    private string GroupTitle(string group) =>
        GroupKeys.TryGetValue(group, out var key) ? L[key].Value : group;
}
