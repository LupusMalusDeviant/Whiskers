@inject IStringLocalizer<SharedResource> L
<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="components-reconnect-container">
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>
        <p class="components-reconnect-first-attempt-visible">
            @L["ReconnectModal_Text_Reconnecting"]
        </p>
        <p class="components-reconnect-repeated-attempt-visible">
            @L["ReconnectModal_Text_RetryPrefix"] <span id="components-seconds-to-next-attempt"></span> @L["ReconnectModal_Text_RetrySuffix"]
        </p>
        <p class="components-reconnect-failed-visible">
            @((MarkupString)L["ReconnectModal_Text_Failed"].Value)
        </p>
        <button id="components-reconnect-button" class="components-reconnect-failed-visible">
            @L["ReconnectModal_Button_Retry"]
        </button>
        <p class="components-pause-visible">
            @L["ReconnectModal_Text_Paused"]
        </p>
        <p class="components-resume-failed-visible">
            @((MarkupString)L["ReconnectModal_Text_ResumeFailed"].Value)
        </p>
        <button id="components-resume-button" class="components-pause-visible components-resume-failed-visible">
            @L["ReconnectModal_Button_Resume"]
        </button>
    </div>
</dialog>
