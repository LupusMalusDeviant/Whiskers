@inject ServerWatch.Services.Auth.RoleService RoleService

@* Only renders child content if the current user has the required role *@
@if (_hasAccess)
{
    @ChildContent
}

@code {
    [Parameter] public ServerWatch.Models.AppRole RequiredRole { get; set; } = ServerWatch.Models.AppRole.Operator;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _hasAccess;

    protected override async Task OnParametersSetAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            var email = state.User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
            _hasAccess = RoleService.HasRole(email, RequiredRole);
        }
    }
}
