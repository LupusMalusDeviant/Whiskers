@inject ServerWatch.Services.AiChat.IAiChatService ChatService
@inject ServerWatch.Services.AiChat.IChatHistoryStore HistoryStore
@inject IJSRuntime JS

@if (ChatService.IsEnabled)
{
    @* Floating Chat Button *@
    @if (!_isOpen)
    {
        <div style="position: fixed; bottom: 24px; right: 24px; z-index: 1000;">
            <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.SmartToy" Size="Size.Large"
                    OnClick="OpenChat" Style="box-shadow: 0 4px 20px rgba(96, 165, 250, 0.3);" />
        </div>
    }

    @* Chat Panel *@
    @if (_isOpen)
    {
        <div style="position: fixed; bottom: 24px; right: 24px; width: 420px; max-height: 560px; z-index: 1001;
                    background: rgba(15, 15, 35, 0.95); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.08);
                    border-radius: 16px; display: flex; flex-direction: column; box-shadow: 0 8px 40px rgba(0,0,0,0.5);">

            @* Header *@
            <div style="padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; gap: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Style="color: var(--sw-accent-blue);" />
                <span style="font-weight: 600; font-size: 0.9rem; flex: 1;">ServerWatch Assistent</span>
                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Size="Size.Small" OnClick="ClearChat" title="Chat leeren"
                               Style="color: rgba(255,255,255,0.4);" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _isOpen = false)"
                               Style="color: rgba(255,255,255,0.4);" />
            </div>

            @* Messages *@
            <div id="sw-chat-messages" style="flex: 1; overflow-y: auto; padding: 12px 16px; display: flex; flex-direction: column; gap: 10px; max-height: 400px;">
                @if (!_messages.Any())
                {
                    <div style="text-align: center; color: rgba(255,255,255,0.3); padding: 40px 0; font-size: 0.85rem;">
                        Frag mich etwas zu deinen Containern, Servern oder Datenbanken.
                    </div>
                }
                @foreach (var msg in _messages)
                {
                    var isUser = msg.Role == "user";
                    <div style="@($"align-self: {(isUser ? "flex-end" : "flex-start")}; max-width: 88%; padding: {(isUser ? "8px 12px" : "10px 14px")}; border-radius: {(isUser ? "12px 12px 4px 12px" : "12px 12px 12px 4px")}; background: {(isUser ? "rgba(96, 165, 250, 0.15)" : "rgba(255,255,255,0.04)")}; font-size: 0.85rem; line-height: 1.5;")">
                        @if (isUser)
                        {
                            @msg.Content
                        }
                        else
                        {
                            @((MarkupString)RenderMarkdown(msg.Content))
                        }
                    </div>
                }
                @if (_thinking)
                {
                    <div style="align-self: flex-start; padding: 10px 14px; border-radius: 12px 12px 12px 4px; background: rgba(255,255,255,0.04); display: flex; align-items: center; gap: 8px;">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width: 16px; height: 16px;" />
                        <span style="color: rgba(255,255,255,0.4); font-size: 0.8rem;">Denkt nach...</span>
                    </div>
                }
            </div>

            @* Input *@
            <div style="padding: 12px 16px; border-top: 1px solid rgba(255,255,255,0.06);">
                <MudTextField @bind-Value="_input" Variant="Variant.Outlined"
                              Placeholder="Nachricht... (Enter zum Senden)"
                              Style="font-size: 0.85rem;"
                              Immediate="true"
                              OnKeyDown="OnKeyDown" Disabled="@_thinking"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Send"
                              AdornmentColor="Color.Primary" OnAdornmentClick="Send" />
            </div>
        </div>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isOpen;
    private bool _thinking;
    private bool _loaded;
    private string _input = "";
    private string _userEmail = "";
    private List<ServerWatch.Services.AiChat.ChatMessage> _messages = new();

    private async Task OpenChat()
    {
        _isOpen = true;

        if (!_loaded)
        {
            // Get user email for persistent history
            if (AuthState != null)
            {
                var state = await AuthState;
                _userEmail = state.User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "anonymous";
            }

            // Load history
            _messages = await HistoryStore.LoadAsync(_userEmail);
            _loaded = true;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_input) || _thinking) return;

        var userMsg = _input.Trim();
        _input = "";
        _messages.Add(new ServerWatch.Services.AiChat.ChatMessage { Role = "user", Content = userMsg });
        _thinking = true;
        StateHasChanged();
        await ScrollToBottom();

        // Send with recent history for context (last 10 messages)
        var recentHistory = _messages.SkipLast(1).TakeLast(10).ToList();
        var response = await ChatService.ChatAsync(userMsg, recentHistory);

        _messages.Add(new ServerWatch.Services.AiChat.ChatMessage { Role = "assistant", Content = response });
        _thinking = false;

        // Persist
        await HistoryStore.SaveAsync(_userEmail, _messages);

        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await Send();
    }

    private async Task ClearChat()
    {
        _messages.Clear();
        await HistoryStore.ClearAsync(_userEmail);
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Task.Delay(50); // small delay for DOM update
            await JS.InvokeVoidAsync("eval", "document.getElementById('sw-chat-messages')?.scrollTo({top: 999999, behavior: 'smooth'})");
        }
        catch { }
    }

    /// <summary>Simple Markdown to HTML renderer for chat messages.</summary>
    private static string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrEmpty(markdown)) return "";

        var html = System.Web.HttpUtility.HtmlEncode(markdown);

        // Code blocks: ```...```
        html = System.Text.RegularExpressions.Regex.Replace(html,
            @"```(\w*)\n?([\s\S]*?)```",
            "<pre style=\"background: rgba(0,0,0,0.3); padding: 8px 10px; border-radius: 6px; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; margin: 6px 0;\"><code>$2</code></pre>");

        // Inline code: `...`
        html = System.Text.RegularExpressions.Regex.Replace(html,
            @"`([^`]+)`",
            "<code style=\"background: rgba(255,255,255,0.08); padding: 1px 5px; border-radius: 3px; font-family: 'JetBrains Mono', monospace; font-size: 0.82em;\">$1</code>");

        // Bold: **...**
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");

        // Italic: *...*
        html = System.Text.RegularExpressions.Regex.Replace(html, @"(?<!\*)\*([^*]+?)\*(?!\*)", "<em>$1</em>");

        // Bullet lists: - item
        html = System.Text.RegularExpressions.Regex.Replace(html,
            @"(?m)^- (.+)$",
            "<li style=\"margin-left: 16px; list-style: disc;\">$1</li>");

        // Numbered lists: 1. item
        html = System.Text.RegularExpressions.Regex.Replace(html,
            @"(?m)^\d+\. (.+)$",
            "<li style=\"margin-left: 16px; list-style: decimal;\">$1</li>");

        // Headers
        html = System.Text.RegularExpressions.Regex.Replace(html, @"(?m)^### (.+)$",
            "<div style=\"font-weight: 700; font-size: 0.9em; color: var(--sw-accent-blue); margin: 8px 0 4px;\">$1</div>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"(?m)^## (.+)$",
            "<div style=\"font-weight: 700; font-size: 0.95em; color: var(--sw-accent-blue); margin: 8px 0 4px;\">$1</div>");

        // Line breaks
        html = html.Replace("\n", "<br/>");

        // Clean up
        html = html.Replace("</pre><br/>", "</pre>");
        html = html.Replace("</li><br/>", "</li>");
        html = html.Replace("</div><br/>", "</div>");

        return html;
    }
}
