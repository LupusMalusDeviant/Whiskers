@page "/servers"
@attribute [Authorize]
@inject ServerWatch.Services.ServerConfig.ServerConfigService ServerConfigService
@inject ServerWatch.Services.Docker.DockerConnectionManager ConnectionManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ServerWatch.Services.Auth.CurrentUserService CurrentUser
@inject ServerWatch.Services.Onboarding.OnboardingService Onboarding

<PageTitle>Server - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Serververwaltung</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Server hinzufügen, konfigurieren und verwalten</MudText>
        </div>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="ShowAddDialog">Server hinzufügen</MudButton>
        }
    </MudStack>
</div>

<MudTable Items="@_servers" Dense="true" Hover="true" Striped="true" Elevation="2">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Host</MudTh>
        <MudTh>Typ</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Aktionen</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            @context.Name
            @if (context.IsDefault)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="ml-2">Standard</MudChip>
            }
        </MudTd>
        <MudTd Style="font-family: monospace;">
            @switch (context.ConnectionType)
            {
                case ServerWatch.Models.ConnectionType.Local:
                    @context.SocketPath
                    break;
                case ServerWatch.Models.ConnectionType.TCP:
                    @($"{context.TcpHost}:{context.TcpPort}")
                    break;
                case ServerWatch.Models.ConnectionType.SSH:
                    @($"{context.SshUser}@@@{context.SshHost}:{context.SshPort}")
                    break;
            }
        </MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Color="@(context.ConnectionType == ServerWatch.Models.ConnectionType.SSH ? Color.Warning : context.ConnectionType == ServerWatch.Models.ConnectionType.TCP ? Color.Info : Color.Success)">
                @context.ConnectionType
            </MudChip>
        </MudTd>
        <MudTd>
            @if (_testResults.TryGetValue(context.Id, out var result))
            {
                @if (result.Success)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                        @result.ContainerCount Container
                    </MudChip>
                }
                else
                {
                    <MudTooltip Text="@result.Error">
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Fehler</MudChip>
                    </MudTooltip>
                }
            }
            else if (_testing.Contains(context.Id))
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.NetworkCheck" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => TestConnection(context))" Title="Verbindung testen" />
            @if (context.ConnectionType == ServerWatch.Models.ConnectionType.SSH && _role >= AppRole.Admin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Hub" Size="Size.Small" Color="Color.Tertiary"
                               OnClick="@(() => StartOnboarding(context))" Title="Ins Mesh onboarden (Tailscale + mTLS, SSH-frei)" />
            }
            @if (!context.IsDefault && _role >= AppRole.Admin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default"
                               OnClick="@(() => EditServer(context))" Title="Bearbeiten" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteServer(context))" Title="Löschen" />
            }
        </MudTd>
    </RowTemplate>
</MudTable>

@if (_showDialog)
{
    <MudDialog Visible="_showDialog" VisibleChanged="@(v => _showDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@(_editingServer == null ? "Server hinzufügen" : "Server bearbeiten")</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_form.Name" Label="Name" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect @bind-Value="_form.ConnectionType" Label="Verbindungstyp" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="ServerWatch.Models.ConnectionType.TCP">TCP (Docker Remote API)</MudSelectItem>
                <MudSelectItem Value="ServerWatch.Models.ConnectionType.SSH">SSH Tunnel</MudSelectItem>
            </MudSelect>

            @if (_form.ConnectionType == ServerWatch.Models.ConnectionType.TCP)
            {
                <MudTextField @bind-Value="_form.TcpHost" Label="Host (Domain / IPv4 / IPv6)" Variant="Variant.Outlined" Class="mb-3" />
                <MudNumericField @bind-Value="_form.TcpPort" Label="Port" Variant="Variant.Outlined" Min="1" Max="65535" Class="mb-3" />
                <MudSwitch @bind-Value="_form.TcpUseTls" Label="TLS verwenden" Color="Color.Primary" />
            }
            else if (_form.ConnectionType == ServerWatch.Models.ConnectionType.SSH)
            {
                <MudTextField @bind-Value="_form.SshHost" Label="Host (Domain / IPv4 / IPv6)" Variant="Variant.Outlined" Class="mb-3" />
                <MudNumericField @bind-Value="_form.SshPort" Label="SSH-Port" Variant="Variant.Outlined" Min="1" Max="65535" Class="mb-3" />
                <MudTextField @bind-Value="_form.SshUser" Label="SSH-Benutzer" Variant="Variant.Outlined" Class="mb-3" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Key"
                               HtmlTag="label" for="ssh-key-upload">
                        @(_sshKeyFileName ?? "SSH-Schlüssel hochladen")
                    </MudButton>
                    <InputFile id="ssh-key-upload" OnChange="OnSshKeyFileChanged" style="display:none;" />
                </MudStack>
            }

            @if (_form.ConnectionType != ServerWatch.Models.ConnectionType.Local)
            {
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Cloud-Provider (Power/Snapshot via API, out-of-band)</MudText>
                <MudSelect @bind-Value="_form.CloudProvider" Label="Provider" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem Value="ServerWatch.Models.CloudProvider.None">Keiner</MudSelectItem>
                    <MudSelectItem Value="ServerWatch.Models.CloudProvider.Hetzner">Hetzner Cloud</MudSelectItem>
                    <MudSelectItem Value="ServerWatch.Models.CloudProvider.Hostinger">Hostinger VPS</MudSelectItem>
                </MudSelect>
                @if (_form.CloudProvider != ServerWatch.Models.CloudProvider.None)
                {
                    <MudTextField @bind-Value="_cloudApiKey" Label="API-Key" Variant="Variant.Outlined"
                                  InputType="InputType.Password" Class="mb-1"
                                  HelperText="@(_hasCloudKey ? "Ein Key ist gespeichert — leer lassen, um ihn beizubehalten." : "API-Token des Providers (Hetzner: Projekt-Token; Hostinger: API-Token). Matching erfolgt über die Server-IP.")" />
                }
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showDialog = false)">Abbrechen</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveServer"
                       Disabled="@string.IsNullOrWhiteSpace(_form.Name)">Speichern</MudButton>
        </DialogActions>
    </MudDialog>
}

@if (_onboarding)
{
    <MudDialog Visible="_onboarding" VisibleChanged="@(v => { if (!_onboardBusy) _onboarding = v; })"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>Onboarding: @_onboardingServer?.Name</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                Installiert Tailscale, deployt Telemetrie + mTLS-Proxy und stellt den Server SSH-frei (mTLS).
            </MudText>
            <MudPaper Class="pa-3" Outlined="true" Style="max-height:55vh; overflow-y:auto; font-size:0.88rem;">
                @foreach (var line in _onboardLog)
                {
                    @if (line.StartsWith(ServerWatch.Services.Onboarding.OnboardingService.LinkMarker))
                    {
                        var url = line.Substring(ServerWatch.Services.Onboarding.OnboardingService.LinkMarker.Length);
                        <MudAlert Severity="Severity.Info" Class="my-2">
                            <MudText Typo="Typo.body2" Class="mb-2">Tailscale-Login — im Browser öffnen und den Node bestätigen:</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@url" Target="_blank"
                                       StartIcon="@Icons.Material.Filled.OpenInNew">Tailscale-Login öffnen</MudButton>
                        </MudAlert>
                    }
                    else
                    {
                        <div style="font-family:monospace;">@line</div>
                    }
                }
                @if (_onboardBusy)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
                }
            </MudPaper>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => { if (!_onboardBusy) _onboarding = false; })" Disabled="_onboardBusy">
                @(_onboardBusy ? "Läuft…" : "Schließen")
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private List<ServerWatch.Models.ServerConfig> _servers = new();
    private bool _showDialog;
    private ServerWatch.Models.ServerConfig? _editingServer;
    private ServerWatch.Models.ServerConfig _form = new();
    private string? _sshKeyFileName;
    private byte[]? _sshKeyData;
    private string _cloudApiKey = "";
    private bool _hasCloudKey;
    private HashSet<string> _testing = new();
    private Dictionary<string, TestResult> _testResults = new();

    private bool _onboarding;
    private bool _onboardBusy;
    private List<string> _onboardLog = new();
    private ServerWatch.Models.ServerConfig? _onboardingServer;

    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add($"Keine Berechtigung — {required} erforderlich (deine Rolle: {_role}).", Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        _servers = ServerConfigService.GetServers();
    }

    private void ShowAddDialog()
    {
        _editingServer = null;
        _form = new ServerWatch.Models.ServerConfig { ConnectionType = ServerWatch.Models.ConnectionType.TCP };
        _sshKeyFileName = null;
        _sshKeyData = null;
        _cloudApiKey = "";
        _hasCloudKey = false;
        _showDialog = true;
    }

    private void EditServer(ServerWatch.Models.ServerConfig server)
    {
        _editingServer = server;
        _form = new ServerWatch.Models.ServerConfig
        {
            Id = server.Id,
            Name = server.Name,
            ConnectionType = server.ConnectionType,
            TcpHost = server.TcpHost,
            TcpPort = server.TcpPort,
            TcpUseTls = server.TcpUseTls,
            SshHost = server.SshHost,
            SshPort = server.SshPort,
            SshUser = server.SshUser,
            SshKeyFileName = server.SshKeyFileName,
            CloudProvider = server.CloudProvider,
            CloudApiKey = server.CloudApiKey,
        };
        _sshKeyFileName = server.SshKeyFileName;
        _sshKeyData = null;
        _cloudApiKey = "";                                  // never prefill the secret
        _hasCloudKey = !string.IsNullOrWhiteSpace(server.CloudApiKey);
        _showDialog = true;
    }

    private async Task SaveServer()
    {
        if (!Require(AppRole.Admin)) return;
        // Resolve the cloud API key: blank field = keep the existing one; clearing the provider clears the key.
        if (_form.CloudProvider == ServerWatch.Models.CloudProvider.None)
            _form.CloudApiKey = null;
        else if (!string.IsNullOrWhiteSpace(_cloudApiKey))
            _form.CloudApiKey = _cloudApiKey.Trim();
        else
            _form.CloudApiKey = _editingServer?.CloudApiKey;   // keep existing (null for new server)

        if (_editingServer != null)
        {
            _form.Id = _editingServer.Id;
            _form.IsDefault = _editingServer.IsDefault;
            _form.Enabled = _editingServer.Enabled;

            if (_sshKeyData != null && _sshKeyFileName != null)
                await ServerConfigService.SaveSshKeyAsync(_form.Id, _sshKeyFileName, _sshKeyData);

            await ServerConfigService.UpdateServerAsync(_form);
            ConnectionManager.InvalidateClient(_form.Id);
            Snackbar.Add($"{_form.Name} aktualisiert", Severity.Success);
        }
        else
        {
            await ServerConfigService.AddServerAsync(_form);

            if (_sshKeyData != null && _sshKeyFileName != null)
                await ServerConfigService.SaveSshKeyAsync(_form.Id, _sshKeyFileName, _sshKeyData);

            Snackbar.Add($"{_form.Name} hinzugefügt", Severity.Success);
        }

        _servers = ServerConfigService.GetServers();
        _showDialog = false;
    }

    private async Task DeleteServer(ServerWatch.Models.ServerConfig server)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Server entfernen",
            $"Server '{server.Name}' wirklich entfernen? Die Verbindung und hinterlegte Zugangsdaten gehen verloren.",
            yesText: "Entfernen", cancelText: "Abbrechen");
        if (confirmed != true) return;
        try
        {
            ConnectionManager.InvalidateClient(server.Id);
            await ServerConfigService.RemoveServerAsync(server.Id);
            _servers = ServerConfigService.GetServers();
            Snackbar.Add($"{server.Name} entfernt", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task TestConnection(ServerWatch.Models.ServerConfig server)
    {
        _testing.Add(server.Id);
        _testResults.Remove(server.Id);
        StateHasChanged();

        try
        {
            var client = await ConnectionManager.GetClientAsync(server.Id);
            var containers = await client.Containers.ListContainersAsync(
                new Docker.DotNet.Models.ContainersListParameters { All = true });
            _testResults[server.Id] = new TestResult { Success = true, ContainerCount = containers.Count };
        }
        catch (Exception ex)
        {
            _testResults[server.Id] = new TestResult { Success = false, Error = ex.Message };
        }
        finally
        {
            _testing.Remove(server.Id);
        }
    }

    private async Task StartOnboarding(ServerWatch.Models.ServerConfig server)
    {
        if (!Require(AppRole.Admin)) return;
        _onboardingServer = server;
        _onboardLog = new();
        _onboarding = true;
        _onboardBusy = true;
        StateHasChanged();

        var progress = new Progress<string>(msg =>
        {
            _onboardLog.Add(msg);
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await Onboarding.OnboardServerAsync(server.Id, progress, CancellationToken.None);
        }
        catch (Exception ex)
        {
            _onboardLog.Add($"❌ {ex.Message}");
        }
        finally
        {
            _onboardBusy = false;
            _servers = ServerConfigService.GetServers();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnSshKeyFileChanged(InputFileChangeEventArgs e)
    {
        var file = e.File;
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 1024 * 100).CopyToAsync(ms);
        _sshKeyData = ms.ToArray();
        _sshKeyFileName = file.Name;
    }

    private class TestResult
    {
        public bool Success { get; set; }
        public int ContainerCount { get; set; }
        public string? Error { get; set; }
    }
}
