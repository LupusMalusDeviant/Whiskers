@page "/services/{ServerId}"
@attribute [Authorize]
@inject ServerWatch.Services.Server.SystemdService SystemdService
@inject ServerWatch.Services.ServerConfig.ServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject ServerWatch.Services.Auth.CurrentUserService CurrentUser

<PageTitle>Dienste - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(""))" />
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.MiscellaneousServices" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Systemdienste</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Systemd-Units starten, stoppen und überwachen</MudText>
        </div>
        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@_serverName</MudChip>
        <MudSpacer />
        <MudTextField @bind-Value="_filter" Placeholder="Filtern..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" />
    </MudStack>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="@FilteredServices" Dense="true" Hover="true" Striped="true" Elevation="2"
              FixedHeader="true" Height="calc(100vh - 250px)">
        <HeaderContent>
            <MudTh>Dienst</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Aktiviert</MudTh>
            <MudTh>Beschreibung</MudTh>
            <MudTh>Aktionen</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudText Style="font-family: monospace;">@context.Name</MudText></MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@GetStateColor(context.ActiveState, context.SubState)"
                         Variant="Variant.Filled">
                    @context.ActiveState/@context.SubState
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Enabled ? Color.Success : Color.Default)"
                         Variant="Variant.Text">
                    @(context.Enabled ? "aktiviert" : "deaktiviert")
                </MudChip>
            </MudTd>
            <MudTd><MudText Typo="Typo.body2">@context.Description</MudText></MudTd>
            <MudTd>
                @if (_role >= AppRole.Admin)
                {
                    @if (context.ActiveState == "active")
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                       title="Stoppen" OnClick="@(() => ManageService(context.Name, "stop"))" />
                        <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small" Color="Color.Info"
                                       title="Neustarten" OnClick="@(() => ManageService(context.Name, "restart"))" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                       title="Starten" OnClick="@(() => ManageService(context.Name, "start"))" />
                    }
                }
                <MudIconButton Icon="@Icons.Material.Filled.Article" Size="Size.Small" Color="Color.Default"
                               title="Protokoll" OnClick="@(() => ShowJournal(context.Name))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog Visible="_showJournal" VisibleChanged="@(v => _showJournal = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
        <TitleContent>Protokoll: @_journalService</TitleContent>
        <DialogContent>
            <MudPaper Style="max-height: 500px; overflow-y: auto; font-family: monospace; font-size: 12px; white-space: pre-wrap; padding: 16px; background: #0d1117;">
                @_journalContent
            </MudPaper>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showJournal = false)">Schließen</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    [Parameter] public string ServerId { get; set; } = "";

    private string _serverName = "";
    private bool _loading = true;
    private string _filter = "";
    private List<ServerWatch.Services.Server.SystemdUnit> _services = new();
    private string? _journalService;
    private string _journalContent = "";
    private bool _showJournal;
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add($"Keine Berechtigung — {required} erforderlich (deine Rolle: {_role}).", Severity.Warning);
            return false;
        }
        return true;
    }

    private IEnumerable<ServerWatch.Services.Server.SystemdUnit> FilteredServices =>
        string.IsNullOrEmpty(_filter)
            ? _services
            : _services.Where(s => s.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                                   || s.Description.Contains(_filter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        var server = ServerConfigService.GetServer(ServerId);
        _serverName = server?.Name ?? ServerId;
        await LoadServices();
    }

    private async Task LoadServices()
    {
        _loading = true;
        try { _services = await SystemdService.ListServicesAsync(ServerId); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _loading = false;
    }

    private async Task ManageService(string name, string action)
    {
        if (!Require(AppRole.Admin)) return;

        // Confirm actions that interrupt a running service.
        var confirmPrompt = action switch
        {
            "stop" => $"Dienst '{name}' stoppen? Der Dienst und alle abhängigen Funktionen werden beendet.",
            "restart" => $"Dienst '{name}' neustarten? Der Dienst wird kurzzeitig unterbrochen.",
            _ => null
        };
        if (confirmPrompt != null)
        {
            var confirmed = await DialogService.ShowMessageBoxAsync(
                "Aktion bestätigen", confirmPrompt, yesText: "Ausführen", cancelText: "Abbrechen");
            if (confirmed != true) return;
        }

        try
        {
            var result = action switch
            {
                "start" => await SystemdService.StartAsync(ServerId, name),
                "stop" => await SystemdService.StopAsync(ServerId, name),
                "restart" => await SystemdService.RestartAsync(ServerId, name),
                _ => throw new ArgumentException($"Unknown action: {action}")
            };
            Snackbar.Add(result.Success ? $"{name}: {action} erfolgreich" : $"{name}: {result.Error}",
                result.Success ? Severity.Success : Severity.Error);
            await LoadServices();
        }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
    }

    private async Task ShowJournal(string name)
    {
        try
        {
            _journalContent = await SystemdService.GetJournalAsync(ServerId, name);
            _journalService = name;
            _showJournal = true;
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private static Color GetStateColor(string active, string sub) => active switch
    {
        "active" when sub == "running" => Color.Success,
        "active" => Color.Info,
        "failed" => Color.Error,
        _ => Color.Default
    };
}
