@page "/cloud"
@attribute [Authorize]
@using ServerWatch.Models
@using ServerWatch.Models.Cloud
@inject ServerWatch.Services.Cloud.CloudControlService CloudControl
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ServerWatch.Services.Auth.CurrentUserService CurrentUser

<PageTitle>Cloud - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Cloud-Steuerung</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Out-of-band Power & Snapshots über Hetzner / Hostinger — Provider pro Server unter „Server" hinterlegen</MudText>
        </div>
    </MudStack>
</div>

<MudStack Row="true" Class="mb-4" Spacing="2">
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAll" Disabled="@_loading">
        Aktualisieren
    </MudButton>
</MudStack>

<MudTable Items="@_servers" Dense="true" Hover="true" Striped="true" Loading="@_loading"
          LoadingProgressColor="Color.Primary" Elevation="2">
    <HeaderContent>
        <MudTh>Server</MudTh>
        <MudTh>Provider</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Typ</MudTh>
        <MudTh>IPv4</MudTh>
        <MudTh>Traffic</MudTh>
        <MudTh>Aktionen</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.ServerWatchName</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Name (#@context.CloudId)</MudText>
        </MudTd>
        <MudTd>@context.Provider</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">@context.Status</MudChip>
        </MudTd>
        <MudTd>@(context.Type ?? "-")</MudTd>
        <MudTd><MudText Typo="Typo.body2" Style="font-family: monospace;">@(context.Ipv4 ?? "-")</MudText></MudTd>
        <MudTd>
            @if (context.Provider == CloudProvider.Hetzner && context.TrafficPercent.HasValue)
            {
                <MudText Typo="Typo.caption">@context.TrafficPercent%</MudText>
            }
            else
            {
                <MudText Typo="Typo.caption">-</MudText>
            }
        </MudTd>
        <MudTd>
            @if (_role >= AppRole.Admin)
            {
                @if (context.Status == "running")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small" Color="Color.Info"
                                   Title="Neustarten" OnClick="@(() => Act(context, "reboot"))" Disabled="@_busy" />
                    <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew" Size="Size.Small" Color="Color.Warning"
                                   Title="Herunterfahren" OnClick="@(() => Act(context, "shutdown"))" Disabled="@_busy" />
                    <MudIconButton Icon="@Icons.Material.Filled.FlashOn" Size="Size.Small" Color="Color.Error"
                                   Title="Hard-Reset (erzwungener Neustart)" OnClick="@(() => Act(context, "reset"))" Disabled="@_busy" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                   Title="Einschalten" OnClick="@(() => Act(context, "poweron"))" Disabled="@_busy" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" Color="Color.Primary"
                               Title="Snapshot erstellen" OnClick="@(() => Act(context, "snapshot"))" Disabled="@_busy" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="pa-4">Kein Server mit konfiguriertem Cloud-Provider. Provider + API-Key pro Server unter <MudLink Href="servers">Server</MudLink> hinterlegen.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<CloudServerInfo> _servers = new();
    private bool _loading = true;
    private bool _busy;
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add($"Keine Berechtigung — {required} erforderlich (deine Rolle: {_role}).", Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        await LoadAll();
    }

    private async Task LoadAll()
    {
        _loading = true;
        try { _servers = await CloudControl.ListAllAsync(); }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task Act(CloudServerInfo s, string action)
    {
        if (!Require(AppRole.Admin)) return;

        // Confirm out-of-band power actions that interrupt the running server.
        var confirmPrompt = action switch
        {
            "reboot" => $"Server '{s.ServerWatchName}' neustarten? Laufende Dienste werden unterbrochen.",
            "shutdown" => $"Server '{s.ServerWatchName}' herunterfahren? Der Server ist danach offline.",
            "reset" => $"Hard-Reset für '{s.ServerWatchName}'? Erzwungener Neustart ohne sauberes Herunterfahren — Datenverlust möglich.",
            _ => null
        };
        if (confirmPrompt != null)
        {
            var confirmed = await DialogService.ShowMessageBoxAsync(
                "Aktion bestätigen", confirmPrompt, yesText: "Ausführen", cancelText: "Abbrechen");
            if (confirmed != true) return;
        }

        _busy = true;
        try
        {
            var msg = action switch
            {
                "poweron" => await CloudControl.PowerOnAsync(s.ServerWatchId),
                "shutdown" => await CloudControl.ShutdownAsync(s.ServerWatchId),
                "reboot" => await CloudControl.RebootAsync(s.ServerWatchId),
                "reset" => await CloudControl.HardResetAsync(s.ServerWatchId),
                "snapshot" => await CloudControl.CreateSnapshotAsync(s.ServerWatchId, $"{s.Name} {DateTime.UtcNow:yyyy-MM-dd HH:mm} UTC"),
                _ => "Unbekannte Aktion"
            };
            Snackbar.Add(msg, Severity.Success);
            await LoadAll();
        }
        catch (Exception ex) { Snackbar.Add($"Fehler ({action}) bei {s.ServerWatchName}: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private static Color GetStatusColor(string status) => status?.ToLowerInvariant() switch
    {
        "running" => Color.Success,
        "off" or "stopped" or "stopping" => Color.Error,
        "starting" or "initializing" => Color.Info,
        _ => Color.Default
    };
}
