@page "/hetzner"
@attribute [Authorize]
@using ServerWatch.Models.Hetzner
@inject ServerWatch.Services.Hetzner.IHetznerService HetznerService
@inject ServerWatch.Services.Hetzner.HetznerConfigService HetznerConfig
@inject ServerWatch.Services.ServerConfig.ServerConfigService ServerConfig
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Hetzner - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Hetzner Cloud</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Cloud-Server überwachen und steuern (out-of-band)</MudText>
        </div>
    </MudStack>
</div>

@if (!HetznerConfig.IsEnabled)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        Hetzner-Integration ist nicht aktiviert. Bitte unter <MudLink Href="settings">Einstellungen</MudLink> ein API-Token hinterlegen.
    </MudAlert>
}
else
{
    @* Summary Cards *@
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Primary" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_servers.Count</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Server</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Success" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_servers.Count(s => s.Status == "running")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Laufend</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.NetworkCheck" Color="Color.Warning" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_servers.Count(s => s.TrafficUsedPercent >= _trafficWarn)</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Traffic-Warnungen</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Backup" Color="Color.Info" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_servers.Count(s => s.BackupsEnabled)</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">mit Backups</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Servers Table *@
    <MudText Typo="Typo.h6" Class="mb-2">Server</MudText>
    <MudTable Items="@_servers" Dense="true" Hover="true" Striped="true" Loading="@_loading"
              LoadingProgressColor="Color.Primary" Elevation="2" Class="mb-6">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Typ</MudTh>
            <MudTh>Standort</MudTh>
            <MudTh>IPv4</MudTh>
            <MudTh>Traffic (ausgehend)</MudTh>
            <MudTh>Backups</MudTh>
            <MudTh>ServerWatch</MudTh>
            <MudTh>Aktionen</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Name</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">#@context.Id</MudText>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">
                    @context.Status
                </MudChip>
                @if (context.RescueEnabled)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">rescue</MudChip>
                }
            </MudTd>
            <MudTd>@(context.ServerType?.Name ?? "-")</MudTd>
            <MudTd>@(context.Datacenter?.Location?.City ?? context.Datacenter?.Location?.Name ?? "-")</MudTd>
            <MudTd><MudText Typo="Typo.body2" Style="font-family: monospace;">@(context.Ipv4 ?? "-")</MudText></MudTd>
            <MudTd>
                <MudStack Spacing="0" Style="min-width: 120px;">
                    <MudProgressLinear Value="@Math.Min(context.TrafficUsedPercent, 100)" Rounded="true"
                                       Color="@(context.TrafficUsedPercent >= _trafficWarn ? Color.Error : Color.Success)" Class="my-1" />
                    <MudText Typo="Typo.caption">@context.TrafficUsedPercent% (@Gb(context.OutgoingTraffic)/@Gb(context.IncludedTraffic))</MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudIcon Icon="@(context.BackupsEnabled ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RemoveCircleOutline)"
                         Color="@(context.BackupsEnabled ? Color.Success : Color.Default)" Size="Size.Small" />
            </MudTd>
            <MudTd>@(LinkedServerName(context) ?? "-")</MudTd>
            <MudTd>
                @if (context.Status == "running")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small" Color="Color.Info"
                                   Title="Neustarten" OnClick="@(() => Do(context, "reboot"))" Disabled="@_actionInProgress" />
                    <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew" Size="Size.Small" Color="Color.Warning"
                                   Title="Herunterfahren (ACPI)" OnClick="@(() => Do(context, "shutdown"))" Disabled="@_actionInProgress" />
                    <MudIconButton Icon="@Icons.Material.Filled.FlashOn" Size="Size.Small" Color="Color.Error"
                                   Title="Hard Reset (power-cycle)" OnClick="@(() => Do(context, "reset"))" Disabled="@_actionInProgress" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                   Title="Einschalten" OnClick="@(() => Do(context, "poweron"))" Disabled="@_actionInProgress" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" Color="Color.Primary"
                               Title="Snapshot erstellen" OnClick="@(() => Snapshot(context))" Disabled="@_actionInProgress" />
                @if (context.BackupsEnabled)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.BackupTable" Size="Size.Small" Color="Color.Default"
                                   Title="Backups deaktivieren" OnClick="@(() => Do(context, "disable_backup"))" Disabled="@_actionInProgress" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Backup" Size="Size.Small" Color="Color.Info"
                                   Title="Backups aktivieren (+20%)" OnClick="@(() => Do(context, "enable_backup"))" Disabled="@_actionInProgress" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">Keine Hetzner-Server gefunden.</MudText>
        </NoRecordsContent>
    </MudTable>

    @* Snapshots Table *@
    @if (_snapshots.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Snapshots</MudText>
        <MudTable Items="@_snapshots" Dense="true" Hover="true" Striped="true" Elevation="2" Class="mb-6">
            <HeaderContent>
                <MudTh>Beschreibung</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Größe</MudTh>
                <MudTh>Quelle</MudTh>
                <MudTh>Erstellt</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.body2">@(context.Description ?? "(ohne Beschreibung)")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">#@context.Id</MudText>
                </MudTd>
                <MudTd>@context.Status</MudTd>
                <MudTd>@(context.ImageSize.HasValue ? $"{context.ImageSize:F1} GB" : "-")</MudTd>
                <MudTd>@(context.CreatedFrom?.Name ?? "-")</MudTd>
                <MudTd>@context.Created</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   Title="Snapshot löschen" OnClick="@(() => DeleteSnapshot(context))" Disabled="@_actionInProgress" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private List<HetznerServer> _servers = new();
    private List<HetznerImage> _snapshots = new();
    private bool _loading = true;
    private bool _actionInProgress;
    private int _trafficWarn = 80;
    private Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        if (!HetznerConfig.IsEnabled) { _loading = false; return; }

        _trafficWarn = HetznerConfig.GetSettings().TrafficWarnPercent;
        await LoadAll();
        _loading = false;
        StateHasChanged();

        var interval = HetznerConfig.GetSettings().PollingIntervalSeconds;
        if (interval > 0)
        {
            _refreshTimer = new Timer(async _ =>
            {
                await LoadAll();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromSeconds(interval), TimeSpan.FromSeconds(interval));
        }
    }

    private async Task LoadAll()
    {
        try
        {
            var serversTask = HetznerService.ListServersAsync();
            var snapsTask = HetznerService.ListSnapshotsAsync();
            await Task.WhenAll(serversTask, snapsTask);
            _servers = serversTask.Result;
            _snapshots = snapsTask.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hetzner-Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task Do(HetznerServer s, string action)
    {
        _actionInProgress = true;
        try
        {
            switch (action)
            {
                case "poweron": await HetznerService.PowerOnAsync(s.Id); break;
                case "shutdown": await HetznerService.ShutdownAsync(s.Id); break;
                case "reboot": await HetznerService.RebootAsync(s.Id); break;
                case "reset": await HetznerService.ResetAsync(s.Id); break;
                case "enable_backup": await HetznerService.EnableBackupsAsync(s.Id); break;
                case "disable_backup": await HetznerService.DisableBackupsAsync(s.Id); break;
            }
            Snackbar.Add($"{s.Name}: Aktion '{action}' ausgelöst.", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler ({action}) bei {s.Name}: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private async Task Snapshot(HetznerServer s)
    {
        _actionInProgress = true;
        try
        {
            var resp = await HetznerService.CreateSnapshotAsync(s.Id, $"{s.Name} {DateTime.UtcNow:yyyy-MM-dd HH:mm} UTC");
            Snackbar.Add($"Snapshot von {s.Name} wird erstellt (#{resp?.Image?.Id}).", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Snapshot-Fehler bei {s.Name}: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private async Task DeleteSnapshot(HetznerImage img)
    {
        _actionInProgress = true;
        try
        {
            await HetznerService.DeleteImageAsync(img.Id);
            Snackbar.Add($"Snapshot #{img.Id} gelöscht.", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Löschen: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private string? LinkedServerName(HetznerServer s)
    {
        if (string.IsNullOrEmpty(s.Ipv4)) return null;
        var match = ServerConfig.GetServers()
            .FirstOrDefault(c => !string.IsNullOrEmpty(c.SshHost) && c.SshHost == s.Ipv4);
        return match?.Name;
    }

    private static Color GetStatusColor(string status) => status?.ToLowerInvariant() switch
    {
        "running" => Color.Success,
        "off" or "stopping" => Color.Error,
        "starting" or "initializing" => Color.Info,
        _ => Color.Default
    };

    private static string Gb(long? bytes) => bytes is null ? "?" : $"{bytes.Value / 1073741824.0:F1} GB";

    public void Dispose() => _refreshTimer?.Dispose();
}
