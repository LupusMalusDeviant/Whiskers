@page "/cves"
@attribute [Authorize]
@using Microsoft.Extensions.Options
@using ServerWatch.Configuration
@using ServerWatch.Models.Cve
@using ServerWatch.Services.Cve
@using ServerWatch.Services.ServerConfig
@inject ICveFindingsStore Store
@inject ICveAgeStore AgeStore
@inject IServerConfigService ServerConfig
@inject ICveMonitorService Monitor
@inject IOptionsMonitor<CveMonitorSettings> SettingsMonitor
@inject ISnackbar Snackbar

<PageTitle>CVE-Monitor — ServerWatch</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" />
        <MudText Typo="Typo.h5">CVE-Monitor</MudText>
        <MudSpacer />

        @if (!SettingsMonitor.CurrentValue.Enabled)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.PauseCircle">
                Monitor deaktiviert (Enabled=false)
            </MudChip>
        }
        @if (Store.IsScanning)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Info">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> Scan läuft …
            </MudChip>
        }
        @if (Store.LastScanAt is { } lastScan)
        {
            <MudText Typo="Typo.body2" Style="color:#888;">Letzter Scan: @lastScan.ToString("yyyy-MM-dd HH:mm 'UTC'")</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Style="color:#888;">Noch kein Scan abgeschlossen</MudText>
        }

        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="RebuildAsync">Aktualisieren</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Search" OnClick="TriggerScan"
                   Disabled="@(Store.IsScanning || !SettingsMonitor.CurrentValue.Enabled)">Jetzt scannen</MudButton>
    </MudStack>

    @* Per-server overview cards *@
    <MudGrid Spacing="2" Class="mb-4">
        @foreach (var srv in _servers)
        {
            var sum = Store.SummarizeServer(srv.Id);
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudPaper Class="pa-3" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle2">@srv.Name</MudText>
                    </MudStack>
                    @if (sum.TotalCount == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color:#888;" Class="mt-1">Keine Findings</MudText>
                    }
                    else
                    {
                        <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                            @if (sum.CriticalCount > 0) { <MudChip T="string" Size="Size.Small" Color="Color.Error">C: @sum.CriticalCount</MudChip> }
                            @if (sum.HighCount > 0) { <MudChip T="string" Size="Size.Small" Color="Color.Warning">H: @sum.HighCount</MudChip> }
                            @if (sum.MediumCount > 0) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">M: @sum.MediumCount</MudChip> }
                            @if (sum.LowCount > 0) { <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">L: @sum.LowCount</MudChip> }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    @* Filter row *@
    <MudPaper Class="pa-3 mb-3" Outlined="true">
        <MudGrid Spacing="2" Class="align-center">
            <MudItem xs="12" sm="3">
                <MudSelect T="string" @bind-Value="_filterServerId" Label="Server" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("")">Alle</MudSelectItem>
                    @foreach (var s in _servers) { <MudSelectItem T="string" Value="@s.Id">@s.Name</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" @bind-Value="_filterMinSeverity" Label="Min. Severity" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("")">Alle</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Critical")">Critical</MudSelectItem>
                    <MudSelectItem T="string" Value="@("High")">High +</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Medium")">Medium +</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Low")">Low +</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" @bind-Value="_filterSource" Label="Quelle" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("")">Beide</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Os")">OS</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Container")">Container</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center">
                <MudSwitch T="bool" @bind-Value="_onlyFixable" Color="Color.Success" Label="Nur fixbar" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField T="string" @bind-Value="_filterSearch" Label="Suche (CVE-ID, Paket, Container, Titel)"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Compute the filtered set once per render instead of re-filtering at each usage below. *@
    @{ var filtered = FilteredGroups(); }
    <MudText Typo="Typo.body2" Style="color:#888;" Class="mb-2">
        @filtered.Count eindeutige CVEs (von @_allGroups.Count gesamt) — eine Zeile pro CVE, aufklappen für betroffene Container/Server.
    </MudText>

    @* One row per CVE; expand to see all affected instances *@
    <MudTable Items="@filtered" Hover="true" Dense="true" Striped="true" Class="mt-1"
              T="CveGroup" OnRowClick="ToggleRow">
        <HeaderContent>
            <MudTh Style="width:32px;"></MudTh>
            <MudTh Style="width:90px;">Severity</MudTh>
            <MudTh>CVE-ID</MudTh>
            <MudTh Style="width:150px;">Betroffen</MudTh>
            <MudTh Style="width:150px;">Offen seit</MudTh>
            <MudTh Style="width:90px;">Fix</MudTh>
            <MudTh>Titel</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIcon Icon="@(_expanded.Contains(context.CveId) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@SeverityColor(context.Severity)">@context.Severity</MudChip>
            </MudTd>
            <MudTd Style="font-family:monospace;">
                @if (!string.IsNullOrEmpty(context.Reference))
                {
                    <MudLink Href="@context.Reference" Target="_blank" @onclick:stopPropagation="true">@context.CveId</MudLink>
                }
                else { @context.CveId }
                @if (!context.IsVerified)
                {
                    <MudTooltip Text="Pending Security-Update ohne aufgelöste CVE-ID (niedrigere Konfidenz)">
                        <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" Style="vertical-align:middle; color:#888; margin-left:4px;" />
                    </MudTooltip>
                }
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    @if (context.ContainerCount > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Icon="@Icons.Material.Filled.Inventory2">@context.ContainerCount</MudChip>
                    }
                    @if (context.Affected.Any(a => a.Source == CveSource.Os))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Dns">OS</MudChip>
                    }
                    <MudTooltip Text="@($"{context.InstanceCount} Instanz(en) auf {context.ServerCount} Server")">
                        <MudText Typo="Typo.caption" Style="color:#888;">@context.ServerCount Srv</MudText>
                    </MudTooltip>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudTooltip Text="@PublishedLabel(context.PublishedDate)">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@AgeColor(context.OpenFor)">@AgeLabel(context.OpenFor)</MudChip>
                </MudTooltip>
            </MudTd>
            <MudTd>
                @if (context.HasFix)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">fixbar</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="color:#888;">kein Fix</MudChip>
                }
            </MudTd>
            <MudTd>@TruncateTitle(context.Title)</MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (_expanded.Contains(context.CveId))
            {
                <MudTr>
                    <td colspan="7" style="background:rgba(255,255,255,0.02); padding:0;">
                        <div class="pa-3">
                            <MudText Typo="Typo.subtitle2" Class="mb-1">Betroffene Instanzen (@context.InstanceCount)</MudText>
                            <MudSimpleTable Dense="true" Striped="true" Style="background:transparent;">
                                <thead>
                                    <tr><th>Server</th><th>OS</th><th>Ziel</th><th>Paket</th><th>Installiert → Fix</th><th>Verifiziert</th><th>Offen seit</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in context.Affected.OrderBy(a => a.ServerName).ThenBy(a => a.TargetLabel))
                                    {
                                        <tr>
                                            <td>@a.ServerName</td>
                                            <td>@(string.IsNullOrEmpty(a.Os) ? "—" : a.Os)</td>
                                            <td>
                                                @if (a.Source == CveSource.Os)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">OS</MudChip>
                                                }
                                                else
                                                {
                                                    <span><code>@a.TargetLabel</code> <span style="color:#888;">@a.Image</span></span>
                                                }
                                            </td>
                                            <td style="font-family:monospace;">@a.Package</td>
                                            <td style="font-family:monospace; font-size:0.85em;">@(a.InstalledVersion ?? "?") → @(string.IsNullOrEmpty(a.FixedVersion) ? "(kein Fix)" : a.FixedVersion)</td>
                                            <td>
                                                @if (a.Verified)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Small" Title="Installierte Paketversion gematcht" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" Style="color:#888;" Title="Pending Update ohne CVE-ID" />
                                                }
                                            </td>
                                            <td>@AgeLabel(DateTime.UtcNow - a.FirstSeenUtc)</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </div>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
        <NoRecordsContent>
            <MudText Typo="Typo.body2">Keine CVEs (oder Filter passt nichts).</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[]{ 25, 50, 100, 250 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private List<ServerWatch.Models.ServerConfig> _servers = new();
    private IReadOnlyList<CveGroup> _allGroups = Array.Empty<CveGroup>();
    private readonly HashSet<string> _expanded = new();

    private string _filterServerId = "";
    private string _filterMinSeverity = "";
    private string _filterSource = "";
    private string _filterSearch = "";
    private bool _onlyFixable;

    protected override async Task OnInitializedAsync()
    {
        _servers = ServerConfig.GetServers();
        await RebuildAsync();
    }

    private async Task RebuildAsync()
    {
        var firstSeen = await AgeStore.GetFirstSeenAsync();
        var names = _servers.ToDictionary(s => s.Id, s => s.Name);
        _allGroups = Store.BuildGroups(firstSeen, names);
        StateHasChanged();
    }

    private void ToggleRow(TableRowClickEventArgs<CveGroup> args)
    {
        var id = args.Item?.CveId;
        if (id is null) return;
        if (!_expanded.Add(id)) _expanded.Remove(id);
    }

    private List<CveGroup> FilteredGroups()
    {
        IEnumerable<CveGroup> q = _allGroups;

        if (!string.IsNullOrEmpty(_filterServerId))
            q = q.Where(g => g.Affected.Any(a => a.ServerId == _filterServerId));

        if (!string.IsNullOrEmpty(_filterMinSeverity) && Enum.TryParse<CveSeverity>(_filterMinSeverity, true, out var minSev))
            q = q.Where(g => g.Severity >= minSev);

        if (!string.IsNullOrEmpty(_filterSource) && Enum.TryParse<CveSource>(_filterSource, true, out var src))
            q = q.Where(g => g.Affected.Any(a => a.Source == src));

        if (_onlyFixable)
            q = q.Where(g => g.HasFix);

        if (!string.IsNullOrWhiteSpace(_filterSearch))
        {
            var n = _filterSearch.Trim();
            q = q.Where(g =>
                g.CveId.Contains(n, StringComparison.OrdinalIgnoreCase) ||
                (g.Title?.Contains(n, StringComparison.OrdinalIgnoreCase) ?? false) ||
                g.Affected.Any(a =>
                    a.Package.Contains(n, StringComparison.OrdinalIgnoreCase) ||
                    (a.ContainerName?.Contains(n, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (a.Os?.Contains(n, StringComparison.OrdinalIgnoreCase) ?? false)));
        }

        return q.ToList();
    }

    private static string AgeLabel(TimeSpan age)
    {
        var d = (int)age.TotalDays;
        if (d <= 0) return "heute";
        if (d == 1) return "1 Tag";
        if (d < 30) return $"{d} Tage";
        if (d < 365) return $"{d / 30} Mon.";
        return $"{d / 365} J. {(d % 365) / 30} Mon.";
    }

    private static Color AgeColor(TimeSpan age) => age.TotalDays switch
    {
        >= 90 => Color.Error,
        >= 30 => Color.Warning,
        _ => Color.Default,
    };

    private static string PublishedLabel(DateTime? d) =>
        d is null ? "Veröffentlichung unbekannt" : $"CVE veröffentlicht: {d.Value:yyyy-MM-dd}";

    private static string? TruncateTitle(string? title) =>
        title is null ? null : (title.Length <= 80 ? title : title[..80] + "…");

    private static Color SeverityColor(CveSeverity s) => s switch
    {
        CveSeverity.Critical => Color.Error,
        CveSeverity.High => Color.Warning,
        CveSeverity.Medium => Color.Info,
        CveSeverity.Low => Color.Default,
        _ => Color.Default
    };

    private Task TriggerScan()
    {
        if (Store.IsScanning) return Task.CompletedTask;
        Snackbar.Add("CVE-Scan gestartet — kann beim ersten Lauf mehrere Minuten dauern (Trivy-DB-Download).", Severity.Info);
        _ = Task.Run(async () =>
        {
            try { await Monitor.RunOneCycleAsync(); }
            catch (Exception ex) { Console.Error.WriteLine($"Manual CVE scan failed: {ex.Message}"); }
        });
        return Task.CompletedTask;
    }
}
