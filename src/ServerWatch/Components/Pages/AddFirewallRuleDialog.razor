@inject ServerWatch.Services.Server.IFirewallService FirewallService
@inject ISnackbar Snackbar
@inject ServerWatch.Services.Auth.ICurrentUserService CurrentUser
@inject ServerWatch.Services.AuditLog.IAuditLogService AuditLog

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_port" Label="Port" Placeholder="80 oder 8000:9000" Required="true" />
            <MudSelect @bind-Value="_protocol" Label="Protokoll">
                <MudSelectItem Value="@("tcp")">TCP</MudSelectItem>
                <MudSelectItem Value="@("udp")">UDP</MudSelectItem>
                <MudSelectItem Value="@("any")">Beide</MudSelectItem>
            </MudSelect>
            <MudSelect @bind-Value="_action" Label="Aktion">
                <MudSelectItem Value="@("allow")">Erlauben</MudSelectItem>
                <MudSelectItem Value="@("deny")">Verweigern</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_from" Label="Von (optional)" Placeholder="192.168.1.0/24" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@_submitting">
            @if (_submitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Regel hinzufügen
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public string ServerId { get; set; } = "";

    private string _port = "";
    private string _protocol = "tcp";
    private string _action = "allow";
    private string? _from;
    private bool _submitting;

    private void Cancel() => MudDialog?.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_port)) return;
        _submitting = true;
        try
        {
            var result = await FirewallService.AddRuleAsync(ServerId, _port, _protocol, _action,
                string.IsNullOrWhiteSpace(_from) ? null : _from);
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            var ruleDesc = $"{_action} {_port}/{_protocol}" + (string.IsNullOrWhiteSpace(_from) ? "" : $" from {_from}");
            await AuditLog.LogAsync(actor, "web", "firewall.add", "firewall", ruleDesc, ruleDesc, serverId: ServerId, success: result.Success);
            if (result.Success)
            {
                Snackbar.Add("Regel hinzugefügt", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
                Snackbar.Add($"Fehler: {result.Error}", Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _submitting = false;
    }
}
