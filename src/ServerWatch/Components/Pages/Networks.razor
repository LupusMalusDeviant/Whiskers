@page "/networks"
@attribute [Authorize]
@inject IDockerService DockerService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ServerWatch.Services.Auth.CurrentUserService CurrentUser

<PageTitle>Netzwerke - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Docker-Netzwerke</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Netzwerke erstellen und Container verbinden</MudText>
        </div>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="ShowCreateDialog">Netzwerk erstellen</MudButton>
        }
        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadNetworks">Aktualisieren</MudButton>
    </MudStack>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @foreach (var group in _networks.GroupBy(n => n.ServerName))
    {
        <MudText Typo="Typo.subtitle1" Class="mb-2 mt-4">@group.Key</MudText>
        <MudTable Items="@group.ToList()" Dense="true" Hover="true" Striped="true" Elevation="2" Class="mb-4">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Treiber</MudTh>
                <MudTh>Scope</MudTh>
                <MudTh>Subnet</MudTh>
                <MudTh>Container</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><code>@context.Name</code></MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@(context.Driver == "bridge" ? Color.Primary : context.Driver == "overlay" ? Color.Tertiary : Color.Default)">
                        @context.Driver
                    </MudChip>
                    @if (context.Internal)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">intern</MudChip>
                    }
                </MudTd>
                <MudTd>@context.Scope</MudTd>
                <MudTd Style="font-family: monospace;">@(string.IsNullOrEmpty(context.Subnet) ? "-" : context.Subnet)</MudTd>
                <MudTd>
                    @if (context.Containers.Any())
                    {
                        <MudTooltip>
                            <ChildContent>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Containers.Count</MudChip>
                            </ChildContent>
                            <TooltipContent>
                                @foreach (var c in context.Containers)
                                {
                                    <div>@c.Name (@c.IPv4Address)</div>
                                }
                            </TooltipContent>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Style="color: #888;">0</MudText>
                    }
                </MudTd>
                <MudTd>
                    @if (!IsSystemNetwork(context.Name) && _role >= AppRole.Admin)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteNetwork(context))" title="Löschen" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

<MudDialog Visible="_showCreateDialog" VisibleChanged="@(v => _showCreateDialog = v)" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Netzwerk erstellen</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_newNetworkName" Label="Name" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect @bind-Value="_newNetworkDriver" Label="Treiber" Variant="Variant.Outlined">
                <MudSelectItem Value="@("bridge")">bridge</MudSelectItem>
                <MudSelectItem Value="@("overlay")">overlay</MudSelectItem>
                <MudSelectItem Value="@("macvlan")">macvlan</MudSelectItem>
            </MudSelect>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showCreateDialog = false)">Abbrechen</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateNetwork"
                       Disabled="@string.IsNullOrWhiteSpace(_newNetworkName)">Erstellen</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    private List<ServerWatch.Models.NetworkInfo> _networks = new();
    private bool _loading = true;
    private bool _showCreateDialog;
    private string _newNetworkName = "";
    private string _newNetworkDriver = "bridge";
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add($"Keine Berechtigung — {required} erforderlich (deine Rolle: {_role}).", Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        await LoadNetworks();
    }

    private async Task LoadNetworks()
    {
        _loading = true;
        try
        {
            _networks = (await DockerService.ListNetworksAsync()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        _loading = false;
    }

    private void ShowCreateDialog()
    {
        _newNetworkName = "";
        _newNetworkDriver = "bridge";
        _showCreateDialog = true;
    }

    private async Task CreateNetwork()
    {
        if (!Require(AppRole.Admin)) return;
        try
        {
            await DockerService.CreateNetworkAsync(_newNetworkName, _newNetworkDriver);
            Snackbar.Add($"Netzwerk '{_newNetworkName}' erstellt.", Severity.Success);
            _showCreateDialog = false;
            await LoadNetworks();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteNetwork(ServerWatch.Models.NetworkInfo network)
    {
        if (!Require(AppRole.Admin)) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Netzwerk löschen",
            $"Netzwerk '{network.Name}' wirklich löschen? Verbundene Container verlieren diese Netzwerkverbindung.",
            yesText: "Löschen", cancelText: "Abbrechen");
        if (confirmed != true) return;
        try
        {
            await DockerService.RemoveNetworkAsync(network.Id, network.ServerId == "local" ? null : network.ServerId);
            Snackbar.Add($"Netzwerk '{network.Name}' gelöscht.", Severity.Success);
            await LoadNetworks();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private static bool IsSystemNetwork(string name) =>
        name is "bridge" or "host" or "none";
}
