@page "/login"
@layout ServerWatch.Components.Layout.MainLayout
@inject IConfiguration Config
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 80vh;">
    <MudPaper Elevation="4" Class="pa-8 mx-auto" Style="width: 100%; max-width: 400px;">
        <div class="d-flex flex-column align-center">
            <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
            <MudText Typo="Typo.h4" Class="mb-2">ServerWatch</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
                Container-Verwaltung
            </MudText>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4 mud-width-full">
                    @(_error == "unauthorized" ? "Ihre E-Mail ist nicht autorisiert, auf diese Anwendung zuzugreifen." : _error)
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       FullWidth="true" Href="login-google"
                       StartIcon="@Icons.Material.Filled.Login">
                Mit Google anmelden
            </MudButton>
        </div>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? _error { get; set; }

    protected override void OnInitialized()
    {
        // When auth is disabled for LAN deployments, there is no login flow —
        // send users straight to the dashboard.
        if (Config.GetValue<bool>("Auth:Disabled"))
        {
            Nav.NavigateTo("/", forceLoad: false);
        }
    }
}
