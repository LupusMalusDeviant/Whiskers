    private async Task OnQbTableChanged(string? table)
    {
        _qbTable = table;
        _qbTableColumns.Clear();
        _qbSetFields.Clear();
        _qbColumnsText = "";
        _qbWhere = "";
        _qbOrderBy = null;

        if (table != null && _dbCreds != null && _container != null && _dbSelectedDatabase != null)
        {
            var schema = await DatabaseService.GetSchemaAsync(ContainerId, _dbSelectedDatabase, table, _container.DatabaseType, _dbCreds, _resolvedServerId);
            _qbTableColumns = schema.Select(c => c.Name).ToList();
            _qbSetFields = schema.Select(c => (c.Name, "")).ToList();
        }
    }

    private string? BuildQueryFromBuilder()
    {
        if (string.IsNullOrEmpty(_qbTable)) return null;

        var where = !string.IsNullOrWhiteSpace(_qbWhere) ? $" WHERE {_qbWhere}" : "";
        var orderBy = !string.IsNullOrEmpty(_qbOrderBy) ? $" ORDER BY {_qbOrderBy} {(_qbOrderDesc ? "DESC" : "ASC")}" : "";

        return _qbAction switch
        {
            "SELECT" => $"SELECT {(!string.IsNullOrWhiteSpace(_qbColumnsText) ? _qbColumnsText.Trim() : "*")} FROM {_qbTable}{where}{orderBy} LIMIT {_qbLimit}",
            "COUNT" => $"SELECT COUNT(*) AS total FROM {_qbTable}{where}",
            "INSERT" => BuildInsertSql(),
            "UPDATE" => BuildUpdateSql(where),
            "DELETE" => $"DELETE FROM {_qbTable}{where}",
            _ => null
        };
    }

    private string? BuildInsertSql()
    {
        var filled = _qbSetFields.Where(f => !string.IsNullOrWhiteSpace(f.Value)).ToList();
        if (!filled.Any()) return null;
        var cols = string.Join(", ", filled.Select(f => f.Key));
        var vals = string.Join(", ", filled.Select(f => $"'{f.Value.Replace("'", "''")}'"));
        return $"INSERT INTO {_qbTable} ({cols}) VALUES ({vals})";
    }

    private string? BuildUpdateSql(string where)
    {
        var filled = _qbSetFields.Where(f => !string.IsNullOrWhiteSpace(f.Value)).ToList();
        if (!filled.Any()) return null;
        var sets = string.Join(", ", filled.Select(f => $"{f.Key} = '{f.Value.Replace("'", "''")}'"));
        return $"UPDATE {_qbTable} SET {sets}{where}";
    }

    private async Task ExecuteBuilderQuery()
    {
        var sql = BuildQueryFromBuilder();
        if (string.IsNullOrEmpty(sql)) return;
        _dbQuery = sql;
        await ExecuteQuery();
    }

