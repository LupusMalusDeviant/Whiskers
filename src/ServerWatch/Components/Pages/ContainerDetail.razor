    private async Task LoadContainer()
    {
        try
        {
            if (string.IsNullOrEmpty(ServerId) && _discoveredServerId == null && !_crossServerSearched)
            {
                // No server in the route → search every server once to locate the container,
                // then pin _discoveredServerId so later refreshes hit only that server.
                _crossServerSearched = true;
                var all = await DockerService.ListAllContainersAsync();
                var match = all.FirstOrDefault(c => c.Id == ContainerId)
                            ?? all.FirstOrDefault(c => MatchesId(c.Id, ContainerId));
                if (match != null)
                {
                    _discoveredServerId = match.ServerId;
                    _container = match;
                }
            }
            else
            {
                var containers = await DockerService.ListContainersAsync(serverId: _resolvedServerId);
                _container = containers.FirstOrDefault(c => c.Id == ContainerId)
                             ?? containers.FirstOrDefault(c => MatchesId(c.Id, ContainerId));
            }

            if (_container?.State == "running")
            {
                _stats = await DockerService.GetContainerStatsAsync(ContainerId, _resolvedServerId);
            }
            else
            {
                _stats = null;
            }
        }
        catch { }
    }

