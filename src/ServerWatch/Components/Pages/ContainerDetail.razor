    private async Task ExecuteMigrationFile()
    {
        if (!Require(AppRole.Admin)) return;
        if (_migrationFileData == null || _container == null || _dbCreds == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "SQL-Datei ausführen",
            $"Datei '{_migrationFileName}' gegen die Datenbank ausführen? Dies verändert Daten/Schema.",
            yesText: "Ausführen", cancelText: "Abbrechen");
        if (confirmed != true) return;
        _dbMigrating = true; _migrationOutput = null;
        try
        {
            var b64 = Convert.ToBase64String(_migrationFileData);
            var db = _dbSelectedDatabase ?? _dbCreds.Database;
            var cmd = _container.DatabaseType switch
            {
                DatabaseType.PostgreSQL => $"echo '{b64}' | base64 -d | PGPASSWORD={Quote(_dbCreds.Password)} psql -U {Quote(_dbCreds.User)} -d {Quote(db)} 2>&1",
                DatabaseType.MySQL => $"echo '{b64}' | base64 -d | MYSQL_PWD={Quote(_dbCreds.Password)} mysql -u {Quote(_dbCreds.User)} {Quote(db)} 2>&1",
                _ => "echo 'Nicht unterstützt'"
            };
            var result = await ExecInContainerViaHost(new[] { "sh", "-c", cmd }, TimeSpan.FromMinutes(5));
            _migrationOutput = string.IsNullOrWhiteSpace(result.StdOut) ? "Erfolgreich ausgeführt." : result.StdOut;
            _migrationSuccess = result.ExitCode == 0;
            if (_migrationSuccess) await LoadDatabaseInfo();
        }
        catch (Exception ex) { _migrationOutput = ex.Message; _migrationSuccess = false; }
        finally { _dbMigrating = false; }
    }

    private async Task OnSeedFileSelected(InputFileChangeEventArgs e)
    {
        using var ms = new System.IO.MemoryStream();
        await e.File.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024).CopyToAsync(ms);
        _seedFileData = ms.ToArray();
        _seedFileName = e.File.Name;
    }

    private async Task ExecuteSeedFile()
    {
        if (!Require(AppRole.Admin)) return;
        if (_seedFileData == null || _container == null || _dbCreds == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Daten importieren",
            $"Datei '{_seedFileName}' in die Datenbank importieren?",
            yesText: "Importieren", cancelText: "Abbrechen");
        if (confirmed != true) return;
        _dbSeeding = true; _seedOutput = null;
        try
        {
            var b64 = Convert.ToBase64String(_seedFileData);
            var db = _dbSelectedDatabase ?? _dbCreds.Database;
            var ext = System.IO.Path.GetExtension(_seedFileName)?.ToLower();
            var cmd = (_container.DatabaseType, ext) switch
            {
                (DatabaseType.PostgreSQL, ".sql") => $"echo '{b64}' | base64 -d | PGPASSWORD={Quote(_dbCreds.Password)} psql -U {Quote(_dbCreds.User)} -d {Quote(db)} 2>&1",
                (DatabaseType.PostgreSQL, ".csv") => $"echo '{b64}' | base64 -d > /tmp/seed.csv && PGPASSWORD={Quote(_dbCreds.Password)} psql -U {Quote(_dbCreds.User)} -d {Quote(db)} -c \"\\COPY (SELECT 1) FROM '/tmp/seed.csv' CSV HEADER\" 2>&1 || echo 'CSV-Import: Bitte Tabellennamen im Query-Editor angeben'",
                (DatabaseType.MySQL, ".sql") => $"echo '{b64}' | base64 -d | MYSQL_PWD={Quote(_dbCreds.Password)} mysql -u {Quote(_dbCreds.User)} {Quote(db)} 2>&1",
                (DatabaseType.MongoDB, ".json") => $"echo '{b64}' | base64 -d > /tmp/seed.json && mongoimport --db {Quote(db)} --file /tmp/seed.json 2>&1",
                _ => $"echo '{b64}' | base64 -d | head -c 100 && echo '... Dateiformat {ext} wird für {_container.DatabaseType} unterstützt via SQL-Pipe'"
            };
            var result = await ExecInContainerViaHost(new[] { "sh", "-c", cmd }, TimeSpan.FromMinutes(5));
            _seedOutput = string.IsNullOrWhiteSpace(result.StdOut) ? "Erfolgreich importiert." : result.StdOut;
            _seedSuccess = result.ExitCode == 0;
            if (_seedSuccess) { _dbLoaded = false; await LoadDatabaseInfo(); }
        }
        catch (Exception ex) { _seedOutput = ex.Message; _seedSuccess = false; }
        finally { _dbSeeding = false; }
    }

    private async Task ExecuteQuery()
    {
        if (!Require(AppRole.Operator)) return;
        if (string.IsNullOrWhiteSpace(_dbQuery) || _dbCreds == null || _container == null) return;
        _dbExecuting = true;
        _dbResult = null;

        try
        {
            var creds = new ServerWatch.Models.DatabaseCredentials
            {
                User = _dbCreds.User,
                Password = _dbCreds.Password,
                Database = _dbSelectedDatabase ?? _dbCreds.Database
            };
            _dbResult = await DatabaseService.ExecuteQueryAsync(ContainerId, _dbQuery, _container.DatabaseType, creds, _resolvedServerId);
        }
        catch (Exception ex)
        {
            _dbResult = new ServerWatch.Models.QueryResult { Error = ex.Message };
        }
        finally
        {
            _dbExecuting = false;
        }
    }

    private async Task BackupDatabase()
    {
        if (!Require(AppRole.Admin)) return;
        if (_dbCreds == null || _container == null) return;
        _dbBackingUp = true;

        try
        {
            var db = _dbSelectedDatabase ?? _dbCreds.Database;
            var (success, filePath, size, error) = await DatabaseService.BackupDatabaseAsync(
                ContainerId, db, _container.DatabaseType, _dbCreds, _resolvedServerId);

            if (success)
                Snackbar.Add($"Backup erstellt: {filePath} ({size / 1024}KB)", Severity.Success);
            else
                Snackbar.Add($"Backup fehlgeschlagen: {error}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally
        {
            _dbBackingUp = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Dispose();
        _termCts?.Cancel();
        try
        {
            if (_termSession != null)
                await SessionManager.DestroySession(_termSession.SessionId);
            await JS.InvokeVoidAsync("ServerWatch.Terminal.dispose", "container-terminal");
        }
        catch { }
        _dotNetRef?.Dispose();
        _termCts?.Dispose();
    }
}
