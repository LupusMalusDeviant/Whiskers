    // Run a command in the container via `docker exec` on the HOST shell plane (nsenter/SSH) instead of
    // the Docker API exec endpoint: the mTLS socket-proxy blocks container exec (EXEC=0), but the host's
    // own docker.sock has full access, so this works uniformly on Local, SSH and TCP+mTLS servers.
    private async Task<(string StdOut, string StdErr, int ExitCode)> ExecInContainerViaHost(string[] cmd, TimeSpan timeout)
    {
        var dockerCmd = "docker exec " + ServerWatch.Utils.ShellUtils.Quote(ContainerId) + " " +
                        string.Join(' ', cmd.Select(ServerWatch.Utils.ShellUtils.Quote));
        var r = await HostCommandExecutor.ExecuteAsync(_resolvedServerId ?? "local", dockerCmd, timeout);
        return (r.Output, r.Error, r.ExitCode);
    }

    private async Task RunMigration()
    {
        if (!Require(AppRole.Admin)) return;
        if (_container == null || _dbCreds == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Migration ausführen",
            "Datenbank-Migrationen ausführen? Dies verändert das Datenbankschema.",
            yesText: "Ausführen", cancelText: "Abbrechen");
        if (confirmed != true) return;
        _dbMigrating = true; _migrationOutput = null;
        try
        {
            // Try artisan migrate (Laravel)
            var result = await ExecInContainerViaHost(new[] { "sh", "-c", "which php && php artisan migrate --force 2>&1 || echo 'NO_ARTISAN'" }, TimeSpan.FromMinutes(2));
            if (!result.StdOut.Contains("NO_ARTISAN"))
            {
                _migrationOutput = result.StdOut; _migrationSuccess = result.ExitCode == 0;
            }
            else
            {
                // Fallback: plain SQL via psql/mysql
                _migrationOutput = "Kein Framework erkannt. Nutze die SQL-Datei Upload-Funktion.";
                _migrationSuccess = false;
            }
        }
        catch (Exception ex) { _migrationOutput = ex.Message; _migrationSuccess = false; }
        finally { _dbMigrating = false; }
    }

    private async Task RollbackMigration()
    {
        if (!Require(AppRole.Admin)) return;
        if (_container == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Migration zurückrollen",
            "Letzte Migration zurückrollen? Dies kann zu Datenverlust führen.",
            yesText: "Rollback", cancelText: "Abbrechen");
        if (confirmed != true) return;
        _dbMigrating = true; _migrationOutput = null;
        try
        {
            var result = await ExecInContainerViaHost(new[] { "sh", "-c", "which php && php artisan migrate:rollback --force 2>&1 || echo 'NO_ARTISAN'" }, TimeSpan.FromMinutes(2));
            _migrationOutput = result.StdOut.Contains("NO_ARTISAN") ? "Kein Framework erkannt." : result.StdOut;
            _migrationSuccess = result.ExitCode == 0 && !result.StdOut.Contains("NO_ARTISAN");
        }
        catch (Exception ex) { _migrationOutput = ex.Message; _migrationSuccess = false; }
        finally { _dbMigrating = false; }
    }

    private async Task CheckMigrationStatus()
    {
        if (!Require(AppRole.Operator)) return;
