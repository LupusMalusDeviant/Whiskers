    private async Task LoadEnvVars()
    {
        try
        {
            // 1. Get running container env vars
            _containerEnv = await DockerService.GetContainerEnvAsync(ContainerId, _resolvedServerId);

            // 2. Detect compose working dir from labels
            _composeWorkingDir = null;
            if (_container?.Labels.TryGetValue("com.docker.compose.project.working_dir", out var workDir) == true)
            {
                _composeWorkingDir = workDir;
            }
            else if (_container?.ComposeProject is { } project && project != "Standalone")
            {
                // Fallback: check standard deployment path
                var sid = _resolvedServerId ?? "local";
                var checkResult = await HostCommandExecutor.ExecuteAsync(sid,
                    $"test -f /opt/deployments/{Quote(project)}/docker-compose.yml && echo /opt/deployments/{Quote(project)}",
                    TimeSpan.FromSeconds(5));
                if (checkResult.Success && !string.IsNullOrWhiteSpace(checkResult.Output))
                    _composeWorkingDir = checkResult.Output.Trim();
            }

            // 3. Load .env file if compose project found
            if (_composeWorkingDir != null)
            {
                var sid = _resolvedServerId ?? "local";
                var result = await HostCommandExecutor.ExecuteAsync(sid,
                    $"cat {Quote(_composeWorkingDir + "/.env")} 2>/dev/null",
                    TimeSpan.FromSeconds(5));

                _dotEnvEntries.Clear();
                _dotEnvError = null;

                if (result.Success && !string.IsNullOrWhiteSpace(result.Output))
                {
                    foreach (var line in result.Output.Split('\n'))
                    {
                        var trimmed = line.Trim();
                        if (string.IsNullOrEmpty(trimmed) || trimmed.StartsWith('#'))
                            continue;

                        var idx = trimmed.IndexOf('=');
                        if (idx > 0)
                        {
                            var key = trimmed[..idx];
                            var val = trimmed[(idx + 1)..];
                            _dotEnvEntries.Add(new EnvEntry
                            {
                                Key = key,
                                Value = "",
                                OriginalValue = val,
                                IsNew = false,
                                IsEditing = false,
                                IsSensitive = IsSensitiveKey(key)
                            });
                        }
                    }
                }
                else
                {
                    _dotEnvError = "Keine .env-Datei gefunden. Sie können eine neue erstellen.";
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Laden der Umgebungsvariablen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _envLoaded = true;
        }
    }

    private async Task SaveEnvAndRestart()
    {
        if (!Require(AppRole.Admin)) return;
        if (_composeWorkingDir == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Umgebungsvariablen speichern",
            "Die .env-Datei wird überschrieben und der Container neu gestartet. Fortfahren?",
            yesText: "Speichern & Neustart", cancelText: "Abbrechen");
        if (confirmed != true) return;
        _envSaving = true;

        try
        {
            var sid = _resolvedServerId ?? "local";

            // Build .env content
            var sb = new System.Text.StringBuilder();
            foreach (var entry in _dotEnvEntries)
            {
                if (!string.IsNullOrWhiteSpace(entry.Key))
                    sb.AppendLine($"{entry.Key}={entry.EffectiveValue}");
            }

            // Write .env file via base64 to avoid escaping issues
            var b64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(sb.ToString()));
            var writeResult = await HostCommandExecutor.ExecuteAsync(sid,
                $"echo '{b64}' | base64 -d > {Quote(_composeWorkingDir + "/.env")}",
                TimeSpan.FromSeconds(10));

            if (!writeResult.Success)
            {
                Snackbar.Add($"Fehler beim Schreiben: {writeResult.Error}", Severity.Error);
                return;
            }

            // Restart via docker compose
            var restartResult = await HostCommandExecutor.ExecuteAsync(sid,
                $"cd {Quote(_composeWorkingDir)} && docker compose up -d 2>&1",
                TimeSpan.FromMinutes(2));

            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            var name = _container?.Name ?? ContainerId;
            if (restartResult.Success)
            {
                await AuditLog.LogAsync(actor, "web", "env.save", "env", ContainerId, name, serverId: _resolvedServerId);
                Snackbar.Add("Umgebungsvariablen gespeichert und Container neu gestartet.", Severity.Success);
                // Reload env vars and container state
                _envLoaded = false;
                await LoadContainer();
                await LoadEnvVars();
            }
            else
            {
                await AuditLog.LogAsync(actor, "web", "env.save", "env", ContainerId, name, details: "Neustart fehlgeschlagen", serverId: _resolvedServerId, success: false);
                Snackbar.Add($"Fehler beim Neustart: {restartResult.Output}\n{restartResult.Error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally
        {
            _envSaving = false;
        }
    }

    // === CSV Download ===

    private async Task DownloadCsv()
    {
        if (_dbResult == null || !_dbResult.Columns.Any()) return;

        var sb = new System.Text.StringBuilder();

        // Header
        sb.AppendLine(string.Join(",", _dbResult.Columns.Select(EscapeCsvField)));

        // Rows — no limit
        foreach (var row in _dbResult.Rows)
        {
            sb.AppendLine(string.Join(",", row.Select(EscapeCsvField)));
        }

        var csv = sb.ToString();
        var fileName = $"query_{(_dbSelectedDatabase ?? "db")}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";

        // Trigger download via JS
        await JS.InvokeVoidAsync("ServerWatch.downloadCsv", fileName, csv);
    }

    private static string EscapeCsvField(string field)
    {
        if (string.IsNullOrEmpty(field)) return "\"\"";
        if (field.Contains(',') || field.Contains('"') || field.Contains('\n') || field.Contains('\r'))
            return $"\"{field.Replace("\"", "\"\"")}\"";
        return field;
    }

