@page "/nginx/{ServerId}"
@attribute [Authorize]
@inject ServerWatch.Services.Server.NginxService NginxService
@inject ServerWatch.Services.ServerConfig.ServerConfigService ServerConfigService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject ServerWatch.Services.Auth.CurrentUserService CurrentUser

<PageTitle>Nginx - ServerWatch</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(""))" />
    <MudText Typo="Typo.h5">Nginx-Seiten</MudText>
    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@_serverName</MudChip>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Variant="Variant.Outlined"
               OnClick="TestConfig">Konfiguration testen</MudButton>
    @if (_role >= AppRole.Admin)
    {
        <MudButton StartIcon="@Icons.Material.Filled.Refresh" Color="Color.Info" Variant="Variant.Outlined"
                   OnClick="ReloadNginx" Class="ml-2">Neu laden</MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_editingSite != null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => _editingSite = null)" />
        <MudText Typo="Typo.h6">@_editingSite</MudText>
        <MudSpacer />
        @if (_role >= AppRole.Admin)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Save" Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="SaveConfig" Disabled="@_saving">Speichern & Neu laden</MudButton>
        }
    </MudStack>
    <MudTextField @bind-Value="_editContent" Lines="30" Variant="Variant.Outlined"
                  Style="font-family: monospace; font-size: 13px;" FullWidth="true" />
}
else
{
    <MudTable Items="@_sites" Dense="true" Hover="true" Striped="true" Elevation="2">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Aktionen</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudLink OnClick="@(() => EditSite(context.Name))">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-1" />
                    @context.Name
                </MudLink>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Enabled ? Color.Success : Color.Default)"
                         Variant="Variant.Filled">
                    @(context.Enabled ? "aktiviert" : "verfügbar")
                </MudChip>
            </MudTd>
            <MudTd>
                @if (_role >= AppRole.Admin)
                {
                    @if (context.Enabled)
                    {
                        <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Text"
                                   OnClick="@(() => ToggleSite(context.Name, false))">Deaktivieren</MudButton>
                    }
                    else
                    {
                        <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                                   OnClick="@(() => ToggleSite(context.Name, true))">Aktivieren</MudButton>
                    }
                }
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => EditSite(context.Name))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public string ServerId { get; set; } = "";

    private string _serverName = "";
    private bool _loading = true;
    private bool _saving;
    private List<ServerWatch.Services.Server.NginxSite> _sites = new();
    private string? _editingSite;
    private string _editContent = "";
    private AppRole _role = AppRole.Viewer;

    private bool Require(AppRole required)
    {
        if (_role < required)
        {
            Snackbar.Add($"Keine Berechtigung — {required} erforderlich (deine Rolle: {_role}).", Severity.Warning);
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        _role = await CurrentUser.GetRoleAsync();
        var server = ServerConfigService.GetServer(ServerId);
        _serverName = server?.Name ?? ServerId;
        await LoadSites();
    }

    private async Task LoadSites()
    {
        _loading = true;
        try { _sites = await NginxService.ListSitesAsync(ServerId); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _loading = false;
    }

    private async Task EditSite(string name)
    {
        try
        {
            _editContent = await NginxService.GetSiteConfigAsync(ServerId, name);
            _editingSite = name;
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task SaveConfig()
    {
        if (!Require(AppRole.Admin)) return;
        if (_editingSite == null) return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Konfiguration speichern", $"Konfiguration für '{_editingSite}' speichern und Nginx neu laden? Fehlerhafte Konfiguration kann die ausgelieferten Seiten stören.",
            yesText: "Speichern & Neu laden", cancelText: "Abbrechen");
        if (confirmed != true) return;

        _saving = true;
        try
        {
            var result = await NginxService.UpdateSiteConfigAsync(ServerId, _editingSite, _editContent);
            if (result.Success)
            {
                Snackbar.Add("Konfiguration gespeichert und Nginx neu geladen", Severity.Success);
                _editingSite = null;
                await LoadSites();
            }
            else
                Snackbar.Add($"Fehler: {result.Error}", Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        _saving = false;
    }

    private async Task ToggleSite(string name, bool enable)
    {
        if (!Require(AppRole.Admin)) return;

        try
        {
            var result = enable
                ? await NginxService.EnableSiteAsync(ServerId, name)
                : await NginxService.DisableSiteAsync(ServerId, name);
            if (result.Success)
            {
                Snackbar.Add($"Seite {name} {(enable ? "aktiviert" : "deaktiviert")}", Severity.Success);
                await LoadSites();
            }
            else
                Snackbar.Add($"Fehler: {result.Error}", Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task TestConfig()
    {
        var result = await NginxService.TestConfigAsync(ServerId);
        Snackbar.Add(result.Success ? "Konfigurationstest erfolgreich!" : $"Konfigurationstest fehlgeschlagen: {result.Error}",
            result.Success ? Severity.Success : Severity.Error);
    }

    private async Task ReloadNginx()
    {
        if (!Require(AppRole.Admin)) return;

        try
        {
            var result = await NginxService.ReloadAsync(ServerId);
            Snackbar.Add(result.Success ? "Nginx neu geladen" : $"Neu laden fehlgeschlagen: {result.Error}",
                result.Success ? Severity.Success : Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
    }
}
