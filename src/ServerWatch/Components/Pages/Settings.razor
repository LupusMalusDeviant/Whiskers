@page "/settings"
@using ServerWatch.Configuration
@attribute [Authorize]
@inject IOptionsMonitor<ServerWatch.Configuration.MattermostSettings> MattermostOptions
@inject IOptionsMonitor<ServerWatch.Configuration.HealthMonitorSettings> HealthOptions
@inject IOptionsMonitor<ServerWatch.Configuration.TerminalSettings> TerminalOptions
@inject IOptionsMonitor<ServerWatch.Configuration.GoogleAuthSettings> AuthOptions
@inject INotificationService NotificationService
@inject IOptionsMonitor<ServerWatch.Configuration.MatrixSettings> MatrixOptions
@inject ServerWatch.Services.Notifications.IMatrixNotificationService MatrixService
@inject IWhitelistService WhitelistService
@inject ServerWatch.Services.Auth.IRoleService RoleService
@inject ServerWatch.Services.Auth.ICurrentUserService CurrentUser
@inject ServerWatch.Services.AuditLog.IAuditLogService AuditLog
@inject ServerWatch.Services.Vault.IVaultService VaultService
@inject ServerWatch.Services.Mcp.IMcpPermissionService McpPermissionService
@inject ISnackbar Snackbar
@inject IOptionsMonitor<ServerWatch.Configuration.CveMonitorSettings> CveSettings
@inject ServerWatch.Services.Cve.ICveFindingsStore CveStore
@inject ServerWatch.Services.Cve.ICveMonitorService CveMonitor
@inject IOptionsMonitor<ServerWatch.Configuration.MetricAlertSettings> MetricAlertOptions
@inject IOptionsMonitor<ServerWatch.Configuration.ImageUpdateSettings> ImageUpdateOptions
@inject IOptionsMonitor<ServerWatch.Configuration.AiChatSettings> AiChatOptions
@inject IOptionsMonitor<ServerWatch.Configuration.TelegramSettings> TelegramOptions
@inject IOptionsMonitor<ServerWatch.Configuration.NtfySettings> NtfyOptions
@inject IOptionsMonitor<ServerWatch.Configuration.DiscordSettings> DiscordOptions
@inject IOptionsMonitor<ServerWatch.Configuration.SlackSettings> SlackOptions
@inject IOptionsMonitor<ServerWatch.Configuration.EmailSettings> EmailOptions
@inject IOptionsMonitor<ServerWatch.Configuration.WebhookNotificationSettings> WebhookOptions
@inject ServerWatch.Services.Persistence.IAppSettingsStore AppSettings
@inject IConfiguration Configuration

<PageTitle>Einstellungen - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Einstellungen</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Benachrichtigungen, Sicherheit und Integrationen</MudText>
        </div>
    </MudStack>
</div>

@if (_role < AppRole.Admin)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">
        Kein Zugriff — diese Seite erfordert Administratorrechte. Deine Rolle: @_role.
    </MudAlert>
}
else
{
<MudExpansionPanels MultiExpansion="true">
    @* Notifications (Mattermost + Matrix) *@
    <MudExpansionPanel Text="Benachrichtigungen" Icon="@Icons.Material.Filled.Notifications" Expanded="true">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Mattermost</MudText>
        <MudGrid>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_mmEnabled" Color="Color.Primary" Label="Aktiviert" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_mmWebhook" Label="Webhook-URL" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_mmChannel" Label="Kanal" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_mmBot" Label="Bot-Benutzername" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_mmThrottle" Label="Throttle (Min)" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="TestMattermost" StartIcon="@Icons.Material.Filled.Send"
                   Disabled="@(!_mmEnabled)" Class="mt-1">Testbenachrichtigung</MudButton>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">Matrix</MudText>
        <MudGrid>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_mxEnabled" Color="Color.Primary" Label="Aktiviert" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_mxHomeserver" Label="Homeserver-URL" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mxRoom" Label="Raum-ID" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="!abc123:matrix.org" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mxToken" Label="Access Token" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_mxThrottle" Label="Throttle (Min)" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="TestMatrix" StartIcon="@Icons.Material.Filled.Send"
                   Disabled="@(!_mxEnabled)" Class="mt-1">Testbenachrichtigung</MudButton>

        <MudDivider Class="my-3" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveNotifications">Benachrichtigungen speichern</MudButton>
    </MudExpansionPanel>

    @* Additional notification channels (Telegram / ntfy / Discord / Email / Webhook) *@
    <MudExpansionPanel Text="Weitere Benachrichtigungskanäle" Icon="@Icons.Material.Filled.Campaign">
        <MudText Typo="Typo.subtitle2" Class="mb-1">Telegram</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_tgEnabled" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_tgToken" Label="Bot-Token" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_tgChat" Label="Chat-ID" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">ntfy</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_ntfyEnabled" /></MudItem>
            <MudItem xs="12" md="5"><MudTextField @bind-Value="_ntfyServer" Label="Server-URL" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="https://ntfy.sh" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_ntfyTopic" Label="Topic" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_ntfyToken" Label="Token (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">Discord</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_dcEnabled" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_dcWebhook" Label="Webhook-URL" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">Slack</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_slEnabled" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_slWebhook" Label="Webhook-URL" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">Email (SMTP)</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_mailEnabled" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailHost" Label="SMTP-Host" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="6" md="3"><MudNumericField @bind-Value="_mailPort" Label="Port" Min="1" Max="65535" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="6" md="3" Class="d-flex align-center"><MudSwitch T="bool" Color="Color.Primary" Label="SSL/TLS" @bind-Value="_mailSsl" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailUser" Label="Benutzer" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailPass" Label="Passwort" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailFrom" Label="Absender (From)" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_mailTo" Label="Empfänger (kommagetrennt)" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-1">Generischer Webhook</MudText>
        <MudGrid>
            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_whEnabled" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_whUrl" Label="URL (POST JSON)" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveChannels">Kanäle speichern</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send" OnClick="TestChannels">Testbenachrichtigung senden</MudButton>
        </MudStack>
    </MudExpansionPanel>

    @* Health Monitoring *@
    <MudExpansionPanel Text="Zustandsüberwachung" Icon="@Icons.Material.Filled.MonitorHeart">
        <MudGrid>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hInterval" Label="Prüfintervall (Sekunden)" Min="5" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hRetention" Label="Verlaufsaufbewahrung (Stunden)" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hLoopThreshold" Label="Neustart-Schleifenschwellwert" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_hLoopWindow" Label="Neustart-Schleifenfenster (Minuten)" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveHealth" Class="mt-2">Speichern</MudButton>
    </MudExpansionPanel>

    @* Metric alerts *@
    <MudExpansionPanel Text="Metrik-Alerts (für AI-Trigger)" Icon="@Icons.Material.Filled.Insights">
        <MudGrid>
            <MudItem xs="12"><MudSwitch @bind-Value="_maEnabled" Color="Color.Primary" Label="Metrik-Alerts aktiv (emittiert high_cpu / high_memory / high_disk / metric_anomaly)" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maCpu" Label="CPU-Schwelle (%)" Min="1" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maMem" Label="RAM-Schwelle (%)" Min="1" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maDisk" Label="Festplatten-Schwelle (%, Host)" Min="1" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maSustained" Label="Anhaltend (Minuten)" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maCooldown" Label="Cooldown (Minuten)" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
        </MudGrid>
        <MudDivider Class="my-2" />
        <MudGrid>
            <MudItem xs="12"><MudSwitch @bind-Value="_maAnom" Color="Color.Secondary" Label="Ausreißererkennung (Anomalie) aktiv" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maAnomWindow" Label="Baseline-Fenster (Samples)" Min="5" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(!_maAnom)" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maAnomSigma" Label="Sigma (Ausreißer-Schwelle)" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(!_maAnom)" /></MudItem>
            <MudItem xs="12" md="4"><MudNumericField @bind-Value="_maAnomFloor" Label="Mindestwert (%) für Anomalie" Min="0" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(!_maAnom)" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveMetricAlert" Class="mt-2">Speichern</MudButton>
    </MudExpansionPanel>

    @* Image / Auto-Update *@
    <MudExpansionPanel Text="Image-Updates" Icon="@Icons.Material.Filled.SystemUpdate">
        <MudGrid>
            <MudItem xs="12"><MudSwitch @bind-Value="_iuEnabled" Color="Color.Primary" Label="Image-Update-Prüfung aktiv" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_iuInterval" Label="Prüfintervall (Stunden)" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudSwitch @bind-Value="_iuNotify" Color="Color.Primary" Label="Bei verfügbarem Update benachrichtigen" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveImageUpdate" Class="mt-2">Speichern</MudButton>
    </MudExpansionPanel>

    @* Terminal *@
    @* CVE-Monitor *@
    <MudExpansionPanel Text="CVE-Monitor" Icon="@Icons.Material.Filled.Security">
        @{
            var cveCfg = CveSettings.CurrentValue;
        }
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(cveCfg.Enabled ? Color.Success : Color.Default)"
                             Variant="Variant.Outlined">
                        @(cveCfg.Enabled ? "Aktiv" : "Deaktiviert")
                    </MudChip>
                    @if (CveStore.IsScanning)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> Scan läuft
                        </MudChip>
                    }
                    @if (CveStore.LastScanAt is { } lsa)
                    {
                        <MudText Typo="Typo.body2" Style="color:#888;">
                            Letzter Scan: @lsa.ToString("yyyy-MM-dd HH:mm 'UTC'")
                        </MudText>
                    }
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               Href="cves" StartIcon="@Icons.Material.Filled.OpenInNew">
                        Zu /cves
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Search" OnClick="TriggerCveScan"
                               Disabled="@(CveStore.IsScanning || !cveCfg.Enabled)">
                        Jetzt scannen
                    </MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveEnabled" Color="Color.Primary" Label="Aktiviert" /></MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveScanContainers" Color="Color.Primary" Label="Container scannen" /></MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveScanOs" Color="Color.Primary" Label="Host-OS scannen" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_cveInterval" Label="Prüfintervall (Stunden)" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_cveMaxScans" Label="Max. parallele Scans" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_cveTrivy" Label="Trivy-Image" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" @bind-Value="_cveSeverity" Label="Ab Schweregrad benachrichtigen" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Critical")">Critical</MudSelectItem>
                    <MudSelectItem Value="@("High")">High</MudSelectItem>
                    <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                    <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveNotify" Color="Color.Primary" Label="Bei Fund benachrichtigen" /></MudItem>
            <MudItem xs="12" md="4"><MudSwitch @bind-Value="_cveOsIds" Color="Color.Primary" Label="OS-CVE-IDs auflösen" /></MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveCve">Speichern</MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Terminal" Icon="@Icons.Material.Filled.Terminal">
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_termEnabled" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_termShell" Label="Standard-Shell" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField @bind-Value="_termMaxSessions" Label="Max. Sitzungen" Min="1" Max="50" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField @bind-Value="_termIdle" Label="Leerlauf-Timeout (Minuten)" Min="1" Max="1440" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveTerminal"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-3">Terminal speichern</MudButton>
    </MudExpansionPanel>

    @* AI advisor chat *@
    <MudExpansionPanel Text="AI-Chat (Berater)" Icon="@Icons.Material.Filled.Chat">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Schreibgeschützter Berater-Chat (keine Aktionen). Der API-Key wird im Klartext unter /app/data gespeichert — wie bei servers.json.
        </MudAlert>
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert" @bind-Value="_aiEnabled" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" @bind-Value="_aiProvider" Label="Provider" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("openai")">OpenAI / kompatibel</MudSelectItem>
                    <MudSelectItem Value="@("anthropic")">Anthropic</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_aiModel" Label="Modell" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="z.B. gpt-4o-mini" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_aiApiUrl" Label="API-URL (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Provider-Default wenn leer" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_aiApiKey" Label="API-Key" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" />
            </MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveAiChat"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-3">AI-Chat speichern</MudButton>
    </MudExpansionPanel>

    @* Restart-only / environment settings — read-only (set via .env, applied on restart) *@
    <MudExpansionPanel Text="Umgebung (Neustart erforderlich)" Icon="@Icons.Material.Filled.Dns">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Diese Werte kommen aus Umgebungsvariablen (<code>.env</code>) und werden erst nach einem Neustart wirksam — hier nur zur Ansicht.
            Das Host-Binding (<code>HOST_BIND</code>/<code>HOST_PORT</code>) liegt auf Compose-Ebene und ist im Container nicht sichtbar.
        </MudAlert>
        <MudSimpleTable Dense="true" Hover="true" Striped="true">
            <tbody>
                <tr><td>Login deaktiviert (AUTH_DISABLED)</td><td>@(Configuration["Auth:Disabled"] ?? "false")</td></tr>
                <tr><td>Google OAuth</td><td>@(string.IsNullOrWhiteSpace(Configuration["GoogleAuth:ClientId"]) ? "nicht konfiguriert" : "konfiguriert")</td></tr>
                <tr><td>OIDC aktiviert</td><td>@(Configuration["Oidc:Enabled"] ?? "false")</td></tr>
                <tr><td>OIDC Authority</td><td>@(string.IsNullOrWhiteSpace(Configuration["Oidc:Authority"]) ? "—" : Configuration["Oidc:Authority"])</td></tr>
                <tr><td>OIDC Anzeigename</td><td>@(string.IsNullOrWhiteSpace(Configuration["Oidc:DisplayName"]) ? "—" : Configuration["Oidc:DisplayName"])</td></tr>
                <tr><td>PathBase</td><td>@(string.IsNullOrWhiteSpace(Configuration["PathBase"]) ? "(root)" : Configuration["PathBase"])</td></tr>
                <tr><td>VPN-Provider</td><td>@(string.IsNullOrWhiteSpace(Configuration["Vpn:Provider"]) ? "none" : Configuration["Vpn:Provider"])</td></tr>
            </tbody>
        </MudSimpleTable>
    </MudExpansionPanel>

    @* MCP Permissions *@
    <MudExpansionPanel Text="MCP-Rechte" Icon="@Icons.Material.Filled.VpnKey"
                       Expanded="false">
        <MudText Typo="Typo.subtitle1" Class="mb-3">API-Schlüssel</MudText>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Jeder API-Schlüssel hat eine Berechtigungsstufe: <b>Lesen</b> (nur Abfragen), <b>Schreiben</b> (Container/Server verwalten) oder <b>Admin</b> (alle Befehle inkl. Shell).
        </MudAlert>

        <MudTable Items="@_mcpApiKeys" Dense="true" Hover="true" Class="mb-4">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Schlüssel</MudTh>
                <MudTh>Stufe</MudTh>
                <MudTh>Aktiv</MudTh>
                <MudTh>Erstellt</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2" Style="font-family: monospace;">
                            @((_revealedKeys.Contains(context.Id)) ? context.Key : context.Key[..8] + "..." + context.Key[^4..])
                        </MudText>
                        <MudIconButton Icon="@(_revealedKeys.Contains(context.Id) ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                       Size="Size.Small" OnClick="@(() => ToggleKeyVisibility(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                       OnClick="@(async () => await CopyKey(context.Key))" />
                    </MudStack>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(context.PermissionLevel)">
                        @GetLevelLabel(context.PermissionLevel)
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudSwitch T="bool" @bind-Value="context.Enabled" Color="Color.Success" />
                </MudTd>
                <MudTd>@context.CreatedAt.ToString("dd.MM.yyyy")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveApiKey(context.Id))" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-6">
            <MudTextField @bind-Value="_newKeyName" Label="Name" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Style="max-width: 200px;" Placeholder="z.B. Claude Code" />
            <MudSelect @bind-Value="_newKeyLevel" Label="Stufe" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width: 150px;">
                <MudSelectItem Value="@("read")">Lesen</MudSelectItem>
                <MudSelectItem Value="@("write")">Schreiben</MudSelectItem>
                <MudSelectItem Value="@("admin")">Admin</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="AddApiKey" StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@string.IsNullOrWhiteSpace(_newKeyName)">Schlüssel erstellen</MudButton>
        </MudStack>

        <MudDivider Class="mb-4" />

        <MudText Typo="Typo.subtitle1" Class="mb-3">Tool-Berechtigungen</MudText>

        @foreach (var category in _mcpTools.GroupBy(t => t.Value.Category).OrderBy(g => g.Key))
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mt-3 mb-1">@category.Key</MudText>
            <MudTable Items="@category.ToList()" Dense="true" Hover="true" Class="mb-2">
                <HeaderContent>
                    <MudTh>Tool</MudTh>
                    <MudTh>Min. Stufe</MudTh>
                    <MudTh>Aktiviert</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Style="font-family: monospace; font-size: 0.85rem;">@context.Key</MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(context.Value.RequiredLevel)">
                            @GetLevelLabel(context.Value.RequiredLevel)
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudSwitch T="bool" @bind-Value="context.Value.Enabled" Color="Color.Success" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveMcpPermissions"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-4" Disabled="@_savingMcp">
            @(_savingMcp ? "Wird gespeichert..." : "MCP-Rechte speichern")
        </MudButton>
    </MudExpansionPanel>


    @* Cloud-Provider (Hetzner/Hostinger) credentials are configured per server under "Server". *@

    @* User Roles *@
    <MudExpansionPanel Text="Benutzerrollen" Icon="@Icons.Material.Filled.AdminPanelSettings">
        <MudGrid>
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    <strong>Viewer:</strong> Nur lesen |
                    <strong>Operator:</strong> Container starten/stoppen, Queries |
                    <strong>Admin:</strong> Alles (Settings, Server, Rollen, Löschen)
                </MudAlert>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="@_roleEntries" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>E-Mail</MudTh>
                        <MudTh>Rolle</MudTh>
                        <MudTh Style="width: 60px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.Email</code></MudTd>
                        <MudTd>
                            <MudSelect T="ServerWatch.Models.AppRole" Value="@context.Role" Dense="true"
                                       ValueChanged="@(async (ServerWatch.Models.AppRole r) => { context.Role = r; await SaveRoles(); })"
                                       Variant="Variant.Text" Style="max-width: 140px;">
                                <MudSelectItem Value="ServerWatch.Models.AppRole.Viewer">Viewer</MudSelectItem>
                                <MudSelectItem Value="ServerWatch.Models.AppRole.Operator">Operator</MudSelectItem>
                                <MudSelectItem Value="ServerWatch.Models.AppRole.Admin">Admin</MudSelectItem>
                            </MudSelect>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(async () => { _roleEntries.Remove(context); await SaveRoles(); })" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                    <MudTextField @bind-Value="_newRoleEmail" Label="E-Mail" Variant="Variant.Outlined" Style="max-width: 300px;" />
                    <MudSelect T="ServerWatch.Models.AppRole" @bind-Value="_newRoleRole" Label="Rolle" Variant="Variant.Outlined" Dense="true" Style="max-width: 140px;">
                        <MudSelectItem Value="ServerWatch.Models.AppRole.Viewer">Viewer</MudSelectItem>
                        <MudSelectItem Value="ServerWatch.Models.AppRole.Operator">Operator</MudSelectItem>
                        <MudSelectItem Value="ServerWatch.Models.AppRole.Admin">Admin</MudSelectItem>
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddRole"
                               Disabled="@string.IsNullOrWhiteSpace(_newRoleEmail)">Hinzufügen</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* Secret Vault *@
    <MudExpansionPanel Text="Secret Vault" Icon="@Icons.Material.Filled.VpnKey">
        <MudGrid>
            @if (!VaultService.IsEnabled)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Vault ist deaktiviert. Setze die Umgebungsvariable <code>VAULT_KEY</code> um Secrets verschlüsselt zu speichern.
                    </MudAlert>
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                        Vault aktiv — @_vaultEntries.Count Secrets gespeichert (AES-256 verschlüsselt)
                    </MudAlert>
                </MudItem>
                <MudItem xs="12">
                    <MudTable Items="@_vaultEntries" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Key</MudTh>
                            <MudTh>Container</MudTh>
                            <MudTh>Erstellt</MudTh>
                            <MudTh>Rotation</MudTh>
                            <MudTh Style="width: 60px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><code style="font-weight: 600;">@context.Key</code></MudTd>
                            <MudTd>@(context.ContainerName ?? "-")</MudTd>
                            <MudTd>@context.CreatedAt.ToLocalTime().ToString("dd.MM.yy")</MudTd>
                            <MudTd>
                                @if (context.RotateAfterDays.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@context.RotateAfterDays Tage</MudChip>
                                }
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(async () => await DeleteVaultSecret(context.Key))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_newVaultKey" Label="Key" Variant="Variant.Outlined" Style="max-width: 200px;" />
                        <MudTextField @bind-Value="_newVaultValue" Label="Value" Variant="Variant.Outlined"
                                      InputType="InputType.Password" Style="flex: 1;" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddVaultSecret"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newVaultKey) || string.IsNullOrWhiteSpace(_newVaultValue))">Speichern</MudButton>
                    </MudStack>
                </MudItem>
            }
        </MudGrid>
    </MudExpansionPanel>

    @* Auth *@
    <MudExpansionPanel Text="Authentifizierung" Icon="@Icons.Material.Filled.Security">
        <MudGrid>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle1">Google OAuth</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Client-ID: @(string.IsNullOrWhiteSpace(AuthOptions.CurrentValue.ClientId) ? "(nicht konfiguriert)" : "***konfiguriert***")
                </MudText>
            </MudItem>
            <MudItem xs="12">
                <MudSwitch T="bool" @bind-Value="_whitelistEnabled" Color="Color.Primary"
                           Label="E-Mail-Whitelist aktiviert" />
            </MudItem>
            @if (_whitelistEnabled && _whitelistEmails.Count == 0)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning">
                        Whitelist ist aktiviert aber leer — niemand kann sich anmelden!
                    </MudAlert>
                </MudItem>
            }
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Erlaubte E-Mail-Adressen</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var email in _whitelistEmails)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                 OnClose="@(() => RemoveEmail(email))">@email</MudChip>
                    }
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_newEmail" Label="E-Mail hinzufügen" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Style="max-width: 350px;"
                                  Placeholder="benutzer@beispiel.de"
                                  OnKeyUp="@(async (e) => { if (e.Key == "Enter") await AddEmail(); })" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddEmail" StartIcon="@Icons.Material.Filled.Add"
                               Disabled="@string.IsNullOrWhiteSpace(_newEmail)">Hinzufügen</MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveWhitelist"
                           StartIcon="@Icons.Material.Filled.Save" Disabled="@_savingWhitelist">
                    @(_savingWhitelist ? "Wird gespeichert..." : "Whitelist speichern")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>
</MudExpansionPanels>
}

@code {
    private AppRole _role = AppRole.Viewer;
    private bool _whitelistEnabled;
    private List<string> _whitelistEmails = new();
    private string _newEmail = "";
    private bool _savingWhitelist;

    // Roles
    private List<ServerWatch.Models.UserRoleEntry> _roleEntries = new();
    private string _newRoleEmail = "";
    private ServerWatch.Models.AppRole _newRoleRole = ServerWatch.Models.AppRole.Operator;

    // Vault
    private List<ServerWatch.Models.VaultEntry> _vaultEntries = new();
    private string _newVaultKey = "";
    private string _newVaultValue = "";

    // MCP Permissions
    private List<ServerWatch.Models.McpApiKeyConfig> _mcpApiKeys = new();
    private Dictionary<string, ServerWatch.Models.McpToolConfig> _mcpTools = new();
    private string _newKeyName = "";
    private string _newKeyLevel = "read";
    private bool _savingMcp;
    private HashSet<string> _revealedKeys = new();

    // Editable settings (saved live to app-settings.json, no restart)
    private bool _mmEnabled; private string _mmWebhook = ""; private string _mmChannel = ""; private string _mmBot = ""; private int _mmThrottle = 5;
    private bool _mxEnabled; private string _mxHomeserver = ""; private string _mxRoom = ""; private string _mxToken = ""; private int _mxThrottle = 5;
    private int _hInterval = 30; private int _hRetention = 24; private int _hLoopThreshold = 5; private int _hLoopWindow = 10;
    private bool _maEnabled = true; private double _maCpu = 90; private double _maMem = 90; private double _maDisk = 90; private int _maSustained = 3; private int _maCooldown = 15;
    private bool _maAnom; private int _maAnomWindow = 20; private double _maAnomSigma = 3; private double _maAnomFloor = 40;
    private bool _cveEnabled; private int _cveInterval = 12; private bool _cveScanContainers = true; private bool _cveScanOs = true; private bool _cveOsIds = true;
    private string _cveTrivy = "aquasec/trivy:latest"; private bool _cveNotify = true; private string _cveSeverity = "High"; private int _cveMaxScans = 3;
    private bool _iuEnabled = true; private int _iuInterval = 6; private bool _iuNotify = true;
    private bool _termEnabled = true; private string _termShell = "/bin/bash"; private int _termMaxSessions = 5; private int _termIdle = 30;
    private bool _aiEnabled; private string _aiProvider = "openai"; private string _aiModel = ""; private string _aiApiUrl = ""; private string _aiApiKey = "";
    // Additional notification channels
    private bool _tgEnabled; private string _tgToken = ""; private string _tgChat = "";
    private bool _ntfyEnabled; private string _ntfyServer = "https://ntfy.sh"; private string _ntfyTopic = ""; private string _ntfyToken = "";
    private bool _dcEnabled; private string _dcWebhook = "";
    private bool _slEnabled; private string _slWebhook = "";
    private bool _mailEnabled; private string _mailHost = ""; private int _mailPort = 587; private bool _mailSsl = true; private string _mailUser = ""; private string _mailPass = ""; private string _mailFrom = ""; private string _mailTo = "";
    private bool _whEnabled; private string _whUrl = "";

    protected override async Task OnInitializedAsync()
    {
        // Settings holds whitelist, roles, vault secrets and MCP keys — Admin only.
        // Non-admins get an access-denied panel and we skip loading sensitive data into the circuit.
        _role = await CurrentUser.GetRoleAsync();
        if (_role < AppRole.Admin) return;

        var data = WhitelistService.GetWhitelist();
        _whitelistEnabled = data.Enabled;
        _whitelistEmails = data.Emails;

        var mcpData = McpPermissionService.GetPermissionData();
        _mcpApiKeys = mcpData.ApiKeys;
        _mcpTools = mcpData.Tools;

        // Roles — merge whitelisted users that aren't in roles yet
        _roleEntries = RoleService.GetRoleData().Roles;
        foreach (var email in _whitelistEmails)
        {
            if (!_roleEntries.Any(r => r.Email.Equals(email, StringComparison.OrdinalIgnoreCase)))
                _roleEntries.Add(new ServerWatch.Models.UserRoleEntry { Email = email, Role = ServerWatch.Models.AppRole.Admin });
        }

        // Vault
        LoadVault();

        // Editable settings — load current effective values.
        var mm = MattermostOptions.CurrentValue;
        _mmEnabled = mm.Enabled; _mmWebhook = mm.WebhookUrl; _mmChannel = mm.Channel; _mmBot = mm.BotUsername; _mmThrottle = mm.ThrottleMinutes;
        var mx = MatrixOptions.CurrentValue;
        _mxEnabled = mx.Enabled; _mxHomeserver = mx.HomeserverUrl; _mxRoom = mx.RoomId; _mxToken = mx.AccessToken; _mxThrottle = mx.ThrottleMinutes;
        var h = HealthOptions.CurrentValue;
        _hInterval = h.CheckIntervalSeconds; _hRetention = h.HistoryRetentionHours; _hLoopThreshold = h.RestartLoopThreshold; _hLoopWindow = h.RestartLoopWindowMinutes;
        var ma = MetricAlertOptions.CurrentValue;
        _maEnabled = ma.Enabled; _maCpu = ma.CpuPercent; _maMem = ma.MemoryPercent; _maDisk = ma.DiskPercent; _maSustained = ma.SustainedMinutes; _maCooldown = ma.CooldownMinutes;
        _maAnom = ma.AnomalyEnabled; _maAnomWindow = ma.AnomalyWindow; _maAnomSigma = ma.AnomalySigma; _maAnomFloor = ma.AnomalyFloorPercent;
        var cv = CveSettings.CurrentValue;
        _cveEnabled = cv.Enabled; _cveInterval = cv.CheckIntervalHours; _cveScanContainers = cv.ScanContainers; _cveScanOs = cv.ScanOs; _cveOsIds = cv.EnableOsCveIds;
        _cveTrivy = cv.TrivyImage; _cveNotify = cv.NotifyOnFinding; _cveSeverity = cv.NotifySeverity; _cveMaxScans = cv.MaxConcurrentScans;
        var iu = ImageUpdateOptions.CurrentValue;
        _iuEnabled = iu.Enabled; _iuInterval = iu.CheckIntervalHours; _iuNotify = iu.NotifyOnUpdate;
        var t = TerminalOptions.CurrentValue;
        _termEnabled = t.Enabled; _termShell = t.DefaultShell; _termMaxSessions = t.MaxSessions; _termIdle = t.IdleTimeoutMinutes;
        var ai = AiChatOptions.CurrentValue;
        _aiEnabled = ai.Enabled; _aiProvider = ai.Provider; _aiModel = ai.Model; _aiApiUrl = ai.ApiUrl ?? ""; _aiApiKey = ai.ApiKey;
        var tg = TelegramOptions.CurrentValue; _tgEnabled = tg.Enabled; _tgToken = tg.BotToken; _tgChat = tg.ChatId;
        var nt = NtfyOptions.CurrentValue; _ntfyEnabled = nt.Enabled; _ntfyServer = nt.ServerUrl; _ntfyTopic = nt.Topic; _ntfyToken = nt.Token;
        var dc = DiscordOptions.CurrentValue; _dcEnabled = dc.Enabled; _dcWebhook = dc.WebhookUrl;
        var sl = SlackOptions.CurrentValue; _slEnabled = sl.Enabled; _slWebhook = sl.WebhookUrl;
        var ml = EmailOptions.CurrentValue; _mailEnabled = ml.Enabled; _mailHost = ml.Host; _mailPort = ml.Port; _mailSsl = ml.UseSsl; _mailUser = ml.Username; _mailPass = ml.Password; _mailFrom = ml.From; _mailTo = ml.To;
        var wh = WebhookOptions.CurrentValue; _whEnabled = wh.Enabled; _whUrl = wh.Url;
    }

    private async Task SaveNotifications()
    {
        var mmCur = MattermostOptions.CurrentValue;
        await AppSettings.SaveSectionAsync("Mattermost", new MattermostSettings
        {
            Enabled = _mmEnabled, WebhookUrl = _mmWebhook?.Trim() ?? "", Channel = _mmChannel?.Trim() ?? "",
            BotUsername = string.IsNullOrWhiteSpace(_mmBot) ? "ServerWatch" : _mmBot.Trim(),
            BotIconUrl = mmCur.BotIconUrl, ThrottleMinutes = _mmThrottle,
        });
        await AppSettings.SaveSectionAsync("Matrix", new MatrixSettings
        {
            Enabled = _mxEnabled, HomeserverUrl = _mxHomeserver?.Trim() ?? "", RoomId = _mxRoom?.Trim() ?? "",
            AccessToken = _mxToken ?? "", ThrottleMinutes = _mxThrottle,
        });
        await Audit("notifications");
        Snackbar.Add("Benachrichtigungen gespeichert (gelten sofort).", Severity.Success);
    }

    private async Task SaveHealth()
    {
        await AppSettings.SaveSectionAsync("HealthMonitor", new HealthMonitorSettings
        {
            CheckIntervalSeconds = _hInterval, HistoryRetentionHours = _hRetention,
            RestartLoopThreshold = _hLoopThreshold, RestartLoopWindowMinutes = _hLoopWindow,
        });
        await Audit("healthmonitor");
        Snackbar.Add("Zustandsüberwachung gespeichert.", Severity.Success);
    }

    private async Task SaveMetricAlert()
    {
        await AppSettings.SaveSectionAsync("MetricAlert", new MetricAlertSettings
        {
            Enabled = _maEnabled, CpuPercent = _maCpu, MemoryPercent = _maMem, DiskPercent = _maDisk,
            SustainedMinutes = _maSustained, CooldownMinutes = _maCooldown,
            AnomalyEnabled = _maAnom, AnomalyWindow = _maAnomWindow, AnomalySigma = _maAnomSigma, AnomalyFloorPercent = _maAnomFloor,
        });
        await Audit("metricalert");
        Snackbar.Add("Metrik-Alerts gespeichert.", Severity.Success);
    }

    private async Task SaveCve()
    {
        var cur = CveSettings.CurrentValue;
        await AppSettings.SaveSectionAsync("CveMonitor", new CveMonitorSettings
        {
            Enabled = _cveEnabled, CheckIntervalHours = _cveInterval, ScanContainers = _cveScanContainers,
            ScanOs = _cveScanOs, EnableOsCveIds = _cveOsIds, TrivyImage = string.IsNullOrWhiteSpace(_cveTrivy) ? cur.TrivyImage : _cveTrivy.Trim(),
            NotifyOnFinding = _cveNotify, NotifySeverity = _cveSeverity, MaxConcurrentScans = _cveMaxScans,
            OsChangelogTimeoutSeconds = cur.OsChangelogTimeoutSeconds,
        });
        await Audit("cvemonitor");
        Snackbar.Add("CVE-Monitor gespeichert.", Severity.Success);
    }

    private async Task SaveImageUpdate()
    {
        await AppSettings.SaveSectionAsync("ImageUpdate", new ImageUpdateSettings
        {
            Enabled = _iuEnabled, CheckIntervalHours = _iuInterval, NotifyOnUpdate = _iuNotify,
        });
        await Audit("imageupdate");
        Snackbar.Add("Image-Updates gespeichert.", Severity.Success);
    }

    private async Task SaveTerminal()
    {
        await AppSettings.SaveSectionAsync("Terminal", new TerminalSettings
        {
            Enabled = _termEnabled,
            DefaultShell = string.IsNullOrWhiteSpace(_termShell) ? "/bin/bash" : _termShell.Trim(),
            MaxSessions = _termMaxSessions,
            IdleTimeoutMinutes = _termIdle,
        });
        await Audit("terminal");
        Snackbar.Add("Terminal gespeichert (neue Sitzungen gelten sofort).", Severity.Success);
    }

    private async Task SaveAiChat()
    {
        await AppSettings.SaveSectionAsync("AiChat", new AiChatSettings
        {
            Enabled = _aiEnabled,
            Provider = string.IsNullOrWhiteSpace(_aiProvider) ? "openai" : _aiProvider,
            Model = _aiModel?.Trim() ?? "",
            ApiUrl = string.IsNullOrWhiteSpace(_aiApiUrl) ? null : _aiApiUrl.Trim(),
            ApiKey = _aiApiKey ?? "",
        });
        await Audit("aichat");
        Snackbar.Add("AI-Chat gespeichert (gilt sofort).", Severity.Success);
    }

    private async Task SaveChannels()
    {
        await AppSettings.SaveSectionAsync("Telegram", new TelegramSettings
        {
            Enabled = _tgEnabled, BotToken = _tgToken?.Trim() ?? "", ChatId = _tgChat?.Trim() ?? "",
            ThrottleMinutes = TelegramOptions.CurrentValue.ThrottleMinutes,
        });
        await AppSettings.SaveSectionAsync("Ntfy", new NtfySettings
        {
            Enabled = _ntfyEnabled, ServerUrl = string.IsNullOrWhiteSpace(_ntfyServer) ? "https://ntfy.sh" : _ntfyServer.Trim(),
            Topic = _ntfyTopic?.Trim() ?? "", Token = _ntfyToken?.Trim() ?? "", ThrottleMinutes = NtfyOptions.CurrentValue.ThrottleMinutes,
        });
        await AppSettings.SaveSectionAsync("Discord", new DiscordSettings
        {
            Enabled = _dcEnabled, WebhookUrl = _dcWebhook?.Trim() ?? "", ThrottleMinutes = DiscordOptions.CurrentValue.ThrottleMinutes,
        });
        await AppSettings.SaveSectionAsync("Slack", new SlackSettings
        {
            Enabled = _slEnabled, WebhookUrl = _slWebhook?.Trim() ?? "", ThrottleMinutes = SlackOptions.CurrentValue.ThrottleMinutes,
        });
        await AppSettings.SaveSectionAsync("Email", new EmailSettings
        {
            Enabled = _mailEnabled, Host = _mailHost?.Trim() ?? "", Port = _mailPort, UseSsl = _mailSsl,
            Username = _mailUser?.Trim() ?? "", Password = _mailPass ?? "", From = _mailFrom?.Trim() ?? "",
            To = _mailTo?.Trim() ?? "", ThrottleMinutes = EmailOptions.CurrentValue.ThrottleMinutes,
        });
        await AppSettings.SaveSectionAsync("WebhookNotification", new WebhookNotificationSettings
        {
            Enabled = _whEnabled, Url = _whUrl?.Trim() ?? "", ThrottleMinutes = WebhookOptions.CurrentValue.ThrottleMinutes,
        });
        await Audit("notification-channels");
        Snackbar.Add("Kanäle gespeichert (gelten sofort).", Severity.Success);
    }

    private async Task TestChannels()
    {
        try
        {
            await NotificationService.SendTestAsync();
            Snackbar.Add("Testbenachrichtigung an alle konfigurierten Kanäle gesendet (vorher speichern!).", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Test teilweise fehlgeschlagen: {ex.Message}", Severity.Warning); }
    }

    private async Task Audit(string section)
    {
        try
        {
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "config.save", "config", section, section);
        }
        catch { }
    }

    private void ToggleKeyVisibility(string keyId)
    {
        if (!_revealedKeys.Remove(keyId))
            _revealedKeys.Add(keyId);
    }

    private async Task CopyKey(string key)
    {
        // JS interop for clipboard would be better, but for now use snackbar
        Snackbar.Add($"Schlüssel: {key}", Severity.Info);
    }

    private Color GetLevelColor(string level) => level switch
    {
        "read" => Color.Info,
        "write" => Color.Warning,
        "admin" => Color.Error,
        _ => Color.Default
    };

    private string GetLevelLabel(string level) => level switch
    {
        "read" => "Lesen",
        "write" => "Schreiben",
        "admin" => "Admin",
        _ => level
    };

    private async Task AddApiKey()
    {
        if (string.IsNullOrWhiteSpace(_newKeyName)) return;
        var newKey = await McpPermissionService.AddApiKeyAsync(_newKeyName.Trim(), _newKeyLevel);
        // Reload from service to avoid duplicates from reference sharing
        var mcpData = McpPermissionService.GetPermissionData();
        _mcpApiKeys = mcpData.ApiKeys;
        _revealedKeys.Add(newKey.Id); // Show the new key immediately
        _newKeyName = "";
        Snackbar.Add($"API-Schlüssel '{newKey.Name}' erstellt. Bitte kopieren und sicher aufbewahren!", Severity.Success);
    }

    private async Task RemoveApiKey(string id)
    {
        await McpPermissionService.RemoveApiKeyAsync(id);
        // Reload from service to stay in sync
        var mcpData = McpPermissionService.GetPermissionData();
        _mcpApiKeys = mcpData.ApiKeys;
        Snackbar.Add("API-Schlüssel gelöscht.", Severity.Info);
    }

    private async Task SaveMcpPermissions()
    {
        _savingMcp = true;
        try
        {
            await McpPermissionService.SavePermissionDataAsync(new ServerWatch.Models.McpPermissionData
            {
                ApiKeys = _mcpApiKeys,
                Tools = _mcpTools
            });
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "config.save", "config", "mcp-permissions", "MCP-Rechte");
            Snackbar.Add("MCP-Rechte gespeichert. Änderungen gelten sofort.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingMcp = false;
        }
    }

    private Task AddEmail()
    {
        var email = _newEmail?.Trim();
        if (!string.IsNullOrWhiteSpace(email) && email.Contains('@') &&
            !_whitelistEmails.Contains(email, StringComparer.OrdinalIgnoreCase))
        {
            _whitelistEmails.Add(email);
            _newEmail = "";
        }
        return Task.CompletedTask;
    }

    private void RemoveEmail(string email)
    {
        _whitelistEmails.Remove(email);
    }

    private async Task SaveWhitelist()
    {
        // An enabled whitelist with zero entries denies everyone (fail-closed) — refuse to save that state
        // so an admin can't accidentally lock the whole instance (including themselves) out.
        if (_whitelistEnabled && _whitelistEmails.Count == 0)
        {
            Snackbar.Add("Eine aktivierte Whitelist ohne Einträge würde alle aussperren. Bitte mindestens eine E-Mail hinzufügen oder die Whitelist deaktivieren.", Severity.Error);
            return;
        }
        _savingWhitelist = true;
        try
        {
            await WhitelistService.SaveWhitelistAsync(new ServerWatch.Models.WhitelistData
            {
                Enabled = _whitelistEnabled,
                Emails = _whitelistEmails
            });
            var actor = await CurrentUser.GetEmailAsync() ?? "unknown";
            await AuditLog.LogAsync(actor, "web", "config.save", "config", "whitelist", "E-Mail-Whitelist");
            Snackbar.Add("Whitelist gespeichert. Änderungen gelten ab der nächsten Anmeldung.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingWhitelist = false;
        }
    }

