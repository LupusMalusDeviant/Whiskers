@page "/settings"
@attribute [Authorize]
@inject IOptionsMonitor<ServerWatch.Configuration.MattermostSettings> MattermostOptions
@inject IOptionsMonitor<ServerWatch.Configuration.HealthMonitorSettings> HealthOptions
@inject IOptionsMonitor<ServerWatch.Configuration.TerminalSettings> TerminalOptions
@inject IOptionsMonitor<ServerWatch.Configuration.GoogleAuthSettings> AuthOptions
@inject INotificationService NotificationService
@inject IOptionsMonitor<ServerWatch.Configuration.MatrixSettings> MatrixOptions
@inject ServerWatch.Services.Notifications.MatrixNotificationService MatrixService
@inject WhitelistService WhitelistService
@inject ServerWatch.Services.Auth.RoleService RoleService
@inject ServerWatch.Services.Vault.VaultService VaultService
@inject ServerWatch.Services.Mcp.McpPermissionService McpPermissionService
@inject ServerWatch.Services.Coolify.CoolifyConfigService CoolifyConfigService
@inject ServerWatch.Services.Coolify.ICoolifyService CoolifyApiService
@inject ServerWatch.Services.Hetzner.HetznerConfigService HetznerConfigService
@inject ServerWatch.Services.Hetzner.IHetznerService HetznerApiService
@inject ISnackbar Snackbar
@inject IOptionsMonitor<ServerWatch.Configuration.CveMonitorSettings> CveSettings
@inject ServerWatch.Services.Cve.CveFindingsStore CveStore
@inject ServerWatch.Services.Cve.CveMonitorService CveMonitor

<PageTitle>Einstellungen - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Einstellungen</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Benachrichtigungen, Sicherheit und Integrationen</MudText>
        </div>
    </MudStack>
</div>

<MudExpansionPanels MultiExpansion="true">
    @* Mattermost *@
    <MudExpansionPanel Text="Mattermost-Benachrichtigungen" Icon="@Icons.Material.Filled.Notifications"
                       IsInitiallyExpanded="true">
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert"
                           Value="@MattermostOptions.CurrentValue.Enabled" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Value="@MattermostOptions.CurrentValue.WebhookUrl" Label="Webhook-URL"
                              Variant="Variant.Outlined" ReadOnly="true"
                              HelperText="Über Umgebungsvariable setzen: Mattermost__WebhookUrl" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@MattermostOptions.CurrentValue.Channel" Label="Kanal"
                              Variant="Variant.Outlined" ReadOnly="true"
                              HelperText="Über Umgebungsvariable setzen: Mattermost__Channel" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@MattermostOptions.CurrentValue.BotUsername" Label="Bot-Benutzername"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="TestMattermost"
                           StartIcon="@Icons.Material.Filled.Send" Disabled="@(!MattermostOptions.CurrentValue.Enabled)">
                    Testbenachrichtigung senden
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* Matrix *@
    <MudExpansionPanel Text="Matrix-Benachrichtigungen" Icon="@Icons.Material.Filled.Chat">
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert"
                           Value="@MatrixOptions.CurrentValue.Enabled" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Value="@MatrixOptions.CurrentValue.HomeserverUrl" Label="Homeserver-URL"
                              Variant="Variant.Outlined" ReadOnly="true"
                              HelperText="Über Umgebungsvariable setzen: Matrix__HomeserverUrl" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@MatrixOptions.CurrentValue.RoomId" Label="Raum-ID"
                              Variant="Variant.Outlined" ReadOnly="true"
                              HelperText="Über Umgebungsvariable setzen: Matrix__RoomId (z.B. !abc123:matrix.org)" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@(string.IsNullOrEmpty(MatrixOptions.CurrentValue.AccessToken) ? "" : "••••••••")"
                              Label="Access Token" Variant="Variant.Outlined" ReadOnly="true"
                              HelperText="Über Umgebungsvariable setzen: Matrix__AccessToken" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="TestMatrix"
                           StartIcon="@Icons.Material.Filled.Send" Disabled="@(!MatrixOptions.CurrentValue.Enabled)">
                    Testbenachrichtigung senden
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* Health Monitoring *@
    <MudExpansionPanel Text="Zustandsüberwachung" Icon="@Icons.Material.Filled.MonitorHeart">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Value="@HealthOptions.CurrentValue.CheckIntervalSeconds" Label="Prüfintervall (Sekunden)"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@HealthOptions.CurrentValue.HistoryRetentionHours" Label="Verlaufsaufbewahrung (Stunden)"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@HealthOptions.CurrentValue.RestartLoopThreshold" Label="Neustart-Schleifenschwellwert"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@HealthOptions.CurrentValue.RestartLoopWindowMinutes" Label="Neustart-Schleifenfenster (Minuten)"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
        </MudGrid>
        <MudAlert Severity="Severity.Info" Class="mt-2">
            Einstellungen werden über Umgebungsvariablen oder appsettings.json konfiguriert. Änderungen erfordern einen Container-Neustart.
        </MudAlert>
    </MudExpansionPanel>

    @* Terminal *@
    @* CVE-Monitor *@
    <MudExpansionPanel Text="CVE-Monitor" Icon="@Icons.Material.Filled.Security">
        @{
            var cveCfg = CveSettings.CurrentValue;
        }
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(cveCfg.Enabled ? Color.Success : Color.Default)"
                             Variant="Variant.Outlined">
                        @(cveCfg.Enabled ? "Aktiv" : "Deaktiviert")
                    </MudChip>
                    @if (CveStore.IsScanning)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> Scan läuft
                        </MudChip>
                    }
                    @if (CveStore.LastScanAt is { } lsa)
                    {
                        <MudText Typo="Typo.body2" Style="color:#888;">
                            Letzter Scan: @lsa.ToString("yyyy-MM-dd HH:mm 'UTC'")
                        </MudText>
                    }
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               Href="cves" StartIcon="@Icons.Material.Filled.OpenInNew">
                        Zu /cves
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Search" OnClick="TriggerCveScan"
                               Disabled="@(CveStore.IsScanning || !cveCfg.Enabled)">
                        Jetzt scannen
                    </MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudAlert Severity="MudBlazor.Severity.Info" Dense="true">
                    Konfiguration aus <code>appsettings.json</code> Sektion <code>CveMonitor</code> — Änderungen werden automatisch übernommen (kein Neustart nötig).
                </MudAlert>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudList T="string" Dense="true">
                    <MudListItem T="string">Enabled: <strong>@cveCfg.Enabled</strong></MudListItem>
                    <MudListItem T="string">CheckIntervalHours: <strong>@cveCfg.CheckIntervalHours</strong></MudListItem>
                    <MudListItem T="string">ScanContainers: <strong>@cveCfg.ScanContainers</strong></MudListItem>
                    <MudListItem T="string">ScanOs: <strong>@cveCfg.ScanOs</strong></MudListItem>
                    <MudListItem T="string">EnableOsCveIds: <strong>@cveCfg.EnableOsCveIds</strong></MudListItem>
                </MudList>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudList T="string" Dense="true">
                    <MudListItem T="string">TrivyImage: <code>@cveCfg.TrivyImage</code></MudListItem>
                    <MudListItem T="string">NotifyOnFinding: <strong>@cveCfg.NotifyOnFinding</strong></MudListItem>
                    <MudListItem T="string">NotifySeverity: <strong>@cveCfg.NotifySeverity</strong></MudListItem>
                    <MudListItem T="string">MaxConcurrentScans: <strong>@cveCfg.MaxConcurrentScans</strong></MudListItem>
                    <MudListItem T="string">OsChangelogTimeoutSeconds: <strong>@cveCfg.OsChangelogTimeoutSeconds</strong></MudListItem>
                </MudList>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Terminal" Icon="@Icons.Material.Filled.Terminal">
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" Color="Color.Primary" Label="Aktiviert"
                           Value="@TerminalOptions.CurrentValue.Enabled" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField Value="@TerminalOptions.CurrentValue.DefaultShell" Label="Standard-Shell"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField Value="@TerminalOptions.CurrentValue.MaxSessions" Label="Max. Sitzungen"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField Value="@TerminalOptions.CurrentValue.IdleTimeoutMinutes" Label="Leerlauf-Timeout (Minuten)"
                              Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* MCP Permissions *@
    <MudExpansionPanel Text="MCP-Rechte" Icon="@Icons.Material.Filled.VpnKey"
                       IsInitiallyExpanded="false">
        <MudText Typo="Typo.subtitle1" Class="mb-3">API-Schlüssel</MudText>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Jeder API-Schlüssel hat eine Berechtigungsstufe: <b>Lesen</b> (nur Abfragen), <b>Schreiben</b> (Container/Server verwalten) oder <b>Admin</b> (alle Befehle inkl. Shell).
        </MudAlert>

        <MudTable Items="@_mcpApiKeys" Dense="true" Hover="true" Class="mb-4">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Schlüssel</MudTh>
                <MudTh>Stufe</MudTh>
                <MudTh>Aktiv</MudTh>
                <MudTh>Erstellt</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2" Style="font-family: monospace;">
                            @((_revealedKeys.Contains(context.Id)) ? context.Key : context.Key[..8] + "..." + context.Key[^4..])
                        </MudText>
                        <MudIconButton Icon="@(_revealedKeys.Contains(context.Id) ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                       Size="Size.Small" OnClick="@(() => ToggleKeyVisibility(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                       OnClick="@(async () => await CopyKey(context.Key))" />
                    </MudStack>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(context.PermissionLevel)">
                        @GetLevelLabel(context.PermissionLevel)
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudSwitch T="bool" @bind-Value="context.Enabled" Color="Color.Success" />
                </MudTd>
                <MudTd>@context.CreatedAt.ToString("dd.MM.yyyy")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveApiKey(context.Id))" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-6">
            <MudTextField @bind-Value="_newKeyName" Label="Name" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Style="max-width: 200px;" Placeholder="z.B. Claude Code" />
            <MudSelect @bind-Value="_newKeyLevel" Label="Stufe" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width: 150px;">
                <MudSelectItem Value="@("read")">Lesen</MudSelectItem>
                <MudSelectItem Value="@("write")">Schreiben</MudSelectItem>
                <MudSelectItem Value="@("admin")">Admin</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="AddApiKey" StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@string.IsNullOrWhiteSpace(_newKeyName)">Schlüssel erstellen</MudButton>
        </MudStack>

        <MudDivider Class="mb-4" />

        <MudText Typo="Typo.subtitle1" Class="mb-3">Tool-Berechtigungen</MudText>

        @foreach (var category in _mcpTools.GroupBy(t => t.Value.Category).OrderBy(g => g.Key))
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mt-3 mb-1">@category.Key</MudText>
            <MudTable Items="@category.ToList()" Dense="true" Hover="true" Class="mb-2">
                <HeaderContent>
                    <MudTh>Tool</MudTh>
                    <MudTh>Min. Stufe</MudTh>
                    <MudTh>Aktiviert</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Style="font-family: monospace; font-size: 0.85rem;">@context.Key</MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(context.Value.RequiredLevel)">
                            @GetLevelLabel(context.Value.RequiredLevel)
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudSwitch T="bool" @bind-Value="context.Value.Enabled" Color="Color.Success" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveMcpPermissions"
                   StartIcon="@Icons.Material.Filled.Save" Class="mt-4" Disabled="@_savingMcp">
            @(_savingMcp ? "Wird gespeichert..." : "MCP-Rechte speichern")
        </MudButton>
    </MudExpansionPanel>

    @* Coolify *@
    <MudExpansionPanel Text="Coolify-Integration" Icon="@Icons.Material.Filled.Cloud">
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" @bind-Value="_coolifyEnabled" Color="Color.Primary"
                           Label="Coolify-Integration aktivieren" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_coolifyApiUrl" Label="Coolify API-URL"
                              Variant="Variant.Outlined" Placeholder="https://coolify.example.com"
                              HelperText="Basis-URL Ihrer Coolify-Instanz (ohne /api/v1)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_coolifyApiToken" Label="API-Token"
                              Variant="Variant.Outlined" InputType="InputType.Password"
                              HelperText="Bearer-Token aus Coolify → Keys & Tokens → API tokens" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="_coolifyPollingInterval" Label="Abfrageintervall (Sekunden)"
                                 Variant="Variant.Outlined" Min="5" Max="300" />
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveCoolifySettings"
                               StartIcon="@Icons.Material.Filled.Save" Disabled="@_savingCoolify">
                        @(_savingCoolify ? "Wird gespeichert..." : "Coolify-Einstellungen speichern")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="TestCoolifyConnection"
                               StartIcon="@Icons.Material.Filled.NetworkCheck" Disabled="@_testingCoolify">
                        @(_testingCoolify ? "Teste..." : "Verbindung testen")
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* Hetzner Cloud *@
    <MudExpansionPanel Text="Hetzner-Cloud-Integration" Icon="@Icons.Material.Filled.CloudQueue">
        <MudGrid>
            <MudItem xs="12">
                <MudSwitch T="bool" @bind-Value="_hetznerEnabled" Color="Color.Primary"
                           Label="Hetzner-Integration aktivieren" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_hetznerApiToken" Label="API-Token"
                              Variant="Variant.Outlined" InputType="InputType.Password"
                              HelperText="@(_hetznerHasToken ? "Ein Token ist gespeichert — Feld leer lassen, um es beizubehalten." : "Token aus Hetzner Cloud Console → Security → API Tokens. Read&Write für Steueraktionen.")" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="_hetznerPollingInterval" Label="Abfrageintervall (Sekunden)"
                                 Variant="Variant.Outlined" Min="15" Max="600" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="_hetznerTrafficWarn" Label="Traffic-Warnschwelle (%)"
                                 Variant="Variant.Outlined" Min="50" Max="100" />
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveHetznerSettings"
                               StartIcon="@Icons.Material.Filled.Save" Disabled="@_savingHetzner">
                        @(_savingHetzner ? "Wird gespeichert..." : "Hetzner-Einstellungen speichern")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="TestHetznerConnection"
                               StartIcon="@Icons.Material.Filled.NetworkCheck" Disabled="@_testingHetzner">
                        @(_testingHetzner ? "Teste..." : "Verbindung testen")
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* User Roles *@
    <MudExpansionPanel Text="Benutzerrollen" Icon="@Icons.Material.Filled.AdminPanelSettings">
        <MudGrid>
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    <strong>Viewer:</strong> Nur lesen |
                    <strong>Operator:</strong> Container starten/stoppen, Queries |
                    <strong>Admin:</strong> Alles (Settings, Server, Rollen, Löschen)
                </MudAlert>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="@_roleEntries" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>E-Mail</MudTh>
                        <MudTh>Rolle</MudTh>
                        <MudTh Style="width: 60px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.Email</code></MudTd>
                        <MudTd>
                            <MudSelect T="ServerWatch.Models.AppRole" Value="@context.Role" Dense="true"
                                       ValueChanged="@(async (ServerWatch.Models.AppRole r) => { context.Role = r; await SaveRoles(); })"
                                       Variant="Variant.Text" Style="max-width: 140px;">
                                <MudSelectItem Value="ServerWatch.Models.AppRole.Viewer">Viewer</MudSelectItem>
                                <MudSelectItem Value="ServerWatch.Models.AppRole.Operator">Operator</MudSelectItem>
                                <MudSelectItem Value="ServerWatch.Models.AppRole.Admin">Admin</MudSelectItem>
                            </MudSelect>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(async () => { _roleEntries.Remove(context); await SaveRoles(); })" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                    <MudTextField @bind-Value="_newRoleEmail" Label="E-Mail" Variant="Variant.Outlined" Dense="true" Style="max-width: 300px;" />
                    <MudSelect T="ServerWatch.Models.AppRole" @bind-Value="_newRoleRole" Label="Rolle" Variant="Variant.Outlined" Dense="true" Style="max-width: 140px;">
                        <MudSelectItem Value="ServerWatch.Models.AppRole.Viewer">Viewer</MudSelectItem>
                        <MudSelectItem Value="ServerWatch.Models.AppRole.Operator">Operator</MudSelectItem>
                        <MudSelectItem Value="ServerWatch.Models.AppRole.Admin">Admin</MudSelectItem>
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddRole"
                               Disabled="@string.IsNullOrWhiteSpace(_newRoleEmail)">Hinzufügen</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    @* Secret Vault *@
    <MudExpansionPanel Text="Secret Vault" Icon="@Icons.Material.Filled.VpnKey">
        <MudGrid>
            @if (!VaultService.IsEnabled)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Vault ist deaktiviert. Setze die Umgebungsvariable <code>VAULT_KEY</code> um Secrets verschlüsselt zu speichern.
                    </MudAlert>
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                        Vault aktiv — @_vaultEntries.Count Secrets gespeichert (AES-256 verschlüsselt)
                    </MudAlert>
                </MudItem>
                <MudItem xs="12">
                    <MudTable Items="@_vaultEntries" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Key</MudTh>
                            <MudTh>Container</MudTh>
                            <MudTh>Erstellt</MudTh>
                            <MudTh>Rotation</MudTh>
                            <MudTh Style="width: 60px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><code style="font-weight: 600;">@context.Key</code></MudTd>
                            <MudTd>@(context.ContainerName ?? "-")</MudTd>
                            <MudTd>@context.CreatedAt.ToLocalTime().ToString("dd.MM.yy")</MudTd>
                            <MudTd>
                                @if (context.RotateAfterDays.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@context.RotateAfterDays Tage</MudChip>
                                }
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(async () => { await VaultService.DeleteSecretAsync(context.Key); LoadVault(); })" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_newVaultKey" Label="Key" Variant="Variant.Outlined" Dense="true" Style="max-width: 200px;" />
                        <MudTextField @bind-Value="_newVaultValue" Label="Value" Variant="Variant.Outlined" Dense="true"
                                      InputType="InputType.Password" Style="flex: 1;" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddVaultSecret"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newVaultKey) || string.IsNullOrWhiteSpace(_newVaultValue))">Speichern</MudButton>
                    </MudStack>
                </MudItem>
            }
        </MudGrid>
    </MudExpansionPanel>

    @* Auth *@
    <MudExpansionPanel Text="Authentifizierung" Icon="@Icons.Material.Filled.Security">
        <MudGrid>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle1">Google OAuth</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Client-ID: @(string.IsNullOrWhiteSpace(AuthOptions.CurrentValue.ClientId) ? "(nicht konfiguriert)" : "***konfiguriert***")
                </MudText>
            </MudItem>
            <MudItem xs="12">
                <MudSwitch T="bool" @bind-Value="_whitelistEnabled" Color="Color.Primary"
                           Label="E-Mail-Whitelist aktiviert" />
            </MudItem>
            @if (_whitelistEnabled && _whitelistEmails.Count == 0)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning">
                        Whitelist ist aktiviert aber leer — niemand kann sich anmelden!
                    </MudAlert>
                </MudItem>
            }
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Erlaubte E-Mail-Adressen</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var email in _whitelistEmails)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                 OnClose="@(() => RemoveEmail(email))">@email</MudChip>
                    }
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_newEmail" Label="E-Mail hinzufügen" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Style="max-width: 350px;"
                                  Placeholder="benutzer@beispiel.de"
                                  OnKeyUp="@(async (e) => { if (e.Key == "Enter") await AddEmail(); })" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddEmail" StartIcon="@Icons.Material.Filled.Add"
                               Disabled="@string.IsNullOrWhiteSpace(_newEmail)">Hinzufügen</MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveWhitelist"
                           StartIcon="@Icons.Material.Filled.Save" Disabled="@_savingWhitelist">
                    @(_savingWhitelist ? "Wird gespeichert..." : "Whitelist speichern")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    private bool _whitelistEnabled;
    private List<string> _whitelistEmails = new();
    private string _newEmail = "";
    private bool _savingWhitelist;

    // Roles
    private List<ServerWatch.Models.UserRoleEntry> _roleEntries = new();
    private string _newRoleEmail = "";
    private ServerWatch.Models.AppRole _newRoleRole = ServerWatch.Models.AppRole.Operator;

    // Vault
    private List<ServerWatch.Models.VaultEntry> _vaultEntries = new();
    private string _newVaultKey = "";
    private string _newVaultValue = "";

    // MCP Permissions
    private List<ServerWatch.Models.McpApiKeyConfig> _mcpApiKeys = new();
    private Dictionary<string, ServerWatch.Models.McpToolConfig> _mcpTools = new();
    private string _newKeyName = "";
    private string _newKeyLevel = "read";
    private bool _savingMcp;
    private HashSet<string> _revealedKeys = new();

    // Coolify
    private bool _coolifyEnabled;
    private string _coolifyApiUrl = "";
    private string _coolifyApiToken = "";
    private int _coolifyPollingInterval = 30;
    private bool _savingCoolify;
    private bool _testingCoolify;

    // Hetzner
    private bool _hetznerEnabled;
    private string _hetznerApiToken = "";
    private bool _hetznerHasToken;
    private int _hetznerPollingInterval = 60;
    private int _hetznerTrafficWarn = 80;
    private bool _savingHetzner;
    private bool _testingHetzner;

    protected override void OnInitialized()
    {
        var data = WhitelistService.GetWhitelist();
        _whitelistEnabled = data.Enabled;
        _whitelistEmails = data.Emails;

        var mcpData = McpPermissionService.GetPermissionData();
        _mcpApiKeys = mcpData.ApiKeys;
        _mcpTools = mcpData.Tools;

        // Coolify
        var coolifySettings = CoolifyConfigService.GetSettings();
        _coolifyEnabled = coolifySettings.Enabled;
        _coolifyApiUrl = coolifySettings.ApiUrl;
        _coolifyApiToken = coolifySettings.ApiToken;
        _coolifyPollingInterval = coolifySettings.PollingIntervalSeconds;

        // Hetzner — never prefill the token field; show a hint if one is stored
        var hetznerSettings = HetznerConfigService.GetSettings();
        _hetznerEnabled = hetznerSettings.Enabled;
        _hetznerPollingInterval = hetznerSettings.PollingIntervalSeconds;
        _hetznerTrafficWarn = hetznerSettings.TrafficWarnPercent;
        _hetznerHasToken = HetznerConfigService.HasToken;
        _hetznerApiToken = "";

        // Roles — merge whitelisted users that aren't in roles yet
        _roleEntries = RoleService.GetRoleData().Roles;
        foreach (var email in _whitelistEmails)
        {
            if (!_roleEntries.Any(r => r.Email.Equals(email, StringComparison.OrdinalIgnoreCase)))
                _roleEntries.Add(new ServerWatch.Models.UserRoleEntry { Email = email, Role = ServerWatch.Models.AppRole.Admin });
        }

        // Vault
        LoadVault();
    }

    private void ToggleKeyVisibility(string keyId)
    {
        if (!_revealedKeys.Remove(keyId))
            _revealedKeys.Add(keyId);
    }

    private async Task CopyKey(string key)
    {
        // JS interop for clipboard would be better, but for now use snackbar
        Snackbar.Add($"Schlüssel: {key}", Severity.Info);
    }

    private Color GetLevelColor(string level) => level switch
    {
        "read" => Color.Info,
        "write" => Color.Warning,
        "admin" => Color.Error,
        _ => Color.Default
    };

    private string GetLevelLabel(string level) => level switch
    {
        "read" => "Lesen",
        "write" => "Schreiben",
        "admin" => "Admin",
        _ => level
    };

    private async Task AddApiKey()
    {
        if (string.IsNullOrWhiteSpace(_newKeyName)) return;
        var newKey = await McpPermissionService.AddApiKeyAsync(_newKeyName.Trim(), _newKeyLevel);
        // Reload from service to avoid duplicates from reference sharing
        var mcpData = McpPermissionService.GetPermissionData();
        _mcpApiKeys = mcpData.ApiKeys;
        _revealedKeys.Add(newKey.Id); // Show the new key immediately
        _newKeyName = "";
        Snackbar.Add($"API-Schlüssel '{newKey.Name}' erstellt. Bitte kopieren und sicher aufbewahren!", Severity.Success);
    }

    private async Task RemoveApiKey(string id)
    {
        await McpPermissionService.RemoveApiKeyAsync(id);
        // Reload from service to stay in sync
        var mcpData = McpPermissionService.GetPermissionData();
        _mcpApiKeys = mcpData.ApiKeys;
        Snackbar.Add("API-Schlüssel gelöscht.", Severity.Info);
    }

    private async Task SaveMcpPermissions()
    {
        _savingMcp = true;
        try
        {
            await McpPermissionService.SavePermissionDataAsync(new ServerWatch.Models.McpPermissionData
            {
                ApiKeys = _mcpApiKeys,
                Tools = _mcpTools
            });
            Snackbar.Add("MCP-Rechte gespeichert. Änderungen gelten sofort.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingMcp = false;
        }
    }

    private Task AddEmail()
    {
        var email = _newEmail?.Trim();
        if (!string.IsNullOrWhiteSpace(email) && email.Contains('@') &&
            !_whitelistEmails.Contains(email, StringComparer.OrdinalIgnoreCase))
        {
            _whitelistEmails.Add(email);
            _newEmail = "";
        }
        return Task.CompletedTask;
    }

    private void RemoveEmail(string email)
    {
        _whitelistEmails.Remove(email);
    }

    private async Task SaveWhitelist()
    {
        _savingWhitelist = true;
        try
        {
            await WhitelistService.SaveWhitelistAsync(new ServerWatch.Models.WhitelistData
            {
                Enabled = _whitelistEnabled,
                Emails = _whitelistEmails
            });
            Snackbar.Add("Whitelist gespeichert. Änderungen gelten ab der nächsten Anmeldung.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingWhitelist = false;
        }
    }

    private async Task TestMattermost()
    {
        try
        {
            await NotificationService.SendTestAsync();
            Snackbar.Add("Mattermost-Testbenachrichtigung gesendet!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task TestMatrix()
    {
        try
        {
            await MatrixService.SendTestAsync();
            Snackbar.Add("Matrix-Testbenachrichtigung gesendet!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveCoolifySettings()
    {
        _savingCoolify = true;
        try
        {
            await CoolifyConfigService.SaveAsync(new ServerWatch.Configuration.CoolifySettings
            {
                Enabled = _coolifyEnabled,
                ApiUrl = _coolifyApiUrl?.Trim() ?? "",
                ApiToken = _coolifyApiToken?.Trim() ?? "",
                PollingIntervalSeconds = _coolifyPollingInterval
            });
            Snackbar.Add("Coolify-Einstellungen gespeichert. Änderungen gelten sofort.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingCoolify = false;
        }
    }

    private async Task TestCoolifyConnection()
    {
        _testingCoolify = true;
        try
        {
            // Temporarily save settings so the service uses the current values
            await CoolifyConfigService.SaveAsync(new ServerWatch.Configuration.CoolifySettings
            {
                Enabled = true,
                ApiUrl = _coolifyApiUrl?.Trim() ?? "",
                ApiToken = _coolifyApiToken?.Trim() ?? "",
                PollingIntervalSeconds = _coolifyPollingInterval
            });

            var success = await CoolifyApiService.TestConnectionAsync();
            if (success)
                Snackbar.Add("Verbindung zu Coolify erfolgreich!", Severity.Success);
            else
                Snackbar.Add("Verbindung fehlgeschlagen. Bitte URL und Token prüfen.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Verbindungsfehler: {ex.Message}", Severity.Error);
        }
        finally
        {
            _testingCoolify = false;
        }
    }

    private async Task SaveHetznerSettings()
    {
        _savingHetzner = true;
        try
        {
            await HetznerConfigService.SaveAsync(new ServerWatch.Configuration.HetznerSettings
            {
                Enabled = _hetznerEnabled,
                ApiToken = _hetznerApiToken?.Trim() ?? "", // empty = keep existing token
                PollingIntervalSeconds = _hetznerPollingInterval,
                TrafficWarnPercent = _hetznerTrafficWarn
            });
            _hetznerHasToken = HetznerConfigService.HasToken;
            _hetznerApiToken = "";
            Snackbar.Add("Hetzner-Einstellungen gespeichert. Änderungen gelten sofort.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingHetzner = false;
        }
    }

    private async Task TestHetznerConnection()
    {
        _testingHetzner = true;
        try
        {
            // Persist current values first so the service uses them (empty token keeps the stored one)
            await HetznerConfigService.SaveAsync(new ServerWatch.Configuration.HetznerSettings
            {
                Enabled = true,
                ApiToken = _hetznerApiToken?.Trim() ?? "",
                PollingIntervalSeconds = _hetznerPollingInterval,
                TrafficWarnPercent = _hetznerTrafficWarn
            });
            _hetznerHasToken = HetznerConfigService.HasToken;
            _hetznerApiToken = "";

            var success = await HetznerApiService.TestConnectionAsync();
            if (success)
                Snackbar.Add("Verbindung zu Hetzner erfolgreich!", Severity.Success);
            else
                Snackbar.Add("Verbindung fehlgeschlagen. Bitte Token prüfen.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Verbindungsfehler: {ex.Message}", Severity.Error);
        }
        finally
        {
            _testingHetzner = false;
        }
    }

    // === Roles ===

    private async Task AddRole()
    {
        if (string.IsNullOrWhiteSpace(_newRoleEmail)) return;
        _roleEntries.Add(new ServerWatch.Models.UserRoleEntry { Email = _newRoleEmail.Trim(), Role = _newRoleRole });
        _newRoleEmail = "";
        await SaveRoles();
    }

    private async Task SaveRoles()
    {
        await RoleService.SaveRoleDataAsync(new ServerWatch.Models.UserRoleData { Roles = _roleEntries });
        Snackbar.Add("Rollen gespeichert.", Severity.Success);
    }

    // === Vault ===

    private void LoadVault()
    {
        _vaultEntries = VaultService.ListSecrets();
    }

    private async Task AddVaultSecret()
    {
        if (string.IsNullOrWhiteSpace(_newVaultKey) || string.IsNullOrWhiteSpace(_newVaultValue)) return;
        try
        {
            await VaultService.SetSecretAsync(_newVaultKey.Trim(), _newVaultValue);
            Snackbar.Add($"Secret '{_newVaultKey}' gespeichert.", Severity.Success);
            _newVaultKey = ""; _newVaultValue = "";
            LoadVault();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    // === CVE Monitor ===

    private Task TriggerCveScan()
    {
        if (CveStore.IsScanning) return Task.CompletedTask;
        Snackbar.Add("CVE-Scan gestartet — kann beim ersten Lauf mehrere Minuten dauern (Trivy-DB-Download).", MudBlazor.Severity.Info);
        _ = Task.Run(async () =>
        {
            try { await CveMonitor.RunOneCycleAsync(); }
            catch (Exception ex) { Console.Error.WriteLine($"Manual CVE scan failed: {ex.Message}"); }
        });
        return Task.CompletedTask;
    }
}
