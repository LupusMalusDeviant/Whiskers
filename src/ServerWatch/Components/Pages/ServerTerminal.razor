@page "/server-terminal/{ServerId}"
@attribute [Authorize]
@inject IJSRuntime JS
@inject ITerminalSessionManager SessionManager
@inject ServerWatch.Services.ServerConfig.ServerConfigService ServerConfigService
@inject ServerWatch.Services.Auth.CurrentUserService CurrentUser
@implements IAsyncDisposable

<PageTitle>Server-Terminal - ServerWatch</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="" />
    <MudText Typo="Typo.h5">Server-Terminal</MudText>
    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@_serverName</MudChip>
</MudStack>

<MudPaper Elevation="2" Class="pa-2" Style="height: calc(100vh - 180px); min-height: 400px;">
    <div id="server-terminal-container" style="height: 100%; width: 100%;"></div>
</MudPaper>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
}

@code {
    [Parameter] public string ServerId { get; set; } = "";

    private ServerWatch.Services.Terminal.TerminalSession? _session;
    private string _error = string.Empty;
    private string _serverName = "";
    private DotNetObjectReference<ServerTerminal>? _dotNetRef;
    private bool _initialized;
    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        var server = ServerConfigService.GetServer(ServerId);
        _serverName = server?.Name ?? ServerId;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized) return;
        _initialized = true;

        if (await CurrentUser.GetRoleAsync() < AppRole.Admin)
        {
            _error = "Keine Berechtigung — Admin erforderlich.";
            StateHasChanged();
            return;
        }

        try
        {
            var server = ServerConfigService.GetServer(ServerId);
            if (server == null)
            {
                _error = "Server nicht gefunden";
                StateHasChanged();
                return;
            }

            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("ServerWatch.Terminal.create", "server-terminal-container", _dotNetRef);

            // For local server: open bash directly
            // For SSH servers: open ssh session to the remote host
            if (server.ConnectionType == ServerWatch.Models.ConnectionType.Local)
            {
                _session = SessionManager.CreateSession(null); // local shell
            }
            else
            {
                // Create an SSH session to the remote server
                _session = SessionManager.CreateSshSession(server);
            }

            _ = ReadStreamAsync(_session.Process!.StandardOutput, _cts.Token);
            _ = ReadStreamAsync(_session.Process!.StandardError, _cts.Token);
        }
        catch (Exception ex)
        {
            _error = $"Fehler beim Initialisieren des Terminals: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReadStreamAsync(System.IO.StreamReader reader, CancellationToken ct)
    {
        var buffer = new char[4096];
        try
        {
            while (!ct.IsCancellationRequested)
            {
                var bytesRead = await reader.ReadAsync(buffer, 0, buffer.Length);
                if (bytesRead == 0) break;
                var text = new string(buffer, 0, bytesRead);
                await InvokeAsync(async () =>
                {
                    await JS.InvokeVoidAsync("ServerWatch.Terminal.write", "server-terminal-container", text);
                });
            }
        }
        catch (OperationCanceledException) { }
        catch { }

        await InvokeAsync(async () =>
        {
            await JS.InvokeVoidAsync("ServerWatch.Terminal.write", "server-terminal-container",
                "\r\n\x1b[31m--- Session ended ---\x1b[0m\r\n");
        });
    }

    [JSInvokable]
    public async Task OnTerminalInput(string data)
    {
        if (_session is { IsRunning: true })
        {
            await _session.WriteAsync(data);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        try
        {
            if (_session != null)
                await SessionManager.DestroySession(_session.SessionId);
            await JS.InvokeVoidAsync("ServerWatch.Terminal.dispose", "server-terminal-container");
        }
        catch { }
        _dotNetRef?.Dispose();
        _cts.Dispose();
    }
}
