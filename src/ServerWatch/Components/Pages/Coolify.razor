@page "/coolify"
@attribute [Authorize]
@inject ServerWatch.Services.Coolify.ICoolifyService CoolifyService
@inject ServerWatch.Services.Coolify.CoolifyConfigService CoolifyConfig
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Coolify - ServerWatch</PageTitle>

<div class="sw-page-header">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div class="sw-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Large" />
        </div>
        <div>
            <MudText Typo="Typo.h5">Coolify-Integration</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Coolify-Anwendungen überwachen und verwalten</MudText>
        </div>
    </MudStack>
</div>

@if (!CoolifyConfig.IsEnabled)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        Coolify-Integration ist nicht aktiviert. Bitte unter <MudLink Href="settings">Einstellungen</MudLink> konfigurieren.
    </MudAlert>
}
else
{
    @* Summary Cards *@
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Apps" Color="Color.Primary" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_applications.Count</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Apps</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Success" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_applications.Count(a => a.DisplayStatus == "running")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Laufend</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Info" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_databases.Count</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Datenbanken</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Warning" Class="mr-3" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_servers.Count</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Server</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Applications Table *@
    <MudText Typo="Typo.h6" Class="mb-2">Applikationen</MudText>
    <MudTable Items="@_applications" Dense="true" Hover="true" Striped="true" Loading="@_loading"
              LoadingProgressColor="Color.Primary" Elevation="2" Class="mb-6">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Git-Repository</MudTh>
            <MudTh>Branch</MudTh>
            <MudTh>Build-Pack</MudTh>
            <MudTh>Domain</MudTh>
            <MudTh>Aktionen</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Name</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Uuid</MudText>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.DisplayStatus)" Variant="Variant.Filled">
                    @context.DisplayStatus
                </MudChip>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 0.8rem;">
                    @TruncateText(context.GitRepository ?? "-", 40)
                </MudText>
            </MudTd>
            <MudTd>@(context.GitBranch ?? "-")</MudTd>
            <MudTd>@(context.BuildPack ?? "-")</MudTd>
            <MudTd>
                @if (!string.IsNullOrWhiteSpace(context.Fqdn))
                {
                    <MudLink Href="@context.Fqdn" Target="_blank" Typo="Typo.body2">
                        @TruncateText(context.Fqdn, 35)
                    </MudLink>
                }
                else
                {
                    <MudText Typo="Typo.body2">-</MudText>
                }
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.RocketLaunch" Size="Size.Small" Color="Color.Primary"
                               title="Deploy" OnClick="@(() => DeployApp(context))"
                               Disabled="@_actionInProgress" />
                @if (context.DisplayStatus == "running")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                   title="Stoppen" OnClick="@(() => StopApp(context))"
                                   Disabled="@_actionInProgress" />
                    <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small" Color="Color.Info"
                                   title="Neustarten" OnClick="@(() => RestartApp(context))"
                                   Disabled="@_actionInProgress" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                   title="Starten" OnClick="@(() => StartApp(context))"
                                   Disabled="@_actionInProgress" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">Keine Applikationen gefunden.</MudText>
        </NoRecordsContent>
    </MudTable>

    @* Databases Table *@
    @if (_databases.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Datenbanken</MudText>
        <MudTable Items="@_databases" Dense="true" Hover="true" Striped="true"
                  Elevation="2" Class="mb-6">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Typ</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Image</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Uuid</MudText>
                </MudTd>
                <MudTd>@context.Type</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-family: monospace;">@(context.Image ?? "-")</MudText>
                </MudTd>
                <MudTd>
                    @if (context.Status?.Contains("running") == true)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                       title="Stoppen" OnClick="@(() => StopDb(context))"
                                       Disabled="@_actionInProgress" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                       title="Starten" OnClick="@(() => StartDb(context))"
                                       Disabled="@_actionInProgress" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @* Servers Table *@
    @if (_servers.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Server</MudText>
        <MudTable Items="@_servers" Dense="true" Hover="true" Striped="true"
                  Elevation="2" Class="mb-6">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>IP</MudTh>
                <MudTh>Erreichbar</MudTh>
                <MudTh>Docker</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Uuid</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.Ip</MudText>
                </MudTd>
                <MudTd>
                    <MudIcon Icon="@(context.IsReachable ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.IsReachable ? Color.Success : Color.Error)" Size="Size.Small" />
                </MudTd>
                <MudTd>@(context.Settings?.DockerVersion ?? "-")</MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private List<ServerWatch.Models.Coolify.CoolifyApplication> _applications = new();
    private List<ServerWatch.Models.Coolify.CoolifyDatabase> _databases = new();
    private List<ServerWatch.Models.Coolify.CoolifyServer> _servers = new();
    private bool _loading = true;
    private bool _actionInProgress;
    private Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        if (!CoolifyConfig.IsEnabled) { _loading = false; return; }

        await LoadAll();
        _loading = false;
        StateHasChanged();

        // Auto-refresh
        var interval = CoolifyConfig.GetSettings().PollingIntervalSeconds;
        if (interval > 0)
        {
            _refreshTimer = new Timer(async _ =>
            {
                await LoadAll();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromSeconds(interval), TimeSpan.FromSeconds(interval));
        }
    }

    private async Task LoadAll()
    {
        try
        {
            var appsTask = CoolifyService.ListApplicationsAsync();
            var dbsTask = CoolifyService.ListDatabasesAsync();
            var serversTask = CoolifyService.ListServersAsync();

            await Task.WhenAll(appsTask, dbsTask, serversTask);

            _applications = appsTask.Result;
            _databases = dbsTask.Result;
            _servers = serversTask.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Coolify-Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeployApp(ServerWatch.Models.Coolify.CoolifyApplication app)
    {
        _actionInProgress = true;
        try
        {
            var result = await CoolifyService.DeployApplicationAsync(app.Uuid);
            Snackbar.Add($"{app.Name}: Deployment gestartet — {result.Message}", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Deploy von {app.Name}: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private async Task StartApp(ServerWatch.Models.Coolify.CoolifyApplication app)
    {
        _actionInProgress = true;
        try
        {
            await CoolifyService.StartApplicationAsync(app.Uuid);
            Snackbar.Add($"{app.Name} wird gestartet...", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private async Task StopApp(ServerWatch.Models.Coolify.CoolifyApplication app)
    {
        _actionInProgress = true;
        try
        {
            await CoolifyService.StopApplicationAsync(app.Uuid);
            Snackbar.Add($"{app.Name} wird gestoppt...", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private async Task RestartApp(ServerWatch.Models.Coolify.CoolifyApplication app)
    {
        _actionInProgress = true;
        try
        {
            await CoolifyService.RestartApplicationAsync(app.Uuid);
            Snackbar.Add($"{app.Name} wird neugestartet...", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private async Task StartDb(ServerWatch.Models.Coolify.CoolifyDatabase db)
    {
        _actionInProgress = true;
        try
        {
            await CoolifyService.StartDatabaseAsync(db.Uuid);
            Snackbar.Add($"{db.Name} wird gestartet...", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private async Task StopDb(ServerWatch.Models.Coolify.CoolifyDatabase db)
    {
        _actionInProgress = true;
        try
        {
            await CoolifyService.StopDatabaseAsync(db.Uuid);
            Snackbar.Add($"{db.Name} wird gestoppt...", Severity.Success);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally { _actionInProgress = false; }
    }

    private static Color GetStatusColor(string status) => status?.ToLowerInvariant() switch
    {
        "running" => Color.Success,
        "stopped" or "exited" => Color.Error,
        "deploying" => Color.Info,
        _ => Color.Default
    };

    private static string TruncateText(string text, int max) =>
        text.Length > max ? text[..(max - 3)] + "..." : text;

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
