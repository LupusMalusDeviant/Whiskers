{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Docker": {
    "SocketPath": "unix:///var/run/docker.sock",
    "PollingIntervalSeconds": 5,
    "StatsPollingIntervalSeconds": 3
  },
  "Mattermost": {
    "WebhookUrl": "",
    "Channel": "",
    "BotUsername": "ServerWatch",
    "BotIconUrl": "",
    "Enabled": false,
    "ThrottleMinutes": 5
  },
  "Matrix": {
    "HomeserverUrl": "",
    "AccessToken": "",
    "RoomId": "",
    "Enabled": false,
    "ThrottleMinutes": 5
  },
  "AiChat": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "Provider": "openai",
    "Enabled": false,
    "ApiUrl": ""
  },
  "GoogleAuth": {
    "ClientId": "",
    "ClientSecret": "",
    "AllowedEmails": []
  },
  "Terminal": {
    "Enabled": true,
    "DefaultShell": "/bin/bash",
    "MaxSessions": 5,
    "IdleTimeoutMinutes": 30
  },
  "HealthMonitor": {
    "CheckIntervalSeconds": 30,
    "HistoryRetentionHours": 24,
    "RestartLoopThreshold": 5,
    "RestartLoopWindowMinutes": 10
  }
}
