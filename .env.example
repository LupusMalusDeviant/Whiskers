## ServerWatch environment variables — copy to .env and fill in values.
## .env is gitignored; never commit real secrets.

# ─── Authentication ───────────────────────────────────────────────
# Google OAuth 2.0 credentials (https://console.cloud.google.com/apis/credentials).
# Leave blank and set AUTH_DISABLED=true for LAN-only / private deployments
# where Google rejects IP- or intranet-based redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADMIN_EMAIL=

# true = skip login entirely. Only safe on a trusted private network.
AUTH_DISABLED=false

# Generic OpenID Connect (alongside or instead of Google) — works with Authentik,
# Keycloak, Pocket ID, Authelia (OIDC), Zitadel, etc. Get real 2FA/passkeys from your IdP.
# Register the redirect URI {PATH_BASE}/signin-oidc at the provider (e.g.
# https://your-server.com/serverwatch/signin-oidc). The user's email must be on the whitelist.
OIDC_ENABLED=false
OIDC_AUTHORITY=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=SSO
OIDC_SCOPES=openid profile email
OIDC_EMAIL_CLAIM=email
# Set to false ONLY for a local/dev IdP without HTTPS.
OIDC_REQUIRE_HTTPS=true

# ─── Notifications ────────────────────────────────────────────────
MATTERMOST_WEBHOOK_URL=
MATTERMOST_ENABLED=false

# ─── Metrics collection ───────────────────────────────────────────
# How often container/server stats are sampled and how many days they're retained.
METRICS_ENABLED=true
METRICS_COLLECTIONINTERVALSECONDS=30
METRICS_RETENTIONDAYS=7

# ─── Metric alerts (drive AI triggers: high_cpu / high_memory / metric_anomaly) ───
METRICALERT_ENABLED=true
METRICALERT_CPUPERCENT=90
METRICALERT_MEMORYPERCENT=90
# Host root-filesystem usage % that fires a high_disk alert (server-level).
METRICALERT_DISKPERCENT=90
# Value must stay above the threshold this long before an event fires.
METRICALERT_SUSTAINEDMINUTES=3
# Min minutes between repeated events for the same container/metric.
METRICALERT_COOLDOWNMINUTES=15
# Simple rolling-z-score outlier detection (off by default — can be noisy).
METRICALERT_ANOMALYENABLED=false
METRICALERT_ANOMALYWINDOW=20
METRICALERT_ANOMALYSIGMA=3
METRICALERT_ANOMALYFLOORPERCENT=40

# ─── URL routing ──────────────────────────────────────────────────
# Path prefix when reverse-proxied under a subpath (e.g. "/serverwatch").
# Leave empty when served at the root.
PATH_BASE=

# ─── AI chat (optional) ───────────────────────────────────────────
AICHAT_ENABLED=false
AICHAT_API_KEY=
AICHAT_API_URL=https://openrouter.ai/api/v1/chat/completions
AICHAT_MODEL=
AICHAT_PROVIDER=openai

# ─── Agent (acting assistant, optional) ───────────────────────────
# Provider: openai | openrouter | ollama | gemini | anthropic | claude-code
AGENT_ENABLED=false
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-4o-mini
# Custom endpoint (empty = provider default; required for ollama/self-host)
AGENT_ENDPOINT=
AGENT_API_KEY=
# Hard upper bound on tool iterations per turn
AGENT_MAX_TOOL_ITERATIONS=8
# Provider "claude-code": the Claude Code CLI points back at ServerWatch via MCP.
# McpKey is a ServerWatch MCP API key (Settings → MCP); its rights = the agent's ceiling.
AGENT_CLAUDE_CODE_MCP_URL=http://localhost:8080/mcp
AGENT_CLAUDE_CODE_MCP_KEY=

# ─── Mesh VPN ─────────────────────────────────────────────────────
# Leave VPN_PROVIDER empty for the legacy in-container Tailscale bring-up (entrypoint.sh).
# Set it to manage the VPN via the in-app provider abstraction instead:
#   none     = VPN runs on the host / a sidecar (recommended; required for the hardened profile)
#   tailscale= app manages Tailscale (Headscale via TAILSCALE_LOGIN_SERVER)
#   netbird  = app manages NetBird   (self-host via NETBIRD_MANAGEMENT_URL; needs the netbird binary)
VPN_PROVIDER=
VPN_HOSTNAME=
TAILSCALE_AUTHKEY=
TAILSCALE_LOGIN_SERVER=
NETBIRD_SETUP_KEY=
NETBIRD_MANAGEMENT_URL=

# ─── Image-search marketplaces (optional) ─────────────────────────
# Docker Hub + GHCR are on by default. Add a self-hosted Harbor for private images:
HARBOR_URL=
HARBOR_USERNAME=
HARBOR_PASSWORD=

# ─── Host binding ─────────────────────────────────────────────────
# Container always listens on 8080 internally; adjust host-side mapping here.
# (Ignored by docker-compose.hardened.yml, which uses host networking — bind via your proxy.)
HOST_BIND=127.0.0.1
HOST_PORT=5100
