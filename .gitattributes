# Force LF line endings for shell scripts, Dockerfile, and compose files.
# Prevents CRLF breakage when contributors commit from Windows.
*.sh           text eol=lf
Dockerfile     text eol=lf
*.Dockerfile   text eol=lf
docker-compose*.yml text eol=lf
.env.example   text eol=lf
.dockerignore  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Default: let Git handle detection.
*              text=auto
